{{ 'section-slideshow.css' | asset_url | stylesheet_tag }}
{% if section.settings.animation_type == 'vertical_stack' %}
  <script src="{{ 'gsap.min.js' | asset_url }}" defer="defer"></script>
{% endif %}
<script src="{{ 'slideshow.js' | asset_url }}" defer="defer"></script>

{% style %}
  {% render 'section-margin' %}
   .start-spin {
  	transition: all {{  section.settings.slide_duration | times: 1000 }}s linear !important;
  }
{% endstyle %}

{%- assign no_media = true -%}

{%- for block in section.blocks -%}
  {%- liquid
    if block.settings.enable_image or block.settings.show_video
      assign no_media = false
    endif
    assign cursor1 = true
    if block.settings.card_overlay_link == blank
      assign cursor1 = false
    endif

    if block.settings.mobile_image != blank
      assign mobile_image = block.settings.mobile_image
    elsif block.settings.image != blank
      assign mobile_image = block.settings.image
    else
      assign mobile_image = blank
    endif

    if block.settings.image != blank
      assign desktop_image = block.settings.image
    elsif block.settings.mobile_image != blank
      assign desktop_image = block.settings.mobile_image
    else
      assign desktop_image = blank
    endif

    if section.settings.image_ratio_mobile != 'adapt' and section.settings.image_ratio_mobile != 'full_height'
      assign aspect_ratio_mobile = section.settings.image_ratio_mobile | split: '/'
      assign temp = aspect_ratio_mobile[0] | append: '.0'
      assign padding_bottom_mobile = aspect_ratio_mobile[1] | divided_by: temp | times: 100 | round: 2
    elsif section.settings.image_ratio_mobile == 'adapt'
      if block.settings.video != blank and block.settings.show_video
        assign padding_bottom_mobile = 1 | divided_by: block.settings.video.aspect_ratio | times: 100 | round: 2
      elsif mobile_image != blank and block.settings.enable_image
        assign padding_bottom_mobile = 1 | divided_by: mobile_image.aspect_ratio | times: 100 | round: 2
      elsif block.settings.enable_image
        assign padding_bottom_mobile = 75
      else
        assign padding_bottom_mobile = 0
      endif
    else
      assign padding_bottom_mobile = 0
    endif

    if section.settings.image_ratio_desktop != 'adapt' and section.settings.image_ratio_desktop != 'full_height'
      assign aspect_ratio_desktop = section.settings.image_ratio_desktop | split: '/'
      assign temp = aspect_ratio_desktop[0] | append: '.0'
      assign padding_bottom_desktop = aspect_ratio_desktop[1] | divided_by: temp | times: 100 | round: 2
    elsif section.settings.image_ratio_desktop == 'adapt'
      if block.settings.video != blank and block.settings.show_video
        assign padding_bottom_desktop = 1 | divided_by: block.settings.video.aspect_ratio | times: 100 | round: 2
      elsif desktop_image != blank and block.settings.enable_image
        assign padding_bottom_desktop = 1 | divided_by: desktop_image.aspect_ratio | times: 100 | round: 2
      elsif block.settings.enable_image
        assign padding_bottom_desktop = 56
      else
        assign padding_bottom_desktop = 0
      endif
    else
      assign padding_bottom_desktop = 0
    endif
  -%}

  {%- style -%}
        .section-{{ section.id }} .slideshow__slide-{{ block.id }}::before {
          content: "";
          display: block;
          width: 0;
          padding-bottom: {{ padding_bottom_mobile }}%;
        }

        @media screen and (min-width: 576px) {
          .section-{{ section.id }} .slideshow__slide-{{ block.id }}::before {
            content: "";
            display: block;
            width: 0;
            padding-bottom: {{ padding_bottom_desktop }}%;
          }
        }
    {%- if section.settings.layout == 'overlay' -%}
    .slideshow-section {
    	padding-top: 0 !important;
    }
    	{%- endif -%}
        {%- if section.settings.image_ratio_mobile == "full_height" -%}
          @media screen and (max-width: 575px) {
            .section-{{ section.id }} .slideshow__slide-{{ block.id }} {
              {%- if section.index == 1 or section.index == nil -%}
                min-height: calc(100vh - var(--announcement-height) - var(--header-height));
                min-height: calc(100svh + var(--announcement-height) - var(--header-height));
              {%- else -%}
                min-height: 100vh;
                min-height: 100svh;
              {%- endif -%}
            }
          }
        {%- endif -%}

        {%- if section.settings.image_ratio_desktop == "full_height" -%}
          @media screen and (min-width: 576px) {
            .section-{{ section.id }} .slideshow__slide-{{ block.id }} {
              {%- if section.index == 1 or section.index == nil -%}
                min-height: calc(100vh - var(--announcement-height) - var(--header-height));
                min-height: calc(100svh + var(--announcement-height) + 10px - var(--header-height));
              {%- else -%}
                min-height: 100vh;
                min-height: 100svh;
              {%- endif -%}
            }
          }
        {%- endif -%}
  {%- endstyle -%}
{%- endfor -%}

{%- if section.settings.layout == 'split_screen' -%}
  <div class="container slideshow_text_inner_container">
    <div class="slideshow_text_inner">
      {%- if section.settings.subheading != blank -%}
        <div class="reveal-text-inner">
          <div class="heading-group__subheading reveal-text">
            {{- section.settings.subheading -}}
          </div>
        </div>
      {%- endif -%}
      {% if section.settings.heading != blank %}
        <div class="reveal-text-inner">
          <{{ section.settings.heading_tag | default: 'h3' }}
            class="reveal-text richtext-link-inside {% if section.settings.heading_font == 'heading'%} {{ section.settings.heading_size}} {% else %}title font--body{% endif %}"
            {{ section.shopify_attributes }}
          >
            {{- section.settings.heading -}}
          </{{ section.settings.heading_tag | default: 'h3' }}>
        </div>
      {% endif -%}
    </div>
    {% if section.settings.description != blank %}
      <div class="reveal-text-inner">
        <p class="slideshow__description reveal-text body-large richtext-link-inside" {{ section.shopify_attributes }}>
          {{- section.settings.description -}}
        </p>
      </div>
    {% endif -%}
  </div>
{%- endif -%}
{% if section.settings.full_width == false %}
  <div class="container">
{% endif %}
<div
  class="section-{{ section.id }}  slideshow slideshow--{{ section.settings.layout }}{% if section.settings.animation_type == 'vertical_stack' %} slideshow--vertical-stack{% endif %}{% if no_media %} slideshow--no-media{% endif %}{% if section.blocks.size > 1 and section.settings.enable_pagination %} slideshow--with-pagination{% endif %}"
  data-autoplay="{{ section.settings.enable_autoplay }}"
  data-loop="{{ section.settings.enable_loop }}"
  data-pagination="{{ section.settings.enable_pagination }}"
  data-animation-type="{{ section.settings.animation_type }}"
  data-layout="{{ section.settings.layout }}"
  data-first-section="{% if section.index == 1 %}true{% else %}false{% endif %}"
  style="--bullet-duration : {{ section.settings.slide_duration }}s"
  {% if section.settings.enable_parallax and section.settings.animation_type == 'slide' -%}
    data-parallax="{{ section.settings.enable_parallax }}"
  {%- endif %}
  {% if section.settings.enable_autoplay -%}
    data-stop-autoplay="{{ section.settings.autoplay_stop_on_hover }}"
  {%- endif %}
  {% if section.settings.layout == 'overlay' -%}
    data-color-scheme="{{ section.blocks[0].settings.color_scheme }}"
  {%- endif %}
  data-flowing-cursor="{{ section.settings.enable_flowing_navigation }}"
>
  <div class="slideshow__container">
    <div class="slideshow__swiper slideshow__swiper--overlay swiper">
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          <div
            class=" swiper-slide slideshow__slide slideshow__slide-{{ block.id }} color-{{ block.settings.color_scheme }}{% if section.settings.image_ratio_desktop == "full_height" %} slideshow__slide--full-desktop{% endif %}{% if section.settings.image_ratio_mobile == "full_height" %} slideshow__slide--full-mobile{% endif %}"
            {% if section.settings.animation_type == 'vertical_stack' and forloop.first %}
              data-slideshow-initial="true"
            {% endif %}
            {% if section.settings.enable_autoplay -%}
              data-swiper-autoplay="{{ section.settings.slide_duration | times: 1000 }}"
            {%- endif %}
            data-has-link="{% if block.settings.card_overlay_link != blank %}true{% else %}false{% endif %}"
            data-color-scheme="color-{{ block.settings.color_scheme }}"
            {{ block.shopify_attributes }}
          >
            {% render 'slideshow-content-group', section: section, block: block, forloop_index: forloop.index0 %}

            {%- if no_media == false -%}
              {% render 'slideshow-media-item', section: section, block: block, forloop_index: forloop.index0 %}
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
      {%- if section.settings.enable_flowing_navigation -%}
        <div class="slideshow__cursor">
          {{- 'general.pagination.shop_now' | t -}}
        </div>
      {%- endif -%}
      {% render 'slideshow-pagination', section: section, init_color_scheme: section.blocks[0].settings.color_scheme %}

      <div
        class="slideshow__progress-bar{% if section.settings.enable_autoplay == false%} slideshow__progress-bar-wihout-autoplay{% endif %}"
      ></div>
    </div>
  </div>
</div>
{% if section.settings.full_width == false %}
  </div>
{% endif %}
{% schema %}
{
  "name": "t:sections.slideshow.name",
  "tag": "section",
  "class": "slideshow-section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.slideshow.settings.layout.label",
      "options": [
        {
          "value": "overlay",
          "label": "t:sections.slideshow.settings.layout.options__1.label"
        },
        {
          "value": "split_screen",
          "label": "t:sections.slideshow.settings.layout.options__2.label"
        }
      ],
      "default": "overlay"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "default": true,
      "label": "t:sections.slideshow.settings.full_width.label"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.all.subheading.label",
      "visible_if": "{{ section.settings.layout == 'split_screen' }}"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "t:sections.content-with-images.settings.heading.default",
      "label": "t:sections.all.heading.label",
      "visible_if": "{{ section.settings.layout == 'split_screen' }}"
    },
    {
      "type": "select",
      "id": "heading_font",
      "options": [
        {
          "value": "heading",
          "label": "t:sections.all.heading_font.options__1.label"
        },
        {
          "value": "body",
          "label": "t:sections.all.heading_font.options__2.label"
        }
      ],
      "default": "heading",
      "label": "t:sections.all.heading_font.label",
      "visible_if": "{{ section.settings.heading != blank and section.settings.layout == 'split_screen'}}"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h6",
          "label": "t:sections.all.heading_size.options__6.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_size.options__5.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__1.label"
        }
      ],
      "default": "h3",
      "label": "t:sections.all.heading_size.label",
      "visible_if": "{{ section.settings.heading != blank and section.settings.heading_font == 'heading' and section.settings.layout == 'split_screen'}}"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.heading_tag.options__6.label"
        },
        {
          "value": "div",
          "label": "t:sections.all.heading_tag.options__7.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_tag.label",
      "info": "t:sections.all.heading_tag.info",
      "visible_if": "{{ section.settings.heading != blank and section.settings.layout == 'split_screen'}}"
    },
    {
      "type": "inline_richtext",
      "id": "description",
      "default": "t:sections.content-with-images.settings.description.default",
      "label": "t:sections.all.text.label",
      "visible_if": "{{ section.settings.layout == 'split_screen' }}"
    },
    {
      "type": "select",
      "id": "image_ratio_desktop",
      "options": [
        {
          "value": "1/1",
          "label": "1:1"
        },
        {
          "value": "2/1",
          "label": "2:1"
        },
        {
          "value": "3/2",
          "label": "3:2"
        },
        {
          "value": "4/3",
          "label": "4:3"
        },
        {
          "value": "16/9",
          "label": "16:9"
        },
        {
          "value": "21/9",
          "label": "21:9"
        },
        {
          "value": "4/5",
          "label": "4:5"
        },
        {
          "value": "3/4",
          "label": "3:4"
        },
        {
          "value": "adapt",
