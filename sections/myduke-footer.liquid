{{ 'section-myduke-footer.css' | asset_url | stylesheet_tag }}

<div class="myduke-footer">
  {%- comment -%} ===== MAIN FOOTER BODY ===== {%- endcomment -%}
  <div class="myduke-footer__main">
    <div class="myduke-footer__main-inner page-width container">
      {%- comment -%} LEFT COLUMN: Logo + Description + Socials {%- endcomment -%}
      <div class="myduke-footer__brand">
        {%- if section.settings.logo != blank -%}
          <a
            href="{{ routes.root_url }}"
            class="myduke-footer__logo-link"
            aria-label="{{ section.settings.logo.alt | default: shop.name | escape }}"
          >
            {%- liquid
              assign logo_height = section.settings.logo_width | divided_by: section.settings.logo.aspect_ratio
              assign logo_alt = section.settings.logo.alt | default: shop.name | escape
              assign logo_2x = section.settings.logo_width | times: 2
            -%}
            {%- capture logo_srcset -%}
              {{ section.settings.logo | image_url: width: section.settings.logo_width }}, {{ section.settings.logo | image_url: width: logo_2x }} 2x
            {%- endcapture -%}
            {{
              section.settings.logo
              | image_url: width: section.settings.logo_width
              | image_tag:
                class: 'myduke-footer__logo-img',
                srcset: logo_srcset,
                width: section.settings.logo_width,
                height: logo_height,
                alt: logo_alt,
                loading: 'lazy'
            }}
          </a>
        {%- else -%}
          <a href="{{ routes.root_url }}" class="myduke-footer__logo-link myduke-footer__logo-link--text">
            <span class="myduke-footer__logo-text">{{ shop.name }}</span>
          </a>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <p class="myduke-footer__description">{{ section.settings.description }}</p>
        {%- endif -%}

        {%- comment -%} Social Icons {%- endcomment -%}
        {%- if section.settings.show_social_icons -%}
          <div class="myduke-footer__socials">
            {%- if section.settings.social_instagram != blank -%}
              <a
                href="{{ section.settings.social_instagram }}"
                class="myduke-footer__social-link"
                target="_blank"
                rel="noopener"
                aria-label="Instagram"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if section.settings.social_facebook != blank -%}
              <a
                href="{{ section.settings.social_facebook }}"
                class="myduke-footer__social-link"
                target="_blank"
                rel="noopener"
                aria-label="Facebook"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if section.settings.social_twitter != blank -%}
              <a
                href="{{ section.settings.social_twitter }}"
                class="myduke-footer__social-link"
                target="_blank"
                rel="noopener"
                aria-label="X (Twitter)"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if section.settings.social_pinterest != blank -%}
              <a
                href="{{ section.settings.social_pinterest }}"
                class="myduke-footer__social-link"
                target="_blank"
                rel="noopener"
                aria-label="Pinterest"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M8 12a4 4 0 1 0 8 0 4 4 0 0 0-8 0"/><path d="M12 2C6.5 2 2 6.5 2 12c0 4.2 2.5 7.8 6.1 9.5-.1-.9-.2-2.3.1-3.3.3-1 2-8.3 2-8.3s-.5-1-.5-2.5c0-2.3 1.4-4.1 3.1-4.1 1.5 0 2.2 1.1 2.2 2.4 0 1.4-.9 3.6-1.4 5.6-.4 1.7.8 3 2.5 3 3 0 5-3.8 5-8.3C21 7 17.5 4 13.3 4"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if section.settings.social_tiktok != blank -%}
              <a
                href="{{ section.settings.social_tiktok }}"
                class="myduke-footer__social-link"
                target="_blank"
                rel="noopener"
                aria-label="TikTok"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.19 8.19 0 0 0 4.78 1.52V6.76a4.83 4.83 0 0 1-1.01-.07z"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if section.settings.social_youtube != blank -%}
              <a
                href="{{ section.settings.social_youtube }}"
                class="myduke-footer__social-link"
                target="_blank"
                rel="noopener"
                aria-label="YouTube"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M22.54 6.42A2.78 2.78 0 0 0 20.59 4.4C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29.94 29.94 0 0 0 1 12a29.94 29.94 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-2.02A29.94 29.94 0 0 0 23 12a29.94 29.94 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/>
                </svg>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} MENU COLUMNS (blocks) {%- endcomment -%}
      {%- if section.blocks.size > 0 -%}
        <div class="myduke-footer__nav">
          {%- for block in section.blocks -%}
            {%- if block.type == 'menu_column' -%}
              <div class="myduke-footer__nav-col" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  {%- comment -%} Mobile: collapsible {%- endcomment -%}
                  <details class="myduke-footer__nav-details myduke-footer__nav-details--mobile">
                    <summary class="myduke-footer__nav-summary">
                      <span>{{ block.settings.heading | escape }}</span>
                      <svg
                        class="myduke-footer__chevron"
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <polyline points="6 9 12 15 18 9"/>
                      </svg>
                    </summary>
                    {%- if block.settings.menu != blank -%}
                      <ul class="myduke-footer__nav-list list-unstyled">
                        {%- for link in block.settings.menu.links -%}
                          <li class="myduke-footer__nav-item">
                            <a
                              href="{{ link.url }}"
                              class="myduke-footer__nav-link"
                              {% if settings.links_blank and link.type == 'http_link' %}
                                target="_blank" rel="noopener"
                              {% endif %}
                            >
                              {{ link.title }}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  </details>

                  {%- comment -%} Desktop: always visible {%- endcomment -%}
                  <div class="myduke-footer__nav-desktop">
                    <h3 class="myduke-footer__nav-heading">{{ block.settings.heading | escape }}</h3>
                    {%- if block.settings.menu != blank -%}
                      <ul class="myduke-footer__nav-list list-unstyled">
                        {%- for link in block.settings.menu.links -%}
                          <li class="myduke-footer__nav-item">
                            <a
                              href="{{ link.url }}"
                              class="myduke-footer__nav-link"
                              {% if settings.links_blank and link.type == 'http_link' %}
                                target="_blank" rel="noopener"
                              {% endif %}
                            >
                              {{ link.title }}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} RIGHT COLUMN: Newsletter (space reserved for later) {%- endcomment -%}
      <div class="myduke-footer__newsletter-col">
        {%- comment -%} Signup form placeholder — to be implemented later {%- endcomment -%}
        <div class="myduke-footer__newsletter-placeholder">
          {%- comment -%} Newsletter form will be added here {%- endcomment -%}
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ===== FOOTER BOTTOM BAR ===== {%- endcomment -%}
  <div class="myduke-footer__bottom">
    <div class="myduke-footer__bottom-inner page-width">
      <div class="myduke-footer__copyright">
        {%- if section.settings.copyright_text != blank -%}
          <span>{{ section.settings.copyright_text }}</span>
        {%- else -%}
          <span
            >&copy; {{ 'now' | date: '%Y' }}
            {{ shop.name }}. All rights reserved.</span
          >
        {%- endif -%}
      </div>

      {%- if section.settings.payment_enable -%}
        <ul class="myduke-footer__payment list-unstyled" role="list" aria-label="Accepted payment methods">
          {%- for type in shop.enabled_payment_types -%}
            <li class="myduke-footer__payment-item">
              {{ type | payment_type_svg_tag: class: 'myduke-footer__payment-icon' }}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "MyDuke Footer",
  "tag": "footer",
  "class": "shopify-section-myduke-footer",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 60,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Logo Width",
      "default": 200,
      "visible_if": "{{ section.settings.logo != blank }}"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Brand Description",
      "default": "Myduke® works alongside our Australian dispensing partners to help Australians access quality smoking cessation treatments, overseeing the entire process from treatment through to delivery and ongoing support."
    },
    {
      "type": "header",
      "content": "Social Links"
    },
    {
      "type": "checkbox",
      "id": "show_social_icons",
      "label": "Show Social Icons",
      "default": true
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "X (Twitter) URL"
    },
    {
      "type": "url",
      "id": "social_pinterest",
      "label": "Pinterest URL"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "social_youtube",
      "label": "YouTube URL"
    },
    {
      "type": "header",
      "content": "Footer Bottom"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "info": "Leave blank to auto-generate from shop name and year.",
      "default": "© 2026 Myduke. All rights reserved. Australian Owned & Operated."
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "label": "Show Payment Icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Menu Column",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Navigation Menu",
          "default": "footer",
          "info": "Select a navigation menu to display in this column."
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "menu_column",
        "settings": {
          "heading": "Shop"
        }
      },
      {
        "type": "menu_column",
        "settings": {
          "heading": "Explore"
        }
      },
      {
        "type": "menu_column",
        "settings": {
          "heading": "Legal"
        }
      },
      {
        "type": "menu_column",
        "settings": {
          "heading": "Contact"
        }
      }
    ]
  }
}
{% endschema %}
