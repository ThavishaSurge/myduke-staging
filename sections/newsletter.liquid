{{ 'section-newsletter.css' | asset_url | stylesheet_tag }}
<script src="{{ 'jarallax.js' | asset_url }}" defer="defer"></script>
{% liquid
  assign image_desktop = blank
  assign image_mobile = blank

  assign has_video = false
  assign has_image = false
  assign has_placeholder = false

  if section.settings.show_video == true and section.settings.video != blank
    assign has_video = true
  elsif section.settings.enable_image
    if section.settings.image_desktop != blank or section.settings.image_mobile != blank
      assign has_image = true

      if section.settings.image_desktop != blank
        assign image_desktop = section.settings.image_desktop
      else
        assign image_desktop = section.settings.image_mobile
      endif

      if section.settings.image_mobile != blank
        assign image_mobile = section.settings.image_mobile
      else
        assign image_mobile = section.settings.image_desktop
      endif
    else
      assign has_placeholder = true
    endif
  endif

  if section.settings.image_ratio_mobile != 'adapt' and section.settings.image_ratio_mobile != 'full_height'
    assign aspect_ratio_mobile = section.settings.image_ratio_mobile | split: '/'
    assign temp_mobile = aspect_ratio_mobile[0] | append: '.0'
    assign padding_bottom_mobile = aspect_ratio_mobile[1] | divided_by: temp_mobile | times: 100 | round: 2
  elsif section.settings.image_ratio_mobile == 'adapt'
    if has_video
      assign padding_bottom_mobile = 1 | divided_by: section.settings.video.aspect_ratio | times: 100 | round: 2
    elsif has_image
      assign padding_bottom_mobile = 1 | divided_by: image_mobile.aspect_ratio | times: 100 | round: 2
    elsif has_placeholder
      assign padding_bottom_mobile = 75
    else
      assign padding_bottom_mobile = 0
    endif
  else
    assign padding_bottom_mobile = 0
  endif

  if section.settings.image_ratio_desktop != 'adapt' and section.settings.image_ratio_desktop != 'full_height'
    assign aspect_ratio_desktop = section.settings.image_ratio_desktop | split: '/'
    assign temp_desktop = aspect_ratio_desktop[0] | append: '.0'
    assign padding_bottom_desktop = aspect_ratio_desktop[1] | divided_by: temp_desktop | times: 100 | round: 2
  elsif section.settings.image_ratio_desktop == 'adapt'
    if has_video
      assign padding_bottom_desktop = 1 | divided_by: section.settings.video.aspect_ratio | times: 100 | round: 2
    elsif has_image
      assign padding_bottom_desktop = 1 | divided_by: image_desktop.aspect_ratio | times: 100 | round: 2
    elsif has_placeholder
      assign padding_bottom_desktop = 56
    else
      assign padding_bottom_desktop = 0
    endif
  else
    assign padding_bottom_desktop = 0
  endif
%}
{% style %}
  {% render 'section-margin' %}

  #Banner-{{ section.id }}.newsletter__inner::before {
    content: '';
    display: block;
    width: 0;
    padding-bottom: {{ padding_bottom_mobile }}%;
  }

  @media screen and (min-width: 576px) {
    #Banner-{{ section.id }}.newsletter__inner::before {
      content: '';
      display: block;
      width: 0;
      padding-bottom: {{ padding_bottom_desktop }}%;
    }
  }

  {% if section.settings.image_ratio_mobile == "full_height" %}
    @media screen and (max-width: 575.99px) {
      #Banner-{{ section.id }}.newsletter__inner {
        min-height: 100vh;
        min-height: 100svh;
      }

      main > .newsletter-section:first-child > #Banner-{{ section.id }}.newsletter__inner {
        min-height: calc(100vh - var(--announcement-height) - var(--header-height));
        min-height: calc(100svh - var(--announcement-height) - var(--header-height));
      }
    }
  {% endif %}

  {% if section.settings.image_ratio_desktop == "full_height" %}
    @media screen and (min-width: 576px) {
      #Banner-{{ section.id }}.newsletter__inner {
        min-height: 100vh;
        min-height: 100svh;
      }

      main > .media-banner-section:first-child > #Banner-{{ section.id }}.newsletter__inner {
        min-height: calc(100vh - var(--announcement-height) - var(--header-height));
        min-height: calc(100svh - var(--announcement-height) - var(--header-height));
      }
    }
  {% endif %}
{% endstyle %}

<div class="newsletter">
  <div
    id="Banner-{{ section.id }}"
    class="newsletter__inner newsletter__wrapper_{{ section.settings.vertical_alignment }} container "
  >
    <div class="newsletter__content  newsletter__content--{{ section.settings.text_alignment}} color-{{ section.settings.color_scheme }} background">
      {% if section.settings.content_heading != blank %}
        <{{ section.settings.content_heading_tag | default: 'h3' }}
          class="text-content__heading {{ section.settings.content_heading_size}} richtext-link-inside"
        >
          {{ section.settings.content_heading }}
        </{{ section.settings.content_heading_tag | default: 'h3' }}>
      {% endif %}
      <div class="newsletter-form">
        <div class="newsletter-form__content">
          {% form 'customer', class: 'newsletter-form' %}
            <div class="newsletter-form__inner">
              <input type="hidden" name="contact[tags]" value="newsletter">

              <div class="custom-field field field--newsletter">
                <div class="field--newsletter-wrapper">
                  <input
                    id="NewsletterForm--{{ section.id }}"
                    dir="ltr"
                    type="email"
                    name="contact[email]"
                    class="body-small"
                    value="{{ form.email }}"
                    aria-required="true"
                    autocorrect="off"
                    autocapitalize="off"
                    autocomplete="email"
                    pattern="[a-z0-9._%+\-]+@[a-z0-9.\-]+\.[a-z]{2,}$"
                    {% if form.errors %}
                      autofocus
                      aria-invalid="true"
                      aria-describedby="Newsletter-error--{{ section.id }}"
                    {% elsif form.posted_successfully? %}
                      aria-describedby="Newsletter-success--{{ section.id }}"
                    {% endif %}
                    placeholder="{{ 'newsletter.label' | t }}"
                    required
                  >
                  {% comment %}
                    <label for="NewsletterForm--{{ section.id }}">
                      {{- 'newsletter.label' | t -}}
                    </label>
                  {% endcomment %}
                  <button type="submit" class="button button--tertiary button--simple focus-inset" aria-label="{{ 'newsletter.button_label' | t }}">
                    <div class="button__content">
                      <span class="button__icons-container">
                        {% render 'icon-arrow-tertiary-button' %}
                        {% render 'icon-arrow-tertiary-button' %}
                      </span>
                    </div>
                  </button>
                </div>
              </div>

              {%- if form.errors -%}
                <small
                  class="form__message form__message--error body-small"
                  id="Newsletter-error--{{ section.id }}"
                >
                  {%- render 'icon-error' -%}
                  {{- form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email -}}
                </small>
              {%- endif -%}
              {%- if form.posted_successfully? -%}
                <small
                  class="form__message form__message--success"
                  id="Newsletter-success--{{ section.id }}"
                  tabindex="-1"
                  autofocus
                >
                  {% render 'icon-success' -%}
                  {{- 'newsletter.success' | t }}
                </small>
              {%- endif -%}
            </div>

            {%- if section.settings.newsletter_text -%}
              <div class="newsletter__text body-small {{ section.settings.text_align }} richtext-link-inside-secondary">
                {{- section.settings.newsletter_text -}}
              </div>
            {%- endif -%}
            {% if section.settings.privacy_policy_consent %}
              <div class="field field--checkbox">
                <input
                  type="checkbox"
                  class="focus-inset"
                  name="newsletter_checkbox"
                  id="newsletter_checkbox"
                  aria-describedby="FooterNewsletter-checkbox-error"
                  required
                  oninvalid="this.classList.add('is-invalid')"
                  onchange="this.classList.remove('is-invalid')"
                >
                <label for="newsletter_checkbox">
                  <span class="field__checkbox">
                    {% render 'icon-checkbox-arrow', class: 'field__checkbox--arrow' -%}
                  </span>
                  <span class="field__label body-small">
                    {{ 'sections.footer.accept_terms' | t }}
                    <a href="{{ shop.privacy_policy.url }}" target="_blank" class="focus-inset">
                      {{- shop.privacy_policy.title -}}
                    </a>
                  </span>
                </label>
                <span id="FooterNewsletter-checkbox-error" class="form__message form__message--error">
                  {{- 'sections.footer.checkbox_error' | t -}}
                </span>
              </div>
            {% endif %}
          {% endform %}
        </div>
      </div>
    </div>
    {%- if has_image or has_placeholder -%}
      <div class="newsletter__img_wrapper">
        <div class="newsletter__fixed">
          <div
            class="newsletter__img{% if section.settings.enable_parallax %} jarallax{% endif %}"
            {% if section.settings.enable_parallax %}
              data-jarallax
              data-speed="0.65"
            {% endif %}
          >
            {%- assign parallax_class = '' -%}
            {%- if section.settings.enable_parallax -%}
              {%- assign parallax_class = ' jarallax-img' -%}
            {%- endif -%}
            {%- if has_image -%}
              {% liquid
                # get mobile calc ratio
                if section.settings.image_ratio_mobile != 'adapt' and section.settings.image_ratio_mobile != 'full_height'
                  assign settings_mobile_aspect_ratio = temp_mobile | divided_by: aspect_ratio_mobile[1] | round: 2
                elsif section.settings.image_ratio_mobile == 'full_height'
                  assign settings_mobile_aspect_ratio = 0.45
                else
                  assign settings_mobile_aspect_ratio = image_mobile.aspect_ratio
                endif

                assign calc_ratio_mobile = 1
                if image_mobile.aspect_ratio > settings_mobile_aspect_ratio
                  assign calc_ratio_mobile = image_mobile.aspect_ratio | divided_by: settings_mobile_aspect_ratio | round: 2
                endif

                # get desktop calc ratio
                if section.settings.image_ratio_desktop != 'adapt' and section.settings.image_ratio_desktop != 'full_height'
                  assign settings_desktop_aspect_ratio = temp_desktop | divided_by: aspect_ratio_desktop[1] | round: 2
                  assign settings_tablet_aspect_ratio = temp_desktop | divided_by: aspect_ratio_desktop[1] | round: 2
                elsif section.settings.image_ratio_desktop == 'full_height'
                  assign settings_tablet_aspect_ratio = 0.6
                  assign settings_desktop_aspect_ratio = 1.2
                else
                  assign settings_tablet_aspect_ratio = image_desktop.aspect_ratio
                  assign settings_desktop_aspect_ratio = image_desktop.aspect_ratio
                endif

                assign calc_ratio_tablet = 1
                if image_desktop.aspect_ratio > settings_tablet_aspect_ratio
                  assign calc_ratio_tablet = image_desktop.aspect_ratio | divided_by: settings_tablet_aspect_ratio | round: 2
                endif

                assign calc_ratio_desktop = 1
                if image_desktop.aspect_ratio > settings_desktop_aspect_ratio
                  assign calc_ratio_desktop = image_desktop.aspect_ratio | divided_by: settings_desktop_aspect_ratio | round: 2
                endif

                assign fetch_priority = 'auto'
                assign image_loading = 'lazy'
                if section.index == 1
                  assign fetch_priority = 'high'
                  assign image_loading = 'eager'
                endif

                assign widths = '360, 533, 720, 940, 1066, 1200, 1400, 1600, 1800, 2000, 2200, 2400, 2600, 2800, 3000, 3264, 3400, 3584, 3800, 4000, 4200, 4400, 4600, 4800, 5000, 5200, 5400, 5600, 6000'
              %}

              {%- capture sizes -%}
										(min-width: 990px) calc({{ calc_ratio_desktop }} * 100vw), (min-width: 576px) calc({{ calc_ratio_tablet }} * 100vw), calc({{ calc_ratio_mobile }} * 100vw)
									{%- endcapture -%}

              {%- if section.settings.image_desktop != blank -%}
                {%- assign base_class = 'newsletter__image' -%}
                {%- if section.settings.image_mobile != blank -%}
                  {%- assign base_class = base_class | append: ' newsletter__image--desktop' -%}
                {%- endif -%}
                {%- assign full_class = base_class | append: parallax_class -%}
                {{
                  section.settings.image_desktop
                  | image_url: width: section.settings.image_desktop.width
                  | image_tag:
                    loading: image_loading,
                    class: full_class,
                    widths: widths,
                    sizes: sizes,
                    fetchpriority: fetch_priority
                }}
              {%- endif -%}

              {%- if section.settings.image_mobile != blank -%}
                {%- assign base_class = 'newsletter__image' -%}
                {%- if section.settings.image_desktop != blank -%}
                  {%- assign base_class = base_class | append: ' newsletter__image--mobile' -%}
                {%- endif -%}
                {%- assign full_class = base_class | append: parallax_class -%}

                {{
                  section.settings.image_mobile
                  | image_url: width: section.settings.image_mobile.width
                  | image_tag:
                    loading: image_loading,
                    class: full_class,
                    widths: widths,
                    sizes: sizes,
                    fetchpriority: fetch_priority
                }}
              {%- endif -%}

            {%- else -%}
              {{ 'hero-apparel-1' | placeholder_svg_tag: 'media-banner__image placeholder-svg' }}
            {%- endif -%}
            {%- if section.settings.overlay_opacity != 0 -%}
              {%- capture overlay_style -%}
										opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}; background: rgba(var(--color-overlay));
									{%- endcapture -%}
              <span class="newsletter__overlay" style="{{ overlay_style }}"></span>
            {%- endif -%}
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.newsletter.name",
  "tag": "section",
  "class": "newsletter-section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.newsletter.settings.paragraph.content"
    },
    {
      "type": "header",
      "content": "t:sections.media-banner.settings.header__media.content"
    },
    {
      "type": "checkbox",
      "id": "enable_image",
      "default": true,
      "label": "t:sections.all.enable_image.label"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "t:sections.all.image.label",
      "visible_if": "{{ section.settings.enable_image }}"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "t:sections.all.image_mobile.label",
      "visible_if": "{{ section.settings.enable_image }}"
    },
    {
      "type": "select",
      "id": "image_ratio_desktop",
      "options": [
        {
          "value": "1/1",
          "label": "1:1"
        },
        {
          "value": "2/1",
          "label": "2:1"
        },
        {
          "value": "3/2",
          "label": "3:2"
        },
        {
          "value": "4/3",
          "label": "4:3"
        },
        {
          "value": "16/9",
          "label": "16:9"
        },
        {
          "value": "21/9",
          "label": "21:9"
        },
        {
          "value": "adapt",
          "label": "t:sections.all.aspect_ratio.adapt_to_media.label"
        },
        {
          "value": "full_height",
          "label": "t:sections.all.aspect_ratio.full_height.label"
        }
      ],
      "default": "full_height",
      "label": "t:sections.all.aspect_ratio.desktop.label"
    },
    {
      "type": "select",
      "id": "image_ratio_mobile",
      "options": [
        {
          "value": "1/1",
          "label": "1:1"
        },
        {
          "value": "2/1",
          "label": "2:1"
        },
        {
          "value": "3/2",
          "label": "3:2"
        },
        {
          "value": "4/3",
          "label": "4:3"
        },
        {
          "value": "16/9",
          "label": "16:9"
        },
        {
          "value": "21/9",
          "label": "21:9"
        },
        {
          "value": "4/5",
          "label": "4:5"
        },
        {
          "value": "3/4",
          "label": "3:4"
        },
        {
          "value": "adapt",
          "label": "t:sections.all.aspect_ratio.adapt_to_media.label"
        },
        {
          "value": "full_height",
          "label": "t:sections.all.aspect_ratio.full_height.label"
        }
      ],
      "default": "full_height",
      "label": "t:sections.all.aspect_ratio.mobile.label"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 10,
      "unit": "%",
      "label": "t:sections.all.overlay_opacity.label",
      "visible_if": "{{ section.settings.enable_image }}"
    },
    {
      "type": "checkbox",
      "id": "enable_parallax",
      "default": false,
      "label": "t:sections.all.slider.enable_parallax.label"
    },
    {
      "type": "header",
      "content": "t:sections.newsletter.settings.header__4.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "background-4",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "inline_richtext",
      "id": "content_heading",
      "label": "t:sections.all.heading.label",
      "default": "t:sections.newsletter.settings.content_heading.default"
    },
    {
      "type": "select",
      "id": "content_heading_size",
      "options": [
        {
          "value": "h5",
          "label": "t:sections.all.heading_size.options__5.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__1.label"
        }
      ],
      "default": "h3",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "select",
      "id": "content_heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.heading_tag.options__6.label"
        },
        {
          "value": "div",
          "label": "t:sections.all.heading_tag.options__7.label"
        }
      ],
      "default": "h3",
      "label": "t:sections.all.heading_tag.label"
    },
    {
      "type": "inline_richtext",
      "id": "newsletter_text",
      "default": "t:sections.newsletter.settings.newsletter_text.default",
      "label": "t:sections.newsletter.settings.newsletter_text.label"
    },
    {
      "type": "checkbox",
      "id": "privacy_policy_consent",
      "default": false,
      "label": "t:sections.footer.settings.privacy_policy_consent.label"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "options": [
        {
          "value": "top",
          "label": "t:sections.all.vertical_alignment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.all.vertical_alignment.options__2.label"
        },
        {
          "value": "bottom",
          "label": "t:sections.all.vertical_alignment.options__3.label"
        }
      ],
      "default": "center",
      "label": "t:sections.all.vertical_alignment.label"
    },
    {
      "type": "text_alignment",
      "id": "text_alignment",
      "default": "center",
      "label": "t:sections.all.horizontal_alignment.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.newsletter.name",
      "category": "t:sections.categories.forms"
    }
  ]
}
{% endschema %}
