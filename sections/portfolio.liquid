{{ 'section-portfolio.css' | asset_url | stylesheet_tag }}

<script src="{{ 'gsap.min.js' | asset_url }}" defer></script>
<script src="{{ 'ScrollTrigger.min.js' | asset_url }}" defer></script>
<script src="{{ 'portfolio.js' | asset_url }}" defer></script>
<script src="{{ 'ScrollToPlugin.min.js' | asset_url }}" defer></script>

{%- style -%}
  {% render 'section-margin' %}
{%- endstyle -%}

<div class="portfolio">
  <!-- Pagination -->
  <div class="portfolio-pagination">
    <span class="portfolio-pagination__current">01</span>
    <span class="portfolio-pagination__separator">—</span>
    <span class="portfolio-pagination__total" data-total="{{ section.blocks.size }}">
      {% if section.blocks.size < 10 %}0{{ section.blocks.size }}{% else %}{{ section.blocks.size }}{% endif %}
    </span>
  </div>

  <!-- Main Content Wrapper -->
  <div class="portfolio-content">
    {%- for block in section.blocks -%}
      <div class="portfolio-content-item color-{{ block.settings.color_scheme }}" {{ block.shopify_attributes }}>
        <!-- Background Image -->
        {%- liquid
          assign image = block.settings.background_image
          if block.settings.overlay_opacity > 0
            assign overlay_opacity = block.settings.overlay_opacity | divided_by: 100.0
          endif
        -%}
        <div class="portfolio-background-image">
          {% if block.settings.background_image != blank %}
            {{
              image
              | image_url: width: image.width
              | image_tag:
                width: image.width,
                height: image.height,
                widths: '1920, 2400, 3000, 3600',
                sizes: '100vw',
                class: 'portfolio-background-image__img',
                loading: 'lazy'
            }}
          {% else %}
            {%- assign placeholder_index = forloop.index0 | modulo: 3 | plus: 1 -%}
            {{ 'hero-apparel-' | append: placeholder_index | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
          {% if overlay_opacity > 0 %}
            <div class="portfolio-background-image__overlay" style="opacity: {{ overlay_opacity }};"></div>
          {% endif %}
        </div>

        <!-- Text -->
        <div class="portfolio-content-left">
          <div class="portfolio-text-wrapper">
            <div class="portfolio-text-item">
              {% if block.settings.subheading != blank %}
                <span class="portfolio-text-item__subheading body-normal">
                  {{- block.settings.subheading | truncate: 20, '' -}}
                </span>
              {% endif %}

              {% if block.settings.heading != blank %}
                <{{ block.settings.heading_tag | default: 'h2' }} class="portfolio-text-item__heading h4">
                  {{ block.settings.heading | truncate: 25, '' }}
                </{{ block.settings.heading_tag | default: 'h2' }}>
              {% endif %}

              {% if block.settings.description != blank %}
                <div class="portfolio-text-item__description richtext-link-inside body-normal">
                  {{ block.settings.description | truncate: 120, '' }}
                </div>
              {% endif %}

              {%- if block.settings.show_button and block.settings.button_label != blank -%}
                {% render 'button',
                  btn_label: block.settings.button_label,
                  btn_style: 'tertiary',
                  btn_link: block.settings.button_link,
                  class: 'portfolio-text-item__button'
                %}
              {%- endif -%}
            </div>
          </div>
        </div>

        <!-- Thumbnail -->
        <div class="portfolio-content-right">
          <div class="portfolio-thumbnail-wrapper">
            {%- liquid
              assign thumbnail_image = block.settings.image
            -%}

            <div class="portfolio-thumbnail-image">
              {% if thumbnail_image != blank %}
                {{
                  thumbnail_image
                  | image_url: width: thumbnail_image.width
                  | image_tag:
                    width: thumbnail_image.width,
                    height: thumbnail_image.height,
                    widths: '400, 600, 800',
                    sizes: '(min-width: 750px) 40rem, 20rem',
                    class: 'portfolio-thumbnail-image__img',
                    loading: 'lazy'
                }}
              {% else %}
                {%- assign placeholder_index = forloop.index0 | modulo: 3 | plus: 1 -%}
                {{ 'product-apparel-' | append: placeholder_index | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>
          </div>
        </div>

        {%- if block.settings.button_link != blank -%}
          <a
            href="{{ block.settings.button_link }}"
            class="portfolio-content-item__overlay-link"
            aria-label="{{ block.settings.heading | default: block.settings.button_label | default: 'View details' }}"
          >
            &nbsp;</a
          >
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.portfolio.name",
  "tag": "section",
  "class": "portfolio-section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "l",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ],
  "blocks": [
    {
      "type": "portfolio-card",
      "name": "t:sections.portfolio.blocks.portfolio-card.name",
      "settings": [
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "default": "background-3",
          "label": "t:sections.all.color_scheme.label"
        },
        {
          "type": "header",
          "content": "t:sections.portfolio.blocks.portfolio-card.settings.media_options.label"
        },
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "t:sections.all.background_image.label"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "t:sections.all.overlay_opacity.label",
          "default": 15
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.all.image.label"
        },
        {
          "type": "header",
          "content": "t:sections.portfolio.blocks.portfolio-card.settings.content_options.label"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "t:sections.all.subheading.label",
          "default": "t:sections.portfolio.blocks.portfolio-card.settings.subheading.default",
          "info": "t:sections.portfolio.blocks.portfolio-card.settings.subheading.info"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.all.heading.label",
          "default": "t:sections.portfolio.blocks.portfolio-card.settings.heading.default",
          "info": "t:sections.portfolio.blocks.portfolio-card.settings.heading.info"
        },
        {
          "type": "select",
          "id": "heading_tag",
          "options": [
            {
              "value": "h1",
              "label": "t:sections.all.heading_tag.options__1.label"
            },
            {
              "value": "h2",
              "label": "t:sections.all.heading_tag.options__2.label"
            },
            {
              "value": "h3",
              "label": "t:sections.all.heading_tag.options__3.label"
            },
            {
              "value": "h4",
              "label": "t:sections.all.heading_tag.options__4.label"
            },
            {
              "value": "h5",
              "label": "t:sections.all.heading_tag.options__5.label"
            },
            {
              "value": "h6",
              "label": "t:sections.all.heading_tag.options__6.label"
            },
            {
              "value": "div",
              "label": "t:sections.all.heading_tag.options__7.label"
            }
          ],
          "default": "h2",
          "label": "t:sections.all.heading_tag.label",
          "info": "t:sections.all.heading_tag.info",
          "visible_if": "{{ block.settings.heading != blank }}"
        },
        {
          "type": "inline_richtext",
          "id": "description",
          "label": "t:sections.all.text.label",
          "default": "t:sections.portfolio.blocks.portfolio-card.settings.description.default",
          "info": "t:sections.portfolio.blocks.portfolio-card.settings.description.info"
        },
        {
          "type": "header",
          "content": "t:sections.all.button.header_button.content"
        },
        {
          "type": "checkbox",
          "id": "show_button",
          "default": true,
          "label": "t:sections.all.button.button_show.label"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "t:sections.all.button.button_label.label",
          "default": "t:sections.all.button.button_label.default_shop_now",
          "visible_if": "{{ block.settings.show_button == true }}"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "t:sections.all.button.button_link.label",
          "visible_if": "{{ block.settings.show_button == true }}"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.portfolio.name",
      "category": "t:sections.categories.banners",
      "blocks": [
        {
          "type": "portfolio-card"
        },
        {
          "type": "portfolio-card"
        },
        {
          "type": "portfolio-card"
        }
      ]
    }
  ]
}
{% endschema %}

