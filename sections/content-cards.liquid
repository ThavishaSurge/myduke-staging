{{ 'section-content-cards.css' | asset_url | stylesheet_tag }}

{% style %}
  {% render 'section-padding' %}
  {% render 'section-margin' %}
{% endstyle %}

<div class="content-cards color-{{ section.settings.color_scheme }} background section-{{ section.id }}-padding">
  {% render 'heading-group', settings: section.settings, class: 'content-cards-header' %}
  {%- if section.blocks.size > 0 -%}
    <div class="container content-cards__wrapper  content-cards__wrapper--{{ section.settings.items_per_row }}">
      {%- for block in section.blocks -%}
        {% liquid
          if section.settings.aspect_ratio == 'adapt'
            if block.settings.image != blank
              assign padding_bottom = 1 | divided_by: block.settings.image.aspect_ratio | times: 100 | round: 2
            else
              assign padding_bottom = '0'
            endif
          elsif section.settings.aspect_ratio == 'landscape'
            assign padding_bottom = '69.5'
          elsif section.settings.aspect_ratio == 'portrait'
            assign padding_bottom = '135.6'
          elsif section.settings.aspect_ratio == 'square'
            assign padding_bottom = '100'
          endif
        %}
        <div class="content-cards__item">
          <div class="content-cards__item--content">
            {% if section.settings.enable_card_numbering %}
              <div class="content-cards__item--count">
                <p class="body-small">
                  {% if forloop.index <= 9 %}0{% endif -%}
                  {{- forloop.index }}
                </p>
              </div>
            {% endif %}
            <div class="content-cards__item--main">
              <div
                class="content-cards__image-wrapper content-cards__item--{{ section.settings.aspect_ratio }}"
                style="--padding-bottom: {{ padding_bottom }}%;"
                {% if section.settings.enable_image_animation %}
                  data-scroll-image-reveal
                  data-reveal-sequence
                {% endif %}
              >
                {%- liquid
                  assign image_styles = 'object-fit: ' | append: section.settings.object_fit
                  if section.settings.aspect_ratio == 'landscape'
                    assign settings_aspect_ratio = 1.26
                  elsif section.settings.aspect_ratio == 'portrait'
                    assign settings_aspect_ratio = 0.88
                  else
                    assign settings_aspect_ratio = 1
                  endif
                -%}

                {%- if block.settings.card_image != blank -%}
                  {% liquid
                    assign card_image = block.settings.card_image

                    assign calc_ratio = 1
                    if block.settings.card_image.aspect_ratio > settings_aspect_ratio
                      assign calc_ratio = card_image.aspect_ratio | divided_by: settings_aspect_ratio | round: 2
                    endif

                    assign image_loading = 'lazy'

                    if section.index == 1 and forloop.index == 1
                      assign image_loading = 'eager'
                    endif

                    assign card_image_class = 'content-cards__image'
                    if section.settings.enable_image_animation
                      assign card_image_class = card_image_class | append: ' scroll-image-reveal__target'
                    endif
                  %}

                  {%- capture image_sizes -%}
											{%- if section.settings.items_per_row == 1 -%}
												calc(100vw * {{ calc_ratio }})
											{%- elsif section.settings.items_per_row == 2 -%}
												(min-width: 576px) calc({{ calc_ratio }} * 50vw), calc(100vw * {{ calc_ratio }})
											{%- elsif section.settings.items_per_row == 3 -%}
												(min-width: 990px) calc({{ calc_ratio }} * 33.3vw), (min-width: 576px) calc({{ calc_ratio }} * 50vw), calc(100vw * {{ calc_ratio }})
											{%- elsif section.settings.items_per_row == 4 -%}
												(min-width: 1200px) calc({{ calc_ratio }} * 25vw), (min-width: 576px) calc({{ calc_ratio }} * 50vw), calc(100vw * {{ calc_ratio }})
											{%- endif -%}
										{%- endcapture -%}

                  {{
                    card_image
                    | image_url: width: card_image.width
                    | image_tag:
                      width: card_image.width,
                      height: card_image.height,
                      widths: '360, 535, 600, 720, 940, 1066, 1200, 1400, 1600, 1800, 2000, 2200, 2400, 2600, 2800, 3000, 3200, 3400, 3600, 3800',
                      sizes: image_sizes,
                      class: card_image_class,
                      style: image_styles,
                      loading: image_loading
                  }}
                {%- else -%}
                  {% liquid
                    assign index = forloop.index | modulo: 3 | plus: 1
                    assign placeholder_class = 'placeholder-svg'
                    if section.settings.enable_image_animation
                      assign placeholder_class = placeholder_class | append: ' scroll-image-reveal__target'
                    endif
                  %}
                  {{ 'hero-apparel-' | append: index | placeholder_svg_tag: placeholder_class }}
                {%- endif -%}

                {%- if block.settings.overlay_opacity != 0 -%}
                  <span
                    class="content-cards__overlay"
                    style="opacity: {{ block.settings.overlay_opacity | times: 0.01 }};"
                  ></span>
                {%- endif -%}
              </div>
              <div class="content-cards__info">
                {%- if block.settings.card_heading != blank -%}
                  <{{ block.settings.card_heading_tag | default: 'h3' }} class="content-cards__info-heading {% if block.settings.card_heading_font == 'heading'%}{{ block.settings.card_heading_size }}{% elsif block.settings.card_heading_font == 'subtitle' %}subtitle{% else %}title body-extra-large{% endif %}">
                    {{- block.settings.card_heading -}}
                  </{{ block.settings.card_heading_tag | default: 'h3' }}>
                {%- endif -%}
                {%- if block.settings.card_description != blank -%}
                  <p class="content-cards__info-description body-normal">
                    {{ block.settings.card_description }}
                  </p>
                {%- endif -%}
              </div>
              {%- if block.settings.card_overlay_link != blank -%}
                <a
                  href="{{ block.settings.card_overlay_link }}"
                  class="content-cards__link-overlay focus-inset"
                  aria-label="{{ block.settings.card_heading }}"
                  {% if settings.links_blank and block.settings.card_overlay_link.type == 'external_link' %}
                    target="_blank"
                  {% endif %}
                ></a>
              {%- endif -%}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}
</div>

{% schema %}
