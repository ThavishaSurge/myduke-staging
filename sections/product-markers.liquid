{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'section-product-markers.css' | asset_url | stylesheet_tag }}

<script src="{{ 'product-markers.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  {% render 'section-padding' %}
   {% render 'section-margin' %}
{%- endstyle -%}

<div class="product-markers color-{{ section.settings.color_scheme }} background section-{{ section.id }}-padding">
  {% render 'heading-group', settings: section.settings, class: 'product-markers-header' %}
  <div class="content">
    {% liquid
      if section.settings.main_image_ratio != 'adapt' and section.settings.main_image_ratio != 'full_height'
        assign aspect_ratio = section.settings.main_image_ratio | split: '/'
        assign temp = aspect_ratio[0] | append: '.0'
        assign padding_bottom = aspect_ratio[1] | divided_by: temp | times: 100 | round: 2
      elsif section.settings.main_image_ratio == 'adapt'
        if section.settings.image != blank
          assign padding_bottom = 1 | divided_by: section.settings.image.aspect_ratio | times: 100 | round: 2
        else
          assign padding_bottom = 0
        endif
      else
        assign padding_bottom = 0
      endif
    %}
    <div
      class="product-markers-for-mobile"
    >
      {%- for block in section.blocks -%}
        <div
          class="product-markers__item-inner js-product-markers__item-inner"
          data-index="{{ forloop.index }}"
        >
          {% render 'product-card-simple',
            section_obj: section,
            section_id: section.id,
            product_card_product: block.settings.product_id,
            product_show_description_overwrite: section.settings.product_show_description,
            show_quick_view_overwrite: section.settings.show_quick_view,
            show_product_variants: section.settings.show_product_variants,
            media_ratio_overwrite: section.settings.image_ratio,
            media_fit_overwrite: section.settings.image_fit
          %}
        </div>
      {% endfor %}
    </div>

    <div
      class="product-markers__markers {{ section.settings.main_image_ratio }}"
      {% if section.settings.main_image_ratio != 'full_height' %}
        style="padding-bottom: {{ padding_bottom }}%;"
      {% endif %}
    >
      {%- for block in section.blocks -%}
        <div
          data-index="{{ forloop.index }}"
          tabindex="0"
          class="product-markers__item js-product-markers__item "
          {{ block.shopify_attributes }}
          style="top: {{ block.settings.position_y }}%; left:{{ block.settings.position_x }}%"
        >
          <div class="product-markers__item-number h3">
            <span class="product-markers__item-number-span"></span>
          </div>
        </div>

        <div
          data-index="{{ forloop.index }}"
          class="product-markers__item-inner js-product-markers__item-inner {% if block.settings.product_id != blank %}collection-product-card {% endif %}"
        >
          {% render 'product-card-simple',
            section_obj: section,
            section_id: section.id,
            product_card_product: block.settings.product_id,
            product_show_description_overwrite: section.settings.product_show_description,
            show_quick_view_overwrite: section.settings.show_quick_view,
            show_product_variants: section.settings.show_product_variants,
            media_ratio_overwrite: section.settings.image_ratio,
            media_fit_overwrite: section.settings.image_fit
          %}
        </div>
      {% endfor %}

      {% if section.settings.image != blank %}
        <div class="product-markers__image-container">
          {% liquid
            assign fetch_priority = 'auto'
            assign image_loading = 'lazy'
            if section.index == 1
              assign fetch_priority = 'high'
              assign image_loading = 'eager'
            endif
          %}
          {{
            section.settings.image
            | image_url: width: section.settings.image.width
            | image_tag:
              loading: image_loading,
              widths: '360, 535, 720, 940, 1100, 1200, 1440, 1600, 1800, 2000, 2100, 2200, 2880, 3200, 3600, 3800',
              sizes: '100vw',
              class: 'product-markers__image',
              fetchpriority: fetch_priority
          }}
        </div>
      {% elsif section.settings.image == blank %}
        <div class="product-markers__placeholder product-markers__image">
          {{ 'hero-apparel-1' | placeholder_svg_tag: 'product-markers__placeholder-svg placeholder-svg' }}
        </div>
      {% endif %}
      {% comment %}<div class="product-markers--overlay" style="opacity: {{ section.settings.overlay_opacity }}"></div>{% endcomment %}

      {%- if section.settings.overlay_opacity != 0 -%}
        {%- capture overlay_style -%}
            opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}; background: rgba(var(--color-overlay));
          {%- endcapture -%}
        <span class="product-markers--overlay" style="{{ overlay_style }}"></span>
      {%- endif -%}
    </div>
  </div>
</div>

