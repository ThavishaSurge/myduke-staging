{{ 'section-info-banner.css' | asset_url | stylesheet_tag }}

<div class="info-banner" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
  <div class="info-banner__container page-width">
    {%- for block in section.blocks -%}
      <div class="info-banner__item" {{ block.shopify_attributes }}>
        {%- if block.settings.icon_svg != blank -%}
          <div class="info-banner__icon" style="color: {{ section.settings.text_color }};">
            {{ block.settings.icon_svg }}
          </div>
        {%- endif -%}
        
        {%- if block.settings.text != blank -%}
          <div class="info-banner__text">
            {{ block.settings.text }}
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Info Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#2c4f58"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text & Icon Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "info_item",
      "name": "Info Item",
      "limit": 6,
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG Code",
          "info": "Paste the raw SVG code for the icon here."
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Info text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Info Banner",
      "category": "Custom",
      "blocks": [
        { "type": "info_item", "settings": { "text": "AHPRA-Registered Doctors" } },
        { "type": "info_item", "settings": { "text": "TGA-Compliant Framework" } },
        { "type": "info_item", "settings": { "text": "Secure Medical Data" } },
        { "type": "info_item", "settings": { "text": "Australian Owned & Operated" } }
      ]
    }
  ]
}
{% endschema %}
