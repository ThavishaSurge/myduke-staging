{{ 'section-myduke-shop-all.css' | asset_url | stylesheet_tag }}
{{ 'component-pagination.css' | asset_url | stylesheet_tag }}
{%- style -%}
  {% render 'section-padding' %}
  {% render 'section-margin' %}
{%- endstyle -%}

{%- liquid
  assign show_device_filter      = section.settings.show_device_filter
  assign show_type_filter        = section.settings.show_type_filter
  assign show_brand_filter       = section.settings.show_brand_filter
  assign show_strength_filter    = section.settings.show_strength_filter
  assign show_sort               = section.settings.show_sort
  assign products_per_page       = section.settings.products_per_page | default: 24
  assign cols_desktop            = section.settings.columns_desktop | default: 6
  assign cols_mobile             = section.settings.columns_mobile | default: 2

  comment
    Collect all collections used for each filter via blocks
  endcomment
  assign device_collections = ''
  assign type_collections   = ''
  for block in section.blocks
    assign col_obj = block.settings.collection_handle
    assign col_handle = col_obj.handle | default: col_obj

    if block.type == 'device_filter_item'
      if col_handle != blank
        assign device_collections = device_collections | append: col_handle | append: ','
      endif
    endif
    if block.type == 'type_filter_item'
      if col_handle != blank
        assign type_collections = type_collections | append: col_handle | append: ','
      endif
    endif
  endfor

  assign device_collections_array = device_collections | split: ','
  assign type_collections_array = type_collections | split: ','

  comment
    Collect unique vendors from source collection for Brands filter
  endcomment
  assign source_col_handle = section.settings.source_collection
  assign unique_vendors = ''
  assign seen_vendor_handles = ''
  for product in collections[source_col_handle].products
    assign vendor_handle = product.vendor | handleize
    assign vendor_check = '|' | append: vendor_handle | append: '|'
    assign seen_check_string = '|' | append: seen_vendor_handles | append: '|'
    unless seen_check_string contains vendor_check
      if seen_vendor_handles == blank
        assign seen_vendor_handles = vendor_handle
      else
        assign seen_vendor_handles = seen_vendor_handles | append: '|' | append: vendor_handle
      endif
      if unique_vendors == blank
        assign unique_vendors = product.vendor
      else
        assign unique_vendors = unique_vendors | append: '§' | append: product.vendor
      endif
    endunless
  endfor
  assign unique_vendors_array = unique_vendors | split: '§'

  comment
    Collect unique Strength values from variant options across the source collection
  endcomment
  assign unique_strengths = ''
  assign seen_strength_handles = ''
  for product in collections[source_col_handle].products
    assign strength_option_index = -1
    for opt_name in product.options
      assign opt_name_lower = opt_name | downcase
      if opt_name_lower == 'strength'
        assign strength_option_index = forloop.index0
      endif
    endfor
    if strength_option_index >= 0
      for variant in product.variants
        assign s_val = ''
        case strength_option_index
          when 0
            assign s_val = variant.option1
          when 1
            assign s_val = variant.option2
          when 2
            assign s_val = variant.option3
        endcase
        if s_val != blank
          assign s_handle = s_val | handleize
          assign s_check = '|' | append: s_handle | append: '|'
          assign seen_s_str = '|' | append: seen_strength_handles | append: '|'
          unless seen_s_str contains s_check
            if seen_strength_handles == blank
              assign seen_strength_handles = s_handle
            else
              assign seen_strength_handles = seen_strength_handles | append: '|' | append: s_handle
            endif
            if unique_strengths == blank
              assign unique_strengths = s_val
            else
              assign unique_strengths = unique_strengths | append: '§' | append: s_val
            endif
          endunless
        endif
      endfor
    endif
  endfor
  assign unique_strengths_array = unique_strengths | split: '§'
-%}

<div
  class="msa color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding section-{{ section.id }}-margin mydk-product-container-auth"
  data-section-id="{{ section.id }}"
  id="shopify-section-shop-all"
>
  <div class="container    {%- comment -%} ── Toolbar: Filters + Sort ── {%- endcomment -%}
    {%- if show_device_filter or show_type_filter or show_brand_filter or show_strength_filter or show_sort -%}
      <div class="msa__toolbar">

        <div class="msa__mobile-toggles">
          {%- if show_device_filter or show_type_filter or show_brand_filter or show_strength_filter -%}
            <button class="msa__mobile-toggle js-msa-mobile-toggle" aria-expanded="false">
              <span class="msa__mobile-toggle-label">Filters</span>
              <svg class="msa__caret" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          {%- endif -%}

          {%- if show_sort -%}
            <div class="msa__sort-group">
              <label class="msa__sort-label" for="msa-sort-{{ section.id }}">
                {{ section.settings.sort_label | default: 'Sort by' }}
              </label>
              <div class="msa__sort-select-wrap">
                <select class="msa__sort-select" id="msa-sort-{{ section.id }}" aria-label="Sort products">
                  {%- if section.settings.show_sort_featured -%}
                    <option value="manual">{{ section.settings.sort_featured_label | default: 'Featured' }}</option>
                  {%- endif -%}
                  {%- if section.settings.show_sort_best -%}
                    <option value="best-selling">{{ section.settings.sort_best_label | default: 'Best Selling' }}</option>
                  {%- endif -%}
                  {%- if section.settings.show_sort_az -%}
                    <option value="title-ascending">{{ section.settings.sort_az_label | default: 'A–Z' }}</option>
                  {%- endif -%}
                  {%- if section.settings.show_sort_za -%}
                    <option value="title-descending">{{ section.settings.sort_za_label | default: 'Z–A' }}</option>
                  {%- endif -%}
                  {%- if section.settings.show_sort_price_asc -%}
                    <option value="price-ascending">{{ section.settings.sort_price_asc_label | default: 'Price: Low → High' }}</option>
                  {%- endif -%}
                  {%- if section.settings.show_sort_price_desc -%}
                    <option value="price-descending">{{ section.settings.sort_price_desc_label | default: 'Price: High → Low' }}</option>
                  {%- endif -%}
                  {%- if section.settings.show_sort_new -%}
                    <option value="created-descending">{{ section.settings.sort_new_label | default: 'Newest' }}</option>
                  {%- endif -%}
                  {%- if section.settings.show_sort_old -%}
                    <option value="created-ascending">{{ section.settings.sort_old_label | default: 'Oldest' }}</option>
                  {%- endif -%}
                </select>
                <svg class="msa__caret" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </div>
          {%- endif -%}
        </div>

        <div class="msa__toolbar-inner">

          <div class="msa__filters">

          {%- if show_device_filter -%}
            <div class="msa__filter-group" data-filter-group="device">
              <button
                class="msa__filter-btn"
                aria-haspopup="listbox"
                aria-expanded="false"
                id="msa-device-btn-{{ section.id }}"
              >
                <span class="msa__filter-label">
                  {{- section.settings.device_filter_label | default: 'Device Compatibility' -}}
                </span>
                <svg class="msa__caret" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>

              <div class="msa__dropdown" role="listbox" aria-labelledby="msa-device-btn-{{ section.id }}">
                <div class="msa__dropdown-inner">
                  <button class="msa__dropdown-item msa__dropdown-item--active" data-filter-value="all" role="option" aria-selected="true">
                    {{ section.settings.device_filter_all_label | default: 'All Devices' }}
                  </button>
                  {%- for block in section.blocks -%}
                    {%- if block.type == 'device_filter_item' -%}
                      {%- assign col_obj = block.settings.collection_handle -%}
                      {%- assign col_handle = col_obj.handle | default: col_obj -%}
                      {%- assign col = collections[col_handle] -%}
                      {%- if col_handle != blank -%}
                        <button
                          class="msa__dropdown-item"
                          data-filter-value="{{ col_handle }}"
                          data-filter-type="device"
                          role="option"
                          aria-selected="false"
                          {{ block.shopify_attributes }}
                        >
                          {{- block.settings.label | default: col.title -}}
                        </button>
                      {%- endif -%}
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
            </div>
          {%- endif -%}

          {%- if show_type_filter -%}
            <div class="msa__filter-group" data-filter-group="type">
              <button
                class="msa__filter-btn"
                aria-haspopup="listbox"
                aria-expanded="false"
                id="msa-type-btn-{{ section.id }}"
              >
                <span class="msa__filter-label">
                  {{- section.settings.type_filter_label | default: 'Product Type' -}}
                </span>
                <svg class="msa__caret" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>

              <div class="msa__dropdown" role="listbox" aria-labelledby="msa-type-btn-{{ section.id }}">
                <div class="msa__dropdown-inner">
                  <button class="msa__dropdown-item msa__dropdown-item--active" data-filter-value="all" role="option" aria-selected="true">
                    {{ section.settings.type_filter_all_label | default: 'All Types' }}
                  </button>
                  {%- for block in section.blocks -%}
                    {%- if block.type == 'type_filter_item' -%}
                      {%- assign col_obj = block.settings.collection_handle -%}
                      {%- assign col_handle = col_obj.handle | default: col_obj -%}
                      {%- assign col = collections[col_handle] -%}
                      {%- if col_handle != blank -%}
                        <button
                          class="msa__dropdown-item"
                          data-filter-value="{{ col_handle }}"
                          data-filter-type="type"
                          role="option"
                          aria-selected="false"
                          {{ block.shopify_attributes }}
                        >
                          {{- block.settings.label | default: col.title -}}
                        </button>
                      {%- endif -%}
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
            </div>
          {%- endif -%}

          {%- if show_brand_filter and unique_vendors_array.size > 0 -%}
            <div class="msa__filter-group" data-filter-group="brand">
              <button
                class="msa__filter-btn"
                aria-haspopup="listbox"
                aria-expanded="false"
                id="msa-brand-btn-{{ section.id }}"
              >
                <span class="msa__filter-label">
                  {{- section.settings.brand_filter_label | default: 'Brands' -}}
                </span>
                <svg class="msa__caret" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>

              <div class="msa__dropdown" role="listbox" aria-labelledby="msa-brand-btn-{{ section.id }}">
                <div class="msa__dropdown-inner">
                  <button class="msa__dropdown-item msa__dropdown-item--active" data-filter-value="all" role="option" aria-selected="true">
                    {{ section.settings.brand_filter_all_label | default: 'All Brands' }}
                  </button>
                  {%- for vendor in unique_vendors_array -%}
                    {%- assign vendor_handle = vendor | handleize -%}
                    <button
                      class="msa__dropdown-item"
                      data-filter-value="{{ vendor_handle }}"
                      data-filter-type="brand"
                      role="option"
                      aria-selected="false"
                    >
                      {{- vendor -}}
                    </button>
                  {%- endfor -%}
                </div>
              </div>
            </div>
          {%- endif -%}

          {%- if show_strength_filter and unique_strengths_array.size > 0 -%}
            <div class="msa__filter-group" data-filter-group="strength">
              <button
                class="msa__filter-btn"
                aria-haspopup="listbox"
                aria-expanded="false"
                id="msa-strength-btn-{{ section.id }}"
              >
                <span class="msa__filter-label">
                  {{- section.settings.strength_filter_label | default: 'Strength' -}}
                </span>
                <svg class="msa__caret" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>

              <div class="msa__dropdown" role="listbox" aria-labelledby="msa-strength-btn-{{ section.id }}">
                <div class="msa__dropdown-inner">
                  <button class="msa__dropdown-item msa__dropdown-item--active" data-filter-value="all" role="option" aria-selected="true">
                    {{ section.settings.strength_filter_all_label | default: 'All Strengths' }}
                  </button>
                  {%- for strength_val in unique_strengths_array -%}
                    {%- assign strength_handle = strength_val | handleize -%}
                    <button
                      class="msa__dropdown-item"
                      data-filter-value="{{ strength_handle }}"
                      data-filter-type="strength"
                      role="option"
                      aria-selected="false"
                    >
                      {{- strength_val -}}
                    </button>
                  {%- endfor -%}
                </div>
              </div>
            </div>
          {%- endif -%}

          </div>

        </div>
      </div>
    {%- endif -%}

    {%- comment -%} ── Active filter pills ── {%- endcomment -%}
    <div class="msa__active-filters" id="msa-active-filters-{{ section.id }}" hidden></div>

    {%- comment -%} ── Results count ── {%- endcomment -%}
    <p class="msa__results-count" id="msa-results-count-{{ section.id }}" aria-live="polite"></p>

    {%- comment -%} ── Product Grid ── {%- endcomment -%}
    <div
      class="msa__grid"
      id="msa-grid-{{ section.id }}"
      data-cols-desktop="{{ cols_desktop }}"
      data-cols-mobile="{{ cols_mobile }}"
      data-products-per-page="{{ products_per_page }}"
      aria-label="Products"
    >
      <div class="msa__list msa__list--{{ cols_desktop }} msa__list--grid">

      {%- assign source_collection = section.settings.source_collection -%}
      {%- assign all_products = collections[source_collection].products -%}

      {%- paginate collections[source_collection].products by 1000 -%}
      {%- if all_products.size > 0 -%}
        {%- for product in collections[source_collection].products -%}
          {%- assign product_device_handles = '' -%}
          {%- assign product_type_handles   = '' -%}
          {%- assign product_strength_handles = '' -%}

          {%- for prod_col in product.collections -%}
            {%- if device_collections_array contains prod_col.handle -%}
              {%- assign product_device_handles = product_device_handles | append: prod_col.handle | append: ',' -%}
            {%- endif -%}
            {%- if type_collections_array contains prod_col.handle -%}
              {%- assign product_type_handles = product_type_handles | append: prod_col.handle | append: ',' -%}
            {%- endif -%}
          {%- endfor -%}

          {%- comment -%} Collect Strength option values for this product's variants {%- endcomment -%}
          {%- assign product_strength_opt_index = -1 -%}
          {%- for opt_name in product.options -%}
            {%- assign opt_lower = opt_name | downcase -%}
            {%- if opt_lower == 'strength' -%}
              {%- assign product_strength_opt_index = forloop.index0 -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if product_strength_opt_index >= 0 -%}
            {%- for variant in product.variants -%}
              {%- assign sv = '' -%}
              {%- case product_strength_opt_index -%}
                {%- when 0 -%}{%- assign sv = variant.option1 -%}
                {%- when 1 -%}{%- assign sv = variant.option2 -%}
                {%- when 2 -%}{%- assign sv = variant.option3 -%}
              {%- endcase -%}
              {%- if sv != blank -%}
                {%- assign sv_handle = sv | handleize -%}
                {%- assign sv_check = ',' | append: sv_handle | append: ',' -%}
                {%- assign existing_str = ',' | append: product_strength_handles | append: ',' -%}
                {%- unless existing_str contains sv_check -%}
                  {%- assign product_strength_handles = product_strength_handles | append: sv_handle | append: ',' -%}
                {%- endunless -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}

          <div
            class="msa__product-item"
            data-product-id="{{ product.id }}"
            data-device-filters="{{ product_device_handles | remove_last: ',' }}"
            data-type-filters="{{ product_type_handles | remove_last: ',' }}"
            data-strength-filters="{{ product_strength_handles | remove_last: ',' }}"
            data-brand-filter="{{ product.vendor | handleize }}"
            data-price="{{ product.price }}"
            data-title="{{ product.title | downcase }}"
            data-created="{{ product.published_at | date: '%s' }}"
            data-sort-featured="{{ forloop.index }}"
            data-best-selling="0"
          >
            <a class="msa__card" href="{{ product.url }}">
              <div class="msa__card-image-wrap">
                {%- if product.featured_image != blank -%}
                  {{
                    product.featured_image
                    | image_url: width: 600
                    | image_tag:
                      loading: 'lazy',
                      widths: '300, 400, 600',
                      sizes: '(min-width: 1200px) 16vw, (min-width: 990px) 20vw, (min-width: 576px) 33vw, 50vw',
                      style: 'object-fit:contain'
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
              <p class="msa__card-title">{{ product.title }}</p>
              <p class="msa__card-price">
                {%- if product.compare_at_price > product.price -%}
                  <span class="msa__card-price--compare">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
                {{ product.price | money }}
              </p>
            </a>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..cols_desktop) -%}
          <div class="msa__product-item msa__product-item--placeholder">
            <div class="msa__card msa__card--placeholder">
              <div class="msa__card-image-wrap">
                {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
              <p class="msa__card-title">Product title</p>
              <p class="msa__card-price">$0.00</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}

      </div>
    </div>

    {%- comment -%} ── Client-side Pagination Wrapper ── {%- endcomment -%}
    <div class="msa__client-pagination"></div>

    {%- endpaginate -%}

    {%- comment -%} ── No results ── {%- endcomment -%}
    <div class="msa__no-results" id="msa-no-results-{{ section.id }}" hidden>
      <p>{{ section.settings.no_results_text | default: 'No products found. Try adjusting your filters.' }}</p>
    </div>

  </div>
</div>

<script>
(function () {
  'use strict';

  var sectionId = '{{ section.id }}';
  var root = document.getElementById('shopify-section-shop-all');
  if (!root) return;

  var grid      = root.querySelector('#msa-grid-' + sectionId + ' .msa__list');
  var noResults = root.querySelector('#msa-no-results-' + sectionId);
  var countEl   = root.querySelector('#msa-results-count-' + sectionId);
  var pillsEl   = root.querySelector('#msa-active-filters-' + sectionId);

  var mobileToggle = root.querySelector('.js-msa-mobile-toggle');
  var toolbar = root.querySelector('.msa__toolbar');

  if (mobileToggle && toolbar) {
    mobileToggle.addEventListener('click', function() {
      var isExpanded = mobileToggle.getAttribute('aria-expanded') === 'true';
      mobileToggle.setAttribute('aria-expanded', !isExpanded);
      if (!isExpanded) {
        toolbar.setAttribute('data-mobile-open', 'true');
      } else {
        toolbar.removeAttribute('data-mobile-open');
      }
    });
  }

  // ── State ──
  var urlParams = new URLSearchParams(window.location.search);
  var state = {
    device: urlParams.get('device') || 'all',
    type: urlParams.get('type') || 'all',
    brand: urlParams.get('brand') || 'all',
    strength: urlParams.get('strength') || 'all',
    sort: urlParams.get('sort') || 'manual',
    page: parseInt(urlParams.get('page')) || 1
  };

  // ── Filter dropdowns ──
  root.querySelectorAll('.msa__filter-group').forEach(function (group) {
    var btn      = group.querySelector('.msa__filter-btn');
    var dropdown = group.querySelector('.msa__dropdown');

    if (!btn || !dropdown) return;

    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      var isOpen = btn.getAttribute('aria-expanded') === 'true';
      // Close all
      root.querySelectorAll('.msa__filter-btn').forEach(function (b) {
        b.setAttribute('aria-expanded', 'false');
        b.closest('.msa__filter-group').querySelector('.msa__dropdown').removeAttribute('data-open');
      });
      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true');
        dropdown.setAttribute('data-open', '');
      }
    });

    group.querySelectorAll('.msa__dropdown-item').forEach(function (item) {
      item.addEventListener('click', function () {
        var filterType  = group.getAttribute('data-filter-group');
        var filterValue = item.getAttribute('data-filter-value');

        // Update active state within dropdown
        group.querySelectorAll('.msa__dropdown-item').forEach(function (i) {
          i.classList.remove('msa__dropdown-item--active');
          i.setAttribute('aria-selected', 'false');
        });
        item.classList.add('msa__dropdown-item--active');
        item.setAttribute('aria-selected', 'true');

        // Update label
        btn.querySelector('.msa__filter-label').textContent = item.textContent.trim();

        // Update state
        state[filterType] = filterValue;
        state.page = 1;

        // Close dropdown
        btn.setAttribute('aria-expanded', 'false');
        dropdown.removeAttribute('data-open');

        applyFiltersAndSort();
      });
    });
  });

  // Close dropdowns on outside click
  document.addEventListener('click', function () {
    root.querySelectorAll('.msa__filter-btn').forEach(function (b) {
      b.setAttribute('aria-expanded', 'false');
    });
    root.querySelectorAll('.msa__dropdown').forEach(function (d) {
      d.removeAttribute('data-open');
    });
  });

  // ── Sort ──
  var sortSelect = root.querySelector('.msa__sort-select');
  if (sortSelect) {
    sortSelect.addEventListener('change', function () {
      state.sort = sortSelect.value;
      state.page = 1;
      applyFiltersAndSort();
    });
  }

  // ── Core: filter + sort ──
  function applyFiltersAndSort() {
    var items = Array.from(grid.querySelectorAll('.msa__product-item:not(.msa__product-item--placeholder)'));

    // Filter
    var visible = items.filter(function (item) {
      var deviceOk   = state.device   === 'all' ||
        (item.dataset.deviceFilters   || '').split(',').indexOf(state.device)   !== -1;
      var typeOk     = state.type     === 'all' ||
        (item.dataset.typeFilters     || '').split(',').indexOf(state.type)     !== -1;
      var brandOk    = state.brand    === 'all' ||
        (item.dataset.brandFilter     || '') === state.brand;
      var strengthOk = state.strength === 'all' ||
        (item.dataset.strengthFilters || '').split(',').indexOf(state.strength) !== -1;
      return deviceOk && typeOk && brandOk && strengthOk;
    });

    // Sort
    visible.sort(function (a, b) {
      switch (state.sort) {
        case 'title-ascending':
          return (a.dataset.title || '').localeCompare(b.dataset.title || '');
        case 'title-descending':
          return (b.dataset.title || '').localeCompare(a.dataset.title || '');
        case 'price-ascending':
          return parseInt(a.dataset.price || '0') - parseInt(b.dataset.price || '0');
        case 'price-descending':
          return parseInt(b.dataset.price || '0') - parseInt(a.dataset.price || '0');
        case 'created-descending':
          return parseInt(b.dataset.created || '0') - parseInt(a.dataset.created || '0');
        case 'created-ascending':
          return parseInt(a.dataset.created || '0') - parseInt(b.dataset.created || '0');
        case 'best-selling':
          return parseInt(b.dataset.bestSelling || '0') - parseInt(a.dataset.bestSelling || '0');
        default:
          return parseInt(a.dataset.sortFeatured || '0') - parseInt(b.dataset.sortFeatured || '0');
      }
    });

    // --- Pagination Logic ---
    var perPageStr = grid.getAttribute('data-products-per-page');
    var perPage = perPageStr ? parseInt(perPageStr, 10) : 24;
    var totalPages = Math.ceil(visible.length / perPage);
    
    if (state.page < 1) state.page = 1;
    if (state.page > totalPages && totalPages > 0) state.page = totalPages;

    var start = (state.page - 1) * perPage;
    var end = start + perPage;

    // Hide all first
    items.forEach(function (item) {
      item.hidden = true;
    });

    // Re-append ONLY paginated in sorted order and show
    visible.forEach(function (item, index) {
      grid.appendChild(item);
      if (index >= start && index < end) {
        item.hidden = false;
      } else {
        item.hidden = true;
      }
    });

    // No results
    if (visible.length === 0) {
      noResults.hidden = false;
    } else {
      noResults.hidden = true;
    }

    // Count
    if (countEl) {
      countEl.textContent = visible.length + ' product' + (visible.length !== 1 ? 's' : '');
    }

    // Pills
    updatePills();

    // Render Pagination
    renderPagination(visible.length, perPage, totalPages);

    // Update URL Params
    var newUrl = new URL(window.location.href);
    ['device', 'type', 'brand', 'strength', 'sort'].forEach(function(key) {
      if (state[key] !== 'all' && state[key] !== 'manual') {
        newUrl.searchParams.set(key, state[key]);
      } else {
        newUrl.searchParams.delete(key);
      }
    });
    if (state.page > 1) {
      newUrl.searchParams.set('page', state.page);
    } else {
      newUrl.searchParams.delete('page');
    }
    history.replaceState(null, '', newUrl.toString());
  }

  function updatePills() {
    if (!pillsEl) return;
    pillsEl.innerHTML = '';
    var hasActive = false;

    function addPill(type, value, label) {
      hasActive = true;
      var pill = document.createElement('button');
      pill.className = 'msa__pill';
      pill.setAttribute('aria-label', 'Remove filter: ' + label);
      pill.innerHTML = label + ' <span aria-hidden="true">&times;</span>';
      pill.addEventListener('click', function () {
        state[type] = 'all';
        state.page = 1;
        // Reset dropdown button label & selection
        var group = root.querySelector('[data-filter-group="' + type + '"]');
        if (group) {
          var allItem = group.querySelector('[data-filter-value="all"]');
          if (allItem) {
            group.querySelectorAll('.msa__dropdown-item').forEach(function (i) {
              i.classList.remove('msa__dropdown-item--active');
              i.setAttribute('aria-selected', 'false');
            });
            allItem.classList.add('msa__dropdown-item--active');
            allItem.setAttribute('aria-selected', 'true');
            var defaultLabel = group.querySelector('.msa__filter-btn .msa__filter-label');
            if (defaultLabel) defaultLabel.textContent = allItem.textContent.trim();
          }
        }
        applyFiltersAndSort();
      });
      pillsEl.appendChild(pill);
    }

    if (state.device !== 'all') {
      var deviceItem = root.querySelector('[data-filter-type="device"][data-filter-value="' + state.device + '"]');
      addPill('device', state.device, deviceItem ? deviceItem.textContent.trim() : state.device);
    }
    if (state.type !== 'all') {
      var typeItem = root.querySelector('[data-filter-type="type"][data-filter-value="' + state.type + '"]');
      addPill('type', state.type, typeItem ? typeItem.textContent.trim() : state.type);
    }
    if (state.brand !== 'all') {
      var brandItem = root.querySelector('[data-filter-type="brand"][data-filter-value="' + state.brand + '"]');
      addPill('brand', state.brand, brandItem ? brandItem.textContent.trim() : state.brand);
    }
    if (state.strength !== 'all') {
      var strengthItem = root.querySelector('[data-filter-type="strength"][data-filter-value="' + state.strength + '"]');
      addPill('strength', state.strength, strengthItem ? strengthItem.textContent.trim() : state.strength);
    }

    pillsEl.hidden = !hasActive;
  }

  // ── Render Pagination ──
  function renderPagination(totalVisible, perPage, totalPages) {
    var wrapper = root.querySelector('.msa__client-pagination');
    if (!wrapper) return;

    if (totalPages <= 1) {
      wrapper.innerHTML = '';
      return;
    }

    var html = '<div class="pagination-wrapper no-js-block" style="margin-top: 4.8rem;">' +
               '<nav class="pagination container" role="navigation" aria-label="Pagination">' +
               '<ul class="pagination__list list-unstyled" role="list">';

    // Prev
    html += '<li class="' + (state.page <= 1 ? 'paginate_none' : '') + '">';
    if (state.page > 1) {
      html += '<a href="#" class="pagination__item-toggler pagination__item-toggler--prev button" data-page="' + (state.page - 1) + '" aria-label="Previous page">';
      html += '<svg class="icon icon-arrow-slider-left" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M14 2L6 10L14 18" stroke="currentColor"/></svg>';
      html += '</a>';
    } else {
      html += '<span class="pagination__item-toggler pagination__item-toggler--prev button" style="opacity:0.5; pointer-events:none;" aria-label="Previous page">';
      html += '<svg class="icon icon-arrow-slider-left" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M14 2L6 10L14 18" stroke="currentColor"/></svg>';
      html += '</span>';
    }
    html += '</li>';

    // Numbers
    for (var i = 1; i <= totalPages; i++) {
      html += '<li>';
      if (i === state.page) {
        html += '<span class="pagination__item pagination__item--current body-normal" aria-current="page">' + i + '</span>';
      } else {
        html += '<a href="#" class="pagination__item body-normal" data-page="' + i + '" aria-label="Page ' + i + '">' + i + '</a>';
      }
      html += '</li>';
    }

    // Next
    html += '<li class="' + (state.page >= totalPages ? 'paginate_none' : '') + '">';
    if (state.page < totalPages) {
      html += '<a href="#" class="pagination__item-toggler pagination__item-toggler--next button" data-page="' + (state.page + 1) + '" aria-label="Next page">';
      html += '<svg class="icon icon-arrow-slider-right" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 2L14 10L6 18" stroke="currentColor"/></svg>';
      html += '</a>';
    } else {
      html += '<span class="pagination__item-toggler pagination__item-toggler--next button" style="opacity:0.5; pointer-events:none;" aria-label="Next page">';
      html += '<svg class="icon icon-arrow-slider-right" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 2L14 10L6 18" stroke="currentColor"/></svg>';
      html += '</span>';
    }
    html += '</li>';

    html += '</ul></nav></div>';

    wrapper.innerHTML = html;

    wrapper.querySelectorAll('a[data-page]').forEach(function (link) {
      link.addEventListener('click', function (e) {
        e.preventDefault();
        state.page = parseInt(this.getAttribute('data-page'), 10);
        applyFiltersAndSort();
        var topEl = root.querySelector('.msa__toolbar');
        if (topEl) {
          var y = topEl.getBoundingClientRect().top + window.scrollY - 100;
          window.scrollTo({top: y, behavior: 'smooth'});
        }
      });
    });
  }

  // ── Init UI from State ──
  function initUIFromState() {
    ['device', 'type', 'brand', 'strength'].forEach(function(filterType) {
      var group = root.querySelector('[data-filter-group="' + filterType + '"]');
      if (group) {
        var item = group.querySelector('[data-filter-value="' + state[filterType] + '"]');
        if (!item) {
          item = group.querySelector('[data-filter-value="all"]');
          state[filterType] = 'all'; // fallback if param is invalid
        }
        if (item) {
          group.querySelectorAll('.msa__dropdown-item').forEach(function(i) {
            i.classList.remove('msa__dropdown-item--active');
            i.setAttribute('aria-selected', 'false');
          });
          item.classList.add('msa__dropdown-item--active');
          item.setAttribute('aria-selected', 'true');
          var btnLabel = group.querySelector('.msa__filter-label');
          if (btnLabel) btnLabel.textContent = item.textContent.trim();
        }
      }
    });

    if (sortSelect && state.sort) {
      var option = sortSelect.querySelector('option[value="' + state.sort + '"]');
      if (option) {
        sortSelect.value = state.sort;
      } else {
        state.sort = 'manual';
      }
    }
  }

  // ── Init ──
  initUIFromState();
  applyFiltersAndSort();
})();
</script>

