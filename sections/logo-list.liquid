                    </svg>
                  {%- endif -%}
                </a>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}
    {% if section.settings.layout == 'static' %}
      {%- if section.settings.ticker_text_heading != blank -%}
        <div class="ticker__heading h5">
          <span class="richtext-link-inside">
            {{- section.settings.ticker_text_heading -}}
          </span>
        </div>
      {% endif %}
      <div class="brands-wrapper marquee{% if section.settings.ticker_text_heading != blank %} brands-wrapper-top{% endif %} ">
        <div class="brands-items marquee-content">
          {% assign block_count = section.blocks.size %}

          {% assign repeat_count = 50 | divided_by: block_count %}
          {% for i in (1..repeat_count) %}
            {%- for block in section.blocks -%}
              <div class="brands-item_wrapper marquee-tag">
                {%- style -%}
                  @media screen and (max-width: 1150px) {
                  	.brands__image{{ forloop.index }} {
                  		width: {{ block.settings.image_width | times: 0.9 | round: 0 }}px;
                  	}
                  }
                  @media screen and (max-width: 780px) {
                  	.brands__image{{ forloop.index }} {
                  		width: {{ block.settings.image_width | times: 0.7 | round: 0 }}px;
                  	}
                  }
                {%- endstyle -%}
                <a
                  class="list-logo brands__item focus-inset{% if section.settings.image_2 != blank %} has-dm-logo{% endif %}"
                  {% if block.settings.brand_link.url != blank %}
                    data-hover-opacity="brand-{{ section.id }}"
                    href="{{ block.settings.brand_link }}"
                    aria-label="{{ 'accessibility.link' | t }}"
                    style="cursor: pointer;"
                  {% else %}
                    tabindex="-1"
                  {% endif %}
                  {{ block.shopify_attributes }}
                >
                  {%- assign width = block.settings.image_width -%}
                  {%- assign height = width | times: 93 | divided_by: 404 | round: 2 -%}
                  {%- assign sizes = '(min-width: 1100px) 750, (min-width: 750px) 550, 275' -%}

                  {%- if block.settings.image_2 != blank or block.settings.image_1 != blank -%}
                    {%- if block.settings.image_1 != blank -%}
                      {{
                        block.settings.image_1
                        | image_url: width: 710
                        | image_tag:
                          loading: 'lazy',
                          sizes: sizes,
                          height: height,
                          width: width,
                          class: 'ticker__image brands__image header__heading-logo header__logo-light'
                      }}
                    {%- endif -%}
                    {%- if block.settings.image_2 != blank -%}
                      {{
                        block.settings.image_2
                        | image_url: width: 710
                        | image_tag:
                          loading: 'lazy',
                          sizes: sizes,
                          height: height,
                          width: width,
                          class: 'ticker__image brands__image header__heading-logo header__heading-logo--overlay'
                      }}
                    {%- endif -%}
                  {% else %}
                    <svg
                      class="ticker__image brands__image"
                      width="{{width}}"
                      height="{{height}}"
                      viewBox="0 0 404 93"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                    >
