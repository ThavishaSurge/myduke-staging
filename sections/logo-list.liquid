{{ 'section-logo-list.css' | asset_url | stylesheet_tag }}
<script src="{{ "logo-list.js" | asset_url }}" defer="defer"></script>
{%- style -%}
   {% render 'section-padding' %}
   {% render 'section-margin' %}

  #shopify-section-{{ section.id }} {
  	--speed: {{ section.settings.ticker_speed }}s;
  }
{%- endstyle -%}

<div
  class="logo-list color-{{ section.settings.color_scheme }} background section-{{ section.id }}-padding"
  data-brands-speed="{{ section.settings.ticker_speed }}"
>
  <div class="container">
    {% if section.settings.layout == 'grid' %}
      <div class="ticker__grid {% if section.settings.ticker_text_heading == blank %} ticker__grid_center{% endif %}">
        {%- if section.settings.ticker_text_heading != blank -%}
          <div class="ticker__heading h5">
            <span class="richtext-link-inside">
              {{- section.settings.ticker_text_heading -}}
            </span>
          </div>
        {% endif %}
        <div class="ticker__inner">
          {%- for block in section.blocks -%}
            {% assign block_count = section.blocks.size %}

            <div
              class="ticker__block {% if block_count > 4 and block_count <= 8 %} ticker__block_4{% endif %} {% if block_count > 8 %} ticker__block_8{% endif %}"
              {{ block.shopify_attributes }}
            >
              {%- assign width = block.settings.image_width -%}
              {%- assign height = width | divided_by: block.settings.image_1.aspect_ratio | round: 2 -%}
              {%- assign sizes = '(min-width: 1100px) 750, (min-width: 750px) 550, 275' -%}
              <div style="width: {{ block.settings.image_width }}px;">
                <a
                  class="list-logo brands__item focus-inset{% if section.settings.image_2 != blank %} has-dm-logo{% endif %}"
                  {% if block.settings.brand_link.url != blank %}
                    data-hover-opacity="brand-{{ section.id }}"
                    href="{{ block.settings.brand_link }}"
                    aria-label="{{ 'accessibility.link' | t }}"
                    style="cursor: pointer;"
                  {% else %}
                    tabindex="-1"
                  {% endif %}
                  {{ block.shopify_attributes }}
                >
                  {%- assign width = block.settings.image_width -%}
                  {%- assign height = width | divided_by: block.settings.image_1.aspect_ratio | round: 2 -%}
                  {%- assign sizes = '(min-width: 1100px) 750, (min-width: 750px) 550, 275' -%}

                  {%- if block.settings.image_2 != blank or block.settings.image_1 != blank -%}
                    {%- if block.settings.image_1 != blank -%}
                      {{
                        block.settings.image_1
                        | image_url: width: 710
                        | image_tag:
                          loading: 'lazy',
                          sizes: sizes,
                          widths: '275, 550, 750',
                          height: height,
                          width: width,
                          class: 'header__heading-logo header__logo-light'
                      }}
                    {%- endif -%}
                    {%- if block.settings.image_2 != blank -%}
                      {{
                        block.settings.image_2
                        | image_url: width: 710
                        | image_tag:
                          loading: 'lazy',
                          sizes: sizes,
                          widths: '275, 550, 750',
                          height: height,
                          width: width,
                          class: 'header__heading-logo header__heading-logo--overlay'
                      }}
                    {%- endif -%}
                  {% else %}
                    {%- unless width -%}
                      {%- assign width = block.settings.image_width | default: 404 -%}
                    {%- endunless -%}
                    {%- unless height -%}
                      {%- assign height = width | times: 93 | divided_by: 404 | round: 2 -%}
                    {%- endunless -%}
                    <svg
                      class="ticker__image brands__image"
                      width="{{width}}"
                      height="{{height}}"
                      viewBox="0 0 404 93"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <path d="M16.6188 1.826V77.726H72.3708V91.25H0.886772V1.826H16.6188ZM128.3 92.906C117.812 92.906 108.658 91.02 100.838 87.248C93.1096 83.476 87.0836 78.14 82.7596 71.24C78.5276 64.34 76.4116 56.106 76.4116 46.538C76.4116 36.97 78.5276 28.736 82.7596 21.836C87.0836 14.844 93.1096 9.50799 100.838 5.828C108.658 2.056 117.812 0.169996 128.3 0.169996C138.88 0.169996 148.034 2.056 155.762 5.828C163.49 9.50799 169.47 14.844 173.702 21.836C178.026 28.736 180.188 36.97 180.188 46.538C180.188 56.106 178.026 64.34 173.702 71.24C169.47 78.14 163.49 83.476 155.762 87.248C148.034 91.02 138.88 92.906 128.3 92.906ZM128.3 79.106C135.292 79.106 141.456 77.91 146.792 75.518C152.128 73.126 156.314 69.538 159.35 64.754C162.478 59.878 164.042 53.806 164.042 46.538C164.042 39.362 162.478 33.382 159.35 28.598C156.314 23.722 152.128 20.088 146.792 17.696C141.456 15.212 135.292 13.97 128.3 13.97C121.4 13.97 115.236 15.212 109.808 17.696C104.38 20.088 100.102 23.722 96.9736 28.598C93.8456 33.382 92.2816 39.362 92.2816 46.538C92.2816 53.806 93.8456 59.878 96.9736 64.754C100.102 69.538 104.38 73.126 109.808 75.518C115.236 77.91 121.4 79.106 128.3 79.106ZM239.175 92.906C231.539 92.906 224.639 91.894 218.475 89.87C212.311 87.846 207.021 84.902 202.605 81.038C198.281 77.082 194.923 72.252 192.531 66.548C190.231 60.844 189.081 54.404 189.081 47.228C189.081 39.96 190.323 33.428 192.807 27.632C195.291 21.836 198.833 16.914 203.433 12.866C208.033 8.726 213.507 5.598 219.855 3.48199C226.203 1.274 233.195 0.169996 240.831 0.169996C249.755 0.169996 257.483 1.55 264.015 4.30999C270.547 7.07 275.745 10.934 279.609 15.902C283.473 20.778 285.681 26.574 286.233 33.29H271.743C270.547 29.334 268.569 25.93 265.809 23.078C263.141 20.226 259.691 18.018 255.459 16.454C251.319 14.798 246.443 13.97 240.831 13.97C233.471 13.97 227.077 15.396 221.649 18.248C216.313 21.008 212.219 24.918 209.367 29.978C206.515 34.946 205.089 40.696 205.089 47.228C205.089 53.76 206.331 59.418 208.815 64.202C211.391 