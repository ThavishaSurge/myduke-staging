{{ 'section-featured-products.css' | asset_url | stylesheet_tag }}
<script src="{{ 'featured-products.js' | asset_url }}" defer="defer"></script>
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{%- style -%}
  {% render 'section-padding' %}
  {% render 'section-margin' %}
{%- endstyle -%}

{% liquid
  case section.settings.main_image_ratio
    when 'landscape'
      assign main_padding_bottom = '75%'
    when 'portrait'
      assign main_padding_bottom = '123.3%'
    when 'square'
      assign main_padding_bottom = '100%'
    else
      assign main_padding_bottom = '100%'
  endcase

  assign has_mobile_slider = false
  if section.settings.product_list.count > 1 or section.settings.product_list == blank
    assign has_mobile_slider = true
  endif
%}

<div
  class="featured-products container color-{{ section.settings.color_scheme }} background section-{{ section.id }}-padding mydk-product-container-auth"
  data-color-scheme="{{ section.settings.color_scheme }}"
>
  {%- assign placeholder_numbers = '1|2|3|4' | split: '|' -%}
  {%- if section.settings.heading != blank -%}
    <div class="featured-products__title-wrapper">
      <{{ section.settings.heading_tag | default: "h2" }}
        class="title featured-products__title {% if section.settings.heading_font == 'heading'%}{{ section.settings.heading_size }} size--{{ section.settings.heading_size }}{% else %}font--body{% endif %}{% if class %} {{ class }}__title{% endif %} richtext-link-inside"
      >
        {{- section.settings.heading -}}
      </{{ section.settings.heading_tag | default: "h2" }}>
    </div>
  {%- endif -%}
  <div
    class="featured-products__wrapper {% if section.settings.list_heading != blank %} featured-products__block--gap{% endif %}"
  >
    <div
      class="featured-products__block"
      style="--detail-image-padding-bottom: {{ main_padding_bottom }};"
    >
      <div class="featured-products__images">
        <div
          class="featured-products__image featured-products__image--active"
          {% if section.settings.enable_image_animation %}
            data-scroll-image-reveal
          {% endif %}
        >
          {%- if section.settings.image -%}
            {% liquid
              if settings.main_image_ratio == 'landscape'
                assign settings_aspect_ratio = 1.5
              elsif section.settings.main_image_ratio == 'portrait'
                assign settings_aspect_ratio = 0.75
              else
                assign settings_aspect_ratio = 1
              endif

              assign calc_ratio = 1
              if section.settings.image.aspect_ratio > settings_aspect_ratio
                assign calc_ratio = section.settings.image.aspect_ratio | divided_by: settings_aspect_ratio | round: 2
              endif

              assign image_class = ''
              if section.settings.enable_image_animation
                assign image_class = image_class | append: ' scroll-image-reveal__target'
              endif
            %}
            {%- capture sizes -%}
                (min-width: 990px) calc(45vw * {{ calc_ratio }}), calc(90vw * {{ calc_ratio }})
              {%- endcapture -%}
            {%- capture styles -%}
                object-fit: {{ section.settings.main_image_fit }};
              {%- endcapture -%}
            {{
              section.settings.image
              | image_url: width: section.settings.image.width
              | image_tag:
                loading: 'lazy',
                class: image_class,
                sizes: sizes,
                widths: '320, 480, 640, 960, 1280, 1440, 1600, 1920, 2200, 2400, 2800, 3000, 3200, 3600',
                style: styles
            }}
          {%- else -%}
            {% liquid
              assign placeholder_class = 'media-banner__image placeholder-svg'
              if section.settings.enable_image_animation
                assign placeholder_class = placeholder_class | append: ' scroll-image-reveal__target'
              endif
            %}
            {{ 'hero-apparel-1' | placeholder_svg_tag: placeholder_class }}
          {%- endif -%}
        </div>
      </div>
    </div>
    <div
      class="featured-products__list featured-products__block color-{{ section.settings.color_scheme_product }} background"
      style="--detail-image-padding-bottom: {{ main_padding_bottom }};"
    >
      {%- if section.settings.list_heading != blank -%}
        <div class="featured-products__info vertical-text parallax-text" data-parallax="500">
          {%- if section.settings.list_heading != blank -%}
            <{{ section.settings.list_heading_tag | default: 'h3' }} class="featured-products__info-heading {{ section.settings.list_heading_size }} richtext-link-inside">
              {{ section.settings.list_heading | truncate: 18, '' }}
            </{{ section.settings.list_heading_tag | default: 'h3' }}>
          {%- endif -%}
        </div>
      {%- endif -%}
      {% if section.settings.animated_badge != blank %}
        {% if section.settings.image_badge != blank %}
          <div class="featured-products__img_badge">
            {{
              section.settings.image_badge
              | image_url: width: section.settings.image_badge.width
              | image_tag:
                width: section.settings.image_badge.width,
                height: section.settings.image_badge.height,
                widths: '360, 535, 600, 720, 940, 1066, 1200, 1400, 1600, 1800, 2000, 2200, 2400, 2600, 2800, 3000, 3200, 3400, 3600, 3800',
                sizes: '372',
                class: '',
                style: 'object-fit: cover'
            }}
          </div>
        {%- endif -%}
      {%- endif -%}
      <div class="featured-products__inner">
        <div class="featured-products__inner-item">
          {%- if has_mobile_slider -%}
            <button class="featured-products__navigation-button featured-products__navigation-button-prev swiper-button-prev">
              {% render 'icon-arrow-left-slider' %}
            </button>
          {%- endif -%}
          <div class="featured-products__items swiper js-featured-products-slider">
            <div class="swiper-wrapper featured-products__swiper-wrapper">
              {%- for product_card in section.settings.product_list -%}
                <div
                  class="featured-products__item js-featured-products-slider-item swiper-slide "
                >
                  {% render 'product-card-featured',
                    product_card_product: product_card,
                    section_id: section.id,
                    columns: section.settings.products_per_row,
                    columns_mobile: section.settings.products_per_row_mobile,
                    color_scheme: section.settings.color_scheme_product
                  %}
                </div>
              {%- else -%}
                {%- for i in (1..3) -%}
                  {% assign index = i | modulo: placeholder_numbers.size %}
                  {% assign placeholder_index = placeholder_numbers[index] %}
                  <div
                    class="featured-products__item featured-products__item--placeholder swiper-slide"
                  >
                    {% render 'product-card-featured-placeholder',
                      product_number: placeholder_index,
                      columns_mobile: section.settings.products_per_row_mobile,
                      color_scheme: section.settings.color_scheme_product
                    %}
                  </div>
                {%- endfor -%}
              {%- endfor -%}
            </div>
          </div>
          {%- if has_mobile_slider -%}
            <button class="featured-products__navigation-button featured-products__navigation-button-next swiper-button-next">
              {% render 'icon-arrow-right-slider' %}
            </button>
          {%- endif -%}
        </div>
        <div class="featured-products-pagination">
          <div class="swiper-pagination swiper-pagination-round"></div>
        </div>
      </div>
    </div>
  </div>

  {% liquid
    assign has_button = false
    if section.settings.heading_group_button_show and section.settings.heading_group_button_label != blank
      assign has_button = true
    endif
  %}
  {%- if has_button %}
    {% render 'button',
      btn_label: section.settings.heading_group_button_label,
      btn_style: 'tertiary',
      btn_link: section.settings.heading_group_button_link,
      featured_button: true,
      class: 'featured-products__button-bottom h5'
    %}
  {%- endif -%}
</div>

{% schema %}
{
