      "info": "t:sections.all.heading_tag.info",
      "visible_if": "{{ section.settings.list_heading != blank }}"
    },
    {
      "type": "checkbox",
      "id": "animated_badge",
      "default": true,
      "label": "t:sections.showcase.settings.animated_badge.label"
    },
    {
