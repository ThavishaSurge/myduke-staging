{{ 'section-hero.css' | asset_url | stylesheet_tag }}
<script src="{{ 'hero.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  {% render 'section-margin' %}
{%- endstyle -%}

{% liquid
  if section.settings.aspect_ratio_primary == 'adapt-to-image'
    if section.settings.image_primary != blank
      assign padding_bottom_primary = 1 | divided_by: section.settings.image_primary.aspect_ratio | times: 100 | round: 2
    else
      assign padding_bottom_primary = '0'
    endif
  elsif section.settings.aspect_ratio_primary == 'landscape'
    assign padding_bottom_primary = '69.5'
  elsif section.settings.aspect_ratio_primary == 'portrait'
    assign padding_bottom_primary = '138.4'
  elsif section.settings.aspect_ratio_primary == 'square'
    assign padding_bottom_primary = '100'
  else
    assign padding_bottom_primary = '0'
  endif
%}

{% liquid
  if section.settings.aspect_ratio_secondary == 'adapt-to-image'
    if section.settings.image_secondary != blank
      assign padding_bottom_secondary = 1 | divided_by: section.settings.image_secondary.aspect_ratio | times: 100 | round: 2
    else
      assign padding_bottom_secondary = '0'
    endif
  elsif section.settings.aspect_ratio_secondary == 'landscape'
    assign padding_bottom_secondary = '69.5'
  elsif section.settings.aspect_ratio_secondary == 'portrait'
    assign padding_bottom_secondary = '138.4'
  elsif section.settings.aspect_ratio_secondary == 'square'
    assign padding_bottom_secondary = '100'
  else
    assign padding_bottom_secondary = '0'
  endif
%}
{% liquid
  if section.settings.list_button_show and section.settings.list_button_label != blank
    assign display_button = true
  else
    assign display_button = false
  endif
%}
{%- style -%}
   .hero-{{ section.id }} .hero__image-primary-wrapper::before {
     content: '';
     display: block;
     width: 0;
     padding-bottom: {{ padding_bottom_primary }}%;
   }
   .hero-{{ section.id }} .hero__image-secondary-wrapper::before {
     content: '';
     display: block;
     width: 0;
     padding-bottom: {{ padding_bottom_secondary }}%;
   }
  	#shopify-section-{{ section.id }} {
  	--ticker-speed : {{ section.settings.ticker_speed }}s;
  }
{%- endstyle -%}

<div class="hero hero-{{ section.id }} ">
  {%- if section.settings.heading_big != blank -%}
    <div class="wrapper container footer__name" style="width: 100%;">
      <svg id="authorNameSvg" preserveAspectRatio="xMidYMid meet">
        <text id="authorText" y="50%" dominant-baseline="central" style="font-size: 50px;">
          {{- section.settings.heading_big -}}
        </text>
      </svg>
    </div>
  {%- endif -%}
  <div class="container">
    <div class="hero__wrapper {% if section.settings.heading_big == blank %} hero__wrapper_text_none {% endif %}">
      <div class="hero__wrapper-text content-{{ section.settings.vertical_alignment }} {% if section.settings.text_center == true %} hero__text-center {% endif %}">
        <div class="hero__text_inner">
          {%- if section.settings.subheading != blank -%}
            <div class="heading-group__subheading">
              {{- section.settings.subheading -}}
            </div>
          {%- endif -%}
          {% if section.settings.heading != blank %}
            <{{ section.settings.heading_tag | default: 'h3' }}
              class="hero__heading {{ section.settings.heading_size}} richtext-link-inside"
              {{ section.shopify_attributes }}
            >
              {{- section.settings.heading -}}
            </{{ section.settings.heading_tag | default: 'h3' }}>
          {% endif -%}
          {%- if display_button %}
            {% render 'button',
              btn_label: section.settings.list_button_label,
              btn_style: section.settings.list_button_style,
              btn_link: section.settings.list_button_link,
              class: 'hero__button '
            %}
          {%- endif -%}
        </div>
        {% if section.settings.description != blank %}
          <p class="hero__description richtext-link-inside" {{ section.shopify_attributes }}>
            {{- section.settings.description -}}
          </p>
        {% endif -%}
      </div>
      <div class="hero__content jarallax" data-jarallax>
        {% liquid
          assign image_primary = section.settings.image_primary
          assign show_image_primary = section.settings.show_image_primary
        %}

        <div class="hero__left-block">
          <div class="hero__left-inner {% if section.settings.enable_parallax %} hero__left-inner-parallax{% endif %}">
            <div
              class="hero__image-primary-wrapper hero__image-wrapper{% if section.settings.enable_animation %} hero__animation-wrapper{% endif %}"
            >
              {% if image_primary != blank %}
                {% comment %} Image settings {% endcomment %}
                {% liquid
                  if section.settings.aspect_ratio_primary == 'adap-to-image'
                    assign settings_aspect_ratio_primary = image_primary.aspect_ratio
                  else
                    if section.settings.aspect_ratio_primary == 'landscape'
                      assign settings_aspect_ratio_primary = 1.44
                    elsif section.settings.aspect_ratio_primary == 'portrait'
                      assign settings_aspect_ratio_primary = 0.76
                    elsif section.settings.aspect_ratio_primary == 'recommended'
                      assign settings_aspect_ratio_primary = 1.26
                    else
                      assign settings_aspect_ratio_primary = 1
                    endif
                  endif

                  assign calc_ratio = 1

                  if image_primary.aspect_ratio > settings_aspect_ratio_primary
                    assign calc_ratio = image_primary.aspect_ratio | divided_by: settings_aspect_ratio_primary | round: 2
                  endif

                  assign image_loading = 'lazy'

                  if section.index == 1
                    assign image_loading = 'eager'
                  endif
                %}
                {% comment %} TODO: add sizes {% endcomment %}
                {%- capture image_sizes -%}
              (min-width: 750px) calc(50vw * {{ calc_ratio }}), calc(100vw * {{ calc_ratio }})
            {%- endcapture -%}
                {%- capture styles -%}
                object-fit: cover;
              {%- endcapture -%}
                {{
                  image_primary
                  | image_url: width: image_primary.width
                  | image_tag:
                    width: image_primary.width,
                    height: image_primary.height,
                    widths: '360, 535, 600, 720, 940, 1066, 1200, 1400, 1600, 1800, 2000, 2200, 2400, 2600, 2800, 3000, 3200, 3400, 3600, 3800',
                    sizes: image_sizes,
                    class: 'hero__image-primary hero__image hero__animation-item',
                    style: styles,
                    loading: image_loading
                }}
              {% else %}
                {%- liquid
                  assign placeholder_class = 'placeholder-svg product-details__animation-item'
                  if section.settings.aspect_ratio_primary == 'adapt-to-image'
                    assign placeholder_class = placeholder_class | append: ' ' | append: 'adapt-to-image'
                  endif
                %}
                {{ 'hero-apparel-1' | placeholder_svg_tag: placeholder_class }}
              {% endif %}
            </div>
            {% if section.settings.animated_badge != blank %}
              {% if section.settings.image_badge != blank %}
                <div class="hero__img_badge">
                  {{
                    section.settings.image_badge
                    | image_url: width: section.settings.image_badge.width
                    | image_tag:
                      width: section.settings.image_badge.width,
                      height: section.settings.image_badge.height,
                      widths: '360, 535, 600, 720, 940, 1066, 1200, 1400, 1600, 1800, 2000, 2200, 2400, 2600, 2800, 3000, 3200, 3400, 3600, 3800',
                      sizes: image_sizes,
                      class: ''
                  }}
                </div>
              {%- endif -%}
            {%- endif -%}
          </div>
        </div>

        <div class="hero__right-block  {% if show_image_primary == blank %} hero__right-block-big{% endif %}">
          <div class="hero__image-secondary-wrapper hero__image-wrapper{% if section.settings.enable_animation %} hero__animation-wrapper{% endif %}">
            {% liquid
              assign image_secondary = section.settings.image_secondary
            %}
            {% if image_secondary != blank %}
              {% comment %} Image settings {% endcomment %}
              {% liquid
                if section.settings.aspect_ratio_secondary == 'adap-to-image'
                  assign settings_aspect_ratio_secondary = image_secondary.aspect_ratio
                else
                  if section.settings.aspect_ratio_secondary == 'landscape'
                    assign settings_aspect_ratio_secondary = 1.44
                  elsif section.settings.aspect_ratio_secondary == 'portrait'
                    assign settings_aspect_ratio_secondary = 0.76
                  elsif section.settings.aspect_ratio_secondary == 'recommended'
                    assign settings_aspect_ratio_secondary = 1.26
                  else
                    assign settings_aspect_ratio_secondary = 1
                  endif
                endif

                assign calc_ratio = 1

                if image_secondary.aspect_ratio > settings_aspect_ratio_secondary
                  assign calc_ratio = image_secondary.aspect_ratio | divided_by: settings_aspect_ratio_secondary | round: 2
                endif

                assign image_loading = 'lazy'

                if section.index == 1
                  assign image_loading = 'eager'
                endif
              %}
              {% comment %} TODO: add sizes {% endcomment %}
              {%- capture image_sizes -%}
              (min-width: 750px) calc(50vw * {{ calc_ratio }}), calc(100vw * {{ calc_ratio }})
            {%- endcapture -%}
              {%- capture styles2 -%}
                object-fit: cover;
              {%- endcapture -%}
              {{
                image_secondary
                | image_url: width: image_secondary.width
                | image_tag:
                  width: image_secondary.width,
                  height: image_secondary.height,
                  widths: '360, 535, 600, 720, 940, 1066, 1200, 1400, 1600, 1800, 2000, 2200, 2400, 2600, 2800, 3000, 3200, 3400, 3600, 3800',
                  sizes: image_sizes,
                  class: 'hero__image-secondary hero__image hero__animation-item',
                  style: styles2,
                  loading: image_loading
              }}
            {% else %}
              {%- liquid
                assign placeholder_class = 'placeholder-svg hero__animation-item'
                if section.settings.aspect_ratio_secondary == 'adapt-to-image'
                  assign placeholder_class = placeholder_class | append: ' ' | append: 'adapt-to-image'
                endif
              %}
              {{ 'hero-apparel-2' | placeholder_svg_tag: placeholder_class }}
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.hero.name",
  "tag": "section",
  "class": "hero-section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.section_heading_group.header.content"
    },
    {
      "type": "text",
      "id": "heading_big",
      "default": "t:sections.hero-section.settings.heading_big.default",
      "label": "t:sections.hero-section.settings.heading_big.label"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.all.subheading.label"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "t:sections.hero-section.settings.heading.default",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h6",
          "label": "t:sections.all.heading_size.options__6.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_size.options__5.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__1.label"
        }
      ],
      "default": "h5",
      "label": "t:sections.all.heading_size.label",
      "visible_if": "{{ section.settings.heading != blank }}"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.heading_tag.options__6.label"
        },
        {
          "value": "div",
          "label": "t:sections.all.heading_tag.options__7.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_tag.label",
      "info": "t:sections.all.heading_tag.info",
      "visible_if": "{{ section.settings.heading != blank }}"
    },
    {
      "type": "header",
      "content": "t:sections.hero-section.settings.content_options.content"
    },
    {
      "type": "inline_richtext",
      "id": "description",
      "default": "t:sections.hero-section.settings.description_primary.default",
      "label": "t:sections.all.text.label"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "options": [
        {
          "value": "top",
          "label": "t:sections.all.vertical_alignment.options__1.label"
        },
        {
          "value": "bottom",
          "label": "t:sections.all.vertical_alignment.options__3.label"
        },
        {
          "value": "stretch",
          "label": "t:sections.all.vertical_alignment.options__4.label"
        }
      ],
      "default": "top",
      "label": "t:sections.all.vertical_alignment.label",
      "visible_if": "{{ section.settings.subheading != blank or section.settings.heading != blank or section.settings.description != blank }}"
    },
    {
      "type": "checkbox",
      "id": "list_button_show",
      "default": false,
      "label": "t:sections.all.button.button_show.label"
    },
    {
      "type": "text",
      "id": "list_button_label",
      "default": "t:sections.image-with-text.blocks.button.default",
      "label": "t:sections.all.button.button_label.label",
      "visible_if": "{{ section.settings.list_button_show }}"
    },
    {
      "type": "url",
      "id": "list_button_link",
      "label": "t:sections.all.button.button_link.label",
      "visible_if": "{{ section.settings.list_button_show }}"
    },
    {
      "type": "select",
      "id": "list_button_style",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.all.button.button_style.options__1.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.all.button.button_style.options__2.label"
        },
        {
          "value": "tertiary",
          "label": "t:sections.all.button.button_style.options__3.label"
        }
      ],
      "default": "tertiary",
      "label": "t:sections.all.button.button_style.label",
      "visible_if": "{{ section.settings.list_button_show }}"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "t:sections.hero-section.settings.enable_animation.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.hero-section.settings.image_primary.content"
    },
    {
      "type": "image_picker",
      "id": "image_primary",
      "label": "t:sections.all.image.label"
    },
    {
      "type": "select",
      "id": "aspect_ratio_primary",
      "options": [
        {
          "value": "landscape",
          "label": "t:sections.all.card.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.all.card.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.all.card.image_ratio.options__3.label"
        },
        {
          "value": "adapt-to-image",
          "label": "t:sections.all.card.image_ratio.options__4.label"
        }
      ],
      "default": "portrait",
      "label": "t:sections.all.card.image_ratio.label"
    },
    {
      "type": "checkbox",
      "id": "enable_parallax",
      "label": "t:sections.hero-section.settings.enable_parallax.label",
      "info": "t:sections.hero-section.settings.enable_parallax.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "animated_badge",
      "default": true,
      "label": "t:sections.showcase.settings.animated_badge.label"
    },
    {
      "type": "image_picker",
      "id": "image_badge",
      "label": "t:sections.image-with-text.settings.badge_icon.label",
      "visible_if": "{{ section.settings.animated_badge }}"
    },
    {
      "type": "header",
      "content": "t:sections.hero-section.settings.image_secondary.content"
    },
    {
      "type": "image_picker",
      "id": "image_secondary",
      "label": "t:sections.all.image.label"
    },
    {
      "type": "select",
      "id": "aspect_ratio_secondary",
      "options": [
        {
          "value": "landscape",
          "label": "t:sections.all.card.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.all.card.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.all.card.image_ratio.options__3.label"
        },
        {
          "value": "adapt-to-image",
          "label": "t:sections.all.card.image_ratio.options__4.label"
        }
      ],
      "default": "portrait",
      "label": "t:sections.all.card.image_ratio.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "l",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.hero-section.name",
      "category": "t:sections.categories.storytelling"
    }
  ]
}
{% endschema %}
