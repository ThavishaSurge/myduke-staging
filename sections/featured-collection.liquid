  "tag": "section",
  "class": "featured-collection-section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme_main",
      "default": "background-2",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.all.image.label"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "options": [
        {
          "value": "landscape",
          "label": "t:sections.all.card.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.all.card.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.all.card.image_ratio.options__3.label"
        },
        {
          "value": "adapt",
          "label": "t:sections.all.card.image_ratio.options__4.label"
        }
      ],
      "default": "portrait",
      "label": "t:sections.all.card.image_ratio.label"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "t:sections.featured-collection.settings.enable_animation.label",
      "default": true
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "t:sections.highlights.settings.products.label",
      "limit": 3
    },
    {
      "type": "header",
      "content": "t:sections.featured-collection.settings.header__content.content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.all.subheading.label",
      "default": "t:sections.featured-collection.settings.subheading.label"
    },
    {
      "type": "inline_richtext",
      "id": "content_heading",
      "label": "t:sections.all.heading.label",
      "default": "t:sections.featured-collection.settings.content_heading.default"
    },
    {
      "type": "select",
      "id": "content_heading_size",
      "options": [
        {
          "value": "h5",
