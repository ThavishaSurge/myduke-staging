{{ 'section-featured-collection.css' | asset_url | stylesheet_tag }}
<script src="{{ 'featured-collection.js' | asset_url }}" defer="defer"></script>
{% style %}
   {% render 'section-margin' %}
  {% render 'section-padding' %}
      {% liquid
       if section.settings.list_button_show and section.settings.list_button_label != blank
         assign display_button = true
       else
         assign display_button = false
       endif
     %}
{% endstyle %}

<div class="featured-collection color-{{ section.settings.color_scheme_main }} background section-{{ section.id }}-padding mydk-product-container-auth">
  <div
    id="Banner-{{ section.id }}"
    class="featured-collection__inner container"
  >
    <div class="featured-collection__content{% if section.settings.animated_badge and section.settings.image_badge != blank %} has-badge{% endif %}">
      <div class="featured-collection__text">
        <div class="featured-collection__content-info">
          <div class="featured-collection__text_inner">
            {%- if section.settings.subheading != blank -%}
              <div class="heading-group__subheading">
                {{- section.settings.subheading -}}
              </div>
            {%- endif -%}
            {% if section.settings.content_heading != blank %}
              <{{ section.settings.content_heading_tag | default: 'h3' }}
                class="featured-collection__heading {{ section.settings.content_heading_size}} richtext-link-inside"
                {{ section.shopify_attributes }}
              >
                {{- section.settings.content_heading -}}
              </{{ section.settings.content_heading_tag | default: 'h3' }}>
            {% endif -%}
          </div>
          {% if section.settings.content_description != blank %}
            <p class="featured-collection__description richtext-link-inside" {{ section.shopify_attributes }}>
              {{- section.settings.content_description -}}
            </p>
          {% endif -%}
        </div>
      </div>
      <div class="featured-collection__info-wraper">
        {%- if section.settings.list_heading != blank -%}
          <div class="featured-collection__info vertical-text parallax-text" data-parallax="400">
            {%- if section.settings.list_heading != blank -%}
              <{{ section.settings.list_heading_tag | default: 'h3' }} class="featured-products__info-heading {{ section.settings.list_heading_size }} richtext-link-inside">
                {{- section.settings.list_heading | truncate: 16, '' -}}
              </{{ section.settings.list_heading_tag | default: 'h3' }}>
            {%- endif -%}
          </div>
        {%- endif -%}
        <div class="featured-collection__img_inner {{ section.settings.aspect_ratio }}">
          {% liquid
            if section.settings.image
              assign image = section.settings.image
            endif
          %}
          {% liquid
            assign image_styles = 'object-fit: cover'

            if section.settings.aspect_ratio == 'adapt'
              assign settings_aspect_ratio = image.aspect_ratio
            else
              if section.settings.aspect_ratio == 'landscape'
                assign settings_aspect_ratio = 1.44
              elsif section.settings.aspect_ratio == 'portrait'
                assign settings_aspect_ratio = 0.76
              elsif section.settings.aspect_ratio == 'recommended'
                assign settings_aspect_ratio = 1.26
              else
                assign settings_aspect_ratio = 1
              endif
            endif

            assign calc_ratio = 1

            if image.aspect_ratio > settings_aspect_ratio
              assign calc_ratio = image.aspect_ratio | divided_by: settings_aspect_ratio | round: 2
            endif

            assign image_loading = 'lazy'

            if section.index == 1
              assign image_loading = 'eager'
            endif
          %}
          {%- capture image_sizes -%}
            (min-width: 750px) calc(50vw * {{ calc_ratio }}), calc(100vw * {{ calc_ratio }})
          {%- endcapture -%}
          <div class="{% if section.settings.enable_animation %} featured-collection__animation-wrapper{% endif %}">
            {% if image != blank %}
              {{
                image
                | image_url: width: image.width
                | image_tag:
                  width: image.width,
                  height: image.height,
                  widths: '360, 535, 600, 720, 940, 1066, 1200, 1400, 1600, 1800, 2000, 2200, 2400, 2600, 2800, 3000, 3200, 3400, 3600, 3800',
                  sizes: image_sizes,
                  class: 'featured-collection__image featured-collection__animation-item',
                  style: image_styles,
                  loading: image_loading
              }}
            {%- else -%}
              {{
                'hero-apparel-1'
                | placeholder_svg_tag: 'media-banner__image placeholder-svg featured-collection__animation-item'
              }}
            {%- endif -%}
          </div>
          {% if section.settings.animated_badge %}
            {% if section.settings.image_badge != blank %}
              <div class="featured-collection__img_badge">
                {{
                  section.settings.image_badge
                  | image_url: width: section.settings.image_badge.width
                  | image_tag:
                    width: section.settings.image_badge.width,
                    height: section.settings.image_badge.height,
                    widths: '360, 535, 600, 720, 940, 1066, 1200, 1400, 1600, 1800, 2000, 2200, 2400, 2600, 2800, 3000, 3200, 3400, 3600, 3800',
                    sizes: '50vw'
                }}
              </div>
            {%- endif -%}
          {%- endif -%}
        </div>
      </div>
    </div>
    {%- if section.settings.products != blank -%}
      <div class="featured-collection_products_wraper">
        {%- for product in section.settings.products -%}
          {% assign delay = forloop.index0 | times: 0.2 %}
          <div class="featured-collection-products__item" style="--delay: {{ delay }}s">
            {% render 'product-card-featured',
              product_card_product: product,
              section_id: section.id,
              columns: section.settings.products_per_row,
              columns_mobile: section.settings.products_per_row_mobile,
              color_scheme: section.settings.color_scheme
            %}
          </div>
        {%- endfor -%}
      </div>
      {% capture datalayerforitems %}
        {%- for product in section.settings.products -%}
          {item_id: "{{product.id}}", item_name: "{{product.title | escape}}", index: "{{forloop.index}}", item_brand: "{{product.vendor}}", item_category: "{% for collection in product.collections %}{{ collection.title | escape }},{% endfor %}", item_variant: "{{product.variants | size}}", price: "{{product.price | money_without_currency}}"},
        {%- endfor -%}
      {% endcapture %}
    {%- endif -%}
  </div>
  {%- if display_button %}
    <div class="featured-collection_button">
      {% render 'button',
        btn_label: section.settings.list_button_label,
        btn_style: 'tertiary',
        btn_link: section.settings.list_button_link,
        featured_button: true,
        class: 'featured-collection-content__button h5'
      %}
    </div>
  {%- endif -%}
</div>
{% render 'datalayersscript', page_type:'pagelisting', datalayerforitems:datalayerforitems %}
{% schema %}
{
