{{ 'section-myduke-faq-page.css' | asset_url | stylesheet_tag }}

{% style %}
  {% render 'section-padding' %}
  {% render 'section-margin' %}
{% endstyle %}

{%- comment -%} Check if any tab names are populated {%- endcomment -%}
{%- assign has_tabs = false -%}
{%- for i in (1..10) -%}
  {%- assign tab_key = 'tab_' | append: i | append: '_name' -%}
  {%- assign tab_name = section.settings[tab_key] -%}
  {%- if tab_name != blank -%}
    {%- assign has_tabs = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

<div
  class="myduke-faq-page color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding section-{{ section.id }}-margin container"
  data-section-id="{{ section.id }}"
>

  <div class="myduke-faq-page__content" id="myduke-form-scroller">
    {%- if section.blocks.size > 0 -%}
      <div class="myduke-faq-page__faq-column">
        {%- if section.settings.faq_heading != blank -%}
          <{{ section.settings.faq_heading_tag | default: 'h2' }} class="myduke-faq-page__faq-title">
            {{- section.settings.faq_heading -}}
          </{{ section.settings.faq_heading_tag | default: 'h2' }}>
        {%- endif -%}

        {%- if has_tabs -%}
          {%- comment -%} ── Tab Navigation ── {%- endcomment -%}
          <ul class="myduke-faq-page__tabs" role="tablist">
            {%- assign first_tab_rendered = false -%}
            {%- for i in (1..10) -%}
              {%- assign tab_key = 'tab_' | append: i | append: '_name' -%}
              {%- assign tab_name = section.settings[tab_key] -%}
              {%- if tab_name != blank -%}
                <li role="presentation">
                  <button
                    class="myduke-faq-page__tab-button{% unless first_tab_rendered %} is-active{% endunless %}"
                    type="button"
                    role="tab"
                    data-tab-target="tab_{{ i }}"
                    aria-selected="{% unless first_tab_rendered %}true{% else %}false{% endunless %}"
                  >
                    {{ tab_name }}
                  </button>
                </li>
                {%- assign first_tab_rendered = true -%}
              {%- endif -%}
            {%- endfor -%}
          </ul>

          {%- comment -%} ── Tab Content Groups ── {%- endcomment -%}
          {%- assign first_group_rendered = false -%}
          {%- for i in (1..10) -%}
            {%- assign tab_key = 'tab_' | append: i | append: '_name' -%}
            {%- assign tab_name = section.settings[tab_key] -%}
            {%- if tab_name != blank -%}
              {%- assign tab_id = 'tab_' | append: i -%}
              <div class="myduke-faq-page__tab-content{% unless first_group_rendered %} is-active{% endunless %}" data-tab-id="{{ tab_id }}">
                <div class="myduke-faq-page__list">
                  {%- for block in section.blocks -%}
                    {%- if block.settings.question != blank and block.settings.tab_assignment == tab_id -%}
                      <div class="myduke-faq-page__item" {{ block.shopify_attributes }}>

                        <button
                          class="myduke-faq-page__trigger"
                          type="button"
                          aria-expanded="false"
                          aria-controls="myduke-faq-page-panel-{{ section.id }}-{{ block.id }}"
                        >
                          <span class="myduke-faq-page__question">{{ block.settings.question }}</span>
                          <span class="myduke-faq-page__icon" aria-hidden="true">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <rect x="1" y="6.5" width="12" height="1" fill="#264653"/>
                              <rect class="myduke-faq-page__icon-vert" x="6.5" y="1" width="1" height="12" fill="#264653"/>
                            </svg>
                          </span>
                        </button>

                        {%- if block.settings.answer != blank -%}
                          <div
                            class="myduke-faq-page__panel"
                            id="myduke-faq-page-panel-{{ section.id }}-{{ block.id }}"
                            role="region"
                          >
                            <div class="myduke-faq-page__panel-inner">
                              <div class="myduke-faq-page__answer">{{ block.settings.answer }}</div>
                            </div>
                          </div>
                        {%- endif -%}

                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
              {%- assign first_group_rendered = true -%}
            {%- endif -%}
          {%- endfor -%}

        {%- else -%}
          {%- comment -%} ── Fallback: No Tabs - Render All FAQs ── {%- endcomment -%}
          <div class="myduke-faq-page__list">
          {%- for block in section.blocks -%}
            {%- if block.settings.question != blank -%}
              <div class="myduke-faq-page__item" {{ block.shopify_attributes }}>

                <button
                  class="myduke-faq-page__trigger"
                  type="button"
                  aria-expanded="{{ forloop.first | default: false }}"
                  aria-controls="myduke-faq-page-panel-{{ section.id }}-{{ forloop.index }}"
                >
                  <span class="myduke-faq-page__question">{{ block.settings.question }}</span>
                  <span class="myduke-faq-page__icon" aria-hidden="true">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <rect x="1" y="6.5" width="12" height="1" fill="#264653"/>
                      <rect class="myduke-faq-page__icon-vert" x="6.5" y="1" width="1" height="12" fill="#264653"/>
                    </svg>
                  </span>
                </button>

                {%- if block.settings.answer != blank -%}
                  <div
                    class="myduke-faq-page__panel{% if forloop.first %} is-open{% endif %}"
                    id="myduke-faq-page-panel-{{ section.id }}-{{ forloop.index }}"
                    role="region"
                  >
                    <div class="myduke-faq-page__panel-inner">
                      <div class="myduke-faq-page__answer">{{ block.settings.answer }}</div>
                    </div>
                  </div>
                {%- endif -%}

              </div>
            {%- endif -%}
          {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.button_text != blank -%}
          <div class="myduke-faq-page__action" style="margin-top: 3.2rem;">
            <a
              href="{{ section.settings.button_link | default: '#' }}"
              class="myduke-faq-sec__btn"
            >
              {{ section.settings.button_text }}
            </a>
          </div>
        {%- endif -%}

      </div>
    {%- endif -%}

    {%- if section.settings.show_contact_form -%}
      <div class="myduke-faq-page__form-wrapper">
        {%- if section.settings.form_heading != blank -%}
          <{{ section.settings.form_heading_tag | default: 'h3' }} class="myduke-faq-page__form-title">
            {{- section.settings.form_heading -}}
          </{{ section.settings.form_heading_tag | default: 'h3' }}>
        {%- endif -%}
        {%- if section.settings.form_text != blank -%}
          <p class="myduke-faq-page__form-text">
            {{- section.settings.form_text -}}
          </p>
        {%- endif -%}
        {%- form 'contact', id: 'MyDukeFaqContactForm', class: 'myduke-faq-page__form' -%}
          {%- if form.posted_successfully? -%}
            <div class="form-status form-status-list form__message form__message--success body-small">
              {% render 'icon-success' %}
              {{- 'templates.contact.form.post_success' | t -}}
            </div>
          {%- elsif form.errors -%}
          {%- endif -%}
          <div class="field field__name">
            <input
              class="field__input focus-inset"
              autocomplete="name"
              type="text"
              id="MyDukeFaqContactForm-name"
              dir="ltr"
              name="contact[{{ 'templates.contact.form.name' | t }}]"
              value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
              placeholder="{{- 'templates.contact.form.name' | t -}}"
            >
            <label
              class="field__label body-small"
              for="MyDukeFaqContactForm-name"
            >
              {{- 'templates.contact.form.name' | t -}}
            </label>
          </div>
          <div class="field">
            <input
              autocomplete="email"
              type="email"
              id="MyDukeFaqContactForm-email"
              dir="ltr"
              class="field__input focus-inset"
              name="contact[email]"
              spellcheck="false"
              pattern="[a-z0-9._%+\-]+@[a-z0-9.\-]+\.[a-z]{2,}$"
              autocapitalize="off"
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              aria-required="true"
              {% if form.errors contains 'email' %}
                aria-invalid="true"
                aria-describedby="MyDukeFaqContactForm-email-error"
              {% endif %}
              placeholder="{{- 'templates.contact.form.email' | t -}}"
              required
            >
            <label
              class="field__label body-small"
              for="MyDukeFaqContactForm-email"
            >
              {{- 'templates.contact.form.email' | t -}}
            </label>

            {%- if form.errors contains 'email' -%}
              <small class="myduke-faq-page__field-error" id="MyDukeFaqContactForm-email-error">
                <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
                <span class="form__message form__message--error">
                  {{- form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email -}}
                </span>
              </small>
            {%- endif -%}
          </div>
          <div class="field">
            <input
              type="tel"
              id="MyDukeFaqContactForm-phone"
              dir="ltr"
              class="field__input"
              autocomplete="tel"
              name="contact[{{ 'templates.contact.form.phone' | t }}]"
              pattern="[0-9\-]*"
              value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
              placeholder="{{- 'templates.contact.form.phone' | t -}}"
            >
            <label
              class="field__label body-small"
              for="MyDukeFaqContactForm-phone"
            >
              {{- 'templates.contact.form.phone' | t -}}
            </label>
          </div>
          <div class="field">
            <textarea
              id="MyDukeFaqContactForm-body"
              dir="ltr"
              class="text-area field__input"
              name="contact[{{ 'templates.contact.form.comment' | t }}]"
              placeholder="{{- 'templates.contact.form.comment' | t -}}"
              aria-required="true"
              required
            >
              {{- form.body -}}
            </textarea>
            <label
              class="field__label body-small"
              for="MyDukeFaqContactForm-body"
            >
              {{- 'templates.contact.form.comment' | t -}}
            </label>
          </div>
          <div class="myduke-faq-page__form-bottom">
            <button
              type="submit"
              class="button button--{{ section.settings.form_button_style }} focus-inset"
            >
              <div class="button__content">
                {% if section.settings.form_button_style == 'tertiary' %}
                  <span class="button__icons-container">
                    {% render 'icon-arrow-tertiary-button' %}
                    {% render 'icon-arrow-tertiary-button' %}
                  </span>
                {% endif %}
                <span class="button__label">
                  {{- 'templates.contact.form.send' | t -}}
                </span>
              </div>
            </button>
            {%- if section.settings.form_additional_text != blank -%}
              <div class="myduke-faq-page__form-add-text body-small">
                {{- section.settings.form_additional_text -}}
              </div>
            {%- endif -%}
          </div>
        {%- endform -%}
      </div>
    {%- endif -%}
  </div>

</div>

<script src="{{ 'myduke-faq-page.js' | asset_url }}" defer></script>
<script src="{{ 'myduke-form-validation.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "FAQ Page (MyDuke)",
  "class": "myduke-faq-page-section",
  "tag": "section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "background-1",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "header",
      "content": "Category Tabs"
    },
    {
      "type": "text",
      "id": "tab_1_name",
      "label": "Tab 1 Name",
      "info": "Leave blank to disable tabs and show all FAQs in a single list"
    },
    {
      "type": "text",
      "id": "tab_2_name",
      "label": "Tab 2 Name"
    },
    {
      "type": "text",
      "id": "tab_3_name",
      "label": "Tab 3 Name"
    },
    {
      "type": "text",
      "id": "tab_4_name",
      "label": "Tab 4 Name"
    },
    {
      "type": "text",
      "id": "tab_5_name",
      "label": "Tab 5 Name"
    },
    {
      "type": "text",
      "id": "tab_6_name",
      "label": "Tab 6 Name"
    },
    {
      "type": "text",
      "id": "tab_7_name",
      "label": "Tab 7 Name"
    },
    {
      "type": "text",
      "id": "tab_8_name",
      "label": "Tab 8 Name"
    },
    {
      "type": "text",
      "id": "tab_9_name",
      "label": "Tab 9 Name"
    },
    {
      "type": "text",
      "id": "tab_10_name",
      "label": "Tab 10 Name"
    },
    {
      "type": "header",
      "content": "FAQ Section"
    },
    {
      "type": "inline_richtext",
      "id": "faq_heading",
      "label": "FAQ heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "select",
      "id": "faq_heading_tag",
      "options": [
        { "value": "h1", "label": "t:sections.all.heading_tag.options__1.label" },
        { "value": "h2", "label": "t:sections.all.heading_tag.options__2.label" },
        { "value": "h3", "label": "t:sections.all.heading_tag.options__3.label" },
        { "value": "h4", "label": "t:sections.all.heading_tag.options__4.label" },
        { "value": "h5", "label": "t:sections.all.heading_tag.options__5.label" },
        { "value": "h6", "label": "t:sections.all.heading_tag.options__6.label" },
        { "value": "div", "label": "t:sections.all.heading_tag.options__7.label" }
      ],
      "default": "h2",
      "label": "FAQ heading tag",
      "info": "t:sections.all.heading_tag.info"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "View all FAQs"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Contact Form"
    },
    {
      "type": "checkbox",
      "id": "show_contact_form",
      "label": "Show contact form",
      "default": false,
      "info": "Display a contact form alongside the FAQs (desktop: right side, mobile: below FAQs)"
    },
    {
      "type": "inline_richtext",
      "id": "form_heading",
      "label": "Form heading",
      "default": "Contact us",
      "visible_if": "{{ section.settings.show_contact_form }}"
    },
    {
      "type": "select",
      "id": "form_heading_tag",
      "options": [
        { "value": "h1", "label": "t:sections.all.heading_tag.options__1.label" },
        { "value": "h2", "label": "t:sections.all.heading_tag.options__2.label" },
        { "value": "h3", "label": "t:sections.all.heading_tag.options__3.label" },
        { "value": "h4", "label": "t:sections.all.heading_tag.options__4.label" },
        { "value": "h5", "label": "t:sections.all.heading_tag.options__5.label" },
        { "value": "h6", "label": "t:sections.all.heading_tag.options__6.label" },
        { "value": "div", "label": "t:sections.all.heading_tag.options__7.label" }
      ],
      "default": "h3",
      "label": "Form heading tag",
      "visible_if": "{{ section.settings.show_contact_form }}"
    },
    {
      "type": "inline_richtext",
      "id": "form_text",
      "label": "Form description text",
      "default": "Have a question? Fill out the form below and we'll get back to you.",
      "visible_if": "{{ section.settings.show_contact_form }}"
    },
    {
      "type": "select",
      "id": "form_button_style",
      "options": [
        { "value": "primary", "label": "t:sections.all.button.button_style.options__1.label" },
        { "value": "secondary", "label": "t:sections.all.button.button_style.options__2.label" },
        { "value": "tertiary", "label": "t:sections.all.button.button_style.options__3.label" },
        { "value": "secondary2", "label": "t:sections.all.button.button_style.options__4.label" },
        { "value": "accent", "label": "t:sections.all.button.button_style.options__5.label" }
      ],
      "default": "primary",
      "label": "Form button style",
      "visible_if": "{{ section.settings.show_contact_form }}"
    },
    {
      "type": "inline_richtext",
      "id": "form_additional_text",
      "label": "Additional text below button",
      "info": "Optional text displayed below the submit button",
      "visible_if": "{{ section.settings.show_contact_form }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-padding.header.content"
    },
    {
      "type": "select",
      "id": "padding_top",
      "options": [
        { "value": "no-indent", "label": "t:sections.all.section-padding.options__1.label" },
        { "value": "xs", "label": "t:sections.all.section-padding.options__2.label" },
        { "value": "s", "label": "t:sections.all.section-padding.options__3.label" },
        { "value": "m", "label": "t:sections.all.section-padding.options__4.label" },
        { "value": "l", "label": "t:sections.all.section-padding.options__5.label" },
        { "value": "xl", "label": "t:sections.all.section-padding.options__6.label" }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-padding.padding_top.label"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "options": [
        { "value": "no-indent", "label": "t:sections.all.section-padding.options__1.label" },
        { "value": "xs", "label": "t:sections.all.section-padding.options__2.label" },
        { "value": "s", "label": "t:sections.all.section-padding.options__3.label" },
        { "value": "m", "label": "t:sections.all.section-padding.options__4.label" },
        { "value": "l", "label": "t:sections.all.section-padding.options__5.label" },
        { "value": "xl", "label": "t:sections.all.section-padding.options__6.label" }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-padding.padding_bottom.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        { "value": "no-indent", "label": "t:sections.all.section-margin.options__1.label" },
        { "value": "xs", "label": "t:sections.all.section-margin.options__2.label" },
        { "value": "s", "label": "t:sections.all.section-margin.options__3.label" },
        { "value": "m", "label": "t:sections.all.section-margin.options__4.label" },
        { "value": "l", "label": "t:sections.all.section-margin.options__5.label" },
        { "value": "xl", "label": "t:sections.all.section-margin.options__6.label" }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        { "value": "no-indent", "label": "t:sections.all.section-margin.options__1.label" },
        { "value": "xs", "label": "t:sections.all.section-margin.options__2.label" },
        { "value": "s", "label": "t:sections.all.section-margin.options__3.label" },
        { "value": "m", "label": "t:sections.all.section-margin.options__4.label" },
        { "value": "l", "label": "t:sections.all.section-margin.options__5.label" },
        { "value": "xl", "label": "t:sections.all.section-margin.options__6.label" }
      ],
      "default": "l",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "select",
          "id": "tab_assignment",
          "label": "Assign to Tab",
          "options": [
            { "value": "tab_1", "label": "Tab 1" },
            { "value": "tab_2", "label": "Tab 2" },
            { "value": "tab_3", "label": "Tab 3" },
            { "value": "tab_4", "label": "Tab 4" },
            { "value": "tab_5", "label": "Tab 5" },
            { "value": "tab_6", "label": "Tab 6" },
            { "value": "tab_7", "label": "Tab 7" },
            { "value": "tab_8", "label": "Tab 8" },
            { "value": "tab_9", "label": "Tab 9" },
            { "value": "tab_10", "label": "Tab 10" }
          ],
          "default": "tab_1",
          "info": "Select which tab this FAQ item should appear under (only applies when tabs are enabled)"
        },
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Page (MyDuke)",
      "category": "t:sections.categories.storytelling",
      "settings": {
        "faq_heading": "Frequently Asked Questions",
        "button_text": "View all FAQs"
      },
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "What materials are your products made from?",
            "answer": "<p>All our products are crafted using high-quality, durable materials selected to ensure longevity, functionality, and style. Specific materials vary by product type and are detailed on each product page.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How do I care for or maintain this product?"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Do you offer warranties or guarantees?"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Can I return or exchange a product?"
          }
        }
      ]
    }
  ]
}
{% endschema %}