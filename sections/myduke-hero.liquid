{{ 'section-myduke-hero.css' | asset_url | stylesheet_tag }}

<div
  class="myduke-hero"
  style="{% if section.settings.background_image != blank %}background-image: url('{{ section.settings.background_image | image_url: width: 2000 }}');{% endif %} --overlay-color: {{ section.settings.overlay_color }}; --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
>
  <div class="page-width container">
    <div class="myduke-hero__inner{% if section.settings.enable_eligibility_form %} myduke-hero__inner--with-form{% endif %}">
      <div class="myduke-hero__content">
        {%- if section.settings.heading != blank -%}
          <h1 class="myduke-hero__heading">{{ section.settings.heading | newline_to_br }}</h1>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <div class="myduke-hero__description">{{ section.settings.description | newline_to_br }}</div>
        {%- endif -%}

        <div class="myduke-hero__buttons">
          {%- if section.settings.button_1_text != blank -%}
            <a
              href="{{ section.settings.button_1_link | default: '#' }}"
              class="myduke-hero__btn myduke-hero__btn--primary"
            >
              {{ section.settings.button_1_text }}
            </a>
          {%- endif -%}

          {%- if section.settings.button_2_text != blank -%}
            <a
              href="{{ section.settings.button_2_link | default: '#' }}"
              class="myduke-hero__btn myduke-hero__btn--secondary"
            >
              {{ section.settings.button_2_text }}
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- if section.settings.enable_eligibility_form -%}
        {{ 'hero-eligibility-form.css' | asset_url | stylesheet_tag }}
        <div class="myduke-hero__form-col">

          <div class="eligibility-card" id="eligibility-card-{{ section.id }}">

            <div class="eligibility-card__tabs" role="tablist">
              <button class="eligibility-card__tab is-active" id="elig-tab-eligibility-{{ section.id }}" role="tab" aria-selected="true" aria-controls="elig-panel-eligibility-{{ section.id }}" data-elig-tab="eligibility">Eligibility</button>
              <button class="eligibility-card__tab" id="elig-tab-signin-{{ section.id }}" role="tab" aria-selected="false" aria-controls="elig-panel-signin-{{ section.id }}" data-elig-tab="signin">Sign in</button>
            </div>

            <div class="eligibility-card__body">

              <div class="eligibility-tab-panel is-active" id="elig-panel-eligibility-{{ section.id }}" role="tabpanel" aria-labelledby="elig-tab-eligibility-{{ section.id }}" data-elig-panel="eligibility">
                <h2 class="eligibility-card__intro-heading">{{ section.settings.elig_heading | default: 'Am I Eligible?' }}</h2>
                <p class="eligibility-card__intro-text">{{ section.settings.elig_description | default: "Take our 30-second quiz to find out if you're a candidate for pharmacy-grade cessation treatment." }}</p>

                <div class="eligibility-step is-active" data-elig-step="1">
                  <p class="eligibility-step__question">What is your age range?</p>
                  <div class="eligibility-step__options eligibility-step__options--4col" role="group">
                    <button class="eligibility-option" data-elig-option data-value="18-25">18–25</button>
                    <button class="eligibility-option" data-elig-option data-value="26-35">26–35</button>
                    <button class="eligibility-option" data-elig-option data-value="36-50">36–50</button>
                    <button class="eligibility-option" data-elig-option data-value="50+">50+</button>
                  </div>
                  <div class="eligibility-progress">
                    <div class="eligibility-progress__label">Question 1 / 3</div>
                    <div class="eligibility-progress__track"><div class="eligibility-progress__bar" style="width:33%;"></div></div>
                  </div>
                  <button class="eligibility-card__btn" data-elig-next>Next</button>
                </div>

                <div class="eligibility-step" data-elig-step="2">
                  <p class="eligibility-step__question">How long have you been smoking?</p>
                  <div class="eligibility-step__options eligibility-step__options--4col" role="group">
                    <button class="eligibility-option" data-elig-option data-value="less-than-1yr">Less than 1 year</button>
                    <button class="eligibility-option" data-elig-option data-value="1-5yr">1–5 years</button>
                    <button class="eligibility-option" data-elig-option data-value="5-15yr">5–15 years</button>
                    <button class="eligibility-option" data-elig-option data-value="15yr+">15+ years</button>
                  </div>
                  <div class="eligibility-progress">
                    <div class="eligibility-progress__label">Question 2 / 3</div>
                    <div class="eligibility-progress__track"><div class="eligibility-progress__bar" style="width:66%;"></div></div>
                  </div>
                  <button class="eligibility-card__btn" data-elig-next>Next</button>
                </div>

                <div class="eligibility-step" data-elig-step="3">
                  <p class="eligibility-step__question">What is your primary goal?</p>
                  <div class="eligibility-step__options" role="group">
                    <button class="eligibility-option" data-elig-option data-value="quit-completely">Quit completely</button>
                    <button class="eligibility-option" data-elig-option data-value="reduce-intake">Reduce intake</button>
                    <button class="eligibility-option" data-elig-option data-value="switch-safer">Switch to a safer alternative</button>
                    <button class="eligibility-option" data-elig-option data-value="explore">Explore options</button>
                  </div>
                  <div class="eligibility-progress">
                    <div class="eligibility-progress__label">Question 3 / 3</div>
                    <div class="eligibility-progress__track"><div class="eligibility-progress__bar" style="width:100%;"></div></div>
                  </div>
                  <button class="eligibility-card__btn" data-elig-submit>Next</button>
                </div>

                <div class="eligibility-processing" data-elig-processing>
                  <p class="eligibility-processing__label">Verifying medical data</p>
                  <div class="eligibility-processing__track"><div class="eligibility-processing__fill" data-elig-processing-bar></div></div>
                  <p class="eligibility-processing__status">Cross-referencing with clinical eligibility criteria</p>
                </div>

                <div class="eligibility-result" data-elig-result="eligible">
                  <p class="eligibility-result__title">You may be eligible</p>
                  <p class="eligibility-result__text">Based on your responses, you're a potential candidate. Complete the full medical assessment to proceed.</p>
                  <div class="eligibility-result__actions">
                    <a href="{{ section.settings.elig_assessment_link | default: '#' }}" class="eligibility-card__btn">Start Full Assessment</a>
                    <button class="eligibility-card__btn eligibility-card__btn--outline" data-elig-retake>Retake Quiz</button>
                  </div>
                </div>

                <div class="eligibility-result" data-elig-result="not-eligible">
                  <p class="eligibility-result__title">Not eligible at this time</p>
                  <p class="eligibility-result__text">Based on your responses, you may not qualify for this program right now. Please consult a healthcare professional.</p>
                  <div class="eligibility-result__actions">
                    <button class="eligibility-card__btn eligibility-card__btn--outline" data-elig-retake>Retake Quiz</button>
                  </div>
                </div>

              </div>

              <div class="eligibility-tab-panel" id="elig-panel-signin-{{ section.id }}" role="tabpanel" aria-labelledby="elig-tab-signin-{{ section.id }}" data-elig-panel="signin">
                <p class="eligibility-signin__msg">Sign in functionality coming soon.</p>
              </div>

            </div>
          </div>

          <script>
          (function () {
            var card = document.getElementById('eligibility-card-{{ section.id }}');
            if (!card) return;
            var answers = {};
            var currentStep = 1;
            var steps = card.querySelectorAll('[data-elig-step]');
            var processing = card.querySelector('[data-elig-processing]');
            var processingBar = card.querySelector('[data-elig-processing-bar]');
            var results = card.querySelectorAll('[data-elig-result]');
            var panels = card.querySelectorAll('[data-elig-panel]');
            var tabs = card.querySelectorAll('[data-elig-tab]');

            tabs.forEach(function(tab) {
              tab.addEventListener('click', function() {
                var target = tab.dataset.eligTab;
                tabs.forEach(function(t) {
                  t.classList.toggle('is-active', t.dataset.eligTab === target);
                  t.setAttribute('aria-selected', t.dataset.eligTab === target ? 'true' : 'false');
                });
                panels.forEach(function(p) {
                  p.classList.toggle('is-active', p.dataset.eligPanel === target);
                });
              });
            });

            card.addEventListener('click', function(e) {
              var option = e.target.closest('[data-elig-option]');
              if (!option) return;
              var group = option.closest('.eligibility-step__options');
              group.querySelectorAll('[data-elig-option]').forEach(function(o) { o.classList.remove('is-selected'); });
              option.classList.add('is-selected');
              answers['step' + currentStep] = option.dataset.value;
            });

            card.addEventListener('click', function(e) {
              if (!e.target.closest('[data-elig-next]')) return;
              if (!answers['step' + currentStep]) {
                var group = steps[currentStep - 1].querySelector('.eligibility-step__options');
                group.style.outline = '2px solid rgba(255,255,255,0.5)';
                setTimeout(function() { group.style.outline = ''; }, 700);
                return;
              }
              showStep(currentStep + 1);
            });

            card.addEventListener('click', function(e) {
              if (!e.target.closest('[data-elig-submit]')) return;
              if (!answers['step' + currentStep]) {
                var group = steps[currentStep - 1].querySelector('.eligibility-step__options');
                group.style.outline = '2px solid rgba(255,255,255,0.5)';
                setTimeout(function() { group.style.outline = ''; }, 700);
                return;
              }
              runProcessing();
            });

            card.addEventListener('click', function(e) {
              if (!e.target.closest('[data-elig-retake]')) return;
              resetQuiz();
            });

            function showStep(n) {
              currentStep = n;
              steps.forEach(function(s) { s.classList.remove('is-active'); });
              var target = card.querySelector('[data-elig-step="' + n + '"]');
              if (target) target.classList.add('is-active');
            }

            function runProcessing() {
              steps.forEach(function(s) { s.classList.remove('is-active'); });
              results.forEach(function(r) { r.classList.remove('is-active'); });
              processing.classList.add('is-active');
              requestAnimationFrame(function() {
                processingBar.style.width = '0%';
                requestAnimationFrame(function() { processingBar.style.width = '100%'; });
              });
              setTimeout(showResult, 2700);
            }

            function showResult() {
              processing.classList.remove('is-active');
              var resultEl = card.querySelector('[data-elig-result="eligible"]');
              if (resultEl) resultEl.classList.add('is-active');
            }

            function resetQuiz() {
              Object.keys(answers).forEach(function(k) { delete answers[k]; });
              card.querySelectorAll('[data-elig-option]').forEach(function(o) { o.classList.remove('is-selected'); });
              results.forEach(function(r) { r.classList.remove('is-active'); });
              processing.classList.remove('is-active');
              processingBar.style.width = '0%';
              showStep(1);
            }
          })();
          </script>

        </div>
      {%- endif -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "MyDuke Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Image Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Image Overlay Opacity",
      "default": 30
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Clinical Support For\nNicotine Dependance"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "myduke offers safe and clinically appropriate pathways for smoking cessation, supported by healthcare professionals every step of the way."
    },
    {
      "type": "text",
      "id": "button_1_text",
      "label": "Primary Button Text",
      "default": "Apply For A Prescription"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Secondary Button Text",
      "default": "How It Works"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "header",
      "content": "Eligibility Form"
    },
    {
      "type": "checkbox",
      "id": "enable_eligibility_form",
      "label": "Show eligibility form",
      "default": false,
      "info": "Displays the step-by-step eligibility quiz card on the right side of the hero."
    },
    {
      "type": "text",
      "id": "elig_heading",
      "label": "Form heading",
      "default": "Am I Eligible?",
      "visible_if": "{{ section.settings.enable_eligibility_form }}"
    },
    {
      "type": "textarea",
      "id": "elig_description",
      "label": "Form description",
      "default": "Take our 30-second quiz to find out if you\u2019re a candidate for pharmacy-grade cessation treatment.",
      "visible_if": "{{ section.settings.enable_eligibility_form }}"
    },
    {
      "type": "url",
      "id": "elig_assessment_link",
      "label": "Start Assessment link",
      "info": "URL for the 'Start Full Assessment' button shown after eligibility is confirmed.",
      "visible_if": "{{ section.settings.enable_eligibility_form }}"
    }
  ],
  "presets": [
    {
      "name": "MyDuke Hero",
      "category": "Custom"
    }
  ]
}
{% endschema %}
