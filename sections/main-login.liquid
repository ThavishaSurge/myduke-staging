{{ 'customer.css' | asset_url | stylesheet_tag: preload: true }}

{%- style -%}
  {% render 'section-margin' %}
{%- endstyle -%}

<div
  class="customer login login--{{ section.id }}  container"
>
  <div class="login__col">
    <div class="login__reset" id="recover">
      <div class="form-header">
        <div class="form-header__inner">
          <h2 class=" login__title h4">
            {{ 'customer.recover_password.title' | t }}
          </h2>
          <p class="login__desc body-large">{{ 'customer.recover_password.subtext' | t }}</p>
        </div>
      </div>
      <div>
        {%- form 'recover_customer_password' -%}
          {% assign recover_success = form.posted_successfully? %}
          <div class="field field--email">
            <input
              type="email"
              value=""
              name="email"
              id="RecoverEmail"
              dir="ltr"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              pattern="[a-z0-9._%+\-]+@[a-z0-9.\-]+\.[a-z]{2,}$"
              autofocus
              {% if form.errors %}
                aria-invalid="true"
                aria-describedby="RecoverEmail-email-error"
                autofocus
              {% endif %}
              placeholder="{{ 'customer.register.placeholders.email' | t }}"
              required
            >
            <label for="RecoverEmail" class="body-small">
              {{- 'customer.login_page.email' | t -}}
            </label>
            {%- if form.errors -%}
              <small id="RecoverEmail-email-error" class="form__message">
                {{ form.errors.messages.form }}
              </small>
            {%- endif -%}
          </div>

          <div class="login__buttons">
            <button type="submit" class="button button--primary login__sign-in focus-inset">
              <div class="button__content">
                <span class="button__label" data-label="{{- 'customer.login_page.submit' | t -}}">
                  {{- 'customer.login_page.submit' | t -}}
                </span>
              </div>
            </button>
            <a
              class="underlined-link reset__sign-in anchor focus-inset"
              href="#login"
            >
              <span class="button__label">
                {{- 'customer.login_page.cancel' | t -}}
              </span>
            </a>
          </div>
        {%- endform -%}
      </div>
    </div>

    <div class="login__form" id="login">
      <div class="login__form-main background">
        <div class="form-header">
          <div class="form-header__inner">
            <h1 class=" login__title h4">
              {{ 'customer.login_page.title' | t }}
            </h1>
            <p class="login__desc body-large">{{ 'customer.login_page.desc' | t }}</p>
          </div>
        </div>
        {%- if recover_success == true -%}
          <p class="form__message form__message--success" tabindex="-1" autofocus>
            {{- 'customer.recover_password.success' | t -}}
          </p>
        {%- endif -%}
        {%- form 'customer_login' -%}
          <div class="field field--email login__field">
            <input
              type="email"
              name="customer[email]"
              class="field__input"
              id="CustomerEmail"
              dir="ltr"
              autocomplete="email"
              autocorrect="off"
              autocapitalize="off"
              autofocus
              required
              {% if form.errors contains 'form' %}
                aria-invalid="true"
                aria-describedby="LoginForm-email-error"
              {% endif %}
              placeholder="{{ 'customer.register.placeholders.email' | t }}"
            >
            <label for="CustomerEmail" class="body-small">
              {{- 'customer.login_page.email' | t -}}
            </label>
            {% unless template.name == 'register' %}
              {{ form.errors | default_errors }}
            {% endunless %}
          </div>

          {%- if form.password_needed -%}
            <div class="field field--pass login__field">
              <div class="field--pass-wrapper">
                <div class="button-pass-visibility">
                  {% render 'icon-eye' %}
                  {% render 'icon-eye-close' %}
                </div>
                <input
                  type="password"
                  value=""
                  name="customer[password]"
                  class="field__input"
                  id="CustomerPassword"
                  dir="ltr"
                  autocomplete="current-password"
                  placeholder="{{ 'customer.register.placeholders.password' | t }}"
                  {% if form.errors contains 'form' %}
                    aria-invalid="true"
                  {% endif %}
                  required
                >
                <label for="CustomerPassword" class="body-small">
                  {{- 'customer.login_page.password' | t -}}
                </label>
              </div>

              {% unless template.name == 'register' %}
                {{ form.errors | default_errors }}
              {% endunless %}
            </div>
          {%- endif -%}

          <div class="login__buttons">
            <button type="submit" class="button button--primary login__sign-in focus-inset">
              <div class="button__content">
                <span class="button__label" data-label="{{- 'customer.log_in' | t -}}">
                  {{- 'customer.log_in' | t -}}
                </span>
              </div>
            </button>
            <a
              href="#recover"
              class="body-small underlined-link-secondary recover-link focus-inset"
            >
              <span>{{- 'customer.login_page.forgot_password' | t -}}</span>
            </a>
          </div>
        {%- endform -%}
      </div>

      <div class="login__form-info background">
        <div class="login__form-info-heading">
          <p class="body-normal">{{ 'customer.login_page.new_customer_title' | t }}</p>
          {% comment %}<span class="body-small">{{ 'customer.login_page.new_customer_text' | t }}</span>{% endcomment %}
        </div>
        {% comment %}{% assign register_btn_label = 'customer.login_page.create_account' | t %}
        {% render 'button',
          btn_label: register_btn_label,
          btn_style: 'transparent',
          btn_link: routes.account_register_url,
          class: 'login__to-register'
        %}{% endcomment %}
        <a
          class="underlined-link login__to-register"
          href="{{ routes.account_register_url }}"
        >
          <span class="button__label">
            {{- 'customer.login_page.create_account' | t -}}
          </span>
        </a>
      </div>
    </div>

    {%- if shop.checkout.guest_login -%}
      <div class="login__guest">
        <div class="login__title h6">
          {{ 'customer.login_page.guest_title' | t }}
        </div>

        {%- form 'guest_login' -%}
          <button class="button button--primary focus-inset">
            <div class="button__content">
              <span class="button__label" data-label="{{- 'customer.login_page.guest_continue' | t -}}">
                {{- 'customer.login_page.guest_continue' | t -}}
              </span>
            </div>
          </button>
        {%- endform -%}
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  window.onload = () => {
    typeof PasswordViewer !== 'undefined' && new PasswordViewer();
  };
</script>

{% schema %}
{
  "name": "t:sections.main-login.name",
  "tag": "section",
  "class": "login-section",
  "settings": [
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "xl",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ]
}
{% endschema %}
