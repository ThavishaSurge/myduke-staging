{% style %}
  .age-verification {
    background-color: rgba(0, 0, 0, 0.6) !important;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    align-items: center;
    justify-content: center;
  }

  .age-verification__wrapper {
    width: 100%;
    height: auto !important;
    padding: 2rem;
    box-shadow: none !important;
  }

  .age-verification__wrapper > .container {
    background-color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    border-radius: 20px;
    padding: 4rem;
    max-width: 500px;
    width: 100%;
    margin: 0 auto;
    text-align: center;
  }

  .age-verification__heading {
    font-size: 2.4rem;
    font-weight: 700;
    margin-top: 0;
    margin-bottom: 1.5rem;
    color: #1a1a1a;
    line-height: 1.3;
  }

  .age-verification .popup-text {
    font-size: 1.6rem;
    color: #4a4a4a;
    margin-bottom: 3.5rem;
    line-height: 1.5;
  }

  .age-verification__buttons {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    flex-direction: row !important;
    margin-top: 0 !important;
  }

  .age-verification__leave-btn {
    background: transparent;
    border: none;
    color: #2b5cff;
    text-decoration: underline;
    font-size: 1.5rem;
    font-weight: 500;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s ease;
  }

  .age-verification__leave-btn:hover {
    color: #1a3fb3;
  }

  .age-verification__popup-close {
    background-color: #218380;
    color: #ffffff;
    border: none;
    border-radius: 30px;
    padding: 1.2rem 3rem;
    font-size: 1.5rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(30, 58, 95, 0.2);
  }

  .age-verification__popup-close:hover {
    background-color: #152943;
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(30, 58, 95, 0.3);
  }

  @media screen and (max-width: 576px) {
    .age-verification__wrapper > .container {
      padding: 3rem 2rem;
    }
    .age-verification__buttons {
      flex-direction: column !important;
      gap: 1.5rem;
    }
    .age-verification__popup-close {
      width: 100%;
    }
  }
{% endstyle %}

<div
  class="age-verification popup"
  data-exit-animation="popupExitFade"
  data-body-scroll-disable="true"
  data-open-trigger="none"
  data-id="{{ section.id }}"
  data-limit-display="1"
  data-limit-lifetime="30"
  tabindex="0"
>
  <div class="age-verification__wrapper popup-wrap">
    <div class="container">
      <div class="age-verification__content">
        <div class="age-verification__question show">
          {%- if section.settings.heading != blank -%}
            <h2 class="age-verification__heading {{ section.settings.heading_size }}">
              {{- section.settings.heading -}}
            </h2>
          {%- endif -%}
          {%- if section.settings.text != blank -%}
            <div class="popup-text rte">
              {{- section.settings.text -}}
            </div>
          {%- endif -%}
          <div class="age-verification__buttons">
            <button class="age-verification__popup-close focus-inset">
              <span class="button__label" data-label="{{- section.settings.button_label_yes -}}">
                {{- section.settings.button_label_yes -}}
              </span>
            </button>
            <a href="https://www.google.com" class="age-verification__leave-btn focus-inset">
              <span class="button__label" data-label="{{- section.settings.button_label_no -}}">
                {{- section.settings.button_label_no -}}
              </span>
            </a>
          </div>
        </div>

        <div class="age-verification__declined">
          {%- if section.settings.heading_declined != blank -%}
            <h2 class="age-verification__heading {{ section.settings.heading_size }}">
              {{- section.settings.heading_declined -}}
            </h2>
          {%- endif -%}
          {%- if section.settings.text_declined != blank -%}
            <div class="popup-text rte">
              {{- section.settings.text_declined -}}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.overlay-group.age-verification.name",
  "class": "age-verification-section",
  "limit": 1,
  "enabled_on": {
    "groups": ["custom.overlay"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.overlay-group.age-verification.settings.header_1.content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.overlay-group.age-verification.settings.heading.label",
      "default": "t:sections.overlay-group.age-verification.settings.heading.default"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h5",
          "label": "t:sections.all.heading_size.options__5.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__1.label"
        }
      ],
      "default": "h4",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:sections.overlay-group.age-verification.settings.text.label",
      "default": "t:sections.overlay-group.age-verification.settings.text.default"
    },
    {
      "type": "text",
      "id": "button_label_no",
      "label": "t:sections.overlay-group.age-verification.settings.button_label_no.label",
      "default": "t:sections.overlay-group.age-verification.settings.button_label_no.default"
    },
    {
      "type": "text",
      "id": "button_label_yes",
      "label": "t:sections.overlay-group.age-verification.settings.button_label_yes.label",
      "default": "t:sections.overlay-group.age-verification.settings.button_label_yes.default"
    },
    {
      "type": "header",
      "content": "t:sections.overlay-group.age-verification.settings.header_2.content"
    },
    {
      "type": "text",
      "id": "heading_declined",
      "label": "t:sections.overlay-group.age-verification.settings.heading.label",
      "default": "t:sections.overlay-group.age-verification.settings.heading_declined.default"
    },
    {
      "type": "richtext",
      "id": "text_declined",
      "label": "t:sections.overlay-group.age-verification.settings.text.label",
      "default": "t:sections.overlay-group.age-verification.settings.text_declined.default"
    }
  ],
  "presets": [
    {
      "name": "t:sections.overlay-group.age-verification.name",
      "category": "t:sections.categories.overlay_group"
    }
  ]
}
{% endschema %}
