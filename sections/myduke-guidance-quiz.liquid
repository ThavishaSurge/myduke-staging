{% schema %}
{
  "name": "Guidance Quiz",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Need Guidance?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Take our quick quiz to find out which nicotine strength is right for you."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fallback Background Color",
      "default": "#F4A261"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image (Optional)"
    }
  ],
  "presets": [
    {
      "name": "Guidance Quiz",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<style>
  .guidance-quiz-section, .guidance-quiz-section * {
    box-sizing: border-box;
  }

  .guidance-quiz-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    padding: 124px 10px;
    position: relative;
    width: 100%;
    background-color: {{ section.settings.background_color }};
    {% if section.settings.background_image %}
      background-image: url('{{ section.settings.background_image | image_url: width: 2000 }}');
      background-size: cover;
      background-position: center;
    {% else %}
      /* Placeholder wavy gradient if no image */
      background: linear-gradient(135deg, #f4a261 0%, #e9c46a 50%, #f4a261 100%);
    {% endif %}
    font-family: var(--font-body-family);
  }

  .guidance-quiz-header {
    text-align: center;
    color: #111;
    margin-bottom: 60px;
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .guidance-quiz-header h2 {
    font-family: var(--font-body-family);
    font-size: 48px;
    letter-spacing: -1.8px;
    margin: 0;
    line-height: 1.1;
    color: var(--black, black);
    font-weight: 400;
  }

  .guidance-quiz-header p {
    font-family: var(--font-body-family);
    font-size: 18px;
    width: 100%;
    max-width: 669px;
    margin: 0 auto;
    line-height: 1.5;
    color: var(--black, black);
    font-variation-settings: "wdth" 100;
  }

  .guidance-quiz-card, .guidance-results-card {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 16px solid rgba(255, 255, 255, 0.2);
    background-clip: padding-box;
    width: 100%;
    max-width: 631px;
    min-height: 688px;
    padding: 48px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    z-index: 2;
  }

  .guidance-results-card {
    max-width: 1096px;
    display: none;
    flex-direction: column;
    gap: 48px;
    padding: 48px;
    min-height: unset;
    border: 16px solid rgba(255, 255, 255, 0.2);
    background-clip: padding-box;
  }

  .guidance-question-text {
    color: #264653;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .guidance-question-text h3 {
    font-family: var(--font-body-family);
    font-size: 31.9px;
    letter-spacing: -0.958px;
    margin: 0;
    line-height: 35.11px;
    font-weight: 400;
  }

  .guidance-question-text p {
    font-family: var(--font-body-family);
    font-size: 18px;
    margin: 0;
    line-height: 25.2px;
  }

  .guidance-options {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: auto;
    margin-top: 40px;
  }

  .guidance-option {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px;
    background-color: #edf3f0;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .guidance-option:hover {
    background-color: #e2ebe7;
  }

  .guidance-option.selected {
    background-color: #218380;
  }

  .guidance-option.selected .guidance-option-text {
    color: #f7f8f8;
  }

  .guidance-option-radio {
    width: 13px;
    height: 13px;
    border-radius: 50%;
    border: 2px solid #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .guidance-option.selected .guidance-option-radio {
    border-color: #fff;
  }

  .guidance-option-radio::after {
    content: '';
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: transparent;
  }

  .guidance-option-text {
    font-family: 'Manrope', sans-serif;
    font-size: 14px;
    color: #264653;
    margin: 0;
    font-weight: 400;
    line-height: 1.4;
  }

  .guidance-footer {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-top: 60px;
  }

  .guidance-progress-container {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .guidance-progress-bar-bg {
    width: 100%;
    height: 7px;
    background-color: rgba(33, 131, 128, 0.15);
  }

  .guidance-progress-bar-fill {
    height: 100%;
    background-color: #264653;
    transition: width 0.3s ease;
  }

  .guidance-progress-text {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    text-transform: uppercase;
    color: #264653;
    font-weight: 500;
    margin: 0;
    line-height: 1;
  }

  .guidance-actions {
    display: flex;
    gap: 8px;
    width: 100%;
  }

  .guidance-btn {
    flex: 1;
    min-height: 40px;
    padding: 9.5px 36px;
    font-size: 14px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s ease;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }

  .guidance-btn-back {
    background-color: #218380;
    color: white;
    opacity: 0.2;
    cursor: not-allowed;
    font-family: var(--font-body-family);
    font-weight: 500;
    text-transform: capitalize;
  }

  .guidance-btn-back.active {
    opacity: 1;
    cursor: pointer;
  }

  .guidance-btn-next, .guidance-btn-shop {
    background-color: transparent;
    border: 1px solid #218380;
    color: #218380;
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
  }

  .guidance-btn-next:hover, .guidance-btn-shop:hover {
    background-color: rgba(33, 131, 128, 0.05);
  }

  .guidance-btn-shop {
    background-color: #218380;
    color: white;
    margin-top: 16px;
  }

  .guidance-btn-shop:hover {
    background-color: #1a6b68;
    color: white;
  }

  .guidance-btn-retake {
    background-color: transparent;
    border: none;
    color: #264653;
    text-decoration: underline;
    margin-top: 16px;
  }

  .guidance-question-block {
    display: none;
    animation: fadeIn 0.4s ease forwards;
    height: 100%;
  }

  .guidance-question-block.active {
    display: flex;
    flex-direction: column;
  }

  /* ===================== */
  /* Results Card Styling  */
  /* ===================== */

  /* Results title */
  .res-main-title {
    font-family: var(--font-body-family);
    font-size: 31.9px;
    letter-spacing: -0.958px;
    line-height: 35.11px;
    font-weight: 400;
    color: #264653;
    margin: 0;
  }

  /* Two-column row */
  .res-columns {
    display: flex;
    gap: 48px;
    align-items: flex-start;
    width: 100%;
  }

  .res-col-left {
    display: flex;
    flex-direction: column;
    gap: 32px;
    flex-shrink: 0;
    flex:1;
  }

  .res-col-right {
    display: flex;
    flex-direction: column;
    gap: 32px;
    flex:1;
    flex-shrink: 0;
  }

  /* Section block */
  .res-section {
    display: flex;
    flex-direction: column;
    gap: 20px;
    width: 100%;
  }

  /* Section header label */
  .res-section-label {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #264653;
    text-transform: uppercase;
    letter-spacing: 0;
    line-height: 1;
    margin: 0;
    border-bottom: 1px solid #e0dacf;
    padding-bottom: 12px;
    width: 100%;
    font-style: normal;
  }

  /* Device name + tagline block */
  .res-device-text-block {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .res-device-title {
    font-family: 'Manrope', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #2b2b2e;
    margin: 0;
    line-height: 19.6px;
  }

  .res-device-tagline {
    font-family: 'Manrope', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #2b2b2e;
    margin: 0;
    line-height: 19.6px;
  }

  /* Why list */
  .res-list {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .res-list-item {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .res-list-item p {
    font-family: 'Manrope', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #2b2b2e;
    margin: 0;
    line-height: 19.6px;
  }

  .res-list-icon {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Nicotine Recommendation Row */
  .res-nic-row {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    width: 100%;
  }

  .res-nic-text {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
    min-width: 0;
  }

  .res-nic-strength-label {
    font-family: 'Manrope', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #2b2b2e;
    margin: 0;
    line-height: 19.6px;
    white-space: nowrap;
  }

  .res-nic-description {
    font-family: 'Manrope', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #2b2b2e;
    margin: 0;
    line-height: 19.6px;
  }

  .nic-pill {
    background-color: #edf3f0;
    padding: 4px 8px;
    border-radius: 37px;
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    font-size: 14px;
    color: #2b2b2e;
    white-space: nowrap;
    flex-shrink: 0;
    line-height: normal;
    display: flex;
    align-items: center;
  }

  /* What You'll Need rows */
  .res-needs-wrapper {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .res-needs-sublabel {
    font-family: 'Manrope', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #2b2b2e;
    margin: 0;
    line-height: 19.6px;
    white-space: nowrap;
  }
  .res-needs-div{
    display:flex;
    flex-direction:column;
    gap: 12px;
  }
  .res-need-row {
    background-color: #edf3f0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px;
    text-decoration: none;
    width: 100%;
    transition: background-color 0.15s ease;
  }

  .res-need-row:hover {
    background-color: #ddeee8;
  }

  .res-need-row p {
    font-family: 'Manrope', sans-serif;
    font-weight: 500;
    font-size: 14px;
    color: #2b2b2e;
    margin: 0;
    line-height: 19.6px;
  }

  .res-need-arrow {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Usage Expectations */
  .res-usage-wrapper {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .res-usage-sublabel {
    font-family: 'Manrope', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #2b2b2e;
    margin: 0;
    line-height: 19.6px;
    white-space: nowrap;
    margin-bottom: 2px;
  }

  /* Personalised Insights */
  .res-insights-text {
    font-family: 'Manrope', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #2b2b2e;
    margin: 0;
    line-height: 19.6px;
  }

  /* Retake button */
  .guidance-btn-retake {
    background-color: transparent;
    border: none;
    color: #264653;
    text-decoration: underline;
    cursor: pointer;
    font-family: 'Manrope', sans-serif;
    align-self: flex-start;
    font-size: 14px;
    padding: 0;
  }

  @media (max-width: 900px) {
    .res-columns {
      flex-direction: column;
      gap: 32px;
    }
    .res-col-left,
    .res-col-right {
      width: 100%;
    }
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    /* Outer section */
    .guidance-quiz-section {
      padding: 64px 24px;
    }

    /* Quiz card (question flow) */
    .guidance-quiz-card {
      padding: 24px;
      border-width: 8px;
      height: auto;
      min-height: 520px;
    }

    /* Results card */
    .guidance-results-card {
      padding: 24px;
      border-width: 8px;
      gap: 24px;
    }

    /* Header */
    .guidance-quiz-header {
      gap: 16px;
      margin-bottom: 40px;
    }
    .guidance-quiz-header h2 {
      font-size: 36px;
      letter-spacing: -1px;
    }

    /* Results title — 26px, tighter tracking */
    .res-main-title {
      font-size: 26px;
      letter-spacing: -0.8px;
      line-height: 1.1;
    }

    /* Columns stack vertically with 48px gap between the two groups */
    .res-columns {
      flex-direction: column;
      gap: 48px;
    }
    .res-col-left,
    .res-col-right {
      width: 100%;
      gap: 32px;
    }

    /* Nicotine recommendation: pill goes full-width below text */
    .res-nic-row {
      flex-direction: column;
      gap: 20px;
    }
    .nic-pill {
      width: 100%;
      justify-content: center;
      text-align: center;
    }

    /* Device tagline uses olive colour on mobile */
    .res-device-tagline {
      color: #264653;
    }

    /* Needs rows — 12px gap between rows */
    .res-needs-wrapper {
      gap: 12px;
    }

    /* Question text */
    .guidance-question-text h3 {
      font-size: 28px;
      line-height: 1.2;
    }
  }
</style>

<div class="page-width container">
  <div class="guidance-quiz-section" id="GuidanceQuiz-{{ section.id }}">
    <div class="guidance-quiz-header">
      <h2>{{ section.settings.heading | escape }}</h2>
      <p>{{ section.settings.subheading | escape }}</p>
    </div>

    <!-- Quiz Card -->
    <div class="guidance-quiz-card" id="quiz-card-{{ section.id }}">
      <div id="quiz-questions-container-{{ section.id }}">
        <!-- Questions injected by JS -->
      </div>

      <div class="guidance-footer">
        <div class="guidance-progress-container">
          <div class="guidance-progress-bar-bg">
            <div class="guidance-progress-bar-fill" id="quiz-progress-{{ section.id }}" style="width: 0%"></div>
          </div>
          <p class="guidance-progress-text" id="quiz-progress-text-{{ section.id }}">Question 1 / 6</p>
        </div>

        <div class="guidance-actions">
          <button
            class="guidance-btn guidance-btn-back"
            id="quiz-btn-back-{{ section.id }}"
            onclick="prevQuestion('{{ section.id }}')"
            disabled
          >
            Back
          </button>
          <button
            class="guidance-btn guidance-btn-next"
            id="quiz-btn-next-{{ section.id }}"
            onclick="nextQuestion('{{ section.id }}')"
          >
            Next
          </button>
        </div>
      </div>
    </div>

    <!-- Results Card -->
    <div class="guidance-results-card" id="results-card-{{ section.id }}">
      <!-- Title -->
      <p class="res-main-title">Your Recommended Setup</p>

      <!-- Two-column layout -->
      <div class="res-columns">
        <!-- LEFT COLUMN -->
        <div class="res-col-left">
          <!-- Your Recommended Devices -->
          <div class="res-section">
            <p class="res-section-label">Your Recommended Devices</p>
            <div class="res-device-text-block">
              <p class="res-device-title" id="res-category-name-{{ section.id }}"></p>
              <p class="res-device-tagline" id="res-category-tagline-{{ section.id }}"></p>
            </div>
          </div>

          <!-- Why It's Right For You -->
          <div class="res-section">
            <p class="res-section-label">Why it's right for you</p>
            <div class="res-list" id="res-why-{{ section.id }}">
              <!-- dynamically injected checkmark rows -->
            </div>
          </div>

          <!-- Your Nicotine Recommendation -->
          <div class="res-section">
            <p class="res-section-label">Your Nicotine Recommendation</p>
            <div class="res-nic-row">
              <div class="res-nic-text">
                <p class="res-nic-strength-label" id="res-nic-strength-label-{{ section.id }}"></p>
                <p class="res-nic-description" id="res-nic-message-{{ section.id }}"></p>
              </div>
              <div class="nic-pill" id="res-nic-range-{{ section.id }}"></div>
            </div>
          </div>

          <!-- Personalised Insights -->
          <div class="res-section">
            <p class="res-section-label">Personalised Insights</p>
            <div id="res-insights-{{ section.id }}">
              <!-- dynamic text paragraphs -->
            </div>
          </div>
        </div>

        <!-- RIGHT COLUMN -->
        <div class="res-col-right">
          <!-- What You'll Need -->
          <div class="res-section">
            <p class="res-section-label">What You'll Need</p>
            <div class="res-needs-wrapper">
              <p class="res-needs-sublabel" id="res-needs-sublabel-{{ section.id }}"></p>
              <div class="res-needs-div" id="res-needs-{{ section.id }}">
                <!-- dynamically injected need rows -->
              </div>
            </div>
          </div>

          <!-- Usage Expectations -->
          <div class="res-section">
            <p class="res-section-label">Usage Expectations</p>
            <div class="res-usage-wrapper">
              <p class="res-usage-sublabel" id="res-usage-sublabel-{{ section.id }}"></p>
              <div class="res-list" id="res-usage-{{ section.id }}">
                <!-- dynamically injected checkmark rows -->
              </div>
            </div>
          </div>

          <!-- Retake Quiz -->
          <button class="guidance-btn-retake" onclick="restartQuiz('{{ section.id }}')">Retake Quiz</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const collectionImages = {
    'closed': {% if collections['closed-systems'].image %}"{{ collections['closed-systems'].image | image_url: width: 500 }}"{% else %}null{% endif %},
    'hybrid': {% if collections['hybrid-systems'].image %}"{{ collections['hybrid-systems'].image | image_url: width: 500 }}"{% else %}null{% endif %},
    'open': {% if collections['open-tank-systems'].image %}"{{ collections['open-tank-systems'].image | image_url: width: 500 }}"{% else %}null{% endif %},
    'nrt': {% if collections['nrt'].image %}"{{ collections['nrt'].image | image_url: width: 500 }}"{% else %}null{% endif %}
  };

  const quizData = [
    {
      id: 'q1',
      question: 'How many cigarettes do you smoke per day?',
      subtext: 'This helps determine your nicotine strength',
      options: [
        { text: '1–5', value: '1-5' },
        { text: '5–10', value: '5-10' },
        { text: '10–20', value: '10-20' },
        { text: '20+', value: '20+' },
        { text: 'None - I am already using nicotine replacement therapy', value: 'nrt' },
      ],
    },
    {
      id: 'q2',
      question: 'How would you prefer to manage nicotine cravings?',
      subtext: '',
      options: [
        { text: "I'd like a vaping device", value: 'vaping' },
        { text: "I'm open to either vaping or nicotine replacement products", value: 'either' },
        { text: "I'd prefer not to use a vaping device", value: 'not_vape' },
      ],
    },
    {
      id: 'q3',
      question: 'What matters most to you?',
      subtext: '',
      options: [
        { text: 'Easiest option - no setup required', value: 'easiest' },
        { text: 'Feels closest to a cigarette', value: 'closest' },
        { text: 'More control & customisation', value: 'control' },
      ],
    },
    {
      id: 'q4',
      question: 'How do you prefer to inhale?',
      subtext: '',
      options: [
        { text: 'Tight draw (like a cigarette)', value: 'tight' },
        { text: 'Airy draw (more vapour)', value: 'airy' },
        { text: 'Not sure', value: 'notsure' },
      ],
    },
    {
      id: 'q5',
      question: 'Would you prefer to refill liquid yourself?',
      subtext: '',
      options: [
        { text: 'No, keep it simple', value: 'no' },
        { text: 'Yes, I want to refill', value: 'yes' },
        { text: "I'd like both options", value: 'both' },
      ],
    },
    {
      id: 'q6',
      question: "What's your experience level?",
      subtext: '',
      options: [
        { text: 'Beginner', value: 'beginner' },
        { text: 'Some experience', value: 'some' },
        { text: 'Experienced', value: 'experienced' },
      ],
    },
    {
      id: 'q7',
      question: "What's your top priority?",
      subtext: '',
      options: [
        { text: 'Quit smoking', value: 'quit' },
        { text: 'Save money', value: 'save' },
        { text: 'Better flavour / performance', value: 'flavour' },
      ],
    },
  ];

  function renderQuiz(sectionId) {
    const container = document.getElementById('quiz-questions-container-' + sectionId);
    container.innerHTML = '';

    quizData.forEach((q, index) => {
      const block = document.createElement('div');
      block.className = `guidance-question-block ${index === 0 ? 'active' : ''}`;
      block.setAttribute('data-index', index + 1);

      let optionsHtml = q.options
        .map(
          (opt, optIndex) => `
        <div class="guidance-option" onclick="selectOption(this, '${sectionId}', '${q.id}', '${opt.value}')">
          <div class="guidance-option-radio"></div>
          <p class="guidance-option-text">${opt.text}</p>
        </div>
      `
        )
        .join('');

      block.innerHTML = `
        <div class="guidance-question-text">
          <h3>${q.question}</h3>
          ${q.subtext ? `<p>${q.subtext}</p>` : ''}
        </div>
        <div class="guidance-options">
          ${optionsHtml}
        </div>
      `;
      container.appendChild(block);
    });

    updateQuizUI(sectionId);
  }

  function calculateRunningScores(answers) {
    let closed = 0,
      hybrid = 0,
      open = 0,
      nrt = 0;

    // Q2
    if (answers.q2 === 'vaping') {
      closed += 2;
      hybrid += 2;
      open += 2;
    }
    if (answers.q2 === 'either') {
      closed += 1;
      hybrid += 1;
      open += 1;
      nrt += 2;
    }
    if (answers.q2 === 'not_vape') {
      nrt += 6;
    }

    // Q3
    if (answers.q3 === 'easiest') {
      closed += 3;
      nrt += 3;
    }
    if (answers.q3 === 'closest') {
      closed += 3;
    }
    if (answers.q3 === 'control') {
      open += 3;
    }

    // Q4
    if (answers.q4 === 'tight') {
      closed += 2;
    }
    if (answers.q4 === 'airy') {
      open += 2;
    }
    if (answers.q4 === 'notsure') {
      closed += 1;
      hybrid += 1;
      nrt += 1;
    }

    // Q5
    if (answers.q5 === 'no') {
      closed += 4;
      nrt += 2;
    }
    if (answers.q5 === 'yes') {
      hybrid += 2;
      open += 2;
    }
    if (answers.q5 === 'both') hybrid += 3;

    // Q6
    if (answers.q6 === 'beginner') {
      closed += 2;
      nrt += 2;
    }
    if (answers.q6 === 'some') hybrid += 3;
    if (answers.q6 === 'experienced') open += 3;

    // Q7
    if (answers.q7 === 'quit') {
      closed += 2;
      nrt += 4;
    }
    if (answers.q7 === 'save') hybrid += 3;
    if (answers.q7 === 'flavour') open += 3;

    return { closed, hybrid, open, nrt };
  }

  function selectOption(element, sectionId, questionId, value) {
    const parent = element.closest('.guidance-options');
    const options = parent.querySelectorAll('.guidance-option');
    options.forEach((opt) => opt.classList.remove('selected'));
    element.classList.add('selected');

    // Save answers to state and sessionStorage
    window.quizState[sectionId].answers[questionId] = value;
    sessionStorage.setItem('myduke_quiz_answers', JSON.stringify(window.quizState[sectionId].answers));

    // Calculate running scores and store in sessionStorage
    const currentScores = calculateRunningScores(window.quizState[sectionId].answers);
    window.quizState[sectionId].scores = currentScores;
    sessionStorage.setItem('myduke_quiz_scores', JSON.stringify(currentScores));
  }

  document.addEventListener('DOMContentLoaded', function () {
    window.quizState = window.quizState || {};

    // Check if we have saved answers and scores
    let savedAnswers = {};
    let savedScores = { closed: 0, hybrid: 0, open: 0, nrt: 0 };
    try {
      const savedA = sessionStorage.getItem('myduke_quiz_answers');
      if (savedA) savedAnswers = JSON.parse(savedA);

      const savedS = sessionStorage.getItem('myduke_quiz_scores');
      if (savedS) savedScores = JSON.parse(savedS);
    } catch (e) {}

    window.quizState['{{ section.id }}'] = {
      currentStep: 1,
      totalSteps: quizData.length,
      answers: savedAnswers,
      scores: savedScores,
    };

    renderQuiz('{{ section.id }}');

    // If we have saved answers, pre-select them
    setTimeout(() => {
      if (Object.keys(savedAnswers).length > 0) {
        const container = document.getElementById('quiz-questions-container-{{ section.id }}');
        quizData.forEach((q, index) => {
          const val = savedAnswers[q.id];
          if (val) {
            const block = container.querySelector(`[data-index="${index + 1}"]`);
            if (block) {
              const options = block.querySelectorAll('.guidance-option');
              const idx = q.options.findIndex((o) => o.value === val);
              if (idx !== -1 && options[idx]) {
                options[idx].classList.add('selected');
              }
            }
          }
        });
      }
    }, 100);
  });

  function updateQuizUI(sectionId) {
    const state = window.quizState[sectionId];
    if (!state) return;

    const container = document.getElementById('quiz-questions-container-' + sectionId);
    const blocks = container.querySelectorAll('.guidance-question-block');

    blocks.forEach((block) => {
      if (parseInt(block.getAttribute('data-index')) === state.currentStep) {
        block.classList.add('active');
      } else {
        block.classList.remove('active');
      }
    });

    const progressFill = document.getElementById('quiz-progress-' + sectionId);
    const progressText = document.getElementById('quiz-progress-text-' + sectionId);

    if (state.totalSteps > 0) {
      const percentage = (state.currentStep / state.totalSteps) * 100;
      progressFill.style.width = percentage + '%';
      progressText.innerText = 'Question ' + state.currentStep + ' / ' + state.totalSteps;
    }

    const backBtn = document.getElementById('quiz-btn-back-' + sectionId);
    const nextBtn = document.getElementById('quiz-btn-next-' + sectionId);

    if (state.currentStep === 1) {
      backBtn.disabled = true;
      backBtn.classList.remove('active');
    } else {
      backBtn.disabled = false;
      backBtn.classList.add('active');
    }

    if (state.currentStep === state.totalSteps) {
      nextBtn.innerText = 'Show Results';
    } else {
      nextBtn.innerText = 'Next';
    }
  }

  function prevQuestion(sectionId) {
    const state = window.quizState[sectionId];
    if (state && state.currentStep > 1) {
      state.currentStep--;
      updateQuizUI(sectionId);
    }
  }

  function nextQuestion(sectionId) {
    const state = window.quizState[sectionId];
    if (state) {
      const container = document.getElementById('quiz-questions-container-' + sectionId);
      const activeBlock = container.querySelector('.guidance-question-block.active');

      if (activeBlock) {
        const selectedOption = activeBlock.querySelector('.guidance-option.selected');
        if (!selectedOption) {
          alert('Please select an option to continue.');
          return;
        }
      }

      if (state.currentStep < state.totalSteps) {
        state.currentStep++;
        updateQuizUI(sectionId);
      } else {
        calculateResults(sectionId);
      }
    }
  }

  function calculateResults(sectionId) {
    const answers = window.quizState[sectionId].answers;
    const scores = calculateRunningScores(answers);
    const { closed, hybrid, open, nrt } = scores;

    // Determine winner
    let max = Math.max(closed, hybrid, open, nrt);
    let winners = [];
    if (closed === max) winners.push('closed');
    if (hybrid === max) winners.push('hybrid');
    if (open === max) winners.push('open');
    if (nrt === max) winners.push('nrt');

    let resultCategory = winners[0];

    // Tie Breakers (using shifted question numbers)
    if (winners.length > 1) {
      if (answers.q6 === 'beginner') {
        resultCategory = 'closed';
      } else if (answers.q5 === 'both') {
        resultCategory = 'hybrid';
      } else if (answers.q6 === 'experienced') {
        resultCategory = 'open';
      } else {
        resultCategory = 'hybrid'; // Rule 4: safest middle-ground
      }
    }

    renderResults(sectionId, resultCategory, answers);
  }

  function renderResults(sectionId, category, answers) {
    // Hide quiz, show results
    document.getElementById('quiz-card-' + sectionId).style.display = 'none';
    document.getElementById('results-card-' + sectionId).style.display = 'flex';

    // SVG icons
    const checkIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
  <path d="M8 0C6.41775 0 4.87104 0.469192 3.55544 1.34824C2.23985 2.22729 1.21447 3.47672 0.608967 4.93853C0.00346629 6.40034 -0.15496 8.00887 0.153721 9.56072C0.462403 11.1126 1.22433 12.538 2.34315 13.6569C3.46197 14.7757 4.88743 15.5376 6.43928 15.8463C7.99113 16.155 9.59966 15.9965 11.0615 15.391C12.5233 14.7855 13.7727 13.7602 14.6518 12.4446C15.5308 11.129 16 9.58225 16 8C16 5.87827 15.1571 3.84344 13.6569 2.34315C12.1566 0.842855 10.1217 0 8 0ZM12.62 5.46667L8.05334 11.66C8.0002 11.7324 7.93297 11.7933 7.8557 11.8391C7.77843 11.8849 7.6927 11.9146 7.60366 11.9265C7.51462 11.9383 7.42411 11.932 7.33756 11.908C7.25101 11.884 7.17021 11.8427 7.1 11.7867L3.84 9.18C3.77152 9.12499 3.71458 9.05698 3.67247 8.97989C3.63035 8.9028 3.60389 8.81814 3.59459 8.73079C3.5853 8.64344 3.59336 8.55511 3.61832 8.47088C3.64327 8.38666 3.68463 8.30819 3.74 8.24C3.85078 8.10557 4.00977 8.01984 4.18296 8.00115C4.35614 7.98247 4.52976 8.0323 4.66667 8.14L7.38667 10.3133L11.5467 4.66667C11.6516 4.5261 11.8078 4.43257 11.9813 4.40636C12.1547 4.38015 12.3315 4.42338 12.4733 4.52667C12.5453 4.57824 12.6064 4.64364 12.6528 4.71906C12.6993 4.79447 12.7302 4.87839 12.7439 4.9659C12.7575 5.05341 12.7536 5.14277 12.7323 5.22875C12.7111 5.31473 12.6729 5.39561 12.62 5.46667Z" fill="#BFDBCF"/>
</svg>`;
    const arrowIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22" fill="none">
  <path d="M3.4375 11L18.5625 11" stroke="#218380" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  <path d="M12.375 17.1875L18.5625 11L12.375 4.8125" stroke="#218380" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
</svg>`;

    // 1. Setup
    let title = '',
      tagline = '',
      link = '',
      why = [],
      needs = [],
      usage = [];

    if (category === 'closed') {
      title = 'Closed System';
      tagline = 'Simple, reliable and closest to smoking.';
      link = '/collections/closed-systems';
      why = [
        'No maintenance or refilling required',
        'Closest experience to smoking a cigarette',
        'Pre-filled pods — simply click and go',
        'Ideal for beginners switching from smoking',
      ];
      needs = ['Closed System Device', 'Pre-Filled Pods', 'USB Charging Cable (if applicable)'];
      usage = ['Approximately 2–4 pods per week depending on usage', 'Minimal maintenance required', 'Replace pods when empty'];
    } else if (category === 'hybrid') {
      title = 'Hybrid System';
      tagline = 'The best of both worlds — flexibility meets simplicity.';
      link = '/collections/hybrid-systems';
      why = [
        'Refillable pod system',
        'More flavour flexibility',
        'Lower ongoing costs',
        'Great balance of simplicity and performance',
      ];
      needs = ['Refillable Pod Device', 'E-Liquid (your chosen flavour)', 'Replacement Pods', 'USB Charging Cable'];
      usage = ['Refill pods as required', 'Replace pods periodically', 'Moderate maintenance required'];
    } else if (category === 'open') {
      title = 'Open Tank System';
      tagline = 'Maximum control and customisation for experienced users.';
      link = '/collections/open-tank-systems';
      why = [
        'Maximum customisation',
        'Greater flavour performance',
        'Larger vapour production',
        'Adjustable airflow and settings',
        'Designed for experienced users',
      ];
      needs = ['Open Tank Device', 'E-Liquid', 'Replacement Coils', 'USB Charging Cable'];
      usage = ['Refill tank regularly', 'Replace coils periodically', 'More maintenance than pod systems'];
    } else if (category === 'nrt') {
      title = 'Nicotine Replacement Therapy';
      tagline = 'A clinically proven, smoke-free approach to managing cravings.';
      link = '/collections/nrt';
      why = [
        'Clinically proven methods to manage cravings',
        'No vaping or inhalation required',
        'Easy to use in areas where vaping is restricted',
        'A measured approach to stepping down nicotine intake',
      ];
      needs = ['NRT Patches, Gums, or Lozenges'];
      usage = ['Use daily as directed', 'Follow the recommended step-down schedule'];
    }

    document.getElementById('res-category-name-' + sectionId).innerText = title;
    document.getElementById('res-category-tagline-' + sectionId).innerText = tagline;

    document.getElementById('res-why-' + sectionId).innerHTML = why
      .map(
        (w) => `
      <div class="res-list-item">
        <div class="res-list-icon">${checkIcon}</div>
        <p>${w}</p>
      </div>`
      )
      .join('');

    document.getElementById('res-needs-' + sectionId).innerHTML = needs
      .map(
        (w) => `
      <a href="${link}" class="res-need-row">
        <p>${w}</p>
        <div class="res-need-arrow">${arrowIcon}</div>
      </a>`
      )
      .join('');

    // Set the "What You'll Need" sub-label (category name)
    const needsSublabelEl = document.getElementById('res-needs-sublabel-' + sectionId);
    if (needsSublabelEl) needsSublabelEl.innerText = title;

    // Set the "Usage Expectations" sub-label
    const usageSublabelEl = document.getElementById('res-usage-sublabel-' + sectionId);
    if (usageSublabelEl) {
      // Derive a nicotine strength label for the usage sub-label
      let usageStrengthLabel = '';
      if (answers.q1 === '1-5') usageStrengthLabel = 'Low Strength Nicotine';
      else if (answers.q1 === '5-10') usageStrengthLabel = 'Medium Strength Nicotine';
      else if (answers.q1 === '10-20' || answers.q1 === 'nrt') usageStrengthLabel = 'High Strength Nicotine';
      else if (answers.q1 === '20+') usageStrengthLabel = 'Extra Strong Nicotine';
      usageSublabelEl.innerText = usageStrengthLabel;
    }

    document.getElementById('res-usage-' + sectionId).innerHTML = usage
      .map(
        (w) => `
      <div class="res-list-item">
        <div class="res-list-icon">${checkIcon}</div>
        <p>${w}</p>
      </div>`
      )
      .join('');

    // 3. Nicotine Strength
    let nicRange = '', nicStrengthLabel = '', nicMsgTail = '';
    if (answers.q1 === '1-5') {
      nicRange = '5–10mg Nicotine Salts';
      nicStrengthLabel = 'Low Strength Nicotine';
      nicMsgTail = 'A lower nicotine strength is typically suitable for lighter smokers.';
    } else if (answers.q1 === '5-10') {
      nicRange = '10–20mg Nicotine Salts';
      nicStrengthLabel = 'Medium Strength Nicotine';
      nicMsgTail = 'A medium nicotine strength is often preferred by moderate smokers.';
    } else if (answers.q1 === '10-20' || answers.q1 === 'nrt') {
      nicRange = '20–30mg Nicotine Salts';
      nicStrengthLabel = 'High Strength Nicotine';
      nicMsgTail = 'This strength is commonly used by customers transitioning from regular smoking.';
    } else if (answers.q1 === '20+') {
      nicRange = '30–50mg Nicotine Salts';
      nicStrengthLabel = 'Extra Strong Nicotine';
      nicMsgTail = 'A higher nicotine strength may help manage cravings during the transition.';
    }

    document.getElementById('res-nic-range-' + sectionId).innerText = nicRange;
    const nicStrengthLabelEl = document.getElementById('res-nic-strength-label-' + sectionId);
    if (nicStrengthLabelEl) nicStrengthLabelEl.innerText = nicStrengthLabel;
    document.getElementById('res-nic-message-' + sectionId).innerText = nicMsgTail;

    // 6. Insights — driven by quiz answers
    let insights = [];
    if (answers.q2 === 'not_vape')
      insights.push('You indicated that you prefer not to use a vaping device.');
    if (answers.q2 === 'either')
      insights.push('You indicated that you are open to managing cravings without a vaping device.');
    if (answers.q3 === 'easiest')
      insights.push("You indicated that simplicity is important, so we've prioritised ease of use in your recommendation.");
    if (answers.q3 === 'closest')
      insights.push('You indicated that a familiar cigarette-style experience is important to you.');
    if (answers.q3 === 'control')
      insights.push('You indicated that greater control and flexibility are important to you.');
    if (answers.q4 === 'tight')
      insights.push('You prefer a tighter draw similar to a traditional cigarette.');
    if (answers.q4 === 'airy')
      insights.push('You prefer a more open draw with increased vapour production.');
    if (answers.q4 === 'notsure')
      insights.push("If you're unsure, most customers transitioning from smoking start with a tighter draw style.");
    if (answers.q5 === 'no')
      insights.push('You prefer a device that requires no refilling or maintenance.');
    if (answers.q5 === 'yes')
      insights.push('You are comfortable refilling your device yourself.');
    if (answers.q7 === 'quit')
      insights.push('Your primary goal is to quit smoking — your recommendation supports a structured step-down approach.');
    if (answers.q7 === 'save')
      insights.push('Saving money is a priority for you, so we have factored cost-efficiency into your recommendation.');
    if (answers.q7 === 'flavour')
      insights.push('Better flavour and performance matter to you, reflected in your recommended setup.');

    const insightsEl = document.getElementById('res-insights-' + sectionId);
    if (insightsEl) {
      insightsEl.innerHTML = insights
        .map((i) => `<p class="res-insights-text" style="margin-bottom: 8px;">${i}</p>`)
        .join('');
    }
  }

  function restartQuiz(sectionId) {
    sessionStorage.removeItem('myduke_quiz_answers');
    sessionStorage.removeItem('myduke_quiz_scores');
    window.quizState[sectionId].answers = {};
    window.quizState[sectionId].scores = { closed: 0, hybrid: 0, open: 0, nrt: 0 };
    window.quizState[sectionId].currentStep = 1;

    document.getElementById('results-card-' + sectionId).style.display = 'none';
    document.getElementById('quiz-card-' + sectionId).style.display = 'flex';

    renderQuiz(sectionId);
  }
</script>
