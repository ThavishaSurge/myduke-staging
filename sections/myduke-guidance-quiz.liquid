{% schema %}
{
  "name": "Guidance Quiz",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Need Guidance?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Take our quick quiz to find out which nicotine strength is right for you."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fallback Background Color",
      "default": "#F4A261"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image (Optional)"
    }
  ],
  "presets": [
    {
      "name": "Guidance Quiz",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<style>
  .guidance-quiz-section, .guidance-quiz-section * {
    box-sizing: border-box;
  }

  .guidance-quiz-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    padding: 124px 10px;
    position: relative;
    width: 100%;
    background-color: {{ section.settings.background_color }};
    {% if section.settings.background_image %}
      background-image: url('{{ section.settings.background_image | image_url: width: 2000 }}');
      background-size: cover;
      background-position: center;
    {% else %}
      /* Placeholder wavy gradient if no image */
      background: linear-gradient(135deg, #f4a261 0%, #e9c46a 50%, #f4a261 100%);
    {% endif %}
    font-family: 'Manrope', 'Instrument Sans', sans-serif;
  }

  .guidance-quiz-header {
    text-align: center;
    color: #111;
    margin-bottom: 60px;
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .guidance-quiz-header h2 {
    font-family: 'Manrope', sans-serif;
    font-size: 48px;
    letter-spacing: -1.8px;
    margin: 0;
    line-height: 1.1;
    color: var(--black, black);
    font-weight: 400;
  }

  .guidance-quiz-header p {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 18px;
    width: 100%;
    max-width: 669px;
    margin: 0 auto;
    line-height: 1.5;
    color: var(--black, black);
    font-variation-settings: "wdth" 100;
  }

  .guidance-quiz-card, .guidance-results-card {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 16px solid rgba(255, 255, 255, 0.2);
    background-clip: padding-box;
    width: 100%;
    max-width: 631px;
    padding: 48px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    z-index: 2;
  }

  .guidance-results-card {
    max-width: 800px; /* Slightly wider for results */
    display: none; /* Hidden initially */
    gap: 32px;
  }

  .guidance-question-text {
    color: #264653;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .guidance-question-text h3 {
    font-family: 'Manrope', sans-serif;
    font-size: 31.9px;
    letter-spacing: -0.958px;
    margin: 0;
    line-height: 35.11px;
    font-weight: 400;
  }

  .guidance-question-text p {
    font-family: 'Manrope', sans-serif;
    font-size: 18px;
    margin: 0;
    line-height: 25.2px;
  }

  .guidance-options {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: auto;
    margin-top: 40px;
  }

  .guidance-option {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px;
    background-color: #edf3f0;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .guidance-option:hover {
    background-color: #e2ebe7;
  }

  .guidance-option.selected {
    background-color: #218380;
  }

  .guidance-option.selected .guidance-option-text {
    color: #f7f8f8;
  }

  .guidance-option-radio {
    width: 13px;
    height: 13px;
    border-radius: 50%;
    border: 2px solid #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .guidance-option.selected .guidance-option-radio {
    border-color: #fff;
  }

  .guidance-option-radio::after {
    content: '';
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: transparent;
  }

  .guidance-option.selected .guidance-option-radio::after {
    background-color: #264653;
  }

  .guidance-option-text {
    font-family: 'Manrope', sans-serif;
    font-size: 14px;
    color: #264653;
    margin: 0;
    font-weight: 400;
    line-height: 1.4;
  }

  .guidance-footer {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-top: 60px;
  }

  .guidance-progress-container {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .guidance-progress-bar-bg {
    width: 100%;
    height: 7px;
    background-color: rgba(33, 131, 128, 0.15);
  }

  .guidance-progress-bar-fill {
    height: 100%;
    background-color: #264653;
    transition: width 0.3s ease;
  }

  .guidance-progress-text {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    text-transform: uppercase;
    color: #264653;
    font-weight: 500;
    margin: 0;
    line-height: 1;
  }

  .guidance-actions {
    display: flex;
    gap: 8px;
    width: 100%;
  }

  .guidance-btn {
    flex: 1;
    min-height: 40px;
    padding: 9.5px 36px;
    font-size: 14px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s ease;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }

  .guidance-btn-back {
    background-color: #218380;
    color: white;
    opacity: 0.2;
    cursor: not-allowed;
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 500;
    text-transform: capitalize;
  }

  .guidance-btn-back.active {
    opacity: 1;
    cursor: pointer;
  }

  .guidance-btn-next, .guidance-btn-shop {
    background-color: transparent;
    border: 1px solid #218380;
    color: #218380;
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
  }

  .guidance-btn-next:hover, .guidance-btn-shop:hover {
    background-color: rgba(33, 131, 128, 0.05);
  }

  .guidance-btn-shop {
    background-color: #218380;
    color: white;
    margin-top: 16px;
  }

  .guidance-btn-shop:hover {
    background-color: #1a6b68;
    color: white;
  }

  .guidance-btn-retake {
    background-color: transparent;
    border: none;
    color: #264653;
    text-decoration: underline;
    margin-top: 16px;
  }

  .guidance-question-block {
    display: none;
    animation: fadeIn 0.4s ease forwards;
    height: 100%;
  }

  .guidance-question-block.active {
    display: flex;
    flex-direction: column;
  }

  /* Results Styling */
  .result-section {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-bottom: 24px;
    border-bottom: 1px solid #e0dacf;
  }

  .result-section:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .result-section h4 {
    font-family: 'Manrope', sans-serif;
    font-size: 24px;
    color: #264653;
    margin: 0;
    font-weight: 600;
  }

  .result-section h5 {
    font-family: 'Manrope', sans-serif;
    font-size: 18px;
    color: #218380;
    margin: 0;
    font-weight: 500;
  }

  .result-section p, .result-section ul {
    font-family: 'Manrope', sans-serif;
    font-size: 16px;
    color: #4a4a4a;
    margin: 0;
    line-height: 1.5;
  }

  .result-section ul {
    padding-left: 20px;
  }

  .result-section li {
    margin-bottom: 8px;
  }

  .result-category-card {
    background: #edf3f0;
    padding: 24px;
    border-radius: 8px;
    text-align: center;
    margin-top: 12px;
  }

  .result-category-card h3 {
    margin: 0 0 8px 0;
    color: #264653;
    font-family: 'Manrope', sans-serif;
    font-size: 28px;
  }

  .result-category-card p {
    color: #264653;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .guidance-quiz-section {
      padding: 40px 16px;
    }
    .guidance-quiz-header {
      gap: 16px;
      margin-bottom: 40px;
    }
    .guidance-quiz-header h2 {
      font-size: 36px;
      letter-spacing: -1px;
    }
    .guidance-quiz-card, .guidance-results-card {
      padding: 32px 24px;
      border-width: 8px;
      height: auto;
      min-height: 600px;
    }
    .guidance-question-text h3 {
      font-size: 28px;
      line-height: 1.2;
    }
  }
</style>

<div class="page-width container">
  <div class="guidance-quiz-section" id="GuidanceQuiz-{{ section.id }}">
    <div class="guidance-quiz-header">
      <h2>{{ section.settings.heading | escape }}</h2>
      <p>{{ section.settings.subheading | escape }}</p>
    </div>

    <!-- Quiz Card -->
    <div class="guidance-quiz-card" id="quiz-card-{{ section.id }}">
      <div id="quiz-questions-container-{{ section.id }}">
        <!-- Questions injected by JS -->
      </div>

      <div class="guidance-footer">
        <div class="guidance-progress-container">
          <div class="guidance-progress-bar-bg">
            <div class="guidance-progress-bar-fill" id="quiz-progress-{{ section.id }}" style="width: 0%"></div>
          </div>
          <p class="guidance-progress-text" id="quiz-progress-text-{{ section.id }}">Question 1 / 6</p>
        </div>

        <div class="guidance-actions">
          <button
            class="guidance-btn guidance-btn-back"
            id="quiz-btn-back-{{ section.id }}"
            onclick="prevQuestion('{{ section.id }}')"
            disabled
          >
            Back
          </button>
          <button
            class="guidance-btn guidance-btn-next"
            id="quiz-btn-next-{{ section.id }}"
            onclick="nextQuestion('{{ section.id }}')"
          >
            Next
          </button>
        </div>
      </div>
    </div>

    <!-- Results Card -->
    <div class="guidance-results-card" id="results-card-{{ section.id }}">
      <div class="result-section">
        <h4>Your Recommended Setup</h4>
        <div class="result-category-card">
          <h3 id="res-category-name-{{ section.id }}">Category</h3>
          <p id="res-category-desc-{{ section.id }}">Description</p>
          <a href="#" id="res-category-link-{{ section.id }}" class="guidance-btn guidance-btn-shop"
            >Shop Recommended Products</a
          >
        </div>
      </div>

      <div class="result-section">
        <h4>Why It's Right For You</h4>
        <ul id="res-why-{{ section.id }}"></ul>
      </div>

      <div class="result-section">
        <h4>Nicotine Recommendation</h4>
        <h5 id="res-nic-strength-{{ section.id }}">Strength</h5>
        <p id="res-nic-range-{{ section.id }}"><strong>Range:</strong> <span></span></p>
        <p id="res-nic-message-{{ section.id }}"></p>
      </div>

      <div class="result-section">
        <h4>What You'll Need</h4>
        <ul id="res-needs-{{ section.id }}"></ul>
      </div>

      <div class="result-section">
        <h4>Usage Expectations</h4>
        <ul id="res-usage-{{ section.id }}"></ul>
      </div>

      <div class="result-section">
        <h4>Personalised Insights</h4>
        <div id="res-insights-{{ section.id }}"></div>
      </div>

      <button class="guidance-btn-retake" onclick="restartQuiz('{{ section.id }}')">Retake Quiz</button>
    </div>
  </div>
</div>

<script>
  const quizData = [
    {
      id: 'q1',
      question: 'How many cigarettes do you smoke per day?',
      subtext: 'This helps determine your nicotine strength',
      options: [
        { text: '1–5', value: '1-5' },
        { text: '5–10', value: '5-10' },
        { text: '10–20', value: '10-20' },
        { text: '20+', value: '20+' },
        { text: 'None - I am already using nicotine replacement therapy (NRT)', value: 'nrt' },
      ],
    },
    {
      id: 'q2',
      question: 'How would you prefer to manage nicotine cravings?',
      subtext: '',
      options: [
        { text: "I'd like a vaping device", value: 'vaping' },
        { text: "I'm open to either vaping or nicotine replacement products", value: 'either' },
        { text: "I'd prefer not to use a vaping device", value: 'not_vape' },
      ],
    },
    {
      id: 'q3',
      question: 'What matters most to you?',
      subtext: '',
      options: [
        { text: 'Easiest option (no setup)', value: 'easiest' },
        { text: 'Feels closest to a cigarette', value: 'closest' },
        { text: 'More control & customisation', value: 'control' },
      ],
    },
    {
      id: 'q4',
      question: 'How do you prefer to inhale?',
      subtext: '',
      options: [
        { text: 'Tight draw (like a cigarette)', value: 'tight' },
        { text: 'Airy draw (more vapour)', value: 'airy' },
        { text: 'Not sure', value: 'notsure' },
      ],
    },
    {
      id: 'q5',
      question: 'Do you want to refill the liquid yourself?',
      subtext: '',
      options: [
        { text: 'No, keep it simple', value: 'no' },
        { text: 'Yes, I want to refill', value: 'yes' },
        { text: "I'd like both options", value: 'both' },
      ],
    },
    {
      id: 'q6',
      question: "What's your experience level?",
      subtext: '',
      options: [
        { text: 'Beginner', value: 'beginner' },
        { text: 'Some experience', value: 'some' },
        { text: 'Experienced', value: 'experienced' },
      ],
    },
    {
      id: 'q7',
      question: "What's your top priority?",
      subtext: '',
      options: [
        { text: 'Quit smoking', value: 'quit' },
        { text: 'Save money', value: 'save' },
        { text: 'Better flavour / performance', value: 'flavour' },
      ],
    },
  ];

  function renderQuiz(sectionId) {
    const container = document.getElementById('quiz-questions-container-' + sectionId);
    container.innerHTML = '';

    quizData.forEach((q, index) => {
      const block = document.createElement('div');
      block.className = `guidance-question-block ${index === 0 ? 'active' : ''}`;
      block.setAttribute('data-index', index + 1);

      let optionsHtml = q.options
        .map(
          (opt, optIndex) => `
        <div class="guidance-option" onclick="selectOption(this, '${sectionId}', '${q.id}', '${opt.value}')">
          <div class="guidance-option-radio"></div>
          <p class="guidance-option-text">${opt.text}</p>
        </div>
      `
        )
        .join('');

      block.innerHTML = `
        <div class="guidance-question-text">
          <h3>${q.question}</h3>
          ${q.subtext ? `<p>${q.subtext}</p>` : ''}
        </div>
        <div class="guidance-options">
          ${optionsHtml}
        </div>
      `;
      container.appendChild(block);
    });

    updateQuizUI(sectionId);
  }

  function calculateRunningScores(answers) {
    let closed = 0,
      hybrid = 0,
      open = 0,
      nrt = 0;

    // Q2
    if (answers.q2 === 'vaping') {
      closed += 2;
      hybrid += 2;
      open += 2;
    }
    if (answers.q2 === 'either') {
      closed += 1;
      hybrid += 1;
      open += 1;
      nrt += 2;
    }
    if (answers.q2 === 'not_vape') {
      nrt += 6;
    }

    // Q3
    if (answers.q3 === 'easiest') {
      closed += 3;
      nrt += 3;
    }
    if (answers.q3 === 'closest') {
      closed += 3;
    }
    if (answers.q3 === 'control') {
      open += 3;
    }

    // Q4
    if (answers.q4 === 'tight') {
      closed += 2;
    }
    if (answers.q4 === 'airy') {
      open += 2;
    }
    if (answers.q4 === 'notsure') {
      closed += 1;
      hybrid += 1;
      nrt += 1;
    }

    // Q5
    if (answers.q5 === 'no') {
      closed += 4;
      nrt += 2;
    }
    if (answers.q5 === 'yes') {
      hybrid += 2;
      open += 2;
    }
    if (answers.q5 === 'both') hybrid += 3;

    // Q6
    if (answers.q6 === 'beginner') {
      closed += 2;
      nrt += 2;
    }
    if (answers.q6 === 'some') hybrid += 3;
    if (answers.q6 === 'experienced') open += 3;

    // Q7
    if (answers.q7 === 'quit') {
      closed += 2;
      nrt += 4;
    }
    if (answers.q7 === 'save') hybrid += 3;
    if (answers.q7 === 'flavour') open += 3;

    return { closed, hybrid, open, nrt };
  }

  function selectOption(element, sectionId, questionId, value) {
    const parent = element.closest('.guidance-options');
    const options = parent.querySelectorAll('.guidance-option');
    options.forEach((opt) => opt.classList.remove('selected'));
    element.classList.add('selected');

    // Save answers to state and sessionStorage
    window.quizState[sectionId].answers[questionId] = value;
    sessionStorage.setItem('myduke_quiz_answers', JSON.stringify(window.quizState[sectionId].answers));

    // Calculate running scores and store in sessionStorage
    const currentScores = calculateRunningScores(window.quizState[sectionId].answers);
    window.quizState[sectionId].scores = currentScores;
    sessionStorage.setItem('myduke_quiz_scores', JSON.stringify(currentScores));
  }

  document.addEventListener('DOMContentLoaded', function () {
    window.quizState = window.quizState || {};

    // Check if we have saved answers and scores
    let savedAnswers = {};
    let savedScores = { closed: 0, hybrid: 0, open: 0, nrt: 0 };
    try {
      const savedA = sessionStorage.getItem('myduke_quiz_answers');
      if (savedA) savedAnswers = JSON.parse(savedA);

      const savedS = sessionStorage.getItem('myduke_quiz_scores');
      if (savedS) savedScores = JSON.parse(savedS);
    } catch (e) {}

    window.quizState['{{ section.id }}'] = {
      currentStep: 1,
      totalSteps: quizData.length,
      answers: savedAnswers,
      scores: savedScores,
    };

    renderQuiz('{{ section.id }}');

    // If we have saved answers, pre-select them
    setTimeout(() => {
      if (Object.keys(savedAnswers).length > 0) {
        const container = document.getElementById('quiz-questions-container-{{ section.id }}');
        quizData.forEach((q, index) => {
          const val = savedAnswers[q.id];
          if (val) {
            const block = container.querySelector(`[data-index="${index + 1}"]`);
            if (block) {
              const options = block.querySelectorAll('.guidance-option');
              const idx = q.options.findIndex((o) => o.value === val);
              if (idx !== -1 && options[idx]) {
                options[idx].classList.add('selected');
              }
            }
          }
        });
      }
    }, 100);
  });

  function updateQuizUI(sectionId) {
    const state = window.quizState[sectionId];
    if (!state) return;

    const container = document.getElementById('quiz-questions-container-' + sectionId);
    const blocks = container.querySelectorAll('.guidance-question-block');

    blocks.forEach((block) => {
      if (parseInt(block.getAttribute('data-index')) === state.currentStep) {
        block.classList.add('active');
      } else {
        block.classList.remove('active');
      }
    });

    const progressFill = document.getElementById('quiz-progress-' + sectionId);
    const progressText = document.getElementById('quiz-progress-text-' + sectionId);

    if (state.totalSteps > 0) {
      const percentage = (state.currentStep / state.totalSteps) * 100;
      progressFill.style.width = percentage + '%';
      progressText.innerText = 'Question ' + state.currentStep + ' / ' + state.totalSteps;
    }

    const backBtn = document.getElementById('quiz-btn-back-' + sectionId);
    const nextBtn = document.getElementById('quiz-btn-next-' + sectionId);

    if (state.currentStep === 1) {
      backBtn.disabled = true;
      backBtn.classList.remove('active');
    } else {
      backBtn.disabled = false;
      backBtn.classList.add('active');
    }

    if (state.currentStep === state.totalSteps) {
      nextBtn.innerText = 'Show Results';
    } else {
      nextBtn.innerText = 'Next';
    }
  }

  function prevQuestion(sectionId) {
    const state = window.quizState[sectionId];
    if (state && state.currentStep > 1) {
      state.currentStep--;
      updateQuizUI(sectionId);
    }
  }

  function nextQuestion(sectionId) {
    const state = window.quizState[sectionId];
    if (state) {
      const container = document.getElementById('quiz-questions-container-' + sectionId);
      const activeBlock = container.querySelector('.guidance-question-block.active');

      if (activeBlock) {
        const selectedOption = activeBlock.querySelector('.guidance-option.selected');
        if (!selectedOption) {
          alert('Please select an option to continue.');
          return;
        }
      }

      if (state.currentStep < state.totalSteps) {
        state.currentStep++;
        updateQuizUI(sectionId);
      } else {
        calculateResults(sectionId);
      }
    }
  }

  function calculateResults(sectionId) {
    const answers = window.quizState[sectionId].answers;
    const scores = calculateRunningScores(answers);
    const { closed, hybrid, open, nrt } = scores;

    // Determine winner
    let max = Math.max(closed, hybrid, open, nrt);
    let winners = [];
    if (closed === max) winners.push('closed');
    if (hybrid === max) winners.push('hybrid');
    if (open === max) winners.push('open');
    if (nrt === max) winners.push('nrt');

    let resultCategory = winners[0];

    // Tie Breakers (using shifted question numbers)
    if (winners.length > 1) {
      if (answers.q6 === 'beginner') {
        resultCategory = 'closed';
      } else if (answers.q5 === 'both') {
        resultCategory = 'hybrid';
      } else if (answers.q6 === 'experienced') {
        resultCategory = 'open';
      } else {
        resultCategory = 'hybrid'; // Rule 4: safest middle-ground
      }
    }

    renderResults(sectionId, resultCategory, answers);
  }

  function renderResults(sectionId, category, answers) {
    // Hide quiz, show results
    document.getElementById('quiz-card-' + sectionId).style.display = 'none';
    document.getElementById('results-card-' + sectionId).style.display = 'flex';

    // 1. Setup
    let title = '',
      subtitle = '',
      link = '',
      why = [],
      needs = [],
      usage = [];

    if (category === 'closed') {
      title = 'Closed Systems';
      subtitle = 'Simple, reliable and closest to smoking.';
      link = '/collections/closed-systems';
      why = [
        'No maintenance or refilling required',
        'Closest experience to smoking a cigarette',
        'Pre-filled pods - simply click and go',
        'Ideal for beginners switching from smoking',
      ];
      needs = ['Closed System Device', 'Pre-Filled Pods', 'USB Charging Cable (if applicable)'];
      usage = [
        'Approximately 2–4 pods per week depending on usage',
        'Minimal maintenance required',
        'Replace pods when empty',
      ];
    } else if (category === 'hybrid') {
      title = 'Hybrid Systems';
      subtitle = 'Flexible, refillable and easy to use.';
      link = '/collections/hybrid-systems';
      why = [
        'Refillable pod system',
        'More flavour flexibility',
        'Lower ongoing costs',
        'Easy to use and maintain',
        'Great balance of simplicity and performance',
      ];
      needs = ['Refillable Pod Device', 'E-Liquid', 'Replacement Pods', 'USB Charging Cable'];
      usage = ['Refill pods as required', 'Replace pods periodically', 'Moderate maintenance required'];
    } else if (category === 'open') {
      title = 'Open Tank Systems';
      subtitle = 'Maximum flavour, control and performance.';
      link = '/collections/open-tank-systems';
      why = [
        'Maximum customisation',
        'Greater flavour performance',
        'Larger vapour production',
        'Adjustable airflow and settings',
        'Designed for experienced users',
      ];
      needs = ['Open Tank Device', 'E-Liquid', 'Replacement Coils', 'USB Charging Cable'];
      usage = ['Refill tank regularly', 'Replace coils periodically', 'More maintenance than pod systems'];
    } else if (category === 'nrt') {
      title = 'Nicotine Replacement Therapy (NRT)';
      subtitle = 'Manage cravings reliably without vaping.';
      link = '/collections/nrt';
      why = [
        'Clinically proven methods to manage cravings',
        'No vaping or inhalation required',
        'Easy to use in areas where vaping is restricted',
        'A measured approach to stepping down nicotine intake',
      ];
      needs = ['NRT Patches, Gums, or Lozenges'];
      usage = ['Use daily as directed', 'Follow the recommended step-down schedule'];
    }

    document.getElementById('res-category-name-' + sectionId).innerText = title;
    document.getElementById('res-category-desc-' + sectionId).innerText = subtitle;
    document.getElementById('res-category-link-' + sectionId).href = link;

    document.getElementById('res-why-' + sectionId).innerHTML = why.map((w) => `<li>${w}</li>`).join('');
    document.getElementById('res-needs-' + sectionId).innerHTML = needs.map((w) => `<li>${w}</li>`).join('');
    document.getElementById('res-usage-' + sectionId).innerHTML = usage.map((w) => `<li>${w}</li>`).join('');

    // 3. Nicotine Strength
    let nicStrength = '',
      nicRange = '',
      nicMsg = '';
    if (answers.q1 === '1-5') {
      nicStrength = 'Low Strength Nicotine';
      nicRange = '5mg–10mg Nicotine Salts';
      nicMsg = 'A lower nicotine strength is typically suitable for lighter smokers.';
    } else if (answers.q1 === '5-10') {
      nicStrength = 'Medium Strength Nicotine';
      nicRange = '10mg–20mg Nicotine Salts';
      nicMsg = 'A medium nicotine strength is often preferred by moderate smokers.';
    } else if (answers.q1 === '10-20' || answers.q1 === 'nrt') {
      nicStrength = 'Medium-High Strength Nicotine';
      nicRange = '20mg–30mg Nicotine Salts';
      nicMsg = 'This strength is commonly used by customers transitioning from regular smoking.';
    } else if (answers.q1 === '20+') {
      nicStrength = 'High Strength Nicotine';
      nicRange = '30mg–50mg Nicotine Salts';
      nicMsg = 'A higher nicotine strength may help manage cravings during the transition.';
    }

    document.getElementById('res-nic-strength-' + sectionId).innerText = nicStrength;
    document.getElementById('res-nic-range-' + sectionId).querySelector('span').innerText = nicRange;
    document.getElementById('res-nic-message-' + sectionId).innerText = nicMsg;

    // 6. Insights
    let insights = [];
    if (answers.q2 === 'not_vape' || answers.q2 === 'either')
      insights.push('You indicated that you are open to managing cravings without a vaping device.');
    if (answers.q3 === 'easiest')
      insights.push(
        "You indicated that simplicity is important, so we've prioritised ease of use in your recommendation."
      );
    if (answers.q3 === 'closest')
      insights.push('You indicated that a familiar cigarette-style experience is important to you.');
    if (answers.q3 === 'control')
      insights.push('You indicated that greater control and flexibility are important to you.');

    if (answers.q4 === 'tight') insights.push('You prefer a tighter draw similar to a traditional cigarette.');
    if (answers.q4 === 'airy') insights.push('You prefer a more open draw with increased vapour production.');
    if (answers.q4 === 'notsure')
      insights.push("If you're unsure, most customers transitioning from smoking start with a tighter draw style.");

    document.getElementById('res-insights-' + sectionId).innerHTML = insights.map((i) => `<p>${i}</p>`).join('');
  }

  function restartQuiz(sectionId) {
    sessionStorage.removeItem('myduke_quiz_answers');
    sessionStorage.removeItem('myduke_quiz_scores');
    window.quizState[sectionId].answers = {};
    window.quizState[sectionId].scores = { closed: 0, hybrid: 0, open: 0, nrt: 0 };
    window.quizState[sectionId].currentStep = 1;

    document.getElementById('results-card-' + sectionId).style.display = 'none';
    document.getElementById('quiz-card-' + sectionId).style.display = 'flex';

    renderQuiz(sectionId);
  }
</script>
