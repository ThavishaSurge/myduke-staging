<div id="custom-page-loader" class="custom-page-loader">
  
  {% if section.settings.enable_overlay %}
    <div class="loader-overlay"></div>
  {% endif %}

  <div class="loader-content">
    <div class="loader-spinner"></div>
    {% if section.settings.loading_text != blank %}
      <div class="loader-text">{{ section.settings.loading_text }}</div>
    {% endif %}
  </div>
</div>

<style>
  #custom-page-loader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: {{ section.settings.fallback_bg_color }};
    
    {% if section.settings.background_image != blank %}
      background-image: url('{{ section.settings.background_image | image_url: width: 2000 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% endif %}
    
    z-index: 999999;
    /* Hidden by default to prevent flashing. JS will switch this to flex if needed. */
    display: none; 
    justify-content: center;
    align-items: center;
    transition: opacity 0.6s ease-in-out, visibility 0.6s ease-in-out;
  }

  {% if section.settings.enable_overlay %}
  .loader-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 1; 
  }
  {% endif %}

  .loader-content {
    position: relative;
    z-index: 2; 
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    background: #ffffff1a;
    padding: 40px 60px;
    border-radius: 16px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
    backdrop-filter: blur(24px); 
    -webkit-backdrop-filter: blur(12px);
  }

  .loader-spinner {
    border: 4px solid rgba(0, 0, 0, 0.05);
    width: 50px;
    height: 50px;
    border-radius: 50%;
    border-left-color: {{ section.settings.spinner_color }};
    animation: spin 1s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  .loader-text {
    font-family: var(--font-body-family); 
    font-size: 2rem;
    font-weight: 400;
    color: {{ section.settings.text_color }};
    letter-spacing: 0.5px;
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  @media (max-width: 767px) {
      .loader-content {
        width: 90%;
      }
  }

</style>

<script>
  (function() {
    const loader = document.getElementById('custom-page-loader');
    if (!loader) return;

    // --- NEW: Check for Back/Forward button usage ---
    // If the user used the back button, hide the loader immediately and stop the script.
    const navEntries = performance.getEntriesByType("navigation");
    if (navEntries.length > 0 && navEntries[0].type === "back_forward") {
      loader.style.display = 'none';
      return; 
    }

    // 1. Get the excluded paths from the schema and format them into an array
    const excludedPathsRaw = "{{ section.settings.excluded_referrers | escape }}";
    const excludedPaths = excludedPathsRaw.split(',').map(path => path.trim()).filter(path => path !== '');
    
    // 2. Check where the user came from (for standard link clicks)
    const referrer = document.referrer;
    let shouldShowLoader = true;

    if (referrer) {
      try {
        const referrerUrl = new URL(referrer);
        
        // Only apply logic if the user is navigating within your own domain
        if (referrerUrl.hostname === window.location.hostname) {
          const referrerPath = referrerUrl.pathname;
          
          // If the previous page path matches anything in our excluded list, don't show the loader
          if (excludedPaths.some(path => referrerPath.includes(path))) {
            shouldShowLoader = false;
          }
        }
      } catch (e) {
        console.error("Invalid referrer URL");
      }
    }

    // 3. If they didn't come from an excluded page, run the loader logic
    if (shouldShowLoader) {
      loader.style.display = 'flex'; 
      
      const loaderStartTime = Date.now();
      const minimumLoadTime = 2000; 

      window.addEventListener('load', function() {
        const elapsedTime = Date.now() - loaderStartTime;
        const delay = Math.max(0, minimumLoadTime - elapsedTime);
        
        setTimeout(function() {
          loader.style.opacity = '0';
          
          setTimeout(function() {
            loader.style.visibility = 'hidden';
            loader.style.display = 'none';
          }, 600); 
        }, delay);
      });
    }
  })();

  window.addEventListener('pageshow', function(event) {
    if (event.persisted) {
      const loader = document.getElementById('custom-page-loader');
      if (loader) {
        loader.style.display = 'none';
        loader.style.opacity = '0';
        loader.style.visibility = 'hidden';
      }
    }
  });
</script>

{% schema %}
{
  "name": "Loading Screen",
  "settings": [
    {
      "type": "header",
      "content": "Behavior"
    },
    {
      "type": "textarea",
      "id": "excluded_referrers",
      "label": "Exclude Previous Pages",
      "info": "Comma-separated list of paths (e.g., /cart, /pages/about). If a user navigates to this page from one of these, the loader will not display."
    },
    {
      "type": "header",
      "content": "Visuals"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Upload a wavy graphic here to match the hero section."
    },
    {
      "type": "color",
      "id": "fallback_bg_color",
      "label": "Fallback Background Color",
      "default": "#F2F5F3",
      "info": "Shows while the image loads or if no image is selected."
    },
    {
      "type": "header",
      "content": "Background Overlay"
    },
    {
      "type": "checkbox",
      "id": "enable_overlay",
      "label": "Enable background overlay",
      "default": true,
      "info": "Adds a color tint over the background image to make the loading box pop."
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Overlay Opacity",
      "default": 10
    },
    {
      "type": "header",
      "content": "Text & Spinner"
    },
    {
      "type": "text",
      "id": "loading_text",
      "label": "Loading Text",
      "default": "Loading your products..."
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1B4332"
    },
    {
      "type": "color",
      "id": "spinner_color",
      "label": "Spinner Color",
      "default": "#226E65",
      "info": "Defaults to the teal used in the 'Shop All Products' button."
    }
  ],
  "presets": [
    {
      "name": "Loading Screen"
    }
  ]
}
{% endschema %}