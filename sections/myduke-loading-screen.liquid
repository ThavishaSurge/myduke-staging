<div id="custom-page-loader" class="custom-page-loader">
  <div class="loader-content">
    <div class="loader-spinner"></div>
    {% if section.settings.loading_text != blank %}
      <div class="loader-text">{{ section.settings.loading_text }}</div>
    {% endif %}
  </div>
</div>

<style>
  /* 1. Full-screen background wrapper */
  #custom-page-loader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: {{ section.settings.fallback_bg_color }};
    
    {% if section.settings.background_image != blank %}
      background-image: url('{{ section.settings.background_image | image_url: width: 2000 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% endif %}
    
    z-index: 999999;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: opacity 0.6s ease-in-out, visibility 0.6s ease-in-out;
  }

  /* 2. Frosted glass container for readability */
  .loader-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    background: rgba(255, 255, 255, 0.75); /* Semi-transparent white */
    padding: 40px 60px;
    border-radius: 16px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
    backdrop-filter: blur(12px); /* Creates the premium glass effect */
    -webkit-backdrop-filter: blur(12px);
  }

  /* 3. The Spinner matched to the site's teal buttons */
  .loader-spinner {
    border: 4px solid rgba(0, 0, 0, 0.05);
    width: 50px;
    height: 50px;
    border-radius: 50%;
    border-left-color: {{ section.settings.spinner_color }};
    animation: spin 1s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  /* 4. The Text matched to the site's typography */
  .loader-text {
    font-family: inherit; /* Pulls your theme's default sans-serif font */
    font-size: 1.1rem;
    font-weight: 500;
    color: {{ section.settings.text_color }};
    letter-spacing: 0.5px;
    text-transform: uppercase; /* Optional: gives a clean, modern pharmacy feel */
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
</style>

<script>
  window.addEventListener('load', function() {
    const loader = document.getElementById('custom-page-loader');
    if (loader) {
      loader.style.opacity = '0';
      setTimeout(function() {
        loader.style.visibility = 'hidden';
        loader.style.display = 'none';
      }, 600); 
    }
  });
</script>

{% schema %}
{
  "name": "Loading Screen",
  "settings": [
    {
      "type": "header",
      "content": "Visuals"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Upload a wavy graphic here to match the hero section."
    },
    {
      "type": "color",
      "id": "fallback_bg_color",
      "label": "Fallback Background Color",
      "default": "#F2F5F3",
      "info": "Shows while the image loads or if no image is selected."
    },
    {
      "type": "header",
      "content": "Text & Spinner"
    },
    {
      "type": "text",
      "id": "loading_text",
      "label": "Loading Text",
      "default": "Loading your products..."
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1B4332"
    },
    {
      "type": "color",
      "id": "spinner_color",
      "label": "Spinner Color",
      "default": "#226E65",
      "info": "Defaults to the teal used in the 'Shop All Products' button."
    }
  ],
  "presets": [
    {
      "name": "Loading Screen"
    }
  ]
}
{% endschema %}