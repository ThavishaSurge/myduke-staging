{{ 'section-content-cards.css' | asset_url | stylesheet_tag }}
{{ 'section-myduke-content-cards.css' | asset_url | stylesheet_tag }}

{% style %}
  {% render 'section-padding' %}
  {% render 'section-margin' %}
{% endstyle %}

<div class="myduke-cc color-{{ section.settings.color_scheme }} section-{{ section.id }}-margin">

  {%- comment -%} ── Header ── {%- endcomment -%}
  {%- if section.settings.subheading != blank or section.settings.heading != blank -%}
    <div class="myduke-cc__header">
      {%- if section.settings.subheading != blank -%}
        <p class="myduke-cc__eyebrow">{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <{{ section.settings.heading_tag }} class="myduke-cc__heading">
          {{ section.settings.heading }}
        </{{ section.settings.heading_tag }}>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── Cards grid ── {%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <div class="myduke-cc__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          case forloop.index
            when 1
              assign icon_color = '#218380'
            when 2
              assign icon_color = '#e67e22'
            when 3
              assign icon_color = '#e07a5f'
            else
              assign icon_color = '#264653'
          endcase
        -%}

        <div class="myduke-cc__card" {{ block.shopify_attributes }}>

          {%- comment -%} Step number {%- endcomment -%}
          <div class="myduke-cc__number" aria-hidden="true">
            <span>{% if forloop.index <= 9 %}0{% endif %}{{ forloop.index }}</span>
          </div>

          {%- comment -%} Card inner content {%- endcomment -%}
          <div class="myduke-cc__card-inner">

            {%- comment -%} Image {%- endcomment -%}
            <div class="myduke-cc__image-wrap">
              {%- if block.settings.card_image != blank -%}
                {%- liquid
                  assign image_loading = 'lazy'
                  if section.index == 1 and forloop.index == 1
                    assign image_loading = 'eager'
                  endif
                -%}
                {{
                  block.settings.card_image
                  | image_url: width: block.settings.card_image.width
                  | image_tag:
                    loading: image_loading,
                    widths: '400, 600, 800, 1000',
                    sizes: '(min-width: 990px) 25vw, (min-width: 576px) 50vw, 100vw',
                    style: 'object-fit:cover'
                }}
              {%- else -%}
                {%- assign placeholder_index = forloop.index | modulo: 3 | plus: 1 -%}
                {{ 'hero-apparel-' | append: placeholder_index | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>

            {%- comment -%} Info: badge + title + check ── {%- endcomment -%}
            <div class="myduke-cc__info">

              {%- if block.settings.card_time_badge != blank -%}
                <div class="myduke-cc__badge">
                  {%- comment -%} Clock icon — Streamline Ultimate style {%- endcomment -%}
                  <svg class="myduke-cc__badge-icon" width="13" height="13" viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                    <circle cx="6.5" cy="6.5" r="5.75" stroke="#2b2b2e" stroke-width="1"/>
                    <path d="M6.5 3.25V6.5L8.75 8.25" stroke="#2b2b2e" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span class="myduke-cc__badge-text">{{ block.settings.card_time_badge }}</span>
                </div>
              {%- endif -%}

              {%- if block.settings.card_heading != blank -%}
                <h3 class="myduke-cc__card-title">{{ block.settings.card_heading }}</h3>
              {%- endif -%}

              {%- if block.settings.card_check_text != blank -%}
                <div class="myduke-cc__check">
                  {%- if block.settings.card_check_icon_svg != blank -%}
                    <span class="myduke-cc__check-icon" aria-hidden="true">{{ block.settings.card_check_icon_svg }}</span>
                  {%- elsif block.settings.card_check_icon != blank -%}
                    {{
                      block.settings.card_check_icon
                      | image_url: width: 32
                      | image_tag:
                        class: 'myduke-cc__check-icon',
                        width: 16,
                        height: 16,
                        loading: 'lazy'
                    }}
                  {%- else -%}
                    <svg class="myduke-cc__check-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                      <circle cx="8" cy="8" r="7.25" stroke="{{ icon_color }}" stroke-width="1"/>
                      <path d="M5 8L7 10.5L11 5.5" stroke="{{ icon_color }}" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  {%- endif -%}
                  <span class="myduke-cc__check-text">{{ block.settings.card_check_text }}</span>
                </div>
              {%- endif -%}

            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── CTA button ── {%- endcomment -%}
  {%- if section.settings.cta_button_label != blank -%}
    <div class="myduke-cc__footer">
      <a
        href="{{ section.settings.cta_button_url | default: '#' }}"
        class="myduke-cc__btn"
        {% if settings.links_blank and section.settings.cta_button_url != blank %}target="_blank" rel="noopener noreferrer"{% endif %}
      >
        {{- section.settings.cta_button_label -}}
      </a>
    </div>
  {%- endif -%}

</div>

