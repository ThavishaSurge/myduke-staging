{{ 'section-showcase.css' | asset_url | stylesheet_tag }}
<script src="{{ 'showcase.js' | asset_url }}" defer="defer"></script>
{% style %}
   {% render 'section-margin' %}
  {% render 'section-padding' %}
      {% liquid
       if section.settings.list_button_show and section.settings.list_button_label != blank
         assign display_button = true
       else
         assign display_button = false
       endif
     %}
{% endstyle %}

<div class="showcase color-{{ section.settings.color_scheme_main }} background section-{{ section.id }}-padding">
  <div
    id="Banner-{{ section.id }}"
    class="showcase__inner container "
  >
    <div class="showcase__content{% if section.settings.animated_badge != blank %} has-badge{% endif %}">
      {%- if section.settings.subheading != blank or section.settings.content_heading != blank %}
        <div class="showcase__text">
          <div class="showcase__text_inner">
            {%- if section.settings.subheading != blank -%}
              <div class="heading-group__subheading">
                {{- section.settings.subheading -}}
              </div>
            {%- endif -%}
            {% if section.settings.content_heading != blank %}
              <{{ section.settings.content_heading_tag | default: 'h3' }}
                class="showcase__heading {{ section.settings.content_heading_size}} richtext-link-inside"
                {{ section.shopify_attributes }}
              >
                {{- section.settings.content_heading -}}
              </{{ section.settings.content_heading_tag | default: 'h3' }}>
            {% endif -%}
          </div>
          {% if section.settings.content_description != blank %}
            <p class="showcase__description richtext-link-inside" {{ section.shopify_attributes }}>
              {{- section.settings.content_description -}}
            </p>
          {% endif -%}

          {%- if display_button and section.settings.products != blank %}
            <button
              type="submit"
              class="button button--{{ section.settings.list_button_style }} showcase__button steps_content_button"
            >
              <span class="button-icon">
                {% render 'icon-plus-dropdown' %}
              </span>

              <span class="button-label">
                {{- section.settings.list_button_label | escape -}}
              </span>
            </button>
          {%- endif -%}
        </div>
      {% endif -%}
      <div class="showcase__img_inner">
        <div
          class="showcase__img_inner-wrapper"
          {% if section.settings.enable_image_animation %}
            data-scroll-image-reveal
          {% endif %}
        >
          {% if section.settings.image != blank %}
            {% liquid
              assign image_class = ''
              if section.settings.enable_image_animation
                assign image_class = image_class | append: ' scroll-image-reveal__target'
              endif
            %}
            {{
              section.settings.image
              | image_url: width: section.settings.image.width
              | image_tag:
                width: section.settings.image.width,
                height: section.settings.image.height,
                widths: '360, 535, 600, 720, 940, 1066, 1200, 1400, 1600, 1800, 2000, 2200, 2400, 2600, 2800, 3000, 3200, 3400, 3600, 3800',
                sizes: '(min-width: 750px) 50vw, 100vw',
                class: image_class,
                style: 'object-fit: cover'
            }}
          {%- else -%}
            {% liquid
              assign placeholder_class = 'media-banner__image placeholder-svg'
              if section.settings.enable_image_animation
                assign placeholder_class = placeholder_class | append: ' scroll-image-reveal__target'
              endif
            %}
            {{ 'hero-apparel-1' | placeholder_svg_tag: placeholder_class }}
          {%- endif -%}
        </div>
        {% if section.settings.animated_badge %}
          {% if section.settings.image_badge != blank %}
            <div class="showcase__img_badge">
              {{
                section.settings.image_badge
                | image_url: width: section.settings.image_badge.width
                | image_tag:
                  width: section.settings.image_badge.width,
                  height: section.settings.image_badge.height,
                  widths: '360, 535, 600, 720, 940, 1066, 1200, 1400, 1600, 1800, 2000, 2200, 2400, 2600, 2800, 3000, 3200, 3400, 3600, 3800',
                  sizes: '372',
                  class: '',
                  style: 'object-fit: cover'
              }}
            </div>
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>
{% render 'showcase-modal',
  products_per_row_mobile: section.settings.products_per_row_mobile,
  product_list: section.settings.products,
  heading_modal: section.settings.heading_modal
%}
{% schema %}
{
  "name": "t:sections.showcase.name",
  "class": "showcase-section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme_main",
      "default": "background-2",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.all.image.label"
    },
    {
      "type": "checkbox",
      "id": "enable_image_animation",
      "label": "t:sections.all.image_enable_animation.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.showcase.settings.header__content.content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.all.subheading.label",
      "default": "t:sections.showcase.settings.subheading.label"
    },
    {
      "type": "inline_richtext",
      "id": "content_heading",
      "label": "t:sections.all.heading.label",
      "default": "t:sections.showcase.settings.content_heading.default"
    },
    {
      "type": "select",
      "id": "content_heading_size",
      "options": [
        {
          "value": "h5",
          "label": "t:sections.all.heading_size.options__5.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__1.label"
        }
      ],
      "default": "h3",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "select",
      "id": "content_heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.heading_tag.options__6.label"
        },
        {
          "value": "div",
          "label": "t:sections.all.heading_tag.options__7.label"
        }
      ],
      "default": "h3",
      "label": "t:sections.all.heading_tag.label",
      "info": "t:sections.all.heading_tag.info"
    },
    {
      "type": "inline_richtext",
      "id": "content_description",
      "label": "t:sections.all.text.label",
      "default": "t:sections.showcase.settings.content_description.default"
    },
    {
      "type": "checkbox",
      "id": "animated_badge",
      "default": true,
      "label": "t:sections.showcase.settings.animated_badge.label"
    },
    {
      "type": "image_picker",
      "id": "image_badge",
      "label": "t:sections.showcase.settings.badge_icon.label",
      "visible_if": "{{ section.settings.animated_badge }}"
    },
    {
      "type": "header",
      "content": "t:sections.showcase.settings.product_modal.label"
    },
    {
      "type": "checkbox",
      "id": "list_button_show",
      "default": true,
      "label": "t:sections.all.button.button_show.label"
    },
    {
      "type": "text",
      "id": "list_button_label",
      "default": "t:sections.showcase.settings.button.default",
      "label": "t:sections.all.button.button_label.label",
      "visible_if": "{{ section.settings.list_button_show }}"
    },
    {
      "type": "select",
      "id": "list_button_style",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.all.button.button_style.options__1.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.all.button.button_style.options__2.label"
        },
        {
          "value": "tertiary",
          "label": "t:sections.all.button.button_style.options__3.label"
        },
          {
            "value": "secondary2",
            "label": "t:sections.all.button.button_style.options__4.label"
          },
          {
            "value": "accent",
            "label": "t:sections.all.button.button_style.options__5.label"
          }
      ],
      "default": "primary",
      "label": "t:sections.all.button.button_style.label",
      "visible_if": "{{ section.settings.list_button_show }}"
    },
    {
      "type": "inline_richtext",
      "id": "heading_modal",
      "label": "t:sections.all.heading.label",
      "default": "t:sections.showcase.settings.heading_modal.label"
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "t:sections.highlights.settings.products.label",
      "limit": 4
    },
    {
      "type": "select",
      "id": "products_per_row_mobile",
      "default": "1",
      "label": "t:sections.all.products_per_row_mobile.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.all.products_per_row_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.all.products_per_row_mobile.options__2.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.all.section-padding.header.content"
    },
    {
      "type": "select",
      "id": "padding_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-padding.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-padding.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-padding.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-padding.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-padding.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-padding.options__6.label"
        }
      ],
      "default": "m",
      "label": "t:sections.all.section-padding.padding_top.label"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-padding.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-padding.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-padding.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-padding.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-padding.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-padding.options__6.label"
        }
      ],
      "default": "m",
      "label": "t:sections.all.section-padding.padding_bottom.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.showcase.name",
      "category": "t:sections.categories.storytelling"
    }
  ]
}
