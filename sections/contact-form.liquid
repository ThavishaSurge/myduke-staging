{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}

{%- style -%}
  {% render 'section-margin' %}
{%- endstyle -%}

<div class="contact-form">
  <div class="contact-form__container">
    <div class="contact-form__inner">
      <div class="contact-form__wrapper container">
        <div class="contact-form__content-wrapper">
          {%- if section.settings.show_contact_info -%}
            <div class="contact-form__info-column">
              {%- if section.settings.info_heading != blank -%}
                <h3 class="contact-form__info-heading">{{ section.settings.info_heading }}</h3>
              {%- endif -%}
              {%- if section.settings.info_description != blank -%}
                <p class="contact-form__info-description">{{ section.settings.info_description }}</p>
              {%- endif -%}
              <div class="contact-form__info-items">
                {%- if section.settings.contact_email != blank -%}
                  <div class="contact-form__info-item">
                    <span class="contact-form__info-label">Email:</span>
                    <a href="mailto:{{ section.settings.contact_email }}" class="contact-form__info-value">
                      {{ section.settings.contact_email }}
                    </a>
                  </div>
                {%- endif -%}
                {%- if section.settings.contact_phone != blank -%}
                  <div class="contact-form__info-item">
                    <span class="contact-form__info-label">Phone:</span>
                    <a href="tel:{{ section.settings.contact_phone | replace: ' ', '' | replace: '(', '' | replace: ')', '' }}" class="contact-form__info-value">
                      {{ section.settings.contact_phone }}
                    </a>
                  </div>
                {%- endif -%}
                {%- if section.settings.contact_hours != blank -%}
                  <div class="contact-form__info-item">
                    <span class="contact-form__info-label">Customer Service Hours:</span>
                    <span class="contact-form__info-value">{{ section.settings.contact_hours }}</span>
                  </div>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}

          <div class="contact-form__form-column">
            {%- if section.settings.heading_form != blank -%}
              <{{ section.settings.heading_form_tag | default: 'h3' }} class="contact-form__title-form {{ section.settings.heading_form_size }} richtext-link-inside">
                {{- section.settings.heading_form -}}
              </{{ section.settings.heading_form_tag | default: 'h3' }}>
            {%- endif -%}
            {%- if section.settings.text_form != blank -%}
              <p class="contact-form__text-form richtext-link-inside">
                {{- section.settings.text_form -}}
              </p>
            {%- endif -%}
            {%- form 'contact', id: 'ContactForm', class: 'contact-form__form' -%}
          {%- if form.posted_successfully? -%}
            <div class="form-status form-status-list form__message form__message--success body-small">
              {% render 'icon-success' %}
              {{- 'templates.contact.form.post_success' | t -}}
            </div>
          {%- elsif form.errors -%}
          {%- endif -%}
          <div class="field field__name">
            <input
              class="field__input focus-inset"
              autocomplete="name"
              type="text"
              id="ContactForm-name"
              dir="ltr"
              name="contact[{{ 'templates.contact.form.name' | t }}]"
              value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
              placeholder="{{- 'templates.contact.form.name' | t -}}"
            >
            <label
              class="field__label body-small"
              for="ContactForm-name"
            >
              {{- 'templates.contact.form.name' | t -}}
            </label>
          </div>
          <div class="field">
            <input
              autocomplete="email"
              type="email"
              id="ContactForm-email"
              dir="ltr"
              class="field__input focus-inset"
              name="contact[email]"
              spellcheck="false"
              pattern="[a-z0-9._%+\-]+@[a-z0-9.\-]+\.[a-z]{2,}$"
              autocapitalize="off"
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              aria-required="true"
              {% if form.errors contains 'email' %}
                aria-invalid="true"
                aria-describedby="ContactForm-email-error"
              {% endif %}
              placeholder="{{- 'templates.contact.form.email' | t -}}"
              required
            >
            <label
              class="field__label body-small"
              for="ContactForm-email"
            >
              {{- 'templates.contact.form.email' | t -}}
            </label>

            {%- if form.errors contains 'email' -%}
              <small class="contact-form__field-error" id="ContactForm-email-error">
                <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
                <span class="form__message form__message--error">
                  {{- form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email -}}
                </span>
              </small>
            {%- endif -%}
          </div>
          <div class="field">
            <input
              type="tel"
              id="ContactForm-phone"
              dir="ltr"
              class="field__input"
              autocomplete="tel"
              name="contact[{{ 'templates.contact.form.phone' | t }}]"
              pattern="[0-9\-]*"
              value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
              placeholder="{{- 'templates.contact.form.phone' | t -}}"
            >
            <label
              class="field__label body-small"
              for="ContactForm-phone"
            >
              {{- 'templates.contact.form.phone' | t -}}
            </label>
          </div>
          <div class="field">
            <textarea
              id="ContactForm-body"
              dir="ltr"
              class="text-area field__input"
              name="contact[{{ 'templates.contact.form.comment' | t }}]"
              placeholder="{{- 'templates.contact.form.comment' | t -}}"
              aria-required="true"
              required
            >
              {{- form.body -}}
            </textarea>
            <label
              class="field__label body-small"
              for="ContactForm-body"
            >
              {{- 'templates.contact.form.comment' | t -}}
            </label>
          </div>
          <div class="contact-form__bottom">
            <button
              type="submit"
              class="button button--{{ section.settings.button_style }} focus-inset"
            >
              <div class="button__content">
                {% if section.settings.button_style == 'tertiary' %}
                  <span class="button__icons-container">
                    {% render 'icon-arrow-tertiary-button' %}
                    {% render 'icon-arrow-tertiary-button' %}
                  </span>
                {% endif %}
                <span class="button__label">
                  {{- 'templates.contact.form.send' | t -}}
                </span>
              </div>
            </button>
            {%- if section.settings.additional_text != blank -%}
              <div class="contact-form__add-text body-small richtext-link-inside">
                {{- section.settings.additional_text -}}
              </div>
            {%- endif -%}
          </div>
        {%- endform -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="{{ 'myduke-form-validation.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "t:sections.contact-form.name",
  "tag": "section",
  "class": "contact-section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Contact Information"
    },
    {
      "type": "checkbox",
      "id": "show_contact_info",
      "label": "Show contact information",
      "default": false,
      "info": "Display contact details to the left of the form (desktop) or above it (mobile)"
    },
    {
      "type": "text",
      "id": "info_heading",
      "label": "Contact info heading",
      "default": "Get in Touch",
      "visible_if": "{{ section.settings.show_contact_info }}"
    },
    {
      "type": "textarea",
      "id": "info_description",
      "label": "Contact info description",
      "default": "We're here to help. Reach out to our team for any inquiries.",
      "visible_if": "{{ section.settings.show_contact_info }}"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Email address",
      "default": "hello@myduke.com.au",
      "visible_if": "{{ section.settings.show_contact_info }}"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Phone number",
      "default": "(03) 8658 6455",
      "visible_if": "{{ section.settings.show_contact_info }}"
    },
    {
      "type": "text",
      "id": "contact_hours",
      "label": "Customer service hours",
      "default": "9am - 5pm AEST, Monday - Friday",
      "visible_if": "{{ section.settings.show_contact_info }}"
    },
    {
      "type": "header",
      "content": "Form Settings"
    },
    {
      "type": "inline_richtext",
      "id": "heading_form",
      "label": "t:sections.all.heading.label",
      "default": "t:sections.contact-form.settings.heading_form.default"
    },
    {
      "type": "select",
      "id": "heading_form_size",
      "options": [
        {
          "value": "h5",
          "label": "t:sections.all.heading_size.options__5.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        }
      ],
      "default": "h5",
      "label": "t:sections.all.heading_size.label",
      "visible_if": "{{ section.settings.heading_form != blank }}"
    },
    {
      "type": "select",
      "id": "heading_form_tag",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.heading_tag.options__6.label"
        },
        {
          "value": "div",
          "label": "t:sections.all.heading_tag.options__7.label"
        }
      ],
      "default": "h3",
      "label": "t:sections.all.heading_tag.label",
      "info": "t:sections.all.heading_tag.info",
      "visible_if": "{{ section.settings.heading_form != blank }}"
    },
    {
      "type": "inline_richtext",
      "id": "text_form",
      "label": "t:sections.all.text.label",
      "default": "t:sections.contact-form.settings.text_form.default"
    },
    {
      "type": "inline_richtext",
      "id": "additional_text",
      "label": "t:sections.contact-form.settings.additional_text.label"
    },
    {
      "type": "select",
      "id": "button_style",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.all.button.button_style.options__1.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.all.button.button_style.options__2.label"
        },
        {
          "value": "tertiary",
          "label": "t:sections.all.button.button_style.options__3.label"
        },
          {
            "value": "secondary2",
            "label": "t:sections.all.button.button_style.options__4.label"
          },
          {
            "value": "accent",
            "label": "t:sections.all.button.button_style.options__5.label"
          }
      ],
      "default": "primary",
      "label": "t:sections.all.button.button_style.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.contact-form.presets.name",
      "category": "t:sections.categories.forms"
    }
  ]
}
{% endschema %}
