{{ 'section-myduke-popular-products.css' | asset_url | stylesheet_tag }}
{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}

<script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'myduke-popular-products.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  {% render 'section-padding' %}
  {% render 'section-margin' %}
{%- endstyle -%}

<div
  class="mdpp color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding section-{{ section.id }}-margin mydk-product-container-auth"
  data-section-id="{{ section.id }}"
  data-list-id="{% if collection %}{{ collection.id }}{% else %}all{% endif %}"
data-list-name="{% if collection %}{{ collection.handle | capitalize }}{% else %}All{% endif %}"
>

  {%- comment -%} ── Header row ── {%- endcomment -%}
  <div class="mdpp__header container">
    <div class="mdpp__header-left">
      {%- if section.settings.subheading != blank -%}
        <p class="mdpp__eyebrow">{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <{{ section.settings.heading_tag }} class="mdpp__heading">
          {{ section.settings.heading }}
        </{{ section.settings.heading_tag }}>
      {%- endif -%}
    </div>

    {%- if section.settings.shop_all_label != blank -%}
      <div class="mdpp__header-right">
        <a
          href="{{ section.settings.shop_all_url | default: '#' }}"
          class="mdpp__shop-all-btn"
        >
          {{- section.settings.shop_all_label -}}
        </a>
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} ── Divider ── {%- endcomment -%}
  {%- if section.settings.show_divider -%}
    <div class="mdpp__divider container"></div>
  {%- endif -%}

  {%- comment -%} ── Cards ── {%- endcomment -%}
  <div class="mdpp__wrapper container">
    {%- liquid
      assign enable_slider = section.settings.enable_slider
      assign cols = section.settings.cards_per_row | default: 6
    -%}

    <div
      class="mdpp__track{% if enable_slider %} js-mdpp-slider swiper{% endif %}"
      {% if enable_slider %}
        data-cards-per-row="{{ cols }}"
        data-cards-per-row-mobile="{{ section.settings.cards_per_row_mobile }}"
        data-space-between="24"
      {% endif %}
    >
      <div class="mdpp__list mdpp__list--{{ cols }}{% if enable_slider %} swiper-wrapper{% else %} mdpp__list--grid{% endif %}">

        {%- for block in section.blocks -%}

          <div
            class="mdpp__item{% if enable_slider %} swiper-slide{% endif %}"
            {{ block.shopify_attributes }}
          >
            {%- liquid
              assign card_image = block.settings.card_image
              assign card_title = block.settings.card_title
              assign card_url   = block.settings.card_url | default: '#'
            -%}

            <a class="mdpp__card" href="{{ card_url }}">
              <div class="mdpp__card-image-wrap">
                {%- if card_image != blank -%}
                  {{
                    card_image
                    | image_url: width: 600
                    | image_tag:
                      loading: 'lazy',
                      widths: '300, 400, 600',
                      sizes: '(min-width: 990px) 16vw, (min-width: 576px) 33vw, 50vw',
                      style: 'object-fit:cover'
                  }}
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
              {%- if card_title != blank -%}
                <p class="mdpp__card-title">{{ card_title }}</p>
              {%- endif -%}
            </a>
          </div>

        {%- else -%}
          {%- comment -%} Placeholders when no blocks added {%- endcomment -%}
          {%- for i in (1..cols) -%}
            <div class="mdpp__item{% if enable_slider %} swiper-slide{% endif %}">
              <div class="mdpp__card mdpp__card--placeholder">
                <div class="mdpp__card-image-wrap">
                  {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
                <p class="mdpp__card-title">Card {{ forloop.index }}</p>
              </div>
            </div>
          {%- endfor -%}
        {%- endfor -%}

      </div>

      {%- comment -%} Slider navigation ── {%- endcomment -%}
      {%- if enable_slider and section.settings.show_slider_nav -%}
        <div class="mdpp__nav">
          <button class="mdpp__nav-btn mdpp__nav-btn--prev js-mdpp-prev" aria-label="Previous">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button class="mdpp__nav-btn mdpp__nav-btn--next js-mdpp-next" aria-label="Next">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      {%- endif -%}
    </div>
  </div>

</div>

{% schema %}
{
  "name": "Manual Products (MyDuke)",
  "tag": "section",
  "class": "mdpp-section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "background-1",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Eyebrow / Subheading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" },
        { "value": "div", "label": "div" }
      ],
      "default": "h2",
      "label": "Heading tag"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "default": true,
      "label": "Show divider below heading"
    },
    {
      "type": "header",
      "content": "Shop All Button"
    },
    {
      "type": "text",
      "id": "shop_all_label",
      "label": "Button label",
      "default": "Shop All Products"
    },
    {
      "type": "url",
      "id": "shop_all_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "enable_slider",
      "label": "Enable slider",
      "default": true,
      "info": "When enabled, cards scroll horizontally. When disabled, cards wrap in a grid."
    },
    {
      "type": "checkbox",
      "id": "show_slider_nav",
      "label": "Show slider navigation arrows",
      "default": false,
      "visible_if": "{{ section.settings.enable_slider == true }}"
    },
    {
      "type": "range",
      "id": "cards_per_row",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 6,
      "label": "Cards visible per row (desktop)"
    },
    {
      "type": "select",
      "id": "cards_per_row_mobile",
      "label": "Cards visible per row (mobile)",
      "default": "2",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.all.section-padding.header.content"
    },
    {
      "type": "select",
      "id": "padding_top",
      "options": [
        { "value": "no-indent", "label": "t:sections.all.section-padding.options__1.label" },
        { "value": "xs",        "label": "t:sections.all.section-padding.options__2.label" },
        { "value": "s",         "label": "t:sections.all.section-padding.options__3.label" },
        { "value": "m",         "label": "t:sections.all.section-padding.options__4.label" },
        { "value": "l",         "label": "t:sections.all.section-padding.options__5.label" },
        { "value": "xl",        "label": "t:sections.all.section-padding.options__6.label" }
      ],
      "default": "m",
      "label": "t:sections.all.section-padding.padding_top.label"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "options": [
        { "value": "no-indent", "label": "t:sections.all.section-padding.options__1.label" },
        { "value": "xs",        "label": "t:sections.all.section-padding.options__2.label" },
        { "value": "s",         "label": "t:sections.all.section-padding.options__3.label" },
        { "value": "m",         "label": "t:sections.all.section-padding.options__4.label" },
        { "value": "l",         "label": "t:sections.all.section-padding.options__5.label" },
        { "value": "xl",        "label": "t:sections.all.section-padding.options__6.label" }
      ],
      "default": "m",
      "label": "t:sections.all.section-padding.padding_bottom.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        { "value": "no-indent", "label": "t:sections.all.section-margin.options__1.label" },
        { "value": "xs",        "label": "t:sections.all.section-margin.options__2.label" },
        { "value": "s",         "label": "t:sections.all.section-margin.options__3.label" },
        { "value": "m",         "label": "t:sections.all.section-margin.options__4.label" },
        { "value": "l",         "label": "t:sections.all.section-margin.options__5.label" },
        { "value": "xl",        "label": "t:sections.all.section-margin.options__6.label" }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        { "value": "no-indent", "label": "t:sections.all.section-margin.options__1.label" },
        { "value": "xs",        "label": "t:sections.all.section-margin.options__2.label" },
        { "value": "s",         "label": "t:sections.all.section-margin.options__3.label" },
        { "value": "m",         "label": "t:sections.all.section-margin.options__4.label" },
        { "value": "l",         "label": "t:sections.all.section-margin.options__5.label" },
        { "value": "xl",        "label": "t:sections.all.section-margin.options__6.label" }
      ],
      "default": "l",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "card_image",
          "label": "Card image"
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Card title",
          "default": "Product Name"
        },
        {
          "type": "url",
          "id": "card_url",
          "label": "Card URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Manual Products (MyDuke)",
      "category": "Products",
      "settings": {
        "heading": "Featured Products",
        "shop_all_label": "Shop All Products",
        "enable_slider": true,
        "cards_per_row": 6
      },
      "blocks": [
        { "type": "product_card", "settings": { "card_title": "Starter Kits" } },
        { "type": "product_card", "settings": { "card_title": "Vape Devices" } },
        { "type": "product_card", "settings": { "card_title": "Closed Pods" } },
        { "type": "product_card", "settings": { "card_title": "E-Liquids" } },
        { "type": "product_card", "settings": { "card_title": "Accessories" } },
        { "type": "product_card", "settings": { "card_title": "NRT" } }
      ]
    }
  ]
}
{% endschema %}
