{{ 'customer.css' | asset_url | stylesheet_tag: preload: true }}

{%- style -%}
  {% render 'section-margin' %}
{%- endstyle -%}

{% comment %}
  {%- style -%}
    {% if section.settings.background_type == "full_height" %}
        .register.register--{{ section.id }} {
          min-height: calc(100vh - var(--announcement-height) - var(--header-height));
          min-height: calc(100svh - var(--announcement-height) - var(--header-height));
        }
    {% else %}
        .register.register--{{ section.id }} {
          padding-block: 3.2rem;
        }

        @media (min-width: 750px) {
          .register.register--{{ section.id }} {
            padding-block: 6.4rem;
          }
        }

        .register.register--{{ section.id }} .login__col {
          margin-inline: auto;
        }
    {% endif %}
  {%- endstyle -%}
{% endcomment %}

<div
  class="customer login register register--{{ section.id }} container container"
>
  <div class="login__col">
    <div class="register__form">
      <div class="form-header">
        <div class="form-header__inner">
          <h1 class=" login__title h4">
            {{ 'customer.register.title' | t }}
          </h1>
          <p class="login__desc body-large">{{ 'customer.register.desc' | t }}</p>
        </div>
      </div>
      {%- form 'create_customer', return_to: routes.account_url -%}
        <div class="register__fields-wrapper">
          <div class="field">
            <input
              type="text"
              name="customer[first_name]"
              id="RegisterForm-FirstName"
              dir="ltr"
              {% if form.first_name %}
                value="{{ form.first_name }}"
              {% endif %}
              autocomplete="given-name"
              placeholder="{{ 'customer.register.placeholders.first_name' | t }}"
              required
            >
            <label for="RegisterForm-FirstName" class="body-small">
              {{- 'customer.register.first_name' | t -}}
            </label>
          </div>
          <div class="field">
            <input
              type="text"
              name="customer[last_name]"
              id="RegisterForm-LastName"
              dir="ltr"
              {% if form.last_name %}
                value="{{ form.last_name }}"
              {% endif %}
              autocomplete="family-name"
              placeholder="{{ 'customer.register.placeholders.last_name' | t }}"
              required
            >
            <label for="RegisterForm-LastName" class="body-small">
              {{- 'customer.register.last_name' | t -}}
            </label>
          </div>
          <div class="field field--email">
            <input
              type="email"
              name="customer[email]"
              id="RegisterForm-email"
              dir="ltr"
              {% if form.email %}
                value="{{ form.email }}"
              {% endif %}
              spellcheck="false"
              autocapitalize="off"
              autocomplete="email"
              pattern="[a-z0-9._%+\-]+@[a-z0-9.\-]+\.[a-z]{2,}$"
              aria-required="true"
              {% if form.errors contains 'email' %}
                aria-invalid="true"
                aria-describedby="RegisterForm-email-error"
              {% endif %}
              placeholder="{{ 'customer.register.placeholders.email' | t }}"
              required
            >
            <label for="RegisterForm-email" class="body-small">
              {{- 'customer.register.email' | t -}}
            </label>
            {%- if form.errors contains 'email' -%}
              <span
                id="RegisterForm-email-error"
                class="form__message form__message--error body-small"
              >
                {{ form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email }}.
              </span>
            {%- endif -%}
          </div>
          <div class="field field--pass">
            <div class="field--pass-wrapper">
              <div class="button-pass-visibility">
                {% render 'icon-eye' %}
                {% render 'icon-eye-close' %}
              </div>
              <input
                type="password"
                name="customer[password]"
                id="RegisterForm-password"
                dir="ltr"
                aria-required="true"
                placeholder="{{ 'customer.register.placeholders.password' | t }}"
                {% if form.errors contains 'password' %}
                  aria-invalid="true"
                  aria-describedby="RegisterForm-password-error"
                {% endif %}
                required
              >
              <label for="RegisterForm-password" class="body-small">
                {{- 'customer.register.password' | t -}}
              </label>
            </div>

            {%- if form.errors contains 'password' -%}
              <span
                id="RegisterForm-password-error"
                class="form__message form__message--error body-small"
              >
                {{ form.errors.translated_fields.password | capitalize }}
                {{ form.errors.messages.password }}.
              </span>
            {%- endif -%}

            {%- if form.errors contains 'form' -%}
              <span
                id="RegisterForm-email-error"
                class="form__message form__message--error body-small"
              >
                {{- 'customer.login_page.customer_exist' | t -}}
              </span>
            {%- endif -%}
          </div>
        </div>

        {%- if section.settings.show_terms or section.settings.show_subscribe -%}
          {% if section.settings.show_terms and shop.terms_of_service.url != blank %}
            <div class="field--terms">
              <div class="field field--checkbox">
                <input
                  type="checkbox"
                  class="focus-inset"
                  name="terms"
                  id="terms"
                  aria-describedby="RegisterForm-terms-error"
                  required
                  oninvalid="this.classList.add('is-invalid')"
                  onchange="this.classList.remove('is-invalid')"
                >
                <label for="terms">
                  <span class="field__checkbox">
                    {% render 'icon-checkbox-arrow', class: 'field__checkbox--arrow' %}
                  </span>
                  <span class="field__label body-small">
                    {{- 'customer.register.terms' | t }}
                    <a href="{{ shop.terms_of_service.url }}" target="_blank">
                      {{- 'customer.register.terms_link' | t -}}
                    </a>
                  </span></label
                >

                <span id="RegisterForm-terms-error" class="form__message form__message--error">
                  {{- 'customer.register.terms_error' | t -}}
                </span>
              </div>
            </div>
          {% endif %}
          {% if section.settings.show_subscribe %}
            <div class="field--terms">
              <div class="field field--checkbox">
                <input
                  type="checkbox"
                  name="customer[accepts_marketing]"
                  value="true"
                  id="RegisterFormSubscribeConsent"
                >
                <label for="RegisterFormSubscribeConsent">
                  <span class="field__checkbox">
                    {% render 'icon-checkbox-arrow', class: 'field__checkbox--arrow' %}
                  </span>
                  <span class="field__label body-small">
                    {{ 'customer.register.newsletter' | t }}
                  </span>
                </label>
              </div>
            </div>
          {% endif %}
        {%- endif -%}

        <div class="login__buttons">
          <button
            type="submit"
            class="button button--primary register__create-acc focus-inset"
          >
            <div class="button__content">
              <span class="button__label" data-label="{{- 'customer.register.submit' | t -}}">
                {{- 'customer.register.submit' | t -}}
              </span>
            </div>
          </button>
        </div>
      {%- endform -%}
      {% if section.settings.additional_text != blank and section.settings.show_terms == false %}
        <p class="register__additional--text body-small richtext-link-inside">
          {{ section.settings.additional_text }}
        </p>
      {% endif %}
    </div>
    <div class="register__form-info background">
      <span>{{ 'customer.register.have_account' | t }}</span>
      <a
        class="underlined-link register__to-sign-in"
        href="{{ routes.account_login_url }}"
      >
        <span class="button__label">
          {{- 'customer.login_page.title' | t -}}
        </span>
      </a>
    </div>
  </div>
</div>

<script>
  window.onload = () => {
    typeof PasswordViewer !== 'undefined' && new PasswordViewer();
  };
</script>

{% schema %}
{
  "name": "t:sections.main-register.name",
  "tag": "section",
  "class": "register-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_terms",
      "default": false,
      "label": "t:sections.main-register.settings.show_terms.label"
    },
    {
      "type": "checkbox",
      "id": "show_subscribe",
      "default": false,
      "label": "t:sections.main-register.settings.show_subscribe.label"
    },
    {
      "type": "inline_richtext",
      "id": "additional_text",
      "default": "t:sections.main-register.settings.additional_text.default",
      "label": "t:sections.main-register.settings.additional_text.label",
      "visible_if": "{{ section.settings.show_terms == false }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "xl",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ]
}
{% endschema %}
