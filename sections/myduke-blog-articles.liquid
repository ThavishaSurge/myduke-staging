<section class="myduke-article">
  <div class="myduke-article__inner">
    
    <header class="myduke-article__header">
      <p class="myduke-article__eyebrow">{{ blog.title }}</p>
      <h1 class="myduke-article__heading">{{ article.title }}</h1>
      
      {%- if section.settings.show_meta -%}
        <div class="myduke-article__meta">
          <span class="myduke-article__author">By {{ article.author }}</span>
          <span class="myduke-article__date">{{ article.published_at | time_tag: '%d.%m.%y' }}</span>
        </div>
      {%- endif -%}
    </header>

    {%- if article.image and section.settings.show_image -%}
      <div class="myduke-article__image-wrapper">
        <img
          srcset="
            {%- if article.image.width >= 375 -%}{{ article.image | image_url: width: 375 }} 375w,{%- endif -%}
            {%- if article.image.width >= 750 -%}{{ article.image | image_url: width: 750 }} 750w,{%- endif -%}
            {%- if article.image.width >= 1100 -%}{{ article.image | image_url: width: 1100 }} 1100w,{%- endif -%}
            {{ article.image | image_url }} {{ article.image.width }}w
          "
          sizes="(min-width: 990px) 1100px, (min-width: 750px) 750px, 100vw"
          src="{{ article.image | image_url: width: 1100 }}"
          alt="{{ article.image.alt | escape }}"
          class="myduke-article__image"
          loading="eager"
          width="{{ article.image.width }}"
          height="{{ article.image.height }}"
        >
      </div>
    {%- endif -%}

    <div class="myduke-article__content">
      {{ article.content }}
    </div>

    <div class="myduke-article__footer">
      <a href="{{ blog.url }}" class="myduke-article__btn">Back to Learn hub</a>
    </div>

  </div>
</section>

<style>
  /* ── Main Article Layout ── */
  .myduke-article {
    background: #ffffff;
    padding-top: 8rem;
    padding-bottom: 8rem;
  }

  .myduke-article__inner {
    max-width: 1000px; /* Constrains line length for optimal reading */
    margin: 0 auto;
    padding: 0 2.4rem;
    display: flex;
    flex-direction: column;
    gap: 4.8rem;
  }

  /* ── Header Area ── */
  .myduke-article__header {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    align-items: flex-start;
  }

  .myduke-article__eyebrow {
    font-family: var(--font-body-family);
    font-size: calc(var(--font-body-scale) * 1.4rem);
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #2b2b2e;
    margin: 0;
  }

  .myduke-article__heading {
    font-family: var(--font-heading-family);
    font-size: 4.8rem;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #264653;
    margin: 0;
  }

  .myduke-article__meta {
    display: flex;
    gap: 1.6rem;
    font-family: var(--font-body-family);
    font-size: 1.4rem;
    color: #2b2b2e;
    opacity: 0.8;
  }

  /* ── Featured Image ── */
  .myduke-article__image-wrapper {
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
  }

  .myduke-article__image {
    width: 100%;
    height: auto;
    max-height: 500px;
    object-fit: cover;
    display: block;
  }

  /* ── Article Content (Rich Text Styling) ── */
  .myduke-article__content {
    font-family: var(--font-secondary-text-family, var(--font-body-family));
    font-size: calc(var(--font-body-scale) * 1.6rem);
    line-height: 1.6;
    letter-spacing: -0.01em;
    color: #264653;
  }

  .myduke-article__content p {
    margin-top: 0;
    margin-bottom: 2.4rem;
  }

  .myduke-article__content h2,
  .myduke-article__content h3,
  .myduke-article__content h4 {
    font-family: var(--font-heading-family);
    color: #264653;
    letter-spacing: -0.02em;
    margin-top: 4.8rem;
    margin-bottom: 1.6rem;
    line-height: 1.2;
  }

  .myduke-article__content h2 { font-size: 3.2rem; }
  .myduke-article__content h3 { font-size: 2.4rem; }

  .myduke-article__content ul,
  .myduke-article__content ol {
    margin-bottom: 2.4rem;
    padding-left: 2.4rem;
  }

  .myduke-article__content li {
    margin-bottom: 0.8rem;
  }

  .myduke-article__content a {
    color: #218380;
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: color 200ms ease;
  }

  .myduke-article__content a:hover {
    color: #264653;
  }

  .myduke-article__content img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 3.2rem 0;
  }

  .myduke-article__content blockquote {
    border-left: 4px solid #bfdbcf;
    padding-left: 2.4rem;
    margin-left: 0;
    font-style: italic;
    font-size: 2rem;
    color: #2b2b2e;
  }

  /* ── Footer / CTA ── */
  .myduke-article__footer {
    margin-top: 3.2rem;
    padding-top: 3.2rem;
    border-top: 1px solid #bfdbcf;
  }

  .myduke-article__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #218380;
    color: #ffffff;
    font-family: var(--font-secondary-text-family);
    font-weight: 500;
    font-size: calc(var(--font-button-scale) * 1.6rem);
    padding: 1.2rem 3.6rem;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 200ms ease;
  }

  .myduke-article__btn:hover {
    background: #264653;
  }

  /* ── Responsive ── */
  @media screen and (max-width: 749px) {
    .myduke-article {
      padding-top: 3.2rem;
      padding-bottom: 3.2rem;
    }
    .myduke-article__inner {
      gap: 3.2rem;
    }
    .myduke-article__heading {
      font-size: 3.2rem;
    }
    .myduke-article__content h2 {
      font-size: 2.6rem;
    }
    .myduke-article__content h3 {
      font-size: 2rem;
    }
    .myduke-article__btn {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Myduke blog post",
  "tag": "article",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Show Featured Image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_meta",
      "label": "Show Author and Date",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Myduke blog post"
    }
  ]
}
{% endschema %}