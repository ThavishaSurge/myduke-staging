{{ 'section-myduke-vendor-logos.css' | asset_url | stylesheet_tag }}
{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}

<script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'myduke-vendor-logos.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  {% render 'section-padding' %}
  {% render 'section-margin' %}
{%- endstyle -%}

{%- comment -%}
  myduke-vendor-logos.liquid
  Vendor logo grid / slider. Reads from "vendor" Metaobjects.
  Setup: Admin → Content → Metaobjects → Add definition (API handle: vendor)
  Fields: name (text), logo (file/image), url (url, optional)
{%- endcomment -%}

<div
  class="mdvl color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding section-{{ section.id }}-margin"
  data-section-id="{{ section.id }}"
>
  <div class="container">

    {%- comment -%} ── Header row ── {%- endcomment -%}
    <div class="mdvl__header">
      <div class="mdvl__header-left">
        {%- if section.settings.heading != blank -%}
          <{{ section.settings.heading_tag }} class="mdvl__heading">
            {{ section.settings.heading }}
          </{{ section.settings.heading_tag }}>
        {%- endif -%}
        {%- if section.settings.description_richtext != blank -%}
          <div class="mdvl__description test">{{ section.settings.description_richtext }}</div>
        {%- endif -%}
      </div>

      {%- if section.settings.shop_all_label != blank -%}
        <div class="mdvl__header-right">
          <a
            href="{{ section.settings.shop_all_url | default: '#' }}"
            class="mdvl__shop-all-btn"
            {% if section.settings.shop_all_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
          >
            {{- section.settings.shop_all_label -}}
          </a>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ── Divider ── {%- endcomment -%}
    {%- if section.settings.show_divider -%}
      <div class="mdvl__divider"></div>
    {%- endif -%}

    {%- comment -%} ── Logo grid / slider ── {%- endcomment -%}
    {%- liquid
      assign enable_slider  = section.settings.enable_slider
      assign cols           = section.settings.logos_per_row | default: 6
      assign logo_height    = section.settings.logo_height | default: 80
    -%}

    <div
      class="mdvl__track{% if enable_slider %} js-mdvl-slider swiper{% endif %}"
      {% if enable_slider %}
        data-logos-per-row="{{ cols }}"
        data-space-between="1"
      {% endif %}
    >
      <div
        class="mdvl__list mdvl__list--{{ cols }}{% if enable_slider %} swiper-wrapper{% else %} mdvl__list--grid{% endif %}"
      >

        {%- for block in section.blocks -%}
          {%- assign vendor_obj = block.settings.vendor_ref -%}

          <div
            class="mdvl__item{% if enable_slider %} swiper-slide{% endif %}"
            {{ block.shopify_attributes }}
          >
            {%- if vendor_obj == blank -%}
              {%- comment -%} Placeholder ── no metaobject selected yet {%- endcomment -%}
              <div class="mdvl__card">
                <span class="mdvl__placeholder-text">Vendor Logo</span>
              </div>

            {%- else -%}
              {%- liquid
                assign vendor_name = vendor_obj.name
                assign vendor_logo = vendor_obj.logo

                if section.settings.dynamic_filter_urls
                  assign vendor_handle = vendor_name | handleize
                  assign vendor_url = '/pages/shop-all?brand=' | append: vendor_handle
                else
                  assign vendor_url = vendor_obj.url
                endif
              -%}

              {%- if vendor_url != blank -%}
                <a
                  href="{{ vendor_url }}"
                  class="mdvl__card"
                  aria-label="{{ vendor_name }}"
                  data-vendor="{{ vendor_name }}"
                  {% if section.settings.shop_all_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                >
              {%- else -%}
                <div class="mdvl__card" aria-label="{{ vendor_name }}" data-vendor="{{ vendor_name }}">
              {%- endif -%}

                {%- if vendor_logo != blank -%}
                  {{
                    vendor_logo
                    | image_url: width: 400
                    | image_tag:
                      loading: 'lazy',
                      widths: '120, 200, 300, 400',
                      sizes: '(min-width: 990px) 14vw, (min-width: 576px) 28vw, 45vw',
                      alt: vendor_name,
                      class: 'mdvl__logo-img'
                  }}
                {%- else -%}
                  <span class="mdvl__fallback-name">{{ vendor_name }}</span>
                {%- endif -%}

              {%- if vendor_url != blank -%}
                </a>
              {%- else -%}
                </div>
              {%- endif -%}
            {%- endif -%}
          </div>

        {%- else -%}
          {%- comment -%} No blocks yet — show placeholder grid {%- endcomment -%}
          {%- for i in (1..cols) -%}
            <div class="mdvl__item{% if enable_slider %} swiper-slide{% endif %}">
              <div class="mdvl__card mdvl__card--placeholder">
                <span class="mdvl__placeholder-text">Brand {{ forloop.index }}</span>
              </div>
            </div>
          {%- endfor -%}
        {%- endfor -%}

      </div>

      {%- comment -%} Optional slider nav ── {%- endcomment -%}
      {%- if enable_slider and section.settings.show_slider_nav -%}
        <div class="mdvl__nav">
          <button class="mdvl__nav-btn js-mdvl-prev" aria-label="Previous">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button class="mdvl__nav-btn js-mdvl-next" aria-label="Next">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Vendor Logos (MyDuke)",
  "tag": "section",
  "class": "mdvl-section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "background-1",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "By Brand"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" },
        { "value": "div", "label": "div" }
      ],
      "default": "h2",
      "label": "Heading tag"
    },
    {
      "type": "richtext",
      "id": "description_richtext",
      "label": "Description",
      "default": "<p>Already own a device? Select it to see only the pods, coils, and accessories that work with your hardwar.</p>"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "default": true,
      "label": "Show divider below header"
    },
    {
      "type": "header",
      "content": "Shop All Button"
    },
    {
      "type": "text",
      "id": "shop_all_label",
      "label": "Button label",
      "default": "Shop All Brands"
    },
    {
      "type": "url",
      "id": "shop_all_url",
      "label": "Button URL"
    },
    {
      "type": "checkbox",
      "id": "shop_all_new_tab",
      "label": "Open in new tab",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "dynamic_filter_urls",
      "label": "Enable dynamic filter URLs",
      "default": false,
      "info": "When enabled, vendor cards will link to '/pages/shop-all?brand=[vendor-name]' instead of the standard vendor URL."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "enable_slider",
      "label": "Enable slider (horizontal scroll)",
      "default": false,
      "info": "When off, logos wrap into multiple rows like the design."
    },
    {
      "type": "checkbox",
      "id": "show_slider_nav",
      "label": "Show prev / next arrows",
      "default": false,
      "visible_if": "{{ section.settings.enable_slider == true }}"
    },
    {
      "type": "range",
      "id": "logos_per_row",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 6,
      "label": "Logos per row (desktop)"
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 40,
      "max": 200,
      "step": 4,
      "default": 80,
      "unit": "px",
      "label": "Card height"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-padding.header.content"
    },
    {
      "type": "select",
      "id": "padding_top",
      "options": [
        { "value": "no-indent", "label": "t:sections.all.section-padding.options__1.label" },
        { "value": "xs",        "label": "t:sections.all.section-padding.options__2.label" },
        { "value": "s",         "label": "t:sections.all.section-padding.options__3.label" },
        { "value": "m",         "label": "t:sections.all.section-padding.options__4.label" },
        { "value": "l",         "label": "t:sections.all.section-padding.options__5.label" },
        { "value": "xl",        "label": "t:sections.all.section-padding.options__6.label" }
      ],
      "default": "m",
      "label": "t:sections.all.section-padding.padding_top.label"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "options": [
        { "value": "no-indent", "label": "t:sections.all.section-padding.options__1.label" },
        { "value": "xs",        "label": "t:sections.all.section-padding.options__2.label" },
        { "value": "s",         "label": "t:sections.all.section-padding.options__3.label" },
        { "value": "m",         "label": "t:sections.all.section-padding.options__4.label" },
        { "value": "l",         "label": "t:sections.all.section-padding.options__5.label" },
        { "value": "xl",        "label": "t:sections.all.section-padding.options__6.label" }
      ],
      "default": "m",
      "label": "t:sections.all.section-padding.padding_bottom.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        { "value": "no-indent", "label": "t:sections.all.section-margin.options__1.label" },
        { "value": "xs",        "label": "t:sections.all.section-margin.options__2.label" },
        { "value": "s",         "label": "t:sections.all.section-margin.options__3.label" },
        { "value": "m",         "label": "t:sections.all.section-margin.options__4.label" },
        { "value": "l",         "label": "t:sections.all.section-margin.options__5.label" },
        { "value": "xl",        "label": "t:sections.all.section-margin.options__6.label" }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        { "value": "no-indent", "label": "t:sections.all.section-margin.options__1.label" },
        { "value": "xs",        "label": "t:sections.all.section-margin.options__2.label" },
        { "value": "s",         "label": "t:sections.all.section-margin.options__3.label" },
        { "value": "m",         "label": "t:sections.all.section-margin.options__4.label" },
        { "value": "l",         "label": "t:sections.all.section-margin.options__5.label" },
        { "value": "xl",        "label": "t:sections.all.section-margin.options__6.label" }
      ],
      "default": "l",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ],
  "blocks": [
    {
      "type": "vendor",
      "name": "Vendor",
      "settings": [
        {
          "type": "metaobject",
          "id": "vendor_ref",
          "label": "Vendor",
          "metaobject_type": "vendor",
          "info": "Select a vendor entry. Create entries in Admin → Content → Metaobjects → Vendor."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Vendor Logos (MyDuke)",
      "category": "Brand",
      "settings": {
        "heading": "By Brand",
        "description_richtext": "<p>Already own a device? Select it to see only the pods, coils, and accessories that work with your hardware.</p>",
        "shop_all_label": "Shop All Brands",
        "enable_slider": false,
        "logos_per_row": 6,
        "logo_height": 80
      },
      "blocks": [
        { "type": "vendor" },
        { "type": "vendor" },
        { "type": "vendor" },
        { "type": "vendor" },
        { "type": "vendor" },
        { "type": "vendor" },
        { "type": "vendor" },
        { "type": "vendor" },
        { "type": "vendor" },
        { "type": "vendor" },
        { "type": "vendor" },
        { "type": "vendor" }
      ]
    }
  ]
}
{% endschema %}
