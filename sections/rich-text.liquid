{{ 'section-rich-text.css' | asset_url | stylesheet_tag }}

{%- style -%}
  {% render 'section-margin' %}
{%- endstyle -%}

<div class="rich-text section-{{ section.id }}-padding">
  <div class="rich-text__inner container horizontal-align--{{ section.settings.text_alignment }}{% if section.settings.layout == 'column' and section.settings.enable_image == true %} vertical-align--{{ section.settings.vertical_alignment }}{% endif %}">
    <div class="rich-text__blocks rich-text__blocks--{{ section.settings.layout }}">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
					{%- when 'subheading' -%}
						<div
							class="rich-text__subheading heading-group__subheading "
							{{ block.shopify_attributes }}
						>
							{{- block.settings.subheading -}}
						</div>
          {%- when 'heading' -%}
            <{{ block.settings.heading_tag | default: 'h3' }}
              class="rich-text__heading {{ block.settings.heading_size }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.heading }}
            </{{ block.settings.heading_tag | default: 'h3' }}>
          {%- when 'text' -%}
            <div class="rich-text__text richtext-link-inside" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>
          {%- when 'button' -%}
            {%- if block.settings.button_label != blank -%}
              <div class="rich-text__button-wrapper" {{ block.shopify_attributes }}>
                <a
                  {% if block.settings.button_link == blank %}
                    aria-disabled="true"
                  {% else %}
                    href="{{ block.settings.button_link }}"
                  {% endif %}
                  class="button button--{{ block.settings.button_style }} focus-inset"
                  {% if settings.links_blank and block.settings.button_link.type == 'external_link' %}
                    target="_blank"
                  {% endif %}
                >
                  <div class="button__content">
                    {% if block.settings.button_label != blank %}
                      <span class="button__label" data-label="{{ block.settings.button_label | escape }}">
                        {{- block.settings.button_label | escape -}}
                      </span>
                    {% endif %}
                  </div>
                </a>
              </div>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "t:sections.rich-text.name",
  "tag": "section",
  "class": "rich-text-section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "text_alignment",
      "id": "text_alignment",
      "default": "left",
      "label": "t:sections.all.horizontal_alignment.label",
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ],
  "blocks": [
		{
			"type": "subheading",
			"name": "t:sections.rich-text.blocks.subheading.name",
			"limit": 1,
			"settings": [
				{
					"type": "text",
					"id": "subheading",
					"default": "t:sections.rich-text.blocks.subheading.settings.heading.default",
					"label": "t:sections.rich-text.blocks.subheading.settings.heading.label"
				}
			]
		},
    {
      "type": "heading",
      "name": "t:sections.rich-text.blocks.heading.name",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "t:sections.rich-text.blocks.heading.settings.heading.default",
          "label": "t:sections.all.heading.label"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            {
              "value": "h5",
              "label": "t:sections.all.heading_size.options__5.label"
            },
            {
              "value": "h4",
              "label": "t:sections.all.heading_size.options__4.label"
            },
            {
              "value": "h3",
              "label": "t:sections.all.heading_size.options__3.label"
            },
            {
              "value": "h2",
              "label": "t:sections.all.heading_size.options__2.label"
            },
            {
              "value": "h1",
              "label": "t:sections.all.heading_size.options__1.label"
            }
          ],
