{{ 'section-product-details.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-details.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  {% render 'section-margin' %}
{%- endstyle -%}

{% liquid
  if section.settings.aspect_ratio_primary == 'adapt-to-image'
    if section.settings.image_primary != blank
      assign padding_bottom_primary = 1 | divided_by: section.settings.image_primary.aspect_ratio | times: 100 | round: 2
    else
      assign padding_bottom_primary = '0'
    endif
  elsif section.settings.aspect_ratio_primary == 'landscape'
    assign padding_bottom_primary = '69.5'
  elsif section.settings.aspect_ratio_primary == 'portrait'
    assign padding_bottom_primary = '138.4'
  elsif section.settings.aspect_ratio_primary == 'square'
    assign padding_bottom_primary = '100'
  else
    assign padding_bottom_primary = '0'
  endif
%}

{% liquid
  if section.settings.aspect_ratio_secondary == 'adapt-to-image'
    if section.settings.image_secondary != blank
      assign padding_bottom_secondary = 1 | divided_by: section.settings.image_secondary.aspect_ratio | times: 100 | round: 2
    else
      assign padding_bottom_secondary = '0'
    endif
  elsif section.settings.aspect_ratio_secondary == 'landscape'
    assign padding_bottom_secondary = '69.5'
  elsif section.settings.aspect_ratio_secondary == 'portrait'
    assign padding_bottom_secondary = '138.4'
  elsif section.settings.aspect_ratio_secondary == 'square'
    assign padding_bottom_secondary = '100'
  else
    assign padding_bottom_secondary = '0'
  endif
%}

{%- style -%}
  .product-details-{{ section.id }} .product-details__image-primary-wrapper::before {
    content: '';
    display: block;
    width: 0;
    padding-bottom: {{ padding_bottom_primary }}%;
  }
  .product-details-{{ section.id }} .product-details__image-secondary-wrapper::before {
    content: '';
    display: block;
    width: 0;
    padding-bottom: {{ padding_bottom_secondary }}%;
  }
{%- endstyle -%}

<div class="product-details product-details-{{ section.id }} background">
  {% render 'heading-group', settings: section.settings, class: 'product-details-header' %}

  <div class="product-details__wrapper container">
    {% if section.settings.description != blank %}
      <div class="product-details__main-description body-extra-large richtext-link-inside">
        {{ section.settings.description }}
      </div>
    {% endif %}
    <div class="product-details__content">
      <div class="product-details__left-block">
        <div class="product-details__left-inner{% if section.settings.enable_parallax %} product-details__left-inner-parallax{% endif %}">
          <div
            class="product-details__image-primary-wrapper product-details__image-wrapper{% if section.settings.enable_animation %} product-details__animation-wrapper{% endif %}"
          >
            {% liquid
              assign image_primary = section.settings.image_primary
            %}
            {% if image_primary != blank %}
              {% comment %} Image settings {% endcomment %}
              {% liquid
                assign image_styles = 'object-fit: cover'

                if section.settings.aspect_ratio_primary == 'adap-to-image'
                  assign settings_aspect_ratio_primary = image_primary.aspect_ratio
                else
                  if section.settings.aspect_ratio_primary == 'landscape'
                    assign settings_aspect_ratio_primary = 1.44
                  elsif section.settings.aspect_ratio_primary == 'portrait'
                    assign settings_aspect_ratio_primary = 0.76
                  elsif section.settings.aspect_ratio_primary == 'recommended'
                    assign settings_aspect_ratio_primary = 1.26
                  else
                    assign settings_aspect_ratio_primary = 1
                  endif
                endif

                assign calc_ratio = 1

                if image_primary.aspect_ratio > settings_aspect_ratio_primary
                  assign calc_ratio = image_primary.aspect_ratio | divided_by: settings_aspect_ratio_primary | round: 2
                endif

                assign image_loading = 'lazy'

                if section.index == 1
                  assign image_loading = 'eager'
                endif
              %}
              {% comment %} TODO: add sizes {% endcomment %}
              {%- capture image_sizes -%}
              (min-width: 750px) calc(50vw * {{ calc_ratio }}), calc(100vw * {{ calc_ratio }})
            {%- endcapture -%}
              {{
                image_primary
                | image_url: width: image_primary.width
                | image_tag:
                  width: image_primary.width,
                  height: image_primary.height,
                  widths: '360, 535, 600, 720, 940, 1066, 1200, 1400, 1600, 1800, 2000, 2200, 2400, 2600, 2800, 3000, 3200, 3400, 3600, 3800',
                  sizes: image_sizes,
                  class: 'product-details__image-primary product-details__image product-details__animation-item',
                  style: image_styles,
                  loading: image_loading
              }}
            {% else %}
              {%- liquid
                assign placeholder_class = 'placeholder-svg product-details__animation-item'
                if section.settings.aspect_ratio_primary == 'adapt-to-image'
                  assign placeholder_class = placeholder_class | append: ' ' | append: 'adapt-to-image'
                endif
              %}
              {{ 'hero-apparel-1' | placeholder_svg_tag: placeholder_class }}
            {% endif %}
          </div>
          {% if section.settings.description_primary != blank %}
            <div class="product-details__item-description body-normal richtext-link-inside">
              {{ section.settings.description_primary }}
            </div>
          {% endif %}
        </div>
      </div>

      <div class="product-details__right-block">
        <div class="product-details__image-secondary-wrapper product-details__image-wrapper{% if section.settings.enable_animation %} product-details__animation-wrapper{% endif %}">
          {% liquid
            assign image_secondary = section.settings.image_secondary
          %}
          {% if image_secondary != blank %}
            {% comment %} Image settings {% endcomment %}
            {% liquid
              assign image_styles = 'object-fit: cover'

              if section.settings.aspect_ratio_secondary == 'adap-to-image'
                assign settings_aspect_ratio_secondary = image_secondary.aspect_ratio
              else
                if section.settings.aspect_ratio_secondary == 'landscape'
                  assign settings_aspect_ratio_secondary = 1.44
                elsif section.settings.aspect_ratio_secondary == 'portrait'
                  assign settings_aspect_ratio_secondary = 0.76
                elsif section.settings.aspect_ratio_secondary == 'recommended'
                  assign settings_aspect_ratio_secondary = 1.26
                else
                  assign settings_aspect_ratio_secondary = 1
                endif
              endif

              assign calc_ratio = 1

              if image_secondary.aspect_ratio > settings_aspect_ratio_secondary
                assign calc_ratio = image_secondary.aspect_ratio | divided_by: settings_aspect_ratio_secondary | round: 2
              endif

              assign image_loading = 'lazy'

              if section.index == 1
                assign image_loading = 'eager'
              endif
            %}
            {% comment %} TODO: add sizes {% endcomment %}
            {%- capture image_sizes -%}
              (min-width: 750px) calc(50vw * {{ calc_ratio }}), calc(100vw * {{ calc_ratio }})
            {%- endcapture -%}
            {{
              image_secondary
              | image_url: width: image_secondary.width
              | image_tag:
                width: image_secondary.width,
                height: image_secondary.height,
                widths: '360, 535, 600, 720, 940, 1066, 1200, 1400, 1600, 1800, 2000, 2200, 2400, 2600, 2800, 3000, 3200, 3400, 3600, 3800',
                sizes: image_sizes,
                class: 'product-details__image-secondary product-details__image product-details__animation-item',
                style: image_styles,
                loading: image_loading
            }}
          {% else %}
            {%- liquid
              assign placeholder_class = 'placeholder-svg product-details__animation-item'
              if section.settings.aspect_ratio_secondary == 'adapt-to-image'
                assign placeholder_class = placeholder_class | append: ' ' | append: 'adapt-to-image'
              endif
            %}
            {{ 'hero-apparel-2' | placeholder_svg_tag: placeholder_class }}
          {% endif %}
        </div>
        {% if section.settings.description_secondary != blank %}
          <div class="product-details__item-description body-normal richtext-link-inside">
            {{ section.settings.description_secondary }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.product-details.name",
  "tag": "section",
  "class": "product-details-section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.section_heading_group.header.content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.all.subheading.label"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "t:sections.product-details.settings.heading.default",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "select",
      "id": "heading_font",
      "options": [
        {
          "value": "heading",
          "label": "t:sections.all.heading_font.options__1.label"
        },
        {
          "value": "body",
          "label": "t:sections.all.heading_font.options__2.label"
        }
      ],
      "default": "heading",
      "label": "t:sections.all.heading_font.label",
      "visible_if": "{{ section.settings.heading != blank }}"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h6",
          "label": "t:sections.all.heading_size.options__6.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_size.options__5.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__1.label"
        }
      ],
      "default": "h5",
      "label": "t:sections.all.heading_size.label",
      "visible_if": "{{ section.settings.heading != blank and section.settings.heading_font == 'heading' }}"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.heading_tag.options__6.label"
        },
        {
          "value": "div",
          "label": "t:sections.all.heading_tag.options__7.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_tag.label",
      "info": "t:sections.all.heading_tag.info",
      "visible_if": "{{ section.settings.heading != blank }}"
    },
    {
      "type": "checkbox",
      "id": "heading_group_button_show",
      "label": "t:sections.all.button.button_show.label",
      "default": false
    },
    {
      "type": "text",
      "id": "heading_group_button_label",
      "label": "t:sections.all.button.button_label.label",
      "default": "t:sections.all.button.button_label.default_learn_more",
      "visible_if": "{{ section.settings.heading_group_button_show }}"
    },
    {
      "type": "url",
      "id": "heading_group_button_link",
      "label": "t:sections.all.button.button_link.label",
      "visible_if": "{{ section.settings.heading_group_button_show }}"
    },
    {
      "type": "select",
      "id": "heading_group_button_style",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.all.button.button_style.options__1.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.all.button.button_style.options__2.label"
        },
        {
          "value": "tertiary",
          "label": "t:sections.all.button.button_style.options__3.label"
        },
          {
            "value": "secondary2",
            "label": "t:sections.all.button.button_style.options__4.label"
          },
          {
            "value": "accent",
            "label": "t:sections.all.button.button_style.options__5.label"
          }
      ],
      "default": "tertiary",
      "label": "t:sections.all.button.button_style.label",
      "visible_if": "{{ section.settings.heading_group_button_show }}"
    },
    {
      "type": "checkbox",
      "id": "heading_group_enable_border_bottom",
      "default": true,
      "label": "t:sections.all.borders.enable_border_bottom.label",
      "visible_if": "{{ section.settings.heading != blank or section.settings.subheading != blank or section.settings.heading_group_button_show }}"
    },
    {
      "type": "header",
      "content": "t:sections.product-details.settings.content_options.content"
    },
    {
      "type": "inline_richtext",
      "id": "description",
      "default": "t:sections.product-details.settings.description.default",
      "label": "t:sections.all.text.label"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "t:sections.product-details.settings.enable_animation.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.product-details.settings.image_primary.content"
    },
    {
      "type": "image_picker",
      "id": "image_primary",
      "label": "t:sections.all.image.label"
    },
    {
      "type": "select",
      "id": "aspect_ratio_primary",
      "options": [
        {
          "value": "landscape",
          "label": "t:sections.all.card.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.all.card.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.all.card.image_ratio.options__3.label"
        },
        {
          "value": "adapt-to-image",
          "label": "t:sections.all.card.image_ratio.options__4.label"
        }
      ],
      "default": "portrait",
      "label": "t:sections.all.card.image_ratio.label"
    },
    {
      "type": "inline_richtext",
      "id": "description_primary",
      "default": "t:sections.product-details.settings.description_primary.default",
      "label": "t:sections.all.text.label"
    },
    {
      "type": "checkbox",
      "id": "enable_parallax",
      "label": "t:sections.product-details.settings.enable_parallax.label",
      "info": "t:sections.product-details.settings.enable_parallax.info",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.product-details.settings.image_secondary.content"
    },
    {
      "type": "image_picker",
      "id": "image_secondary",
      "label": "t:sections.all.image.label"
    },
    {
      "type": "select",
      "id": "aspect_ratio_secondary",
      "options": [
        {
          "value": "landscape",
          "label": "t:sections.all.card.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.all.card.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.all.card.image_ratio.options__3.label"
        },
        {
          "value": "adapt-to-image",
          "label": "t:sections.all.card.image_ratio.options__4.label"
        }
      ],
      "default": "portrait",
      "label": "t:sections.all.card.image_ratio.label"
    },
    {
      "type": "inline_richtext",
      "id": "description_secondary",
      "label": "t:sections.all.text.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "l",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.product-details.name",
      "category": "t:sections.categories.storytelling"
    }
  ]
}
{% endschema %}
