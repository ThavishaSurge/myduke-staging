{{ 'section-product-recommendations.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

{%- style -%}
  {% render 'section-padding' %}
  {% render 'section-margin' %}
{%- endstyle -%}

<div
  class="product-recommendations section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} background mydk-product-container-auth"
  style="--gap: 24px;"
  data-list-id="{% if collection %}{{ collection.id }}{% else %}all{% endif %}"
data-list-name="{% if collection %}{{ collection.handle | capitalize }}{% else %}All{% endif %}"
>
  <product-recommendations
    data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ section.settings.products_limit }}"
    data-layout="{{ section.settings.layout }}"
  >
    {%- if recommendations.performed -%}
      {%- if recommendations.products_count > 0 -%}
        {% comment %} RENDER HEADING GROUP {% endcomment %}
        {%- liquid
          assign has_slider_controls = false
          if section.settings.layout == 'slider' and section.settings.enable_slider_controls
            assign has_slider_controls = true
          endif
        -%}
        {% render 'heading-group',
          settings: section.settings,
          class: 'product-recommendations-header',
          has_slider_controls: has_slider_controls
        %}

        {% comment %} RENDER MAIN CONTENT {% endcomment %}
        <div
          class="product-recommendations__layout container product-recommendations__layout--spacing-gap{% if section.settings.layout == 'slider' %} js-recommendation-slider swiper{% endif %}"
          {% if section.settings.layout == 'slider' %}
            data-products-per-row="{{ section.settings.products_per_row }}"
            data-products-per-row-mobile="{{ section.settings.products_per_row_mobile }}"
            data-space-between="24"
          {% endif %}
        >
          <div class="product-recommendations__list product-recommendations__list--{{ section.settings.products_per_row }} product-recommendations__list--mobile-{{ section.settings.products_per_row_mobile }} product-recommendations__list--{{ section.settings.layout }}{% if section.settings.layout == 'slider' %} swiper-wrapper{% endif %}">
            {%- for recommendation in recommendations.products -%}
              <div class="product-recommendations__item{% if section.settings.layout == 'slider' %} swiper-slide{% endif %}">
                {% render 'product-card',
                  product_card_product: recommendation,
                  section_obj: section,
                  section_id: section.id,
                  forloop_index: forloop.index,
                  columns: section.settings.products_per_row,
                  columns_mobile: section.settings.products_per_row_mobile,
                  show_quick_view_overwrite: section.settings.show_quick_view,
                  heading_tag: 'h3'
                %}
              </div>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="product-recommendations__loading" style="display: none;">
        {% render 'icon-loading' %}
      </div>
    {%- endif -%}
  </product-recommendations>
</div>

{% schema %}
{
