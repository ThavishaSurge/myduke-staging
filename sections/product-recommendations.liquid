        {
          "value": "grid",
          "label": "t:sections.all.section_layout.options__2.label"
        }
      ],
      "default": "slider"
    },
    {
      "type": "range",
      "id": "products_limit",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 6,
      "label": "t:sections.product-recommendations.settings.products_limit.label"
    },
    {
      "type": "range",
      "id": "products_per_row",
