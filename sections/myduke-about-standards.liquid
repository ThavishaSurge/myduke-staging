{{ 'myduke-about-standards.css' | asset_url | stylesheet_tag }}

{% style %}
  .myduke-about-standards[data-section-id="{{ section.id }}"] {
    {%- if section.settings.bg_image != blank -%}
    background-image: url('{{ section.settings.bg_image | image_url: width: 1920 }}');
    background-size: cover;
    background-position: center;
    background-attachment: scroll;
    {%- else -%}
    background: #264653;
    {%- endif -%}
  }
{% endstyle %}

<section
  class="myduke-about-standards"
  data-section-id="{{ section.id }}"
>
  <div class="myduke-about-standards__card">

    <div class="myduke-about-standards__heading-group">
      {%- if section.settings.eyebrow != blank -%}
        <p class="myduke-about-standards__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="myduke-about-standards__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="myduke-about-standards__description">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    <div class="myduke-about-standards__table">

      {%- comment -%} Header row {%- endcomment -%}
      <div class="myduke-about-standards__header-row">
        <div class="myduke-about-standards__col-feature"></div>
        <div class="myduke-about-standards__col-myduke">
          {%- if section.settings.myduke_logo != blank -%}
            <img
              src="{{ section.settings.myduke_logo | image_url: width: 200 }}"
              alt="MyDuke"
              width="{{ section.settings.myduke_logo.width }}"
              height="{{ section.settings.myduke_logo.height }}"
              loading="lazy"
            >
          {%- endif -%}
        </div>
        <div class="myduke-about-standards__col-standard">
          <span class="myduke-about-standards__standard-label">
            {{ section.settings.standard_clinic_label | default: 'Standard Clinic' }}
          </span>
        </div>
      </div>

      {%- comment -%} Data rows {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'row' and block.settings.feature != blank -%}
          <div class="myduke-about-standards__row" {{ block.shopify_attributes }}>

            <div class="myduke-about-standards__col-feature">
              <span class="myduke-about-standards__feature-text">{{ block.settings.feature }}</span>
            </div>

            <div class="myduke-about-standards__col-myduke">
              <span class="myduke-about-standards__check-icon" aria-label="Yes">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M8 0C6.41775 0 4.87104 0.469192 3.55544 1.34824C2.23985 2.22729 1.21447 3.47672 0.608967 4.93853C0.00346629 6.40034 -0.15496 8.00887 0.153721 9.56072C0.462403 11.1126 1.22433 12.538 2.34315 13.6569C3.46197 14.7757 4.88743 15.5376 6.43928 15.8463C7.99113 16.155 9.59966 15.9965 11.0615 15.391C12.5233 14.7855 13.7727 13.7602 14.6518 12.4446C15.5308 11.129 16 9.58225 16 8C16 5.87827 15.1571 3.84344 13.6569 2.34315C12.1566 0.842855 10.1217 0 8 0ZM12.62 5.46667L8.05334 11.66C8.0002 11.7324 7.93297 11.7933 7.8557 11.8391C7.77843 11.8849 7.6927 11.9146 7.60366 11.9265C7.51462 11.9383 7.42411 11.932 7.33756 11.908C7.25101 11.884 7.17021 11.8427 7.1 11.7867L3.84 9.18C3.77152 9.12499 3.71458 9.05698 3.67247 8.97989C3.63035 8.9028 3.60389 8.81814 3.59459 8.73079C3.5853 8.64344 3.59336 8.55511 3.61832 8.47088C3.64327 8.38666 3.68463 8.30819 3.74 8.24C3.85078 8.10557 4.00977 8.01984 4.18296 8.00115C4.35614 7.98247 4.52976 8.0323 4.66667 8.14L7.38667 10.3133L11.5467 4.66667C11.6516 4.5261 11.8078 4.43257 11.9813 4.40636C12.1547 4.38015 12.3315 4.42338 12.4733 4.52667C12.5453 4.57824 12.6064 4.64364 12.6528 4.71906C12.6993 4.79447 12.7302 4.87839 12.7439 4.9659C12.7575 5.05341 12.7536 5.14277 12.7323 5.22875C12.7111 5.31473 12.6729 5.39561 12.62 5.46667Z" fill="#218380"/>
                </svg>
              </span>
            </div>

            <div class="myduke-about-standards__col-standard">
              {%- if block.settings.standard_result == 'check' -%}
                <span class="myduke-about-standards__check-icon" aria-label="Yes">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M8 0C6.41775 0 4.87104 0.469192 3.55544 1.34824C2.23985 2.22729 1.21447 3.47672 0.608967 4.93853C0.00346629 6.40034 -0.15496 8.00887 0.153721 9.56072C0.462403 11.1126 1.22433 12.538 2.34315 13.6569C3.46197 14.7757 4.88743 15.5376 6.43928 15.8463C7.99113 16.155 9.59966 15.9965 11.0615 15.391C12.5233 14.7855 13.7727 13.7602 14.6518 12.4446C15.5308 11.129 16 9.58225 16 8C16 5.87827 15.1571 3.84344 13.6569 2.34315C12.1566 0.842855 10.1217 0 8 0ZM12.62 5.46667L8.05334 11.66C8.0002 11.7324 7.93297 11.7933 7.8557 11.8391C7.77843 11.8849 7.6927 11.9146 7.60366 11.9265C7.51462 11.9383 7.42411 11.932 7.33756 11.908C7.25101 11.884 7.17021 11.8427 7.1 11.7867L3.84 9.18C3.77152 9.12499 3.71458 9.05698 3.67247 8.97989C3.63035 8.9028 3.60389 8.81814 3.59459 8.73079C3.5853 8.64344 3.59336 8.55511 3.61832 8.47088C3.64327 8.38666 3.68463 8.30819 3.74 8.24C3.85078 8.10557 4.00977 8.01984 4.18296 8.00115C4.35614 7.98247 4.52976 8.0323 4.66667 8.14L7.38667 10.3133L11.5467 4.66667C11.6516 4.5261 11.8078 4.43257 11.9813 4.40636C12.1547 4.38015 12.3315 4.42338 12.4733 4.52667C12.5453 4.57824 12.6064 4.64364 12.6528 4.71906C12.6993 4.79447 12.7302 4.87839 12.7439 4.9659C12.7575 5.05341 12.7536 5.14277 12.7323 5.22875C12.7111 5.31473 12.6729 5.39561 12.62 5.46667Z" fill="#218380"/>
                  </svg>
                </span>
              {%- elsif block.settings.standard_result == 'cross' -%}
                <span class="myduke-about-standards__cross-icon" aria-label="No">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <rect width="16" height="16" rx="8" fill="#939393"/>
                    <path d="M4.47266 11.5278L11.5298 4.4707" stroke="white" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M4.47266 4.4707L11.5298 11.5278" stroke="white" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              {%- elsif block.settings.standard_result == 'varies' -%}
                <span class="myduke-about-standards__varies-text">Varies</span>
              {%- endif -%}
            </div>

          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>

    {%- if section.settings.button_text != blank -%}
      <div class="myduke-about-standards__cta">
        <a
          href="{{ section.settings.button_link | default: '#' }}"
          class="myduke-about-standards__button"
        >
          {{- section.settings.button_text -}}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Standards (About)",
  "tag": "section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "header",
      "content": "Card"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "The MyDuke Difference"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Why Choose MyDuke?"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Table Header"
    },
    {
      "type": "image_picker",
      "id": "myduke_logo",
      "label": "MyDuke Logo"
    },
    {
      "type": "text",
      "id": "standard_clinic_label",
      "label": "Standard Clinic Label",
      "default": "Standard Clinic"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Start your assessment"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Comparison Row",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Feature"
        },
        {
          "type": "select",
          "id": "standard_result",
          "label": "Standard Clinic Result",
          "default": "cross",
          "options": [
            { "value": "check", "label": "Checkmark (Yes)" },
            { "value": "cross", "label": "Cross (No)" },
            { "value": "varies", "label": "Varies" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Standards (About)",
      "blocks": [
        {
          "type": "row",
          "settings": {
            "feature": "AHPRA-registered doctor review",
            "standard_result": "varies"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "Specialist pharmacy dispensing",
            "standard_result": "cross"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "Structured tapering protocol",
            "standard_result": "cross"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "Ongoing clinical follow-up",
            "standard_result": "cross"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "TGA-compliant products only",
            "standard_result": "varies"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "Transparent pricing, no upsells",
            "standard_result": "cross"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "Digital health assessment",
            "standard_result": "check"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "Nicotine strength management",
            "standard_result": "cross"
          }
        }
      ]
    }
  ]
}
{% endschema %}
