{% style %}
  {% render 'section-padding' %}
  {% render 'section-margin' %}

  /* ── Cost Calculator section ── */

  .myduke-calc {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 8rem;
    padding-bottom: 8rem;
    padding-left: 1rem;
    padding-right: 1rem;
    {%- if section.settings.bg_image == blank -%}
    background: #f0a11f;
    {%- endif -%}
  }

  .myduke-calc__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Card ── */
  .myduke-calc__card {
    position: relative;
    z-index: 1;
    background: #ffffff;
    backdrop-filter: blur(2.4rem);
    -webkit-backdrop-filter: blur(2.4rem);
    border: 2px solid rgba(255, 255, 255, 0.2);
    padding: 4.8rem;
    width: 100%;
    max-width: 63.1rem;
    display: flex;
    flex-direction: column;
    gap: 4.8rem;
  }

  /* ── Heading ── */
  .myduke-calc__heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    font-size: 3.2rem;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #264653;
    margin: 0;
  }

  /* ── Queries block ── */
  .myduke-calc__queries {
    display: flex;
    flex-direction: column;
    gap: 2.4rem;
  }

  .myduke-calc__count-group {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }

  .myduke-calc__count-label {
    font-family: var(--font-body-family);
    font-size: calc(var(--font-body-scale) * 1.4rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #264653;
    margin: 0;
  }

  .myduke-calc__count-display {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    font-size: 4.8rem;
    line-height: 1.1;
    letter-spacing: -0.038em;
    color: #264653;
    margin: 0;
  }

  /* ── Slider ── */
  .myduke-calc__slider-wrap {
    height: 3.2rem;
    display: flex;
    align-items: center;
    width: 100%;
  }

  .myduke-calc__slider {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 1rem;
    background: transparent;
    outline: none;
    cursor: pointer;
    margin: 0;
    padding: 0;
  }

  /* Track — webkit: filled left portion via CSS variable set by JS */
  .myduke-calc__slider::-webkit-slider-runnable-track {
    height: 1rem;
    border-radius: 9.9rem;
    background: linear-gradient(
      to right,
      #218380 var(--calc-fill, 0%),
      #edf3f0 var(--calc-fill, 0%)
    );
  }

  /* Track — firefox */
  .myduke-calc__slider::-moz-range-track {
    height: 1rem;
    border-radius: 9.9rem;
    background: #edf3f0;
    border: none;
  }

  .myduke-calc__slider::-moz-range-progress {
    height: 1rem;
    border-radius: 9.9rem 0 0 9.9rem;
    background: #218380;
  }

  /* Thumb — dot-grid handle matching Figma */
  .myduke-calc__slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 4.2rem;
    height: 3.2rem;
    margin-top: -1.1rem;
    background-color: #ffffff;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-radius: 0.8rem;
    cursor: grab;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    background-image: radial-gradient(circle, #264653 1.5px, transparent 1.5px);
    background-size: 6px 6px;
    background-position: center;
    background-repeat: repeat;
  }

  .myduke-calc__slider::-moz-range-thumb {
    width: 4.2rem;
    height: 3.2rem;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-radius: 0.8rem;
    background-color: #ffffff;
    cursor: grab;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    background-image: radial-gradient(circle, #264653 1.5px, transparent 1.5px);
    background-size: 6px 6px;
    background-position: center;
    background-repeat: repeat;
  }

  .myduke-calc__slider:active::-webkit-slider-thumb { cursor: grabbing; }
  .myduke-calc__slider:active::-moz-range-thumb { cursor: grabbing; }

  /* ── Info list rows ── */
  .myduke-calc__list {
    display: flex;
    flex-direction: column;
  }

  .myduke-calc__list-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.2rem 0;
    border-bottom: 1px solid #efece6;
    font-family: var(--font-body-family);
    font-size: calc(var(--font-body-scale) * 1.4rem);
    line-height: 1.4;
    color: #264653;
  }

  .myduke-calc__list-row--facts {
    flex-direction: column;
    align-items: flex-start;
    gap: 1.2rem;
  }

  .myduke-calc__facts-header {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    width: 100%;
  }

  .myduke-calc__facts-icon {
    flex-shrink: 0;
    display: block;
    width: 1.8rem;
    height: 1.8rem;
  }

  .myduke-calc__facts-title {
    font-family: var(--font-body-family);
    font-size: calc(var(--font-body-scale) * 1.4rem);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #264653;
    margin: 0;
  }

  .myduke-calc__facts-list {
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .myduke-calc__facts-list li {
    font-family: var(--font-body-family);
    font-size: calc(var(--font-body-scale) * 1.4rem);
    line-height: 1.4;
    color: #264653;
  }

  /* ── Savings result tiles ── */
  .myduke-calc__savings {
    display: flex;
    gap: 1.2rem;
  }

  .myduke-calc__tile {
    flex: 1 0 0;
    min-width: 0;
    padding: 3.2rem;
    display: flex;
    flex-direction: column;
    gap: 6.4rem;
    overflow: hidden;
  }

  .myduke-calc__tile--week { background: #ffe4a0; }
  .myduke-calc__tile--year { background: #edf3f0; }

  .myduke-calc__tile-label {
    font-family: var(--font-body-family);
    font-size: calc(var(--font-body-scale) * 1.4rem);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1;
    color: #000000;
    margin: 0;
  }

  .myduke-calc__tile-value {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: 300;
    font-size: 3.6rem;
    line-height: 1.2;
    letter-spacing: -0.04em;
    color: #000000;
    margin: 0;
  }

  /* ── CTA row ── */
  .myduke-calc__cta {
    display: flex;
    align-items: center;
    gap: 1.6rem;
  }

  .myduke-calc__cta-text {
    flex: 1 0 0;
    min-width: 0;
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    font-size: calc(var(--font-body-scale) * 1.6rem);
    line-height: 1.4;
    letter-spacing: -0.02em;
    color: #264653;
    margin: 0;
  }

  .myduke-calc__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #218380;
    color: #ffffff;
    font-family: var(--font-button-family);
    font-style: var(--font-button-style);
    font-weight: 500;
    font-size: calc(var(--font-button-scale) * 1rem);
    letter-spacing: var(--font-button-letter-spacing);
    text-transform: capitalize;
    padding: 0.95rem 3.6rem;
    min-height: 4rem;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 200ms ease;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .myduke-calc__btn:hover {
    background: #264653;
    color: #ffffff;
  }

  /* ── Responsive ── */
  @media screen and (max-width: 989px) {
    .myduke-calc__card {
      padding: 3.2rem;
      gap: 3.2rem;
    }
    .myduke-calc__heading {
      font-size: 2.6rem;
    }
    .myduke-calc__tile {
      gap: 3.2rem;
    }
  }

  @media screen and (max-width: 575px) {
    .myduke-calc {
      padding-top: 4rem;
      padding-bottom: 4rem;
      padding-left: 1.2rem;
      padding-right: 1.2rem;
    }
    .myduke-calc__card {
      padding: 2.4rem;
      gap: 2.4rem;
    }
    .myduke-calc__heading {
      font-size: 2.2rem;
    }
    .myduke-calc__count-display {
      font-size: 3.6rem;
    }
    .myduke-calc__savings {
      flex-direction: column;
    }
    .myduke-calc__tile {
      gap: 2.4rem;
    }
    .myduke-calc__cta {
      flex-direction: column;
      align-items: flex-start;
    }
    .myduke-calc__btn {
      width: 100%;
      text-align: center;
    }
  }
{% endstyle %}

{%- liquid
  assign slider_min     = section.settings.slider_min
  assign slider_max     = section.settings.slider_max
  assign slider_default = section.settings.slider_default
  assign cost_raw       = section.settings.cost_per_cigarette | default: '2.00'
-%}

<div class="myduke-calc color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding section-{{ section.id }}-margin">

  {%- if section.settings.bg_image != blank -%}
    {{
      section.settings.bg_image
      | image_url: width: 1920
      | image_tag:
        class: 'myduke-calc__bg',
        loading: 'lazy',
        widths: '768, 1024, 1440, 1920',
        sizes: '100vw',
        alt: ''
    }}
  {%- endif -%}

  <div class="myduke-calc__card">

    {%- if section.settings.heading != blank -%}
      <{{ section.settings.heading_tag }} class="myduke-calc__heading">
        {{ section.settings.heading }}
      </{{ section.settings.heading_tag }}>
    {%- endif -%}

    <div class="myduke-calc__queries">

      <div class="myduke-calc__count-group">
        <p class="myduke-calc__count-label">{{ section.settings.slider_label }}</p>
        <p class="myduke-calc__count-display">
          <span id="myduke-calc-count-{{ section.id }}">{{ slider_default }}</span>&nbsp;{{ section.settings.slider_unit }}
        </p>
      </div>

      <div class="myduke-calc__slider-wrap">
        <input
          type="range"
          class="myduke-calc__slider"
          id="myduke-calc-slider-{{ section.id }}"
          min="{{ slider_min }}"
          max="{{ slider_max }}"
          value="{{ slider_default }}"
          aria-label="{{ section.settings.slider_label }}"
        >
      </div>

      <div class="myduke-calc__list">

        <div class="myduke-calc__list-row">
          <span>{{ section.settings.cost_label }}</span>
          <span>${{ cost_raw }}{%- if section.settings.show_gst_label -%}+GST{%- endif -%}</span>
        </div>

        {%- if section.blocks.size > 0 -%}
          <div class="myduke-calc__list-row myduke-calc__list-row--facts">
            <div class="myduke-calc__facts-header">
              <svg class="myduke-calc__facts-icon" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                <circle cx="9" cy="9" r="8" stroke="#264653" stroke-width="1.2"/>
                <path d="M9 8v4.5" stroke="#264653" stroke-width="1.2" stroke-linecap="round"/>
                <circle cx="9" cy="5.5" r="0.8" fill="#264653"/>
              </svg>
              <p class="myduke-calc__facts-title">{{ section.settings.facts_label }}</p>
            </div>
            <ul class="myduke-calc__facts-list">
              {%- for block in section.blocks -%}
                {%- if block.settings.fact_text != blank -%}
                  <li {{ block.shopify_attributes }}>{{ block.settings.fact_text }}</li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

      </div>
    </div>

    <div class="myduke-calc__savings">
      <div class="myduke-calc__tile myduke-calc__tile--week">
        <p class="myduke-calc__tile-label">{{ section.settings.weekly_label }}</p>
        <p class="myduke-calc__tile-value" id="myduke-calc-weekly-{{ section.id }}">$0.00</p>
      </div>
      <div class="myduke-calc__tile myduke-calc__tile--year">
        <p class="myduke-calc__tile-label">{{ section.settings.yearly_label }}</p>
        <p class="myduke-calc__tile-value" id="myduke-calc-yearly-{{ section.id }}">$0.00</p>
      </div>
    </div>

    {%- if section.settings.cta_text != blank or section.settings.cta_button_label != blank -%}
      <div class="myduke-calc__cta">
        {%- if section.settings.cta_text != blank -%}
          <p class="myduke-calc__cta-text">{{ section.settings.cta_text }}</p>
        {%- endif -%}
        {%- if section.settings.cta_button_label != blank -%}
          <a
            href="{{ section.settings.cta_button_url | default: '#' }}"
            class="myduke-calc__btn"
            {% if settings.links_blank and section.settings.cta_button_url != blank %}target="_blank" rel="noopener noreferrer"{% endif %}
          >
            {{- section.settings.cta_button_label -}}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</div>

<script>
(function () {
  var slider = document.getElementById('myduke-calc-slider-{{ section.id }}');
  if (!slider) return;

  var countEl  = document.getElementById('myduke-calc-count-{{ section.id }}');
  var weeklyEl = document.getElementById('myduke-calc-weekly-{{ section.id }}');
  var yearlyEl = document.getElementById('myduke-calc-yearly-{{ section.id }}');
  var costPerCig = parseFloat('{{ cost_raw | escape }}') || 2.00;

  function fmt(n) {
    return '$' + n.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }

  function updateFill() {
    var min = parseFloat(slider.min) || 1;
    var max = parseFloat(slider.max) || 60;
    var pct = ((parseFloat(slider.value) - min) / (max - min)) * 100;
    slider.style.setProperty('--calc-fill', pct.toFixed(2) + '%');
  }

  function calc() {
    var cigs = parseInt(slider.value, 10);
    countEl.textContent = cigs;
    weeklyEl.textContent = fmt(cigs * 7 * costPerCig);
    yearlyEl.textContent = fmt(cigs * 365 * costPerCig);
    updateFill();
  }

  slider.addEventListener('input', calc);
  calc();
})();
</script>

{% schema %}
{
  "name": "Cost Calculator (MyDuke)",
  "class": "myduke-calc-section",
  "tag": "section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "background-1",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image",
      "info": "Full-bleed image behind the card. Falls back to amber if unset."
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.all.heading.label",
      "default": "See What You Could Save"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        { "value": "h1", "label": "t:sections.all.heading_tag.options__1.label" },
        { "value": "h2", "label": "t:sections.all.heading_tag.options__2.label" },
        { "value": "h3", "label": "t:sections.all.heading_tag.options__3.label" },
        { "value": "h4", "label": "t:sections.all.heading_tag.options__4.label" },
        { "value": "h5", "label": "t:sections.all.heading_tag.options__5.label" },
        { "value": "h6", "label": "t:sections.all.heading_tag.options__6.label" },
        { "value": "div", "label": "t:sections.all.heading_tag.options__7.label" }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_tag.label",
      "info": "t:sections.all.heading_tag.info",
      "visible_if": "{{ section.settings.heading != blank }}"
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "text",
      "id": "slider_label",
      "label": "Slider label",
      "default": "Cigarettes per day"
    },
    {
      "type": "text",
      "id": "slider_unit",
      "label": "Count unit",
      "default": "Cigarettes",
      "info": "Text shown after the number, e.g. \"Cigarettes\"."
    },
    {
      "type": "range",
      "id": "slider_min",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 1,
      "label": "Slider minimum"
    },
    {
      "type": "range",
      "id": "slider_max",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 60,
      "label": "Slider maximum"
    },
    {
      "type": "range",
      "id": "slider_default",
      "min": 1,
      "max": 100,
      "step": 1,
      "default": 30,
      "label": "Default value",
      "info": "Initial slider position. Must be between minimum and maximum."
    },
    {
      "type": "header",
      "content": "Cost"
    },
    {
      "type": "text",
      "id": "cost_per_cigarette",
      "label": "Cost per cigarette ($)",
      "default": "2.00",
      "info": "Numeric value only, e.g. \"2.00\". Drives the weekly and yearly savings calculation."
    },
    {
      "type": "text",
      "id": "cost_label",
      "label": "Cost row label",
      "default": "Cost per cigarette"
    },
    {
      "type": "checkbox",
      "id": "show_gst_label",
      "label": "Show \"+GST\" suffix on cost",
      "default": true
    },
    {
      "type": "header",
      "content": "Quick Facts"
    },
    {
      "type": "text",
      "id": "facts_label",
      "label": "Facts section label",
      "default": "Quick Facts"
    },
    {
      "type": "header",
      "content": "Results"
    },
    {
      "type": "text",
      "id": "weekly_label",
      "label": "Weekly tile label",
      "default": "Savings per week"
    },
    {
      "type": "text",
      "id": "yearly_label",
      "label": "Yearly tile label",
      "default": "Savings per year"
    },
    {
      "type": "header",
      "content": "CTA"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "Ready to start saving"
    },
    {
      "type": "text",
      "id": "cta_button_label",
      "label": "Button label",
      "default": "Start your assessment"
    },
    {
      "type": "url",
      "id": "cta_button_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-padding.header.content"
    },
    {
      "type": "select",
      "id": "padding_top",
      "options": [
        { "value": "no-indent", "label": "t:sections.all.section-padding.options__1.label" },
