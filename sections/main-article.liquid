{{ 'section-main-article.css' | asset_url | stylesheet_tag }}

<script src="{{ 'copy.js' | asset_url }}" defer="defer"></script>

{% assign template_base = template | split: '.' | first %}
{%- style -%}
  {% render 'section-padding' %}
{%- endstyle -%}
{%- if settings.show_breadcrumbs and template_base == 'article' -%}
  {% render 'breadcrumbs' %}
{%- endif -%}
<article
  class="article-template article-template-{{ section.id }} section-{{ section.id }}-padding"
  itemscope
  itemtype="http://schema.org/BlogPosting"
>
  <div class="article-template-blocks container">
    <div class="article-template-box ">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'article-header' -%}
            {% liquid
              assign show_meta = false

              if block.settings.blog_show_tags == true or block.settings.blog_show_author == true or block.settings.blog_show_date == true
                assign show_meta = true
              endif
            %}
            {% liquid
              assign show_share_block = false
              assign has_at_least_one_share = false

              if block.settings.show_share_facebook or block.settings.show_share_twitter or block.settings.show_share_pinterest or block.settings.show_share_copy or block.settings.show_share_telegram
                assign has_at_least_one_share = true
              endif

              if block.settings.show_share and has_at_least_one_share
                assign show_share_block = true
              endif
            %}
            <div class="article-template-box_list {% if show_share_block != true and show_meta != true %} article-template-box_list_none{% endif %} ">
              <div class="article-template-header-info ">
                {% if show_meta == true %}
                  <div class="article-template-header-text">
                    <div class="article-template-header-meta">
                      {%- if block.settings.blog_show_tags and article.tags.size > 0 -%}
                        <ul class="article-template-tags list-unstyled">
                          {%- for tag in article.tags -%}
                            <li class="article-template-tag">
                              <a
                                class="article-template-tag__link body-small"
                                href="{{ blog.url }}/tagged/{{ tag | handle }}"
                                aria-label="{{- tag -}}"
                              >
                                <span>{{- tag -}}</span>
                              </a>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}
                      {%- if block.settings.blog_show_author == true -%}
                        <span class="article-template-author body-small">
                          <span>{{ 'general.blog.author' | t }}&nbsp;</span>
                          <span
                            itemprop="author"
                            itemscope
                            itemtype="http://schema.org/Person"
                          >
                            {{ article.author }}
                          </span>
                        </span>
                      {%- endif -%}
                      {%- if block.settings.blog_show_date == true -%}
                        <span class="article-template-date body-small">
                          {{ article.published_at | time_tag: '%d.%m.%y' }}
                        </span>
                      {%- endif -%}
                    </div>
                  </div>
                {% endif %}
                {% if show_meta == true and show_share_block == true %}
                  <div class="article-template-delimiter"></div>
                {% endif %}
                {%- if show_share_block -%}
                  <div class="article-template-share">
                    <span class="article-template-share__title body-small">{{ 'blogs.article.share' | t }}</span>
                    <ul class="article-template-share-list list-unstyled">
                      {%- if block.settings.show_share_facebook -%}
                        <li class="article-template-share-list__item">
                          <a
                            href="https://www.facebook.com/sharer.php?u={{ shop.url | append: article.url }}"
                            class="article-template-share-list__button button button--tertiary body-small facebook-btn focus-inset"
                            target="_blank"
                            aria-label="{{ 'general.share.links.facebook' | t }}"
                          >
                            <span>{{ 'general.share.links.facebook' | t }}</span>
                          </a>
                        </li>
                      {%- endif -%}

                      {%- if block.settings.show_share_twitter -%}
                        <li class="article-template-share-list__item">
                          <a
                            href="https://twitter.com/share?url={{ shop.url | append: article.url }}&text={{ article.title | escape }}"
                            class="article-template-share-list__button button button--tertiary body-small twitter-btn focus-inset"
                            target="_blank"
                            aria-label="{{ 'general.share.links.twitter' | t }}"
                          >
                            <span>{{ 'general.share.links.twitter' | t }}</span>
                          </a>
                        </li>
                      {%- endif -%}

                      {%- if block.settings.show_share_telegram -%}
                        <li class="article-template-share-list__item">
                          <a
                            href="https://t.me/share/url?url={{ shop.url | append: article.url }}&text={{ article.title | escape }}"
                            class="article-template-share-list__button button button--tertiary body-small telegram-btn focus-inset"
                            target="_blank"
                            aria-label="{{ 'general.share.links.telegram' | t }}"
                          >
                            <span>{{ 'general.share.links.telegram' | t }}</span>
                          </a>
                        </li>
                      {%- endif -%}

                      {%- if block.settings.show_share_pinterest and article.image != blank -%}
                        <li class="article-template-share-list__item">
                          {%- assign height = article.image.width
                            | divided_by: article.image.aspect_ratio
                            | round: 2
                          -%}
                          <a
                            href="https://pinterest.com/pin/create/bookmarklet/?media={{ article.image | image_url: width: article.image.width, height: height }}&url={{ shop.url | append: article.url }}&description={{ article.title | escape }}"
                            class="article-template-share-list__button button button--tertiary body-small pinterest-btn focus-inset"
                            target="_blank"
                            aria-label="{{ 'general.share.links.pinterest' | t }}"
                          >
                            <span>{{ 'general.share.links.pinterest' | t }}</span>
                          </a>
                        </li>
                      {%- endif -%}

                      {%- if block.settings.show_share_copy -%}
                        <li class="article-template-share-list__item copy-btn">
                          <button
                            class="article-template-share-list__button button button--tertiary body-small  focus-inset"
                          >
                            {% render 'icon-copy' %}
                            <span class="article-template-share-list__button__label copy-btn__label">
                              {{- 'general.share.copy_to_clipboard' | t -}}
                            </span>
                          </button>
                          <span class="article-template-share-list__button__success subtitle copy-btn__success">
                            {{- 'general.share.success_message' | t -}}
                          </span>
                          <span class="article-template-share-list__button__error subtitle copy-btn__error">
                            {{- 'general.share.error_message' | t -}}
                          </span>
                        </li>
                      {%- endif -%}
                    </ul>
                  </div>
                {%- endif -%}
              </div>
            </div>
        {%- endcase -%}
      {%- endfor -%}

      <div class="article-template-blocks-box  {% if show_share_block != true and show_meta != true%} article-template-blocks-box_full{% endif %}">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
              {% comment %}-- -- -- -- -- -- -- APP BLOCK -- -- -- -- -- -- --{% endcomment %}
            {%- when '@app' -%}
              <div class="container page-width--narrow" {{ block.shopify_attributes }}>
                {% render block %}
              </div>
              {% comment %}-- -- -- -- -- -- -- ARTICLE HEADER BLOCK -- -- -- -- -- -- --{% endcomment %}
            {%- when 'article-header' -%}
              <header
                class="article-template-block {% if block.settings.show_image != true %} no-image-main{% endif %} article-template-header article-template-header-{{ block.id }}{% if block.settings.blog_show_date %} article-template-header--with-date{% endif %} "
                {{ block.shopify_attributes }}
              >
                {% liquid
                  assign article_image = blank
                  assign image_special_styles = ''
                  if article.image != blank and block.settings.image == blank
                    assign article_image = article.image
                  elsif block.settings.image != blank
                    assign article_image = block.settings.image
                    if article_image.focal_point != blank
                      assign image_special_styles = 'object-position: {{ article_image.presentation.focal_point }};'
                    else
                      assign image_special_styles = 'object-position: center center;'
                    endif
                  else
                    assign article_image = blank
                  endif

                  if block.settings.image_ratio_mobile != 'adapt' and block.settings.image_ratio_mobile != 'full_height'
                    assign aspect_ratio_mobile = block.settings.image_ratio_mobile | split: '/'
                    assign temp_mobile = aspect_ratio_mobile[0] | append: '.0'
                    assign padding_bottom_mobile = aspect_ratio_mobile[1] | divided_by: temp_mobile | times: 100 | round: 2
                  elsif block.settings.image_ratio_mobile == 'adapt'
                    assign padding_bottom_mobile = 1 | divided_by: article_image.aspect_ratio | times: 100 | round: 2
                  else
                    assign padding_bottom_mobile = 0
                  endif

                  if block.settings.image_ratio_desktop != 'adapt' and block.settings.image_ratio_desktop != 'full_height'
                    assign aspect_ratio_desktop = block.settings.image_ratio_desktop | split: '/'
                    assign temp_desktop = aspect_ratio_desktop[0] | append: '.0'
                    assign padding_bottom_desktop = aspect_ratio_desktop[1] | divided_by: temp_desktop | times: 100 | round: 2
                  elsif block.settings.image_ratio_desktop == 'adapt'
                    assign padding_bottom_desktop = 1 | divided_by: article_image.aspect_ratio | times: 100 | round: 2
                  else
                    assign padding_bottom_desktop = 0
                  endif
                %}
                <div class="article-template-header-wrapper {% if article_image == blank %} no-image{% endif %} ">
                  <div class="article-template-header-container">
                    {%- style -%}
                        .article-template-{{ section.id }} .article-template-header-{{ block.id }} .article-template-header-image-wrapper {
                          display: flex;
                        }
                        .article-template-{{ section.id }} .article-template-header-{{ block.id }} .article-template-header-image-wrapper::after {
                          content: '';
                          display: block;
                          width: 0;
                          padding-bottom: {{ padding_bottom_mobile }}%;
                        }
                        @media screen and (min-width: 750px) {
                          .article-template-{{ section.id }} .article-template-header-{{ block.id }} .article-template-header-image-wrapper::after {
                            content: '';
                            display: block;
                            width: 0;
                            padding-bottom: {{ padding_bottom_desktop }}%;
                          }
                        }


                      {% if block.settings.image_ratio_mobile == "full_height" %}

                          @media screen and (max-width: 749.99px) {
                            .article-template-{{ section.id }} .article-template-header-{{ block.id }} .article-template-header-image-wrapper {
                              min-height: 100vh;
                              min-height: 100svh;
                            }

                            main > .article-template-{{ section.id }} .article-template-header-{{ block.id }} .article-template-header-image-wrapper {
                              min-height: calc(100vh - var(--announcement-height) - var(--header-height));
                              min-height: calc(100svh - var(--announcement-height) - var(--header-height));
                            }
                          }

                      {% endif %}

                      {% if block.settings.image_ratio_desktop == "full_height" %}
                        @media screen and (min-width: 750px) {
                          .article-template-{{ section.id }} .article-template-header-{{ block.id }} .article-template-header-image-wrapper {
                            min-height: 100vh;
                            min-height: 100svh;
                          }

                          .article-template-{{ section.id }} .article-template-header-{{ block.id }} .article-template-header-image-wrapper {
                            min-height: calc(100vh - var(--announcement-height) - var(--header-height));
                            min-height: calc(100svh - var(--announcement-height) - var(--header-height));
                          }
                        }
                      {% endif %}
                    {%- endstyle -%}
                    <div class="article-template-header-main">
                      <{{ block.settings.heading_tag | default: 'h1' }}
                        class="article-template-title {{ block.settings.heading_size | default: 'h2'}}"
                        itemprop="headline"
                      >
                        {{- article.title | escape -}}
                      </{{ block.settings.heading_tag | default: 'h1' }}>
                      {%- if block.settings.show_image == true -%}
                        <div class="article-template-header-image-wrapper">
                          {% liquid
                            # get mobile calc ratio
                            if block.settings.image_ratio_mobile != 'adapt' and block.settings.image_ratio_mobile != 'full_height'
                              assign settings_mobile_aspect_ratio = temp_mobile | divided_by: aspect_ratio_mobile[1] | round: 2
                            elsif block.settings.image_ratio_mobile == 'full_height'
                              assign settings_mobile_aspect_ratio = 0.45
                            else
                              assign settings_mobile_aspect_ratio = article_image.aspect_ratio
                            endif

                            assign calc_ratio_mobile = 1
                            if article_image.aspect_ratio > settings_mobile_aspect_ratio
                              assign calc_ratio_mobile = article_image.aspect_ratio | divided_by: settings_mobile_aspect_ratio | round: 2
                            endif

                            # get desktop calc ratio
                            if block.settings.image_ratio_desktop != 'adapt' and block.settings.image_ratio_desktop != 'full_height'
                              assign settings_desktop_aspect_ratio = temp_desktop | divided_by: aspect_ratio_desktop[1] | round: 2
                            elsif block.settings.image_ratio_desktop == 'full_height'
                              assign settings_desktop_aspect_ratio = 1.2
                            else
                              assign settings_desktop_aspect_ratio = article_image.aspect_ratio
                            endif

                            assign calc_ratio_mobile = 1
                            if article_image.aspect_ratio > settings_mobile_aspect_ratio
                              assign calc_ratio_mobile = article_image.aspect_ratio | divided_by: settings_mobile_aspect_ratio | round: 2
                            endif

                            assign calc_ratio_desktop = 1
                            if article_image.aspect_ratio > settings_desktop_aspect_ratio
                              assign calc_ratio_desktop = article_image.aspect_ratio | divided_by: settings_desktop_aspect_ratio | round: 2
                            endif

                            assign fetch_priority = 'auto'
                            assign image_loading = 'lazy'
                            if section.index == 1
                              assign fetch_priority = 'high'
                              assign image_loading = 'eager'
                            endif

                            assign widths = '360, 533, 720, 940, 1066, 1200, 1400, 1600, 1800, 2000, 2200, 2400, 2600, 2800, 3000, 3264, 3400, 3584, 3800, 4000, 4200, 4400, 4600, 4800, 5000, 5200, 5400, 5600, 6000'
                          %}
                          {%- capture sizes -%}
														(min-width: 750px) calc(100vw * {{ calc_ratio_desktop }}), calc(100vw * {{ calc_ratio_mobile }}) 
													{%- endcapture -%}

													{{calc_ratio_desktop }}
                          {% if article_image != blank %}
                            {{
                              article_image
                              | image_url: width: article_image.image_width
                              | image_tag:
                                width: article_image.image_width,
                                height: article_image.image_height,
                                widths: widths,
                                style: image_special_styles,
                                sizes: sizes,
                                class: 'article-template-header-image',
                                loading: image_loading,
                                fetchpriority: fetch_priority
                            }}

                          {% else %}
                            {% liquid
                              assign placeholder_classes = 'article-template-header-image placeholder-svg'
                              if block.settings.image_ratio_desktop == 'adapt'
                                assign placeholder_classes = placeholder_classes | append: ' ' | append: 'adapt-desktop article-template-header-image-placeholder'
                              endif
                              if block.settings.image_ratio_mobile == 'adapt'
                                assign placeholder_classes = placeholder_classes | append: ' ' | append: 'adapt-mobile media-image-placeholder'
                              endif
                            %}
                            {{ 'hero-apparel-1' | placeholder_svg_tag: placeholder_classes }}
                          {% endif %}
                          {%- if block.settings.overlay_opacity != 0 -%}
                            {%- capture overlay_style -%}
                          opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }}; background: rgba(var(--color-overlay));
                        {%- endcapture -%}
                            <span
                              class="article-template-header-overlay"
                              style="{{ overlay_style }}"
                            ></span>
                          {%- endif -%}
                        </div>
                      {% endif %}
                      {%- if article.excerpt.size > 0 and block.settings.blog_show_excerpt -%}
                        <div class="article-template-excerpt rte body-normal">
                          {{ article.excerpt }}
                        </div>
                      {%- endif -%}
                      {% liquid
                        assign show_meta = false

                        if block.settings.blog_show_tags == true or block.settings.blog_show_author == true or block.settings.blog_show_date == true
                          assign show_meta = true
                        endif
                      %}
                      {% liquid
                        assign show_share_block = false
                        assign has_at_least_one_share = false

                        if block.settings.show_share_facebook or block.settings.show_share_twitter or block.settings.show_share_pinterest or block.settings.show_share_copy or block.settings.show_share_telegram
                          assign has_at_least_one_share = true
                        endif

                        if block.settings.show_share and has_at_least_one_share
                          assign show_share_block = true
                        endif
                      %}

                      <div class="article-template-header-info_inner">
                        {% if show_meta == true %}
                          <div class="article-template-header-text">
                            <div class="article-template-header-meta">
                              {%- if block.settings.blog_show_tags and article.tags.size > 0 -%}
                                <ul class="article-template-tags list-unstyled">
                                  {%- for tag in article.tags -%}
                                    <li class="article-template-tag">
                                      <a
                                        class="article-template-tag__link body-small"
                                        href="{{ blog.url }}/tagged/{{ tag | handle }}"
                                        aria-label="{{- tag -}}"
                                      >
                                        <span>{{- tag -}}</span>
                                      </a>
                                    </li>
                                  {%- endfor -%}
                                </ul>
                              {%- endif -%}
                              {%- if block.settings.blog_show_author == true -%}
                                <span class="article-template-author body-small">
                                  <span>{{ 'general.blog.author' | t }}&nbsp;</span>
                                  <span
                                    itemprop="author"
                                    itemscope
                                    itemtype="http://schema.org/Person"
                                  >
                                    {{ article.author }}
                                  </span>
                                </span>
                              {%- endif -%}
                              {%- if block.settings.blog_show_date == true -%}
                                <span class="article-template-date body-small">
                                  {{ article.published_at | time_tag: '%d.%m.%y' }}
                                </span>
                              {%- endif -%}
                            </div>
                          </div>
                        {% endif %}
                        {%- if show_share_block -%}
                          <div class="article-template-share">
                            <span class="article-template-share__title body-small">
                              {{- 'blogs.article.share' | t -}}
                            </span>
                            <ul class="article-template-share-list list-unstyled">
                              {%- if block.settings.show_share_facebook -%}
                                <li class="article-template-share-list__item">
                                  <a
                                    href="https://www.facebook.com/sharer.php?u={{ shop.url | append: article.url }}"
                                    class="article-template-share-list__button button button--tertiary body-small facebook-btn focus-inset"
                                    target="_blank"
                                    aria-label="{{ 'general.share.links.facebook' | t }}"
                                  >
                                    <span>{{ 'general.share.links.facebook' | t }}</span>
                                  </a>
                                </li>
                              {%- endif -%}

                              {%- if block.settings.show_share_twitter -%}
                                <li class="article-template-share-list__item">
                                  <a
                                    href="https://twitter.com/share?url={{ shop.url | append: article.url }}&text={{ article.title | escape }}"
                                    class="article-template-share-list__button button button--tertiary body-small twitter-btn focus-inset"
                                    target="_blank"
                                    aria-label="{{ 'general.share.links.twitter' | t }}"
                                  >
                                    <span>{{ 'general.share.links.twitter' | t }}</span>
                                  </a>
                                </li>
                              {%- endif -%}

                              {%- if block.settings.show_share_telegram -%}
                                <li class="article-template-share-list__item">
                                  <a
                                    href="https://t.me/share/url?url={{ shop.url | append: article.url }}&text={{ article.title | escape }}"
                                    class="article-template-share-list__button button button--tertiary body-small telegram-btn focus-inset"
                                    target="_blank"
                                    aria-label="{{ 'general.share.links.telegram' | t }}"
                                  >
                                    <span>{{ 'general.share.links.telegram' | t }}</span>
                                  </a>
                                </li>
                              {%- endif -%}

                              {%- if block.settings.show_share_pinterest and article.image != blank -%}
                                <li class="article-template-share-list__item">
                                  {%- assign height = article.image.width
                                    | divided_by: article.image.aspect_ratio
                                    | round: 2
                                  -%}
                                  <a
                                    href="https://pinterest.com/pin/create/bookmarklet/?media={{ article.image | image_url: width: article.image.width, height: height }}&url={{ shop.url | append: article.url }}&description={{ article.title | escape }}"
                                    class="article-template-share-list__button button button--tertiary body-small pinterest-btn focus-inset"
                                    target="_blank"
                                    aria-label="{{ 'general.share.links.pinterest' | t }}"
                                  >
                                    <span>{{ 'general.share.links.pinterest' | t }}</span>
                                  </a>
                                </li>
                              {%- endif -%}

                              {%- if block.settings.show_share_copy -%}
                                <li class="article-template-share-list__item copy-btn">
                                  <button
                                    class="article-template-share-list__button button button--tertiary body-small  focus-inset"
                                  >
                                    {% render 'icon-copy' %}
                                    <span class="article-template-share-list__button__label copy-btn__label">
                                      {{- 'general.share.copy_to_clipboard' | t -}}
                                    </span>
                                  </button>
                                  <span class="article-template-share-list__button__success subtitle copy-btn__success">
                                    {{- 'general.share.success_message' | t -}}
                                  </span>
                                  <span class="article-template-share-list__button__error subtitle copy-btn__error">
                                    {{- 'general.share.error_message' | t -}}
                                  </span>
                                </li>
                              {%- endif -%}
                            </ul>
                          </div>
                        {%- endif -%}
                      </div>
                    </div>
                  </div>
                </div>
              </header>
              {% comment %}-- -- -- -- -- -- -- CONTENT BLOCK -- -- -- -- -- -- --{% endcomment %}
            {%- when 'content' -%}
              <div
                class="article-template-block article-template-content"
                itemprop="articleBody"
                {{ block.shopify_attributes }}
              >
                <div class="article-template-content__rte rte body-normal">
                  {{ article.content }}
                </div>
              </div>
              {% comment %}-- -- -- -- -- -- -- ARTICLE FOOTER BLOCK -- -- -- -- -- -- --{% endcomment %}
            {%- when 'article-footer' -%}
              {% liquid
                assign show_share_block = false
                assign has_at_least_one_share = false

                if block.settings.show_share_facebook or block.settings.show_share_twitter or block.settings.show_share_pinterest or block.settings.show_share_copy or block.settings.show_share_telegram
                  assign has_at_least_one_share = true
                endif

                if block.settings.show_share and has_at_least_one_share
                  assign show_share_block = true
                endif
              %}

              <footer
                class="article-template-block article-template-footer"
                {{ block.shopify_attributes }}
              >
                {%- if show_share_block
                  or block.settings.blog_show_author
                  or block.settings.blog_show_tags
                  or block.settings.blog_show_date
                -%}
                  <div class="article-template-footer-container">
                    <div class="article-template-footer-wrapper">
                      {%- if block.settings.blog_show_author
                        or block.settings.blog_show_date
                        or block.settings.blog_show_tags
                      -%}
                        <div class="article-template-footer-main">
                          {%- if block.settings.blog_show_tags and article.tags.size > 0 -%}
                            <ul class="article-template-tags list-unstyled">
                              {%- for tag in article.tags -%}
                                <li class="article-template-tag">
                                  <a
                                    class="article-template-tag__link body-small"
                                    href="{{ blog.url }}/tagged/{{ tag | handle }}"
                                    aria-label="{{- tag -}}"
                                  >
                                    <span>{{- tag -}}</span>
                                  </a>
                                </li>
                              {%- endfor -%}
                            </ul>
                          {%- endif -%}

                          {%- if block.settings.blog_show_author == true -%}
                            <span class="article-template-author body-small">
                              <span>{{ 'general.blog.author' | t }}&nbsp;</span>
                              <span
                                itemprop="author"
                                itemscope
                                itemtype="http://schema.org/Person"
                              >
                                {{ article.author }}
                              </span>
                            </span>
                          {%- endif -%}
                          {%- if block.settings.blog_show_date == true -%}
                            <span class="article-template-date body-small {% if block.settings.blog_show_author == false and block.settings.blog_show_tags == false %} article-template-date_none{% endif %}">
                              {{ article.published_at | time_tag: '%d.%m.%y' }}
                            </span>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                      {%- if show_share_block -%}
                        <div class="article-template-share">
                          <span class="article-template-share__title subtitle">{{ 'blogs.article.share' | t }}</span>
                          <ul class="article-template-share-list list-unstyled">
                            {%- if block.settings.show_share_facebook -%}
                              <li class="article-template-share-list__item">
                                <a
                                  href="https://www.facebook.com/sharer.php?u={{ shop.url | append: article.url }}"
                                  class="article-template-share-list__button button button--tertiary body-small facebook-btn focus-inset"
                                  target="_blank"
                                  aria-label="{{ 'general.share.links.facebook' | t }}"
                                >
                                  <span>{{ 'general.share.links.facebook' | t }}</span>
                                </a>
                              </li>
                            {%- endif -%}

                            {%- if block.settings.show_share_twitter -%}
                              <li class="article-template-share-list__item">
                                <a
                                  href="https://twitter.com/share?url={{ shop.url | append: article.url }}&text={{ article.title | escape }}"
                                  class="article-template-share-list__button button button--tertiary body-small twitter-btn focus-inset"
                                  target="_blank"
                                  aria-label="{{ 'general.share.links.twitter' | t }}"
                                >
                                  <span>{{ 'general.share.links.twitter' | t }}</span>
                                </a>
                              </li>
                            {%- endif -%}

                            {%- if block.settings.show_share_telegram -%}
                              <li class="article-template-share-list__item">
                                <a
                                  href="https://t.me/share/url?url={{ shop.url | append: article.url }}&text={{ article.title | escape }}"
                                  class="article-template-share-list__button button button--tertiary body-small telegram-btn focus-inset"
                                  target="_blank"
                                  aria-label="{{ 'general.share.links.telegram' | t }}"
                                >
                                  <span>{{ 'general.share.links.telegram' | t }}</span>
                                </a>
                              </li>
                            {%- endif -%}

                            {%- if block.settings.show_share_pinterest and article.image != blank -%}
                              <li class="article-template-share-list__item">
                                {%- assign height = article.image.width
                                  | divided_by: article.image.aspect_ratio
                                  | round: 2
                                -%}
                                <a
                                  href="https://pinterest.com/pin/create/bookmarklet/?media={{ article.image | image_url: width: article.image.width, height: height }}&url={{ shop.url | append: article.url }}&description={{ article.title | escape }}"
                                  class="article-template-share-list__button button button--tertiary body-small pinterest-btn focus-inset"
                                  target="_blank"
                                  aria-label="{{ 'general.share.links.pinterest' | t }}"
                                >
                                  <span>{{ 'general.share.links.pinterest' | t }}</span>
                                </a>
                              </li>
                            {%- endif -%}

                            {%- if block.settings.show_share_copy -%}
                              <li class="article-template-share-list__item copy-btn">
                                <button
                                  class="article-template-share-list__button button button--tertiary body-small  focus-inset"
                                >
                                  {% render 'icon-copy' %}
                                  <span class="article-template-share-list__button__label copy-btn__label">
                                    {{- 'general.share.copy_to_clipboard' | t -}}
                                  </span>
                                </button>
                                <span class="article-template-share-list__button__success subtitle copy-btn__success">
                                  {{- 'general.share.success_message' | t -}}
                                </span>
                                <span class="article-template-share-list__button__error subtitle copy-btn__error">
                                  {{- 'general.share.error_message' | t -}}
                                </span>
                              </li>
                            {%- endif -%}
                          </ul>
                        </div>
                      {%- endif -%}
                    </div>
                  </div>
                {%- endif -%}
                {%- if block.settings.next_post -%}
                  {% assign articles = blog.articles %}
                  {% assign current_index = null %}

                  {% for a in articles %}
                    {% if a.id == article.id %}
                      {% assign current_index = forloop.index0 %}
                      {% break %}
                    {% endif %}
                  {% endfor %}

                  {% if current_index != null %}
                    {% assign next_index = current_index | plus: 1 %}

                    {% if next_index >= articles.size %}
                      {% assign next_article = articles.first %}
                    {% else %}
                      {% assign next_article = articles[next_index] %}
                    {% endif %}
                  {% endif %}

                  {% if next_article %}
                    <div class="article-template-next_blog">
                      <a href="{{ next_article.url }}" class="button button__content button button--tertiary">
                        <div class="button__content">
                          <span class="button__icons-container">
                            {% render 'icon-arrow-tertiary-button' %}
                            {% render 'icon-arrow-tertiary-button' %}
                          </span>
                          <span class="button__label">{{ 'general.blog.next_post' | t }}</span>
                        </div>
                      </a>

                      <{{ block.settings.next_post_heading_tag | default: 'h1' }}
                        class="article-template-title {{ block.settings.heading_size | default: 'h4'}}"
                        itemprop="headline"
                      >
                        <a href="{{ next_article.url }}" class="article-card-title__link">
                          {{ next_article.title | escape }}
                        </a>
                      </{{ block.settings.next_post_heading_tag | default: 'h1' }}>
                    </div>
                  {% endif %}
                {%- endif -%}
              </footer>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {% comment %}-- -- -- -- -- -- -- COMMENTS -- -- -- -- -- -- --{% endcomment %}
  {%- if blog.comments_enabled? -%}
    <div class="article-template-comments ">
      <div id="comments" class="article-template-comments-container container">
        <div class="article-template-comments-wrapper">
          {%- if article.comments_count > 0 -%}
            {%- assign anchor_id = '#Comments-' | append: article.id -%}

            <h2 class="h6" id="Comments-{{ article.id }}" tabindex="-1">
              {{ 'blogs.article.comments' | t: count: article.comments_count }}
            </h2>
            {% paginate article.comments by 8 %}
              <div class="article-template-comments-list">
                {%- if comment.status == 'pending' and comment.content -%}
                  <article
                    id="{{ comment.id }}"
                    class="article-template-comments-list__comment"
                  >
                    {{ comment.content }}
                    <footer class="right">
                      <span class="article-template-comments-list__comment-meta subtitle">{{ comment.author }}</span>
                    </footer>
                  </article>
                {%- endif -%}

                {%- for comment in article.comments -%}
                  <article
                    id="{{ comment.id }}"
                    class="article-template-comments-list__comment"
                  >
                    {{ comment.content }}
                    <footer class="right">
                      <span class="article-template-comments-list__comment-meta subtitle">{{ comment.author }}</span
                      ><span class="article-template-comments-list__comment-meta subtitle" style="flex-shrink: 0;">
                        {{- comment.created_at | time_tag: '%d/%m/%y' -}}
                      </span>
                    </footer>
                  </article>
                {%- endfor -%}
                {% render 'pagination', paginate: paginate, anchor: anchor_id %}
              </div>
            {% endpaginate %}
          {%- endif -%}
          {% form 'new_comment', article %}
            {%- liquid
              assign post_message = 'blogs.article.success'
              if blog.moderated? and comment.status == 'unapproved'
                assign post_message = 'blogs.article.success_moderated'
              endif
            -%}
            <h2 class="h6">{{ 'blogs.article.comment_form_title' | t }}</h2>
            {%- if form.errors -%}
              <div class="form__message form__message--error" role="alert">
                <div class="form-status" tabindex="-1" autofocus>
                  {% render 'icon-error' %}
                  {{ 'templates.contact.form.error_heading' | t }}
                </div>
              </div>
              <ul class="form-status-list list-unstyled caption-large">
                {%- for field in form.errors -%}
                  <li>
                    <a href="#CommentForm-{{ field }}" class="link">
                      {%- if form.errors.translated_fields[field] contains 'author' -%}
                        {{ 'blogs.article.name' | t }}
                      {%- elsif form.errors.translated_fields[field] contains 'body' -%}
                        {{ 'blogs.article.message' | t }}
                      {%- else -%}
                        {{ form.errors.translated_fields[field] }}
                      {%- endif -%}
                      {{ form.errors.messages[field] }}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- elsif form.posted_successfully? -%}
              <div class="form-status-list form__message form__message--success" role="status">
                <div class="form-status" tabindex="-1" autofocus>
                  {% render 'icon-success' %}
                  {{ post_message | t }}
                </div>
              </div>
            {%- endif -%}

            <div
              {% if blog.moderated? == false %}
                class="article-template-comments-fields-wrapper"
              {% endif %}
            >
              <div class="article-template-comments-fields">
                <div class="field field--with-error">
                  <input
                    type="text"
                    name="comment[author]"
                    id="CommentForm-author"
                    dir="ltr"
                    class="field__input"
                    autocomplete="name"
                    value="{{ form.author }}"
                    aria-required="true"
                    required
                    {% if form.errors contains 'author' %}
                      aria-invalid="true"
                      aria-describedby="CommentForm-author-error"
                    {% endif %}
                    placeholder="{{ 'blogs.article.name' | t }}"
                  >
                  <label class="body-small" for="CommentForm-author">{{ 'blogs.article.name' | t }}</label>
                  {%- if form.errors contains 'author' -%}
                    <small id="CommentForm-author-error">
                      <span class="form__message form__message--error">
                        {%- render 'icon-error' -%}
                        {{- 'blogs.article.name' | t }}
                        {{ form.errors.messages.author }}.</span
                      >
                    </small>
                  {%- endif -%}
                </div>
                <div class="field field--with-error">
                  <input
                    type="email"
                    name="comment[email]"
                    id="CommentForm-email"
                    dir="ltr"
                    class="field__input"
                    autocomplete="email"
                    value="{{ form.email }}"
                    autocorrect="off"
                    autocapitalize="off"
                    aria-required="true"
                    pattern="[a-z0-9._%+\-]+@[a-z0-9.\-]+\.[a-z]{2,}$"
                    required
                    {% if form.errors contains 'email' %}
                      aria-invalid="true"
                      aria-describedby="CommentForm-email-error"
                    {% endif %}
                    placeholder="{{ 'blogs.article.email' | t }}"
                  >
                  <label class="body-small" for="CommentForm-email">{{ 'blogs.article.email' | t }}</label>
                  {%- if form.errors contains 'email' -%}
                    <small id="CommentForm-email-error">
                      <span class="form__message form__message--error">
                        {%- render 'icon-error' -%}
                        {{- 'blogs.article.email' | t }}
                        {{ form.errors.messages.email }}.</span
                      >
                    </small>
                  {%- endif -%}
                </div>
              </div>
              <div class="field field--with-error">
                <textarea
                  rows="5"
                  name="comment[body]"
                  id="CommentForm-body"
                  dir="ltr"
                  class="text-area field__input"
                  aria-required="true"
                  required
                  {% if form.errors contains 'body' %}
                    aria-invalid="true"
                    aria-describedby="CommentForm-body-error"
                  {% endif %}
                  placeholder="{{ 'blogs.article.message' | t }}"
                >{{ form.body }}</textarea>
                <label class="body-small" for="CommentForm-body">{{ 'blogs.article.message' | t }}</label>
              </div>
              {%- if form.errors contains 'body' -%}
                <small id="CommentForm-body-error">
                  <span class="form__message form__message--error">
                    {%- render 'icon-error' -%}
                    {{- 'blogs.article.message' | t }}
                    {{ form.errors.messages.body }}.</span
                  >
                </small>
              {%- endif -%}
            </div>
            {%- if blog.moderated? -%}
              <p class="article-template-comments-warning body-small">{{ 'blogs.article.moderated' | t }}</p>
            {%- endif -%}
            <button type="submit" class="button button--primary focus-inset article-comments-form-submit-btn">
              <div class="button__content">
                <span class="button__label" data-label="{{ 'blogs.article.post' | t }}">
                  {{ 'blogs.article.post' | t }}
                </span>
              </div>
            </button>
          {% endform %}
        </div>
      </div>
    </div>
  {%- endif -%}
</article>

<script type="application/ld+json">
  {{ article | structured_data }}
</script>

