{{ 'section-myduke-faq.css' | asset_url | stylesheet_tag }}

{% style %}
  {% render 'section-padding' %}
  {% render 'section-margin' %}
{% endstyle %}

<div
  class="myduke-faq color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding section-{{ section.id }}-margin"
  data-section-id="{{ section.id }}"
>
  <div class="myduke-faq__inner">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.cta_button_label != blank -%}
      <div class="myduke-faq__header">

        <div class="myduke-faq__header-text">
          {%- if section.settings.eyebrow != blank -%}
            <p class="myduke-faq__eyebrow">{{ section.settings.eyebrow }}</p>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <{{ section.settings.heading_tag }} class="myduke-faq__heading">
              {{ section.settings.heading }}
            </{{ section.settings.heading_tag }}>
          {%- endif -%}
        </div>

        {%- if section.settings.cta_button_label != blank -%}
          <a
            href="{{ section.settings.cta_button_url | default: '#' }}"
            class="myduke-faq__header-btn"
            {% if settings.links_blank and section.settings.cta_button_url != blank %}target="_blank" rel="noopener noreferrer"{% endif %}
          >
            {{- section.settings.cta_button_label -}}
          </a>
        {%- endif -%}

      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="myduke-faq__list">
        {%- for block in section.blocks -%}
          {%- if block.settings.question != blank -%}
            <div class="myduke-faq__item" {{ block.shopify_attributes }}>

              <button
                class="myduke-faq__trigger"
                type="button"
                aria-expanded="false"
                aria-controls="myduke-faq-panel-{{ section.id }}-{{ forloop.index }}"
              >
                <span class="myduke-faq__question">{{ block.settings.question }}</span>
                <span class="myduke-faq__icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="1" y="6.5" width="12" height="1" fill="#264653"/>
                    <rect class="myduke-faq__icon-vert" x="6.5" y="1" width="1" height="12" fill="#264653"/>
                  </svg>
                </span>
              </button>

              {%- if block.settings.answer != blank -%}
                <div
                  class="myduke-faq__panel"
                  id="myduke-faq-panel-{{ section.id }}-{{ forloop.index }}"
                  hidden
                >
                  <div class="myduke-faq__answer">{{ block.settings.answer }}</div>
                </div>
              {%- endif -%}

            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

<script src="{{ 'myduke-faq.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "FAQ (MyDuke)",
  "class": "myduke-faq-section",
  "tag": "section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "background-1",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "FAQs"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.all.heading.label",
      "default": "Your Questions Answered"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        { "value": "h1", "label": "t:sections.all.heading_tag.options__1.label" },
        { "value": "h2", "label": "t:sections.all.heading_tag.options__2.label" },
        { "value": "h3", "label": "t:sections.all.heading_tag.options__3.label" },
        { "value": "h4", "label": "t:sections.all.heading_tag.options__4.label" },
        { "value": "h5", "label": "t:sections.all.heading_tag.options__5.label" },
        { "value": "h6", "label": "t:sections.all.heading_tag.options__6.label" },
        { "value": "div", "label": "t:sections.all.heading_tag.options__7.label" }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_tag.label",
      "info": "t:sections.all.heading_tag.info"
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
      "type": "text",
      "id": "cta_button_label",
      "label": "Button label",
      "default": "Apply for a Prescription"
    },
    {
      "type": "url",
      "id": "cta_button_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-padding.header.content"
    },
    {
      "type": "select",
      "id": "padding_top",
      "options": [
        { "value": "no-indent", "label": "t:sections.all.section-padding.options__1.label" },
        { "value": "xs", "label": "t:sections.all.section-padding.options__2.label" },
        { "value": "s", "label": "t:sections.all.section-padding.options__3.label" },
        { "value": "m", "label": "t:sections.all.section-padding.options__4.label" },
        { "value": "l", "label": "t:sections.all.section-padding.options__5.label" },
        { "value": "xl", "label": "t:sections.all.section-padding.options__6.label" }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-padding.padding_top.label"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "options": [
        { "value": "no-indent", "label": "t:sections.all.section-padding.options__1.label" },
        { "value": "xs", "label": "t:sections.all.section-padding.options__2.label" },
        { "value": "s", "label": "t:sections.all.section-padding.options__3.label" },
        { "value": "m", "label": "t:sections.all.section-padding.options__4.label" },
        { "value": "l", "label": "t:sections.all.section-padding.options__5.label" },
        { "value": "xl", "label": "t:sections.all.section-padding.options__6.label" }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-padding.padding_bottom.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        { "value": "no-indent", "label": "t:sections.all.section-margin.options__1.label" },
        { "value": "xs", "label": "t:sections.all.section-margin.options__2.label" },
        { "value": "s", "label": "t:sections.all.section-margin.options__3.label" },
        { "value": "m", "label": "t:sections.all.section-margin.options__4.label" },
        { "value": "l", "label": "t:sections.all.section-margin.options__5.label" },
        { "value": "xl", "label": "t:sections.all.section-margin.options__6.label" }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        { "value": "no-indent", "label": "t:sections.all.section-margin.options__1.label" },
        { "value": "xs", "label": "t:sections.all.section-margin.options__2.label" },
        { "value": "s", "label": "t:sections.all.section-margin.options__3.label" },
        { "value": "m", "label": "t:sections.all.section-margin.options__4.label" },
        { "value": "l", "label": "t:sections.all.section-margin.options__5.label" },
        { "value": "xl", "label": "t:sections.all.section-margin.options__6.label" }
      ],
      "default": "l",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ (MyDuke)",
      "category": "t:sections.categories.storytelling",
      "settings": {
        "eyebrow": "FAQs",
        "heading": "Your Questions Answered",
        "cta_button_label": "Apply for a Prescription"
      },
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "Is MyDuke legal in Australia?",
            "answer": "<p>Yes. All products facilitated through MyDuke are prescribed by AHPRA-registered doctors and dispensed by licensed Australian pharmacies in full compliance with TGA regulations.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How long does it take to get a prescription after assessment?"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How long does delivery take?"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Can I access myduke® support if I live in a remote area?"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "What treatment options are available in Australia to help quit smoking?"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Why can't I see the medication and price before completing the assessment?"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Can I return my order if I have changed my mind?"
          }
