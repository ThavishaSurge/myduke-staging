{{ 'section-myduke-faq.css' | asset_url | stylesheet_tag }}

{%- comment -%} Check if any tab names are populated {%- endcomment -%}
{%- assign has_tabs = false -%}
{%- for i in (1..10) -%}
  {%- assign tab_key = 'tab_' | append: i | append: '_name' -%}
  {%- assign tab_name = section.settings[tab_key] -%}
  {%- if tab_name != blank -%}
    {%- assign has_tabs = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

<div
  class="myduke-faq color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding section-{{ section.id }}-margin container"
  data-section-id="{{ section.id }}"
>
  <div class="myduke-faq__inner">

    {%- comment -%} ── Grid area: heading (top-left on desktop, top on mobile) ── {%- endcomment -%}
    <div class="myduke-faq__left">
      {%- if section.settings.eyebrow != blank -%}
        <p class="myduke-faq__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <{{ section.settings.heading_tag }} class="myduke-faq__heading">
          {{ section.settings.heading }}
        </{{ section.settings.heading_tag }}>
      {%- endif -%}
    </div>

    {%- comment -%} ── Grid area: accordion (right on desktop, middle on mobile) ── {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="myduke-faq__right">

        {%- if has_tabs -%}
          {%- comment -%} ── Tab Navigation ── {%- endcomment -%}
          <ul class="myduke-faq__tabs" role="tablist">
            {%- assign first_tab_rendered = false -%}
            {%- for i in (1..10) -%}
              {%- assign tab_key = 'tab_' | append: i | append: '_name' -%}
              {%- assign tab_name = section.settings[tab_key] -%}
              {%- if tab_name != blank -%}
                {%- assign tab_id = 'tab_' | append: i -%}
                {%- comment -%} Check if this tab has any questions assigned {%- endcomment -%}
                {%- assign has_questions = false -%}
                {%- for block in section.blocks -%}
                  {%- if block.settings.question != blank and block.settings.tab_assignment == tab_id -%}
                    {%- assign has_questions = true -%}
                    {%- break -%}
                  {%- endif -%}
                {%- endfor -%}
                {%- if has_questions -%}
                  <li role="presentation">
                    <button
                      class="myduke-faq__tab-button{% unless first_tab_rendered %} is-active{% endunless %}"
                      type="button"
                      role="tab"
                      data-tab-target="tab_{{ i }}"
                      aria-selected="{% unless first_tab_rendered %}true{% else %}false{% endunless %}"
                    >
                      {{ tab_name }}
                    </button>
                  </li>
                  {%- assign first_tab_rendered = true -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </ul>

          {%- comment -%} ── Tab Content Groups ── {%- endcomment -%}
          {%- assign first_group_rendered = false -%}
          {%- for i in (1..10) -%}
            {%- assign tab_key = 'tab_' | append: i | append: '_name' -%}
            {%- assign tab_name = section.settings[tab_key] -%}
            {%- if tab_name != blank -%}
              {%- assign tab_id = 'tab_' | append: i -%}
              {%- comment -%} Check if this tab has any questions assigned {%- endcomment -%}
              {%- assign has_questions = false -%}
              {%- for block in section.blocks -%}
                {%- if block.settings.question != blank and block.settings.tab_assignment == tab_id -%}
                  {%- assign has_questions = true -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
              {%- if has_questions -%}
                <div class="myduke-faq__tab-content{% unless first_group_rendered %} is-active{% endunless %}" data-tab-id="{{ tab_id }}">
                  <div class="myduke-faq__list">
                    {%- for block in section.blocks -%}
                      {%- if block.settings.question != blank and block.settings.tab_assignment == tab_id -%}
                        <div class="myduke-faq__item" {{ block.shopify_attributes }}>

                          <button
                            class="myduke-faq__trigger"
                            type="button"
                            aria-expanded="false"
                            aria-controls="myduke-faq-panel-{{ section.id }}-{{ block.id }}"
                          >
                            <span class="myduke-faq__question">{{ block.settings.question }}</span>
                            <span class="myduke-faq__icon" aria-hidden="true">
                              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <rect x="1" y="6.5" width="12" height="1" fill="#264653"/>
                                <rect class="myduke-faq__icon-vert" x="6.5" y="1" width="1" height="12" fill="#264653"/>
                              </svg>
                            </span>
                          </button>

                          {%- if block.settings.answer != blank -%}
                            <div
                              class="myduke-faq__panel"
                              id="myduke-faq-panel-{{ section.id }}-{{ block.id }}"
                              role="region"
                            >
                              <div class="myduke-faq__panel-inner">
                                <div class="myduke-faq__answer">{{ block.settings.answer }}</div>
                              </div>
                            </div>
                          {%- endif -%}

                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                </div>
                {%- assign first_group_rendered = true -%}
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}

        {%- else -%}
          {%- comment -%} ── Fallback: No Tabs - Render All FAQs ── {%- endcomment -%}
          <div class="myduke-faq__list">
            {%- for block in section.blocks -%}
              {%- if block.settings.question != blank -%}
                <div class="myduke-faq__item" {{ block.shopify_attributes }}>

                  <button
                    class="myduke-faq__trigger"
                    type="button"
                    aria-expanded="{{ forloop.first | default: false }}"
                    aria-controls="myduke-faq-panel-{{ section.id }}-{{ forloop.index }}"
                  >
                    <span class="myduke-faq__question">{{ block.settings.question }}</span>
                    <span class="myduke-faq__icon" aria-hidden="true">
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="1" y="6.5" width="12" height="1" fill="#264653"/>
                        <rect class="myduke-faq__icon-vert" x="6.5" y="1" width="1" height="12" fill="#264653"/>
                      </svg>
                    </span>
                  </button>

                  {%- if block.settings.answer != blank -%}
                    <div
                      class="myduke-faq__panel{% if forloop.first %} is-open{% endif %}"
                      id="myduke-faq-panel-{{ section.id }}-{{ forloop.index }}"
                      role="region"
                    >
                      <div class="myduke-faq__panel-inner">
                        <div class="myduke-faq__answer">{{ block.settings.answer }}</div>
                      </div>
                    </div>
                  {%- endif -%}

                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

      </div>
    {%- endif -%}

    {%- comment -%} ── Grid area: cta (bottom-left on desktop, last on mobile) ── {%- endcomment -%}
    {%- if section.settings.cta_button_label != blank -%}
      <div class="myduke-faq__cta">
        <a
          href="{{ section.settings.cta_button_url | default: '#' }}"
          class="myduke-faq__header-btn"
          {% if settings.links_blank and section.settings.cta_button_url != blank %}target="_blank" rel="noopener noreferrer"{% endif %}
        >
          {{- section.settings.cta_button_label -}}
        </a>
      </div>
    {%- endif -%}

  </div>
</div>

<script src="{{ 'myduke-faq.js' | asset_url }}" defer></script>

