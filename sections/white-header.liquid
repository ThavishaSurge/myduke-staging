     White Header — forced white bg + black text
     ============================================= */
  .shopify-section-white-header .header-wrapper {
    background: #ffffff !important;
  }
  .shopify-section-white-header .header__heading-link,
  .shopify-section-white-header .header__menu-item,
  .shopify-section-white-header .header-label,
  .shopify-section-white-header .header__active-menu-item,
  .shopify-section-white-header .header__icon,
  .shopify-section-white-header .header__icon svg,
  .shopify-section-white-header .header__icon path,
  .shopify-section-white-header nav a,
  .shopify-section-white-header .list-menu__item {
    color: #000000 !important;
    fill: #000000 !important;
  }
  .shopify-section-white-header .header__icon svg {
    color: #000000 !important;
    stroke: #000000 !important;
  }
  /* Buttons inside the white header */
  .shopify-section-white-header .button,
  .shopify-section-white-header .btn,
  .shopify-section-white-header [class*="button--"],
  .shopify-section-white-header .header__additional-button {
    color: #000000 !important;
    border-color: #000000 !important;
    background: transparent !important;
  }
  .shopify-section-white-header .button--primary,
  .shopify-section-white-header .header__additional-button--primary {
    background: #000000 !important;
    color: #ffffff !important;
  }
  /* Burger / hamburger icon strokes */
  .shopify-section-white-header header-drawer .header__icon svg line,
  .shopify-section-white-header header-drawer .header__icon svg rect {
    stroke: #000000 !important;
  }
  .header-label {
    font-family: var(--font-header-menu-family);
    font-style: var(--font-header-menu-style);
    font-weight: var(--font-header-menu-weight);
    font-size: calc(var(--font-header-menu-text-scale) * 1rem);
    text-transform: var(--font-header-menu-text-transform);
    letter-spacing: var(--font-header-menu-letter-spacing);
    line-height: 1.5;
    word-break: break-word;
    transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }
  @media screen and (min-width: 990px) and (max-width: 1360px) {
    .header-label {
      font-size: calc(var(--font-header-menu-text-scale) * 0.9rem);
    }
  }

