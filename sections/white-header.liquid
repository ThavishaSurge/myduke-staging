    body:has(main > .featured-products-section:first-child:not(.not-margin)) .shopify-section-white-header:not(.shopify-section-header-sticky):not(.not-mode) .header-wrapper,
    body:has(main > .media-banner-section:first-child:not(.not-margin)) .shopify-section-white-header:not(.shopify-section-header-sticky):not(.not-mode) .header-wrapper,
    body:has(main > .slideshow-section:first-child:not(.not-margin) > .slideshow--overlay) .shopify-section-white-header:not(.shopify-section-header-sticky):not(.not-mode) .header-wrapper,
    body:has(main > .collection-grid-section:first-child:not(.not-margin) .collection-hero__wrapper--with-image) .shopify-section-white-header:not(.shopify-section-header-sticky):not(.not-mode) .header-wrapper {
      background: {{ section.settings.overlay_bg_color }} !important;
    }
  {% endif %}
  {% if section.settings.header_bg_color != blank %}
    .shopify-section-white-header .header-wrapper {
      background: {{ section.settings.header_bg_color }} !important;
    }
  {% endif %}
  {% if section.settings.logo_scrolled != blank %}
    .header__heading-logo--scrolled {
      opacity: 0;
      visibility: hidden;
      position: absolute;
      transition: opacity 0.4s, visibility 0.4s;
    }
    .shopify-section-white-header.shopify-section-header-sticky .header__heading-logo--scrolled,
    .shopify-section-white-header.shopify-section-header-sticky .header-wrapper:hover .header__heading-logo--scrolled,
    .shopify-section-white-header .header-wrapper--tsk-solid .header__heading-logo--scrolled {
      opacity: 1;
      visibility: visible;
      position: static;
    }
    .shopify-section-white-header.shopify-section-header-sticky .header__heading-logo:not(.header__heading-logo--scrolled):not(.header__heading-logo--overlay),
    .shopify-section-white-header.shopify-section-header-sticky .header-wrapper:hover .header__heading-logo:not(.header__heading-logo--scrolled):not(.header__heading-logo--overlay),
    .shopify-section-white-header .header-wrapper--tsk-solid .header__heading-logo:not(.header__heading-logo--scrolled):not(.header__heading-logo--overlay) {
      opacity: 0;
      visibility: hidden;
      position: absolute;
    }
  {% endif %}
</style>
