{% comment %} calc header height script {% endcomment %}
<script>
  (function () {
    const initHeaderHeight = () => {
      const header = document.querySelector('.shopify-section-white-header');
      if (!header) return;

      let headerObserver;
      let intersectionObserver;
      let dynamicResizeObserver;
      let lastRatio = 1;

      const updateDynamicHeight = (intersectionRatio = 1) => {
        const headerHeight = header?.getBoundingClientRect().height || 0;
        const effectiveHeight = (headerHeight * intersectionRatio).toFixed(2);
        document.documentElement.style.setProperty('--header-height-dynamic', `${effectiveHeight}px`);
      };

      const createObservers = () => {
        if (headerObserver) headerObserver.disconnect();
        if (intersectionObserver) intersectionObserver.disconnect();
        if (dynamicResizeObserver) dynamicResizeObserver.disconnect();

        headerObserver = new ResizeObserver(() => {
          const headerHeight = header.getBoundingClientRect().height.toFixed(2);
          document.documentElement.style.setProperty('--header-height', `${headerHeight}px`);
        });

        intersectionObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                updateDynamicHeight(entry.intersectionRatio);
                lastRatio = entry.intersectionRatio;
              } else {
                document.documentElement.style.setProperty('--header-height-dynamic', '0px');
                lastRatio = 0;
              }
            });
          },
          {
            threshold: Array.from({ length: 1000 }, (_, i) => i / 1000),
          }
        );

        dynamicResizeObserver = new ResizeObserver(() => {
          updateDynamicHeight(lastRatio);
        });

        headerObserver.observe(header);
        intersectionObserver.observe(header);
        dynamicResizeObserver.observe(header);
      };

      createObservers();
    };

    initHeaderHeight();

    document.addEventListener('shopify:section:load', initHeaderHeight);
    document.addEventListener('shopify:section:unload', initHeaderHeight);
    document.addEventListener('shopify:section:reorder', initHeaderHeight);
  })();
</script>

