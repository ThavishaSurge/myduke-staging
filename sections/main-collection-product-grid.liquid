        },
        {
          "type": "image_picker",
          "id": "all_products_slide_image",
          "label": "t:sections.main-collection-product-grid.blocks.collection-banner.settings.all_products_slide_image.label",
          "visible_if": "{{ block.settings.all_products_slide_enable and block.settings.enable_hero_slider }}"
        },
        {
          "type": "header",
          "content": "t:sections.main-collection-product-grid.blocks.collection-banner.settings.header_image.content"
        },
        {
          "type": "checkbox",
          "id": "show_collection_image",
          "default": false,
          "label": "t:sections.main-collection-product-grid.blocks.collection-banner.settings.show_collection_image.label"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.main-collection-product-grid.blocks.collection-banner.settings.image.label"
        },
        {
          "type": "image_picker",
          "id": "image_products",
          "label": "t:sections.main-collection-product-grid.blocks.collection-banner.settings.image_products.label",
