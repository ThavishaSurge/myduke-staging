{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{% if section.blocks.size > 0 %}
  {{ 'component-collection-hero.css' | asset_url | stylesheet_tag }}
{% endif %}
{%- if settings.pagination_type == 'load_more' or settings.pagination_type == 'infinite_scroll' -%}
  <script src="{{ 'load-more.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{{ 'component-card.css' | asset_url | stylesheet_tag }}

{%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
  {{ 'component-facets.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
{%- endif -%}
{% if section.settings.enable_per_row_button %}
  <script src="{{ 'products-per-row.js' | asset_url }}" defer="defer"></script>
{% endif %}

{% if section.blocks.size > 0 %}
  <script src="{{ 'collection-hero-slider.js' | asset_url }}" defer="defer"></script>
{% endif %}

{%- style -%}
  {% render 'section-margin' %}

  .facets__container {
    visibility: hidden !important;
  }
  .facets__container:not(.active) .facets__wrapper--vertical {
    transform: translateX(100%) !important;
  }
  .facets__container.active {
    visibility: visible !important;
  }
{%- endstyle -%}

{%- liquid
  assign sort_by = collection.sort_by | default: collection.default_sort_by
  if collection.url
    assign results_url = collection.url
  else
    assign terms = collection.terms | escape
    assign results_url = '?q=' | append: terms | append: '&options%5Bprefix%5D=last&sort_by=' | append: sort_by
  endif
-%}

{% if section.blocks.size > 0 %}
  {% assign block = section.blocks[0] %}
  {% if block.type == 'collection-banner' and block.settings.show_collection_image %}
    {% liquid
      assign collection_image = blank

      if collection.id != blank
        if block.settings.image != blank
          assign collection_image = block.settings.image
        else
          assign collection_image = collection.image
        endif
      else
        if block.settings.image_products != blank
          assign collection_image = block.settings.image_products
        endif
      endif

      if block.settings.image_ratio != 'adapt' and block.settings.image_ratio != 'adapt_content'
        assign aspect_ratio = block.settings.image_ratio | split: '/'
        assign temp = aspect_ratio[0] | append: '.0'
        assign padding_bottom = aspect_ratio[1] | divided_by: temp | times: 100 | round: 2
      elsif block.settings.image_ratio == 'adapt'
        assign padding_bottom = 1 | divided_by: collection_image.aspect_ratio | times: 100 | round: 2
      else
        assign padding_bottom = 0
      endif
    -%}
  {% endif %}
{% endif %}
{% comment %}
  {% if section.settings.enable_sticky %}
    {% style %}
      .collection-top {
        position: sticky;
        top: 0;
        z-index: 3;
        transition: top 0.85s cubic-bezier(0.602, 0.007, 0.374, 0.995);
      }
      .shopify-section-header-sticky.shopify-section-header-sticky:not(.shopify-section-header-hidden)
        ~ main
        > .collection-grid-section
        .collection-top,
      .shopify-section-header-always-sticky ~ main > .collection-grid-section .collection-top,
      .shopify-section-header:has([data-sticky-type='always']) ~ main > .collection-grid-section .collection-top {
        top: calc(var(--header-height));
      }
    {% endstyle %}
  {% endif %}
{% endcomment %}
{% if section.blocks.size > 0 and block.type == 'collection-banner' %}
  <div class="collection-hero mydk-product-container-auth">
    <div
      class="collection-hero__wrapper{% if block.settings.enable_hero_slider %} collection-hero__wrapper-with-slider{% endif %}{% if block.settings.show_collection_image and collection_image != blank %} color-{{ block.settings.color_scheme }} background collection-hero__wrapper--with-image{% endif %} container"
      style="--padding-bottom: {{ padding_bottom }}%"
      {% if block.settings.show_collection_image and collection_image != blank -%}
        data-color-scheme="{{ block.settings.color_scheme }}"
      {%- endif %}
    >
      <div class="collection-hero__content">
        <div class="collection-hero__text">
          <h1 class="collection-hero__title {{ block.settings.heading_size }}">
            <span class="visually-hidden">{{ 'sections.collection_template.title' | t }}: </span>
            {{- collection.title | escape -}}
          </h1>
          {%- if block.settings.show_collection_description and collection.description != blank -%}
            <div class="collection-hero__description rte">
              {{ collection.description }}
            </div>
          {%- endif -%}
        </div>
        {% if block.settings.enable_hero_slider %}
          {%- liquid
            case block.settings.sort
              when 'products_high', 'products_low'
                assign collections = collections | sort: 'all_products_count'
              when 'date', 'date_reversed'
                assign collections = collections | sort: 'published_at'
              when 'alphabetical', 'alphabetical_reversed'
                assign collections = collections | sort: 'title'
            endcase

            if block.settings.sort == 'products_high' or block.settings.sort == 'date_reversed' or block.settings.sort == 'alphabetical_reversed'
              assign collections = collections | reverse
            endif
          -%}
          <div class="collection-hero__slider">
            <div class="collection-hero__slider-wrapper swiper">
              <div class="swiper-wrapper">
                {% assign hero_slide_index = 0 %}
                {% if block.settings.all_products_slide_enable %}
                  <div class="swiper-slide">
                    <a
                      href="{{ routes.all_products_collection_url }}"
                      class="collection-slide-link"
                      aria-label="{{ 'sections.collection_template.all_products' | t }}"
                    >
                      <span class="collection-slide-image">
                        {% if block.settings.all_products_slide_image %}
                          {% liquid
                            if block.settings.all_products_slide_image.alt != blank
                              assign image_alt = block.settings.all_products_slide_image.alt
                            else
                              assign image_alt = 'sections.collection_template.all_products' | t
                            endif
                            assign max_width = 400
                            if block.settings.all_products_slide_image.width < max_width
                              assign max_width = block.settings.all_products_slide_image.width
                            endif
                            assign hero_slide_loading = 'lazy'
                            assign hero_slide_fetch = 'auto'
                          %}
                          {{
                            block.settings.all_products_slide_image
                            | image_url: width: max_width
                            | image_tag:
                              loading: hero_slide_loading,
                              widths: '180, 250, 360, 400',
                              sizes: '(max-width: 750px) 180px, (max-width: 1159px) 250px, 400px',
                              fetchpriority: hero_slide_fetch,
                              alt: image_alt
                          }}
                          {% assign hero_slide_index = 1 %}
                        {% else %}
                          {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                          {% assign hero_slide_index = 1 %}
                        {% endif %}
                      </span>
                      <span href="{{ routes.all_products_collection_url }}" class="collection-slide__title body-normal">
                        {{ 'sections.collection_template.all_products' | t }}
                      </span>
                    </a>
                  </div>
                {% endif %}
                {% for coll in collections %}
                  {% if coll.handle == collection.handle %}
                    {% continue %}
                  {% endif %}
                  {% assign hero_slide_loading = 'lazy' %}
                  {% assign hero_slide_fetch = 'auto' %}

                  <div class="swiper-slide">
                    <a href="{{ coll.url }}" class="collection-slide-link" aria-label="{{ coll.title }}">
                      <span class="collection-slide-image">
                        {% if coll.featured_image != blank %}
                          {% liquid
                            if coll.featured_image.alt != blank
                              assign image_alt = coll.featured_image.alt
                            else
                              assign image_alt = coll.title
                            endif
                            assign max_width = 400
                            if coll.featured_image.width < max_width
                              assign max_width = coll.featured_image.width
                            endif
                          %}
                          {{
                            coll.featured_image
                            | image_url: width: max_width
                            | image_tag:
                              loading: hero_slide_loading,
                              widths: '180, 288, 360, 400',
                              sizes: '(max-width: 750px) 180px, (max-width: 1159px) 250px, 400px',
                              fetchpriority: hero_slide_fetch,
                              alt: image_alt
                          }}
                          {% assign hero_slide_index = hero_slide_index | plus: 1 %}
                        {% else %}
                          {% liquid
                            assign index = forloop.index | modulo: 3 | plus: 1
                          %}
                          {{ 'hero-apparel-' | append: index | placeholder_svg_tag: 'placeholder-svg' }}
                        {% endif %}
                      </span>
                      <span class="collection-slide__title">{{ coll.title }}</span>
                    </a>
                  </div>
                {% endfor %}
              </div>
              <div class="collection-hero__navigation-wrapper no-js-hidden">
                <button class="collection-hero__navigation-button-prev swiper-button-prev focus-inset">
                  {% render 'icon-arrow-left-slider' %}
                </button>
                <button class="collection-hero__navigation-button-next swiper-button-next focus-inset">
                  {% render 'icon-arrow-right-slider' %}
                </button>
              </div>
            </div>
          </div>
        {% endif %}

        {% comment %}
          {% if block.settings.enable_filters %}
            {% assign button_label = 'products.facets.view_all_label' | t %}
            {% if block.settings.filter_type == 'product_type' %}
              {% assign count = 0 %}
              {% for filter in collection.filters %}
                {% if filter.type == 'list' and filter.param_name == 'filter.p.product_type' %}
                  {%- for value in filter.values -%}
                    {% assign count = count | plus: 1 %}
                  {% endfor %}
                {% endif %}
              {% endfor %}
              {% if count > 1 %}
                <facet-filters-form class="facets facets_tags">
                  <form id="FacetFiltersByProductTypeForm" class="facets__form">
                    <div class="facets-tag-wrapper js-filter">
                      {%- for filter in collection.filters -%}
                        {% if filter.type == 'list' and filter.param_name == 'filter.p.product_type' %}
                          <div
                            id="Details-Tag-{{ forloop.index }}-{{ section.id }}"
                            class="disclosure-has-popup facets__disclosure js-filter"
                            data-index="tag-{{ forloop.index }}"
                          >
                            <div id="FacetTag-{{ forloop.index }}-{{ section.id }}" class="facets__display">
                              <div class="collection-hero__filters">
                                <facet-remove>
                                  {% render 'button',
                                    btn_label: button_label,
                                    btn_link: results_url,
                                    btn_style: 'secondary',
                                    class: 'facets__reset-link facets-tag__button  js-hero-filter-clear button disabled'
                                  %}
                                </facet-remove>
                                {%- for value in filter.values -%}
                                  <div
                                    class="list-menu__item facets__item facets__item-tag js-hero-filter focus-inset {% if collection_image == blank  %}js-hero-filter--no-image{% endif %}"
                                  >
                                    <input
                                      dir="ltr"
                                      type="checkbox"
                                      class="focus-inset"
                                      name="{{ value.param_name }}"
                                      value="{{ value.value }}"
                                      id="Filter-{{ filter.label | escape }}-tag-{{ forloop.index }}"
                                      {% if value.active %}
                                        checked
                                      {% endif %}
                                      {% if value.count == 0 and value.active == false %}
                                        disabled
                                      {% endif %}
                                    >
                                    <label
                                      for="Filter-{{ filter.label | escape }}-tag-{{ forloop.index }}"
                                      tabindex="0"
                                      class="facet-checkbox secondary_text focus-inset {% if value.count == 0 and value.active == false %} facet-checkbox--disabled{% endif %}"
                                    >
                                      {{ value.label | escape }}
                                    </label>
                                  </div>
                                {%- endfor -%}
                              </div>
                            </div>
                          </div>
                        {% endif %}
                      {%- endfor -%}
                    </div>
                  </form>
                </facet-filters-form>
              {% endif %}
            {% else %}
              {% if collection.all_tags.size > 0 %}
                <div class="collection-hero__filters tag-filters">
                  {% render 'button',
                    btn_label: button_label,
                    btn_link: results_url,
                    btn_style: 'secondary',
                    class: 'tag-filters__item js-hero-filter-clear disabled'
                  %}
                  {% for tag in collection.all_tags %}
                    {% if current_tags contains tag %}
                      <a
                        href="{{ tag | link_to_remove_tag: tag | split:'href="' | last | split:'"' | first }}"
                        class="tag-filters__item button focus-inset js-hero-filter {% if collection_image == blank  %}js-hero-filter--no-image{% endif %}"
                        aria-label="{{ tag }}"
                        id="{{ tag |  handleize }}"
                      >
                        {{ tag }}
                      </a>
                    {% else %}
                      <a
                        href="{{ tag | link_to_add_tag: tag | split:'href="' | last | split:'"' | first }}"
                        class="tag-filters__item button focus-inset js-hero-filter {% if collection_image == blank  %}js-hero-filter--no-image{% endif %}"
                        aria-label="{{ tag }}"
                        id="{{ tag |  handleize }}"
                      >
                        {{ tag }}
                      </a>
                    {% endif %}
                  {% endfor %}
                </div>
              {% endif %}
            {% endif %}
          {% endif %}
        {% endcomment %}
      </div>

      {%- if block.settings.show_collection_image and collection_image != blank -%}
        {% liquid
          assign fetch_priority = 'high'
          assign image_loading = 'eager'

          if block.settings.image_ratio != 'adapt' and block.settings.image_ratio != 'adapt_content'
            assign settings_aspect_ratio = temp | divided_by: aspect_ratio[1] | round: 2
          elsif block.settings.image_ratio == 'adapt'
            assign settings_aspect_ratio = collection_image.aspect_ratio
          else
            assign settings_aspect_ratio = 1
          endif

          assign calc_ratio = 1
          if collection_image.aspect_ratio > settings_aspect_ratio
            assign calc_ratio = collection_image.aspect_ratio | divided_by: settings_aspect_ratio | round: 2
          endif
        %}
        {%- capture sizes -%}
          calc(100vw * {{ calc_ratio }})
        {%- endcapture -%}

        {%- capture styles -%} 
          object-fit: cover;
          {%- if collection_image.presentation.focal_point -%}
            object-position: {{ collection_image.presentation.focal_point }};
          {%- endif -%}
        {%- endcapture -%}

        <div class="collection-hero__image-wrapper">
          {% liquid
            assign max_width = 1920
            if collection_image.width < max_width
              assign max_width = collection_image.width
            endif
          %}
          {{
            collection_image
            | image_url: width: max_width
            | image_tag:
              loading: image_loading,
              widths: '360, 535, 720, 940, 1100, 1200, 1440, 1600, 1920',
              sizes: sizes,
              styles: styles,
              fetchpriority: fetch_priority,
              alt: collection_image.alt
          }}
        </div>
        <div
          class="collection-hero__overlay"
          style="opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }}"
        ></div>
      {%- endif -%}
    </div>
  </div>
{% endif %}

<div class="section-{{ section.id }}-padding">
  {%- if collection.all_products_count > 0 -%}
    <div class="collection-top {% if section.settings.enable_border_top %} section-border-top{% endif %}">
      <div class="collection-top__container container">
        <div class="collection-top__container-left">
          {% if section.settings.enable_filtering %}
            <button
              type="button"
              data-desktop-modal="FacetsWrapperDesktop-{{ section.id }}"
              class="button facets-button-show vertical no-js-hidden focus-inset"
            >
              <span class="show-label" aria-label="{{ 'products.facets.filters' | t }}">
                {%- render 'icon-filter' -%}
              </span>
              <span class="hide-label hidden" aria-label="{{ 'accessibility.close' | t }}">
                {%- render 'icon-filter' -%}
              </span>
              <span class="button__label" data-label="{{ 'products.facets.filters' | t }}">
                {{ 'products.facets.filters' | t -}}
              </span>
            </button>
            {% if section.settings.enable_filter_button_per_type %}
              {%- for filter in collection.filters -%}
                <button
                  type="button"
                  class="facet-open-button focus-inset button button--secondary"
                  data-filter-index="{{ forloop.index }}"
                >
                  {{ filter.label | escape }}
                </button>
              {%- endfor -%}
            {% endif %}
          {% endif %}
        </div>
        <div class="collection-top__container-right">
          {% if section.settings.enable_per_row_button %}
            <div class="collection-top__layout-toggler">
              {% liquid
                if cart.attributes['cells-view'] != null and cart.attributes['cells-view'] != blank
                  assign per_row = cart.attributes['cells-view']
                else
                  assign per_row = section.settings.default_per_row
                endif
              %}

              <button
                type="button"
                data-per-row="{{ per_row }}"
                aria-label="Per row toggle"
                tabindex="0"
                class="collection-top__layout-toggler-button js-per-row__button focus-inset"
              >
                <span class="collection-top__layout-toggler-icon">
                  {% if per_row == 'large' %}
                    {% render 'icon-cells-large' %}
                  {% else %}
                    {% render 'icon-cells-small' %}
                  {% endif %}
                </span>
                <span class="collection-top__layout-toggler-label body-normal">
                  {{- 'products.facets.view' | t -}}
                </span>
              </button>
            </div>
          {% endif %}
          {% if section.settings.enable_product_count %}
            <div class="facets__product-count" role="status">
              <div class="facets__product-count-text body-normal">
                <span class="body-normal" id="ProductCount">
                  {%- if collection.all_products_count and collection.products_count -%}
                    {%- if collection.products_count == collection.all_products_count -%}
                      {{ 'products.facets.product_count_simple' | t: count: collection.all_products_count }}
                    {%- else -%}
                      {{
                        'products.facets.product_count'
                        | t: product_count: collection.products_count, count: collection.all_products_count
                      }}
                    {%- endif -%}
                  {%- else -%}
                    {{ 'templates.search.results' | t: terms: collection.terms, count: collection.results_count }}
                  {%- endif -%}
                </span>
              </div>
            </div>
          {% endif %}
          {%- if section.settings.enable_sorting -%}
            <facet-filters-form class="no-js-hidden">
              <form id="FacetSortForm" class="facets-sorting">
                {% comment %}
                  <div class="facets-sorting__label body-small">
                    {{- 'products.facets.sort_by_label' | t -}}
                  </div>
                {% endcomment %}
                <div class="facet-filters__field facets-sorting__field">
                  {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}

                  <div class="facet-sort-select">
                    <input
                      class="facet-sort-select__input"
                      type="hidden"
                      name="sort_by"
                      id="SortBy"
                      value="{{ sort_by }}"
                      aria-describedby="a11y-refresh-page-message"
                    >
                    <div class="facet-sort-select__select focus-inset button button--secondary" tabindex="0">
                      <div class="facet-sort-select__icon">
                        {% render 'icon-sort' %}
                      </div>
                      <span class="facet-sort-select__current body-normal">
                        {%- for option in collection.sort_options -%}
                          {% if option.value == sort_by %}
                            {{- option.name | escape -}}
                          {% endif %}
                        {%- endfor -%}
                      </span>
                    </div>
                    <div
                      class="facet-sort-modal"
                      role="dialog"
                      aria-modal="true"
                      tabindex="-1"
                    >
                      <div class="facet-sort-modal__overlay"></div>
                      <div class="facet-sort-modal__inner">
                        <div class="facets-modal__header">
                          <div class="facets-modal__heading-wrapper">
                            {%- render 'icon-sort' -%}
                            <div class="facets-modal__heading body-large">
                              {{ 'products.facets.sort_by_label' | t }}
                            </div>
                          </div>

                          {% render 'modal-close-button',
                            class: 'facets-modal__close facet-sort-modal__close',
                            only_icon: true
                          %}
                        </div>
                        <div class="facet-sort-select__options-wrapper">
                          <div class="facet-sort-select__options">
                            {%- for option in collection.sort_options -%}
                              <div
                                class="facet-sort-select__option focus-inset{% if option.value == sort_by %} facet-sort-select__option--selected{% endif %}"
                                data-value="{{ option.value | escape }}"
                                tabindex="0"
                              >
                                <span class="circle-check"></span>
                                {{- option.name | escape -}}
                                {% comment %}{% render 'icon-check' %}{% endcomment %}
                              </div>
                            {%- endfor -%}
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </form>
            </facet-filters-form>
            <noscript>
              <facet-filters-form>
                <form id="FacetSortForm" class="facets-sorting">
                  <label class="facets-sorting__label" for="SortByNoScript">
                    {{- 'products.facets.sort_by_label' | t -}}
                  </label>
                  <div class="facet-filters__field facets-sorting__field">
                    {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
                    <div class="select field">
                      <select
                        name="sort_by"
                        class="select__select focus-inset"
                        id="SortByNoScript"
                        aria-describedby="a11y-refresh-page-message"
                      >
                        {%- for option in collection.sort_options -%}
                          <option
                            value="{{ option.value | escape }}"
                            {% if option.value == sort_by %}
                              selected="selected"
                            {% endif %}
                          >
                            {{ option.name | escape }}
                          </option>
                        {%- endfor -%}
                      </select>
                      {% render 'icon-caret' %}
                    </div>
                  </div>
                  <button type="submit" class="button button--tertiary focus-inset">
                    {{- 'products.facets.sort_button' | t -}}
                  </button>
                </form>
              </facet-filters-form>
            </noscript>
          {%- endif -%}
        </div>
      </div>
      {% comment %} ACTIVE DESKTOP FILTERS {% endcomment %}
      {%- if section.settings.enable_filtering -%}
        <div class="facets__top facets small-hide container">
          <div class="active-facets active-facets-desktop" data-type="filters">
            {% assign active_facets = false %}
            {%- for filter in collection.filters -%}
              {% if filter.active_values.size > 0 or filter.min_value.value != null or filter.max_value.value != null %}
                {% assign active_facets = true %}
                {% break %}
              {% endif %}
            {% endfor %}

            <div class="active-facets__wrapper{% if active_facets %} active-facets__wrapper_margin{% endif %}">
              {%- for filter in collection.filters -%}
                {%- for value in filter.active_values -%}
                  <facet-remove>
                    <a href="{{ value.url_to_remove }}" class="active-facets__button focus-inset">
                      <span class="active-facets__button-inner body-normal">
                        <span>{{ value.label | escape }}</span>
                        {% render 'icon-close' %}
                      </span>
                      <span class="visually-hidden">{{ 'products.facets.clear_filter' | t }}</span>
                    </a>
                  </facet-remove>
                {%- endfor -%}
                {% if filter.type == 'price_range' %}
                  {%- if filter.min_value.value != null or filter.max_value.value != null -%}
                    {% liquid
                      assign min_value = filter.min_value.value | default: 0.0 | divided_by: 100.0
                      assign max_value = filter.max_value.value | default: filter.range_max | divided_by: 100.0
                      assign filter_range_max = filter.range_max | divided_by: 100.0 | ceil
                    %}
                    {% if min_value != 0 or max_value != filter_range_max %}
                      <facet-remove>
                        <a href="{{ filter.url_to_remove }}" class="active-facets__button focus-inset">
                          <span class="active-facets__button-inner body-normal">
                            <span>
                              {%- if filter.min_value.value -%}
                                {{ filter.min_value.value | money }}
                              {%- else -%}
                                {{ 0 | money }}
                              {%- endif -%}
                              —
                              {% if filter.max_value.value %}
                                {{ filter.max_value.value | money }}
                              {% else -%}
                                {{ filter.range_max | money }}
                              {%- endif -%}
                            </span>
                            {% render 'icon-close' %}
                          </span>
                          <span class="visually-hidden">{{ 'products.facets.clear_filter' | t }}</span>
                        </a>
                      </facet-remove>
                    {% endif %}
                  {%- endif -%}
                {% endif %}
              {%- endfor -%}
              {% if active_facets %}
                <facet-remove>
                  <a
                    href="{{ results_url }}"
                    class="active-facets__button active-facets__button-all focus-inset"
                  >
                    <span class="active-facets__button-inner body-normal">
                      <span>{{- 'products.facets.clear_all' | t -}}</span>
                      {% render 'icon-close' %}
                    </span>
                    <span class="visually-hidden">{{ 'products.facets.clear_all' | t }}</span>
                  </a>
                </facet-remove>
              {% endif %}
            </div>
          </div>
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="collection-wrapper container collection-wrapper--{{ section.settings.columns }} collection-wrapper--vertical">
    {%- if collection.all_products_count > 0 -%}
      {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
        {% render 'facets',
          results: collection,
          enable_filtering: section.settings.enable_filtering,
          enable_sorting: section.settings.enable_sorting,
          image_filter_ratio: section.settings.image_filter_ratio,
          image_filter_fit: section.settings.image_filter_fit,
          image_filter_columns: section.settings.image_filter_columns,
          total_selected_filters: section.settings.enable_total_selected,
          enable_reset_per_type: section.settings.enable_reset_per_type
        %}
      {%- endif -%}
    {%- endif -%}

    <div
      id="ProductGridContainer"
      data-products-in-row="{% if section.settings.enable_per_row_button %}{% if cart.attributes.cells-view %}{{ cart.attributes.cells-view |  escape }}{% else %}{{ section.settings.default_per_row }}{% endif %}{% endif %}"
      class="products-grid full-width {% if section.settings.enable_filtering == false or collection.all_products_count == 0 %} products-grid_no-filter{% endif %}"
    >
      {%- paginate collection.products by section.settings.products_per_page -%}
        {%- if collection.products.size == 0 -%}
          <div
            class="collection collection-product collection--empty"
            id="product-grid"
            data-id="{{ section.id }}"
          >
            <div class="loading-overlay no-js-hidden">
              <div class="loading-overlay__spinner">
                {% render 'icon-loading' %}
              </div>
            </div>

            <div class="title-wrapper container">
              <h2 class="h6 richtext-link-inside">
                {% if collection.all_products_count == 0 %}
                  {{ 'sections.collection_template.empty' | t -}}
                  <br>
                {% else %}
                  {{ 'sections.collection_template.empty_results' | t -}}
                  <br>
                  {{ 'sections.collection_template.results_use_fewer_filters_html' | t: link: collection.url }}
                {% endif %}
              </h2>
            </div>
          </div>
        {%- else -%}
          <div class="collection collection-product">
            <div class="loading-overlay no-js-hidden">
              <div class="loading-overlay__spinner">
                {% render 'icon-loading' %}
              </div>
            </div>

            <div
              id="product-grid"
              data-id="{{ section.id }}"
              class="collection-product-list{% if section.settings.enable_per_row_button == false %} collection-product-list--{{ section.settings.columns }} collection-product-list-mobile--{{section.settings.columns_mobile}}{% endif %} load-more-grid"
            >
              {%- for product in collection.products -%}
                <div class="collection-product-card">
                  {% render 'product-card',
                    product_card_product: product,
                    columns: section.settings.columns,
                    columns_mobile: section.settings.columns_mobile,
                    section_obj: section,
                    section_id: section.id,
                    forloop_index: forloop.index,
                    show_quick_view_overwrite: section.settings.show_quick_view,
                    dynamic_collection_grid: section.settings.enable_per_row_button
                  %}
                </div>
              {%- endfor -%}
            </div>

            {%- if paginate.pages > 1 -%}
              {%- if settings.pagination_type == 'load_more' -%}
                {% render 'load-more', paginate: paginate %}
                <div class="js-hidden">
                  {% render 'pagination', paginate: paginate %}
                </div>
              {%- elsif settings.pagination_type == 'infinite_scroll' -%}
                {% render 'infinite-scroll',
                  next_url: paginate.next.url,
                  count_pages: paginate.pages,
                  current_page: paginate.current_page
                %}
                <div class="js-hidden">
                  {% render 'pagination', paginate: paginate %}
                </div>
              {% else %}
                {% render 'pagination', paginate: paginate %}
              {%- endif -%}
            {%- endif -%}

            {% if section.settings.description != blank %}
              <div class="collection-product__description body-normal richtext-link-inside">
                {{ section.settings.description }}
              </div>
            {% endif %}
          </div>
        {%- endif -%}
      {%- endpaginate -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-collection-product-grid.name",
  "tag": "section",
  "class": "collection-grid-section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 3,
      "max": 45,
      "step": 1,
      "default": 20,
      "label": "t:sections.main-collection-product-grid.settings.products_per_page.label"
    },
    {
      "type": "checkbox",
      "id": "enable_border_top",
      "default": true,
      "label": "t:sections.all.borders.enable_border_top.label"
    },
    {
      "type": "inline_richtext",
      "id": "description",
      "label": "t:sections.all.text.label",
      "default": "t:sections.main-collection-product-grid.blocks.collection-banner.settings.description.default"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.per_row.header.content"
    },
    {
      "type": "checkbox",
      "id": "enable_per_row_button",
      "default": true,
      "label": "t:sections.main-collection-product-grid.settings.per_row.enable_per_row_button.label"
    },
    {
      "type": "select",
      "id": "default_per_row",
      "label": "t:sections.main-collection-product-grid.settings.per_row.default_per_row.label",
      "default": "large",
      "options": [
        {
          "value": "small",
          "label": "t:sections.main-collection-product-grid.settings.per_row.default_per_row.options__1.label"
        },
        {
          "value": "large",
          "label": "t:sections.main-collection-product-grid.settings.per_row.default_per_row.options__2.label"
        }
      ],
      "info": "t:sections.main-collection-product-grid.settings.per_row.default_per_row.info",
      "visible_if": "{{ section.settings.enable_per_row_button == true }}"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "t:sections.main-collection-product-grid.settings.columns.label",
      "visible_if": "{{ section.settings.enable_per_row_button == false }}"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "1",
      "label": "t:sections.main-collection-product-grid.settings.columns_mobile.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__2.label"
        }
      ],
      "visible_if": "{{ section.settings.enable_per_row_button == false }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.card.header_product_card.content"
    },
    {
      "type": "checkbox",
      "id": "show_quick_view",
      "default": true,
      "label": "t:sections.all.card.show_quick_view.label",
      "info": "t:sections.all.card.show_quick_view.info",
      "visible_if": "{{ settings.quickview_show == true }}"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.header__1.content"
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "default": true,
      "label": "t:sections.main-collection-product-grid.settings.enable_filtering.label",
      "info": "t:sections.main-collection-product-grid.settings.enable_filtering.info"
    },
    {
      "type": "checkbox",
      "id": "enable_filter_button_per_type",
      "default": true,
      "label": "t:sections.main-collection-product-grid.settings.enable_filter_button_per_type.label",
      "visible_if": "{{ section.settings.enable_filtering == true }}"
    },
    {
      "type": "checkbox",
      "id": "enable_total_selected",
      "default": true,
      "label": "t:sections.main-collection-product-grid.settings.enable_total_selected.label",
      "visible_if": "{{ section.settings.enable_filtering == true }}"
    },
    {
      "type": "checkbox",
      "id": "enable_reset_per_type",
      "default": true,
      "label": "t:sections.main-collection-product-grid.settings.enable_reset_per_type.label",
      "visible_if": "{{ section.settings.enable_filtering == true }}"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "default": true,
      "label": "t:sections.main-collection-product-grid.settings.enable_sorting.label"
    },
    {
      "type": "checkbox",
      "id": "enable_product_count",
      "default": true,
      "label": "t:sections.main-collection-product-grid.settings.enable_product_count.label"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.image_filter.content",
      "visible_if": "{{ section.settings.enable_filtering == true }}"
    },
    {
      "type": "select",
      "id": "image_filter_ratio",
      "options": [
        {
          "value": "3/2",
          "label": "t:sections.all.card.image_ratio.options__1.label"
        },
        {
          "value": "3/4",
          "label": "t:sections.all.card.image_ratio.options__2.label"
        },
        {
          "value": "1/1",
          "label": "t:sections.all.card.image_ratio.options__3.label"
        }
      ],
      "default": "1/1",
      "label": "t:sections.all.card.image_ratio.label",
      "visible_if": "{{ section.settings.enable_filtering == true }}"
    },
    {
      "type": "select",
      "id": "image_filter_fit",
      "options": [
        {
          "value": "contain",
          "label": "t:sections.all.card.image_fit.options__1.label"
        },
        {
          "value": "cover",
          "label": "t:sections.all.card.image_fit.options__2.label"
        }
      ],
      "default": "cover",
      "label": "t:sections.all.card.image_fit.label",
      "visible_if": "{{ section.settings.enable_filtering == true }}"
    },
    {
      "type": "range",
      "id": "image_filter_columns",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "t:sections.main-collection-product-grid.settings.image_filter_columns.label",
      "visible_if": "{{ section.settings.enable_filtering == true }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "xl",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ],
  "blocks": [
    {
      "type": "collection-banner",
      "name": "t:sections.main-collection-product-grid.blocks.collection-banner.name",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.main-collection-product-grid.blocks.collection-banner.settings.paragraph.content"
        },
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "default": "background-3",
          "label": "t:sections.main-collection-product-grid.blocks.collection-banner.settings.color_scheme.label",
          "info": "t:sections.main-collection-product-grid.blocks.collection-banner.settings.color_scheme.info"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            {
              "value": "h6",
              "label": "t:sections.all.heading_size.options__6.label"
            },
            {
              "value": "h5",
              "label": "t:sections.all.heading_size.options__5.label"
            },
            {
              "value": "h4",
              "label": "t:sections.all.heading_size.options__4.label"
            },
            {
              "value": "h3",
              "label": "t:sections.all.heading_size.options__3.label"
            },
            {
              "value": "h2",
              "label": "t:sections.all.heading_size.options__2.label"
            }
          ],
          "default": "h3",
          "label": "t:sections.all.heading_size.label"
        },
        {
          "type": "checkbox",
          "id": "show_collection_description",
          "default": false,
          "label": "t:sections.main-collection-product-grid.blocks.collection-banner.settings.show_collection_description.label"
        },
        {
          "type": "header",
          "content": "t:sections.main-collection-product-grid.blocks.collection-banner.settings.slider_settings.content"
        },
        {
          "type": "checkbox",
          "id": "enable_hero_slider",
          "default": true,
          "label": "t:sections.main-collection-product-grid.blocks.collection-banner.settings.enable_hero_slider.label"
