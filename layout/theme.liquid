<!doctype html>
<html
  class="no-js"
  lang="{{ request.locale.iso_code }}"
  data-scheme="{{ settings.color_scheme }}"
  dir="{% render '_page_direction' %}"
>
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {% render '_favicon' %}

    {%- unless settings.type_header_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    <meta
      name="description"
      content="{% if page_description %}{{ page_description | escape }}{% else %}{{ shop.description | escape }}{% endif %}{% if current_page != 1 %} - Page {{ current_page }}{% endif %}"
    >

    {% render '_meta-tags' %}

    <script src="{{  'jquery.min.js' | asset_url }}"></script>
    <script src="{{ 'constants.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'pubsub.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'jarallax.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'jarallax-video.min.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'scroll-image-reveal.js' | asset_url }}" defer="defer"></script>

    {% comment %} DYNAMICALLY RETURNS ALL SCRIPTS REQUIRED BY SHOPIFY {% endcomment %}
    {{ content_for_header }}

    {% comment %} FONTS {% endcomment %}
    {% render '_fonts' %}

    {% comment %} DARK MODE VARIABLES {% endcomment %}
    {% render '_color-vars' %}

    {% comment %} BASIC VARIABLES AND STYLES {% endcomment %}
    {% render '_base-vars-styles' %}

    {% comment %} ACCOUNT COMPONENT VARIABLES {% endcomment %}
    {% render '_shopify-account-vars' %}

    {% comment %} SWIPER MIN CSS {% endcomment %}
    {{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}

    {% comment %} BASIC STYLES {% endcomment %}
    {{ 'base.css' | asset_url | stylesheet_tag }}

    {% comment %} RICH TEXT (RTE) STYLES {% endcomment %}
    {{ 'component-rte.css' | asset_url | stylesheet_tag }}

    {% comment %} CART DRAWER & CART NOTIFICATION {% endcomment %}
    {%- if request.page_type != 'cart' -%}
      {%- if settings.enable_cart_drawer -%}
        {{ 'component-cart-drawer.css' | asset_url | stylesheet_tag }}
        {{ 'component-cart-items.css' | asset_url | stylesheet_tag }}
        <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
        {%- if settings.show_shipping -%}
          {{ 'component-cart-shipping.css' | asset_url | stylesheet_tag }}
        {%- endif -%}
      {%- endif -%}
    {%- endif -%}

    {% comment %} RTL STYLES {% endcomment %}
    {% capture direction %}{% render '_page_direction' %}{% endcapture %}
    {% if direction == 'rtl' %}
      {{ 'component-rtl.css' | asset_url | stylesheet_tag }}
    {% endif %}

    {% comment %} PRODUCTS STYLES {% endcomment %}
    {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
    {%- if settings.quickview_show or settings.featured_quickadd_show -%}
      {{- 'quick-view.css' | asset_url | stylesheet_tag -}}
      <script src="{{ 'quick-view.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    {% comment %} FONTS PRELOAD {% endcomment %}
    {%- unless settings.type_body_font.system? -%}
      {% comment %}theme-check-disable AssetPreload{% endcomment %}
      <link rel="preload" as="font" href="{{ settings.type_body_font | font_url }}" type="font/woff2" crossorigin>
      {% comment %}theme-check-enable AssetPreload{% endcomment %}
    {%- endunless -%}
    {%- unless settings.type_header_font.system? -%}
      {% comment %}theme-check-disable AssetPreload{% endcomment %}
      <link rel="preload" as="font" href="{{ settings.type_header_font | font_url }}" type="font/woff2" crossorigin>
      {% comment %}theme-check-enable AssetPreload{% endcomment %}
    {%- endunless -%}

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
      if (Shopify.designMode) {
        document.documentElement.classList.add('shopify-design-mode');
      }
    </script>

    <script src="{{ 'popup.js' | asset_url }}" defer="defer"></script>

    {% if settings.show_back_to_top %}
      <script src="{{ 'scroll-top.js' | asset_url }}" defer="defer"></script>
    {% endif %}
  </head>

  {%- comment -%} Pages that should show the white header instead of the standard header {%- endcomment -%}
  {%- assign white_header_templates = 'page.contact,page.faq' | split: ',' -%}
  {%- assign use_white_header = false -%}
  {%- for wht in white_header_templates -%}
    {%- if template == wht -%}
      {%- assign use_white_header = true -%}
    {%- endif -%}
  {%- endfor -%}

  <body class="template-{{ template.name }} template-{{ template | replace: '.', '-' }}{% if use_white_header %} white-header-page{% endif %}">
    <a class="skip-to-content-link visually-hidden" href="#MainContent">
      {{- 'accessibility.skip_to_text' | t -}}
    </a>

    {% sections 'header-group' %}

    {% sections 'overlay-group' %}

    {%- if settings.show_breadcrumbs -%}
      {% assign template_base = template | split: '.' | first %}
      {%- unless template_base == 'index' or template_base == 'product' or template_base == 'article' -%}
        {% render 'breadcrumbs', class: 'base-breadcrumbs' %}
      {%- endunless -%}
    {%- endif -%}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {%- if settings.show_back_to_top -%}
      {% render 'scroll-top' %}
    {%- endif -%}

    {%- if request.page_type != 'cart' and settings.enable_cart_drawer -%}
      {%- render 'cart-drawer' -%}
    {%- endif -%}

    {% comment %}
      {%- if request.page_type != 'cart' and settings.enable_cart_notification -%}
        {%- render 'cart-notification' -%}
      {%- endif -%}
    {% endcomment %}

    <ul hidden>
      <li id="a11y-refresh-page-message">
        {{- 'accessibility.refresh_page' | t -}}
      </li>
    </ul>

    {% render '_support_scripts' %}

    <script>
      window.icons = {
        cellsLarge: `{% render 'icon-cells-large' %}`,
        cellsSmall: `{% render 'icon-cells-small' %}`,
      };
    </script>

    <script src="{{ 'user.js' | asset_url }}"></script>
    <script src="{{ 'grpc-bundled.js' | asset_url }}"></script>
    <script src="{{ 'nicotine.js' | asset_url }}"></script>
    <script src="{{ 'loadSubscription.js' | asset_url }}"></script>
    <script>
    var cartId = document.cookie.split('; ').find(row => row.startsWith('cart=')).split('=')[1];
    if (cartId) {
      grpcModule.getCartCompletionStatus(cartId).then((res)=>{
        if (res){
          document.cookie = 'cart=;expires=Thu, 01 Jan 1970 00:00:01 GMT;';
        }
      });
    }
    </script>
    <script>
      payload = tokenPayload();
      console.log(payload);
      var spanLogin = document.getElementById('login_html_span');
      var spanLoginmobile = document.getElementById('login_html_span_mobile');
      if(isAuthenticated()) {
        console.log('Authenticated');
        spanLogin.href = "https://staging.myduke.com.au/customer";
        spanLoginmobile.href = "https://staging.myduke.com.au/customer";
        $('#login_html_span span').html('My Account');
        //document.querySelectorAll('.customertype_withoutlogin').forEach(function(el) {el.style.display = 'none';});
        //document.querySelectorAll('.onlywithlogin').forEach(function(el) {el.style.display = 'block';});

        $('.afterlogin').show();
        $('.logoutlink span').text('Logout ('+ getEmail() + ')');
        $('#menu-drawer .menu-drawer__menu').append('<li class="our-services "><a href="javascript:void(0)" onclick="logout()" class="menu-drawer__menu-item list-menu__item link link--text focus-inset">Logout ('+ getEmail() + ')</a></li>');
        $('.menu-drawer__utility-links .login-mobile').hide();

        {% comment %} New Codes {% endcomment %}
         $('.mydk-header-shop-btn').show();
         $('.mydk-header-getstarted-btn').hide();
      } else {
        console.log('NOT - Authenticated');
        $('.afterlogin').hide();
        document.querySelectorAll('.customertype_withlogin').forEach(function(el) {el.style.display = 'none';});
        $('#login_html_span span').html('Login');
        $('.header__icons a').html('Take the assessment');
        //$('.header__icons a').attr('href','#');
        $('.list-menu .shop').hide();
        $('.menu-drawer__utility-links .login-mobile').show();
        {% comment %} new codes {% endcomment %}
         $('.mydk-header-shop-btn').hide();
         $('.mydk-header-getstarted-btn').show();
    }
    </script>

    <!-- Start of HubSpot Embed Code -->
    <script type="text/javascript" id="hs-script-loader" async defer src="//js-ap1.hs-scripts.com/442968870.js"></script>
    <!-- End of HubSpot Embed Code -->
  </body>
</html>
