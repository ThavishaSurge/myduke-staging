      "type": "myduke-about-our-story",
      "blocks": {
        "card_PqKxVC": {
          "type": "card",
          "settings": {
            "text": "Following changes to Australia's nicotine regulations, many people who smoke have been required to navigate complex medical, pharmacy, and compliance processes when seeking support to quit. myduke® was developed to simplify this pathway while maintaining the safeguards required under Australian law.\n\nThe platform focuses on structured clinical review, transparency, and regulatory alignment, supporting informed decision-making in the context of smoking cessation."
          }
        },
        "card_gYXYTm": {
          "type": "card",
          "settings": {
            "text": "myduke® operates within Australia's public health framework, which prioritises harm reduction for adult smokers while limiting inappropriate access. The service is designed to support adults who are seeking alternatives to combustible cigarettes as part of a broader smoking cessation approach."
          }
        }
      },
