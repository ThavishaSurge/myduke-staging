{% comment %}
  When the 'Enable overlay mode' setting is turned on in the Header, the 'Hero', 'Media Banner', 'Slideshow', 'Login', and 'Registration' sections will be shifted underneath the header if they are the first section inside the <main> element.

  The styles are applied immediately after the page loads. Then, in header.js, the initHeaderOverlay script checks if the Header is the last section in the Header group and verifies the order of sections in <main>. It also applies the appropriate color scheme to the breadcrumbs. If these JS checks fail, the .not-mode class is added to the header, and the .not-margin class is added to the section.
{% endcomment %}

{%- liquid
  assign header_selector = '.shopify-section-header:not(.not-mode)'
  assign header_not_sticky_selector = '.shopify-section-header:not(.shopify-section-header-sticky):not(.not-mode)'
  assign featured_products_selector = '.featured-products-section:first-child:not(.not-margin)'
  assign media_banner_selector = '.media-banner-section:first-child:not(.not-margin)'
  assign slideshow_selector = '.slideshow-section:first-child:not(.not-margin) > .slideshow--overlay'
  assign collection_selector = '.collection-grid-section:first-child:not(.not-margin) .collection-hero__wrapper--with-image'

  assign scheme = section.settings.color_scheme_overlay_mode
  for color_scheme in settings.color_schemes
    if forloop.first
      assign scheme_default = color_scheme
    endif
  endfor
-%}

<style>
    [data-scheme=light] body:has(main > {{ featured_products_selector }}) {{ header_not_sticky_selector }} .header-wrapper,
    [data-scheme=light] body:has(main > {{ media_banner_selector }}) {{ header_not_sticky_selector }} .header-wrapper,
    [data-scheme=light] body:has(main > {{ slideshow_selector }}) {{ header_not_sticky_selector }} .header-wrapper,
    [data-scheme=light] body:has(main > {{ collection_selector }}) {{ header_not_sticky_selector }} .header-wrapper {
      background: transparent;
      transition: background-color 0.4s cubic-bezier(0.86, 0, 0.07, 1);
      --color-background: {{ scheme.settings.colors_background_1.red }},{{ scheme.settings.colors_background_1.green }},{{ scheme.settings.colors_background_1.blue }};
      --color-background-secondary: {{ scheme.settings.colors_background_2.red }},{{ scheme.settings.colors_background_2.green }},{{ scheme.settings.colors_background_2.blue }};
