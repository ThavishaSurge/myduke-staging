{% liquid
  assign tag_wrapper = 'div'
  if request.page_type == 'index' and is_h1_logo == true
    assign tag_wrapper = 'h1'
  endif
  if request.page_type == 'password'
    assign tag_wrapper = 'h2'
  endif

  assign has_svg = false
  if section.settings.logo_svg != blank
    assign has_svg = true
  endif

  if has_svg == false
    if section.settings.logo != blank and section.settings.logo_2 == blank
      assign aspect_ratio = section.settings.logo.aspect_ratio
      assign padding_bottom = 1 | divided_by: aspect_ratio | times: 100
    elsif section.settings.logo == blank and section.settings.logo_2 != blank
      assign aspect_ratio = section.settings.logo_2.aspect_ratio
      assign padding_bottom = 1 | divided_by: aspect_ratio | times: 100
    elsif section.settings.logo != blank and section.settings.logo_2 != blank
      assign aspect_ratio = section.settings.logo.aspect_ratio | at_most: section.settings.logo_2.aspect_ratio
      assign padding_bottom = 1 | divided_by: aspect_ratio | times: 100
    else
      assign padding_bottom = 0
    endif
  endif
%}
<{{ tag_wrapper }} class="header__heading{% if class != blank %} {{ class }}{% endif %}">
  {%- if show_logo -%}
    <a
      href="{{ routes.root_url }}"
      class="header__heading-link header-overlay-transition focus-inset{% if position != blank %} header__heading-link--{{position}}{% endif %}"
      {% unless has_svg %}
        {% if section.settings.logo != blank or section.settings.logo_2 != blank %}
          style="--logo-width: {{ section.settings.logo_width }}px; --padding_bottom: {{ padding_bottom }}%;"
        {% endif %}
      {% endunless %}
    >
      {%- if has_svg -%}
        {%- comment -%} ── Inline SVG logo – default (pre-scroll) ── {%- endcomment -%}
        <span
          class="header__heading-logo header__heading-logo--svg"
          style="display:block; width:{{ section.settings.logo_width }}px; max-width:100%; height:auto; line-height:0;"
          aria-label="{{ shop.name }}"
          role="img"
        >
          {{ section.settings.logo_svg }}
        </span>
        {%- if section.settings.logo_svg_scrolled != blank -%}
          {%- comment -%} ── Inline SVG logo – scrolled (solid header) ── {%- endcomment -%}
          <span
            class="header__heading-logo header__heading-logo--svg header__heading-logo--scrolled"
            style="display:block; width:{{ section.settings.logo_width }}px; max-width:100%; height:auto; line-height:0;"
            aria-label="{{ shop.name }}"
            role="img"
            aria-hidden="true"
          >
            {{ section.settings.logo_svg_scrolled }}
          </span>
        {%- endif -%}
      {%- elsif section.settings.logo != blank -%}
        {%- assign image_size = section.settings.logo_width | append: 'x' -%}
        {%- assign image_size_2x = section.settings.logo_width | times: 2 | at_most: 5760 -%}
        <img
          srcset="{{ section.settings.logo | image_url: width: image_size }} 1x, {{ section.settings.logo | image_url: width: image_size_2x }} 2x"
          src="{{ section.settings.logo | image_url: width: image_size }}"
          class="header__heading-logo"
          width="{{ section.settings.logo_width }}"
          height="auto"
          alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
          loading="lazy"
        >
        {%- if section.settings.logo_2 != blank -%}
          <img
            srcset="{{ section.settings.logo_2 | image_url: width: image_size }} 1x, {{ section.settings.logo_2 | image_url: width: image_size_2x }} 2x"
            src="{{ section.settings.logo_2 | image_url: width: image_size }}"
            class="header__heading-logo header__heading-logo--overlay"
            width="{{ section.settings.logo_width }}"
            height="auto"
            alt="{{ section.settings.logo_2.alt | default: shop.name | escape }}"
            loading="lazy"
          >
        {%- endif -%}
        {%- if section.settings.logo_scrolled != blank -%}
          <img
            srcset="{{ section.settings.logo_scrolled | image_url: width: image_size }} 1x, {{ section.settings.logo_scrolled | image_url: width: image_size_2x }} 2x"
            src="{{ section.settings.logo_scrolled | image_url: width: image_size }}"
            class="header__heading-logo header__heading-logo--scrolled"
            width="{{ section.settings.logo_width }}"
            height="auto"
            alt="{{ section.settings.logo_scrolled.alt | default: shop.name | escape }}"
            loading="lazy"
          >
        {%- endif -%}
      {%- elsif section.settings.logo_2 != blank -%}
        {%- assign image_size = section.settings.logo_width | append: 'x' -%}
        {%- assign image_size_2x = section.settings.logo_width | times: 2 | at_most: 5760 -%}
        <img
          srcset="{{ section.settings.logo_2 | image_url: width: image_size }} 1x, {{ section.settings.logo_2 | image_url: width: image_size_2x }} 2x"
          src="{{ section.settings.logo_2 | image_url: width: image_size }}"
          class="header__heading-logo header__heading-logo--overlay"
          width="{{ section.settings.logo_width }}"
          height="auto"
          alt="{{ section.settings.logo_2.alt | default: shop.name | escape }}"
          loading="lazy"
        >
        {%- if section.settings.logo_scrolled != blank -%}
          <img
            srcset="{{ section.settings.logo_scrolled | image_url: width: image_size }} 1x, {{ section.settings.logo_scrolled | image_url: width: image_size_2x }} 2x"
            src="{{ section.settings.logo_scrolled | image_url: width: image_size }}"
            class="header__heading-logo header__heading-logo--scrolled"
            width="{{ section.settings.logo_width }}"
            height="auto"
            alt="{{ section.settings.logo_scrolled.alt | default: shop.name | escape }}"
            loading="lazy"
          >
        {%- endif -%}
      {%- else -%}
        <span class="header-label" style="max-width: {{ section.settings.logo_width }}px;">
          {{- shop.name -}}
        </span>
      {%- endif -%}
    </a>
  {%- endif -%}
</{{ tag_wrapper }}>

