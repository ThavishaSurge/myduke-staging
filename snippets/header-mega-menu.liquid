{%- for block in section.blocks -%}
  {% assign mega_menu_trigger = block.settings.mega_menu_trigger | handle | strip %}

  {%- if link.handle == mega_menu_trigger and block.type == 'mega_menu' -%}
    {%- if block.settings.mega_menu_submenu != blank or block.settings.mega_menu_collections != blank -%}
      <div
        class="header__mega-menu mega-menu color-{{ block.settings.mega_menu_color_scheme }}"
        {{ block.shopify_attributes }}
      >
        <div
          class="mega-menu__wrapper"
          tabindex="-1"
          role="dialog"
        >
          {%- if block.settings.mega_menu_submenu != blank -%}
            <div class="mega-menu__right">
              <div class="mega-menu__submenu">
                {%- for link in block.settings.mega_menu_submenu.links -%}
                  <ul
                    class="mega-menu__subitem list-unstyled"
                    style="transition-delay: {{ forloop.index0 | times: 0.1 }}s"
                  >
                    <li class="mega-menu__subitem-title">
                      {%- if block.settings.enable_clickable_top_level -%}
                        <a
                          href="{{ link.url }}"
                          class="mega-menu__link body-large focus-inset list-menu-item-hover"
                          {% if link.current %}
                            aria-current="page"
                          {% endif %}
                          aria-label="{{ link.title | escape }}"
                          data-gtm-event="top_navigation_interaction"
                          data-gtm-cta="{{ link.title | escape }}"
                        >
                          <span>{{- link.title | escape -}}</span>
                        </a>
                      {%- else -%}
                        <span class="body-large">{{- link.title | escape -}}</span>
                      {%- endif -%}
                    </li>
                    {%- if link.links != blank -%}
                      {%- for childlink in link.links -%}
                        <li class="mega-menu__subitem-item">
                          {%- if childlink.links != blank -%}
                            <div class="mega-menu__subitem-details">
                              <div class="mega-menu__subitem-summary focus-inset">
                                <a
                                  href="{{ childlink.url }}"
                                  class="mega-menu__link body-large focus-inset list-menu-item-hover"
                                  {% if childlink.current %}
                                    aria-current="page"
                                  {% endif %}
                                  aria-label="{{ childlink.title | escape }}"
                                >
                                  <span>{{- childlink.title | escape -}}</span>
                                </a>
                              </div>

                              <ul class="list-unstyled">
                                {%- for grandchildlink in childlink.links -%}
                                  <li class="mega-menu__subitem-item mega-menu__subitem-item--child">
                                    <a
                                      href="{{ grandchildlink.url }}"
                                      class="mega-menu__link body-normal focus-inset list-menu-item-hover"
                                      {% if grandchildlink.current %}
                                        aria-current="page"
                                      {% endif %}
                                      aria-label="{{ grandchildlink.title | escape }}"
                                    >
                                      <span>{{- grandchildlink.title | escape -}}</span>
                                    </a>
                                  </li>
                                {%- endfor -%}
                              </ul>
                            </div>

                          {%- else -%}
                            <a
                              href="{{ childlink.url }}"
                              class="mega-menu__link body-large focus-inset list-menu-item-hover"
                              {% if childlink.current %}
                                aria-current="page"
                              {% endif %}
                              aria-label="{{ childlink.title | escape }}"
                            >
                              <span>{{- childlink.title | escape -}}</span>
                            </a>
                          {%- endif -%}
                        </li>
                      {%- endfor -%}
                    {%- endif -%}

                    {% if block.settings.enable_shop_all_button %}
                      {% liquid
                        assign shop_all_label = 'sections.header.shop_all' | t
                      %}
                      {% render 'button',
                        btn_link: routes.all_products_collection_url,
                        btn_label: shop_all_label,
                        btn_style: 'tertiary',
                        class: 'mega-menu__subitem-shop-all-button'
                      %}
                    {% endif %}
                  </ul>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}

          {%- if block.settings.mega_menu_collections != blank -%}
            {%- for collection in block.settings.mega_menu_collections -%}
              <div class="mega-menu__collection">
                {% render 'collection-card-mega-menu', card_collection: collection, columns: 4 %}
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}
