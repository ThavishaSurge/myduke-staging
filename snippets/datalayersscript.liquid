{% if page_type == 'pagelisting' %}
<script>
  var waitforuserid = setInterval(function () {
    if(typeof getUserId() !== 'undefined'){
      clearInterval(waitforuserid);
      var dataLayerarray = ({
        event: "view_item_list",
        'user_type': "customer",
        'userID': getUserId(),
        'page_type': "VPN/view_item_list",
        'utm_source': (readgafCookie('utm_source')?readgafCookie('utm_source'):"NA"),
        'utm_medium': (readgafCookie('utm_medium')?readgafCookie('utm_medium'):"NA"),
        'utm_campaign': (readgafCookie('utm_campaign')?readgafCookie('utm_campaign'):"NA"),
        'utm_version': (readgafCookie('utm_version')?readgafCookie('utm_version'):"NA"),
        'utm_content': (readgafCookie('utm_content')?readgafCookie('utm_content'):"NA"),
        ecommerce: {
          item_list_id: "{% if collection %}{{ collection.id }}{% endif %}", //unique id of the list
          item_list_name: "{% if collection %}{{ collection.handle | capitalize }}{% endif %}",  // All, nicotine, you may also like etc
          items: [
            {{datalayerforitems}}
          ]
        }
      });
      console.log(dataLayerarray);
      dataLayer.push({ ecommerce: null });  // Clear the previous ecommerce object.
      dataLayer.push(dataLayerarray);
    }
  }, 500);
  
</script>
{% endif %}
{% if page_type == 'product' %}
<script>
var waitforuserid = setInterval(function () {
  if(typeof getUserId() !== 'undefined'){
    clearInterval(waitforuserid);
    var dataLayerarray = ({
      event: "view_item",
      'user_type': "customer",
      'userID': getUserId(),
      'page_type': "VPN/view_item",
      'utm_source': (readgafCookie('utm_source')?readgafCookie('utm_source'):"NA"),
      'utm_medium': (readgafCookie('utm_medium')?readgafCookie('utm_medium'):"NA"),
      'utm_campaign': (readgafCookie('utm_campaign')?readgafCookie('utm_campaign'):"NA"),
      'utm_version': (readgafCookie('utm_version')?readgafCookie('utm_version'):"NA"),
      'utm_content': (readgafCookie('utm_content')?readgafCookie('utm_content'):"NA"),
      ecommerce: {
        currency: "{{shop.currency}}",
        value: "{{product.price | money_without_currency}}",
        items: [
        {
          item_id: "{{product.id}}",  // unique id of the product
          item_name: "{{product.title | escape}}", // VEEV ONE Device
          index: "1",
          item_brand: "{{product.vendor}}",
          item_category: "{% for collection in product.collections %}{{ collection.title | escape }},{% endfor %}",  //device, e-liquid etc
          item_variant: "{{product.variants | size}}",
          price: "{{product.price | money_without_currency}}",
          quantity: "{{product.selected_or_first_available_variant.inventory_quantity}}"
        }
        ]
      }
    });
    console.log(dataLayerarray);
    dataLayer.push({ ecommerce: null });  // Clear the previous ecommerce object.
    dataLayer.push(dataLayerarray);
  }
}, 500);
</script>
{% endif %}
