{% comment %}
  Eligibility Form Snippet — embedded in the hero section.
  Renders a multi-step quiz card with:
    - Tab bar: Eligibility | Sign in
    - Step 1: Age range
    - Step 2: Smoking duration
    - Step 3: Primary goal
    - Processing screen (animated progress)
    - Result screen (eligible / not eligible)
  Sign-in tab is a placeholder (to be wired up later).
{% endcomment %}

{{ 'hero-eligibility-form.css' | asset_url | stylesheet_tag }}

<div class="eligibility-card" id="eligibility-card-{{ section.id }}">

  {%- comment -%} Tab bar {%- endcomment -%}
  <div class="eligibility-card__tabs" role="tablist">
    <button
      class="eligibility-card__tab is-active"
      id="elig-tab-eligibility-{{ section.id }}"
      role="tab"
      aria-selected="true"
      aria-controls="elig-panel-eligibility-{{ section.id }}"
      data-elig-tab="eligibility"
    >
      Eligibility
    </button>
    <button
      class="eligibility-card__tab"
      id="elig-tab-signin-{{ section.id }}"
      role="tab"
      aria-selected="false"
      aria-controls="elig-panel-signin-{{ section.id }}"
      data-elig-tab="signin"
    >
      Sign in
    </button>
  </div>

  {%- comment -%} Card body {%- endcomment -%}
  <div class="eligibility-card__body">

    {%- comment -%} === ELIGIBILITY PANEL === {%- endcomment -%}
    <div
      class="eligibility-tab-panel is-active"
      id="elig-panel-eligibility-{{ section.id }}"
      role="tabpanel"
      aria-labelledby="elig-tab-eligibility-{{ section.id }}"
      data-elig-panel="eligibility"
    >
      {%- comment -%} Persistent intro text (stays across all steps) {%- endcomment -%}
      <h2 class="eligibility-card__intro-heading">
        {{ section.settings.elig_heading | default: 'Am I Eligible?' }}
      </h2>
      <p class="eligibility-card__intro-text">
        {{ section.settings.elig_description | default: 'Take our 30-second quiz to find out if you're a candidate for pharmacy-grade cessation treatment.' }}
      </p>

      {%- comment -%} ---- Step 1: Age range ---- {%- endcomment -%}
      <div class="eligibility-step is-active" data-elig-step="1">
        <p class="eligibility-step__question">What is your age range?</p>
        <div class="eligibility-step__options eligibility-step__options--4col" role="group" aria-label="Age range options">
          <button class="eligibility-option" data-elig-option data-value="18-25">18–25</button>
          <button class="eligibility-option" data-elig-option data-value="26-35">26–35</button>
          <button class="eligibility-option" data-elig-option data-value="36-50">36–50</button>
          <button class="eligibility-option" data-elig-option data-value="50+">50+</button>
        </div>
        <div class="eligibility-progress">
          <div class="eligibility-progress__label">Question 1 / 3</div>
          <div class="eligibility-progress__track" role="progressbar" aria-valuenow="33" aria-valuemin="0" aria-valuemax="100">
            <div class="eligibility-progress__bar" style="width: 33%;"></div>
          </div>
        </div>
        <button class="eligibility-card__btn" data-elig-next>Next</button>
      </div>

      {%- comment -%} ---- Step 2: Smoking duration ---- {%- endcomment -%}
      <div class="eligibility-step" data-elig-step="2">
        <p class="eligibility-step__question">How long have you been smoking?</p>
        <div class="eligibility-step__options eligibility-step__options--4col" role="group" aria-label="Smoking duration options">
          <button class="eligibility-option" data-elig-option data-value="less-than-1yr">Less than 1 year</button>
          <button class="eligibility-option" data-elig-option data-value="1-5yr">1–5 years</button>
          <button class="eligibility-option" data-elig-option data-value="5-15yr">5–15 years</button>
          <button class="eligibility-option" data-elig-option data-value="15yr+">15+ years</button>
        </div>
        <div class="eligibility-progress">
          <div class="eligibility-progress__label">Question 2 / 3</div>
          <div class="eligibility-progress__track" role="progressbar" aria-valuenow="66" aria-valuemin="0" aria-valuemax="100">
            <div class="eligibility-progress__bar" style="width: 66%;"></div>
          </div>
        </div>
        <button class="eligibility-card__btn" data-elig-next>Next</button>
      </div>

      {%- comment -%} ---- Step 3: Primary goal ---- {%- endcomment -%}
      <div class="eligibility-step" data-elig-step="3">
        <p class="eligibility-step__question">What is your primary goal?</p>
        <div class="eligibility-step__options" role="group" aria-label="Primary goal options">
          <button class="eligibility-option" data-elig-option data-value="quit-completely">Quit completely</button>
          <button class="eligibility-option" data-elig-option data-value="reduce-intake">Reduce intake</button>
          <button class="eligibility-option" data-elig-option data-value="switch-safer">Switch to a safer alternative</button>
          <button class="eligibility-option" data-elig-option data-value="explore">Explore options</button>
        </div>
        <div class="eligibility-progress">
          <div class="eligibility-progress__label">Question 3 / 3</div>
          <div class="eligibility-progress__track" role="progressbar" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100">
            <div class="eligibility-progress__bar" style="width: 100%;"></div>
          </div>
        </div>
        <button class="eligibility-card__btn" data-elig-submit>Next</button>
      </div>

      {%- comment -%} ---- Processing screen ---- {%- endcomment -%}
      <div class="eligibility-processing" data-elig-processing>
        <p class="eligibility-processing__label">Verifying medical data</p>
        <div class="eligibility-processing__track">
          <div class="eligibility-processing__fill" data-elig-processing-bar></div>
        </div>
        <p class="eligibility-processing__status">Cross-referencing with clinical eligibility criteria</p>
      </div>

      {%- comment -%} ---- Result: Eligible ---- {%- endcomment -%}
      <div class="eligibility-result" data-elig-result="eligible">
        <p class="eligibility-result__title">You may be eligible</p>
        <p class="eligibility-result__text">
          Based on your responses, you're a potential candidate. Complete the full medical assessment to proceed.
        </p>
        <div class="eligibility-result__actions">
          <a href="{{ section.settings.elig_assessment_link | default: '#' }}" class="eligibility-card__btn">
            Start Full Assessment
          </a>
          <button class="eligibility-card__btn eligibility-card__btn--outline" data-elig-retake>
            Retake Quiz
          </button>
        </div>
      </div>

      {%- comment -%} ---- Result: Not eligible ---- {%- endcomment -%}
      <div class="eligibility-result" data-elig-result="not-eligible">
        <p class="eligibility-result__title">Not eligible at this time</p>
        <p class="eligibility-result__text">
          Based on your responses, you may not qualify for this program right now. Please consult a healthcare professional.
        </p>
        <div class="eligibility-result__actions">
          <button class="eligibility-card__btn eligibility-card__btn--outline" data-elig-retake>
            Retake Quiz
          </button>
        </div>
      </div>

    </div>{%- comment -%} /eligibility-tab-panel {%- endcomment -%}

    {%- comment -%} === SIGN IN PANEL (placeholder) === {%- endcomment -%}
    <div
      class="eligibility-tab-panel"
      id="elig-panel-signin-{{ section.id }}"
      role="tabpanel"
      aria-labelledby="elig-tab-signin-{{ section.id }}"
      data-elig-panel="signin"
    >
      <p class="eligibility-signin__msg">Sign in functionality coming soon.</p>
    </div>

  </div>{%- comment -%} /eligibility-card__body {%- endcomment -%}

</div>

<script>
(function () {
  const card = document.getElementById('eligibility-card-{{ section.id }}');
  if (!card) return;

  // ---- State ----
  const answers = {};
  let currentStep = 1;
  const totalSteps = 3;

  // ---- Cached DOM ----
  const steps        = card.querySelectorAll('[data-elig-step]');
  const processing   = card.querySelector('[data-elig-processing]');
  const processingBar = card.querySelector('[data-elig-processing-bar]');
  const results      = card.querySelectorAll('[data-elig-result]');
  const panels       = card.querySelectorAll('[data-elig-panel]');
  const tabs         = card.querySelectorAll('[data-elig-tab]');

  // ---- Tab switching ----
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.eligTab;
      tabs.forEach(t => {
        t.classList.toggle('is-active', t.dataset.eligTab === target);
        t.setAttribute('aria-selected', t.dataset.eligTab === target ? 'true' : 'false');
      });
      panels.forEach(p => {
        p.classList.toggle('is-active', p.dataset.eligPanel === target);
      });
    });
  });

  // ---- Option selection ----
  card.addEventListener('click', e => {
    const option = e.target.closest('[data-elig-option]');
    if (!option) return;
    const group = option.closest('.eligibility-step__options');
    group.querySelectorAll('[data-elig-option]').forEach(o => o.classList.remove('is-selected'));
    option.classList.add('is-selected');
    answers['step' + currentStep] = option.dataset.value;
  });

  // ---- Next button ----
  card.addEventListener('click', e => {
    if (!e.target.closest('[data-elig-next]')) return;
    if (!answers['step' + currentStep]) {
      // Nudge user to select an option
      const group = steps[currentStep - 1].querySelector('.eligibility-step__options');
      group.style.outline = '2px solid rgba(255,255,255,0.5)';
      group.style.borderRadius = '6px';
      setTimeout(() => { group.style.outline = ''; group.style.borderRadius = ''; }, 700);
      return;
    }
    showStep(currentStep + 1);
  });

  // ---- Submit (last step) ----
  card.addEventListener('click', e => {
    if (!e.target.closest('[data-elig-submit]')) return;
    if (!answers['step' + currentStep]) {
      const group = steps[currentStep - 1].querySelector('.eligibility-step__options');
      group.style.outline = '2px solid rgba(255,255,255,0.5)';
      group.style.borderRadius = '6px';
      setTimeout(() => { group.style.outline = ''; group.style.borderRadius = ''; }, 700);
      return;
    }
    runProcessing();
  });

  // ---- Retake ----
  card.addEventListener('click', e => {
    if (!e.target.closest('[data-elig-retake]')) return;
    resetQuiz();
  });

  // ---- Helpers ----
  function showStep(n) {
    currentStep = n;
    steps.forEach(s => s.classList.remove('is-active'));
    const target = card.querySelector('[data-elig-step="' + n + '"]');
    if (target) target.classList.add('is-active');
  }

  function runProcessing() {
    // Hide all steps
    steps.forEach(s => s.classList.remove('is-active'));
    results.forEach(r => r.classList.remove('is-active'));
    processing.classList.add('is-active');

    // Animate bar
    requestAnimationFrame(() => {
      processingBar.style.width = '0%';
      requestAnimationFrame(() => {
        processingBar.style.width = '100%';
      });
    });

    // After animation, show result
    setTimeout(showResult, 2700);
  }

  function showResult() {
    processing.classList.remove('is-active');
    // Eligibility logic: everyone is "eligible" for the demo
    // (can be made conditional on answers later)
    const resultKey = 'eligible';
    const resultEl = card.querySelector('[data-elig-result="' + resultKey + '"]');
    if (resultEl) resultEl.classList.add('is-active');
  }

  function resetQuiz() {
    // Clear answers
    Object.keys(answers).forEach(k => delete answers[k]);
    // Clear selections
    card.querySelectorAll('[data-elig-option]').forEach(o => o.classList.remove('is-selected'));
    // Hide everything
    results.forEach(r => r.classList.remove('is-active'));
    processing.classList.remove('is-active');
    processingBar.style.width = '0%';
    // Back to step 1
    showStep(1);
  }
})();
</script>

