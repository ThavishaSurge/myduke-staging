<script>
  window.dataLayer = window.dataLayer || [];
  window.GTMHelper = window.GTMHelper || {};

  // --- UTM STORAGE MANAGER ---
  window.GTMHelper.saveUTMs = function() {
    const urlParams = new URLSearchParams(window.location.search);
    const utmParams = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_version'];
    
    utmParams.forEach(function(param) {
      if (urlParams.has(param) && urlParams.get(param) !== "") {
        // Save as a cookie for 30 days, available across the entire site
        document.cookie = `myduke_${param}=${urlParams.get(param)}; path=/; max-age=2592000; SameSite=Lax`;
      }
    });
  };

  // Run the storage function immediately
  window.GTMHelper.saveUTMs();

// --- BUILD BASE DATA ---
  window.GTMHelper.getBaseData = function() {
    let pageType = "{{ template.name | default: 'other' }}";
    
    // Customize the page type string based on the template
    if (pageType === "index") {
      pageType = "home";
    } else if (pageType === "page") {
      // If it's a standard page, pull its specific URL handle (e.g., 'about-us', 'contact')
      pageType = "{{ page.handle | default: 'page' | replace: '-', '_' }}"; 
    }
    
    // Safely call your existing custom function
    let userId = (typeof getUserId === 'function' && getUserId() !== 'undefined') ? getUserId() : "";
    let userType = userId ? "existing" : "new";

    // Helper to grab UTMs directly from the URL, or from our custom cookies
    let getUTM = function(param) {
      // 1. Always check the live URL first
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.has(param) && urlParams.get(param) !== "") {
        return urlParams.get(param);
      }
      
      // 2. Check our newly saved cookies for subsequent page views
      const cookieMatch = document.cookie.match(new RegExp('(^| )myduke_' + param + '=([^;]+)'));
      if (cookieMatch) {
        return cookieMatch[2];
      }
      
      return "NA";
    };

    return {
      'user_type': userType,
      'userID': userId,
      'page_type': pageType,
      'utm_source': getUTM('utm_source'),
      'utm_medium': getUTM('utm_medium'),
      'utm_campaign': getUTM('utm_campaign'),
      'utm_version': getUTM('utm_version'),
      'utm_content': getUTM('utm_content')
    };
  };

  // --- MAIN ASYNC PUSH FUNCTION ---
  window.GTMHelper.pushEvent = function(eventName, specificEventData = {}) {
    let attempts = 0;
    
    // Set up the polling interval exactly like your previous site
    let waitForUser = setInterval(function() {
      attempts++;
      
      // If the function is ready and returns a value, OR we hit a timeout to prevent infinite loops
      if ((typeof getUserId === 'function' && typeof getUserId() !== 'undefined') || attempts > 10) {
        clearInterval(waitForUser);
        
        const baseData = window.GTMHelper.getBaseData();
        
        // Clear previous ecommerce object to prevent data leakage
        if (specificEventData.ecommerce) {
           window.dataLayer.push({ ecommerce: null });
        }

        // Merge the event name, base data, and specific event data
        const payload = Object.assign({ event: eventName }, baseData, specificEventData);
        
        window.dataLayer.push(payload);
        console.log(`GTM Event Pushed: ${eventName}`, payload);
      }
    }, 500);
  };


  // --- GLOBAL LIST & SELECT ITEM TRACKER ---
  document.addEventListener('DOMContentLoaded', function() {
    const listContainers = document.querySelectorAll('.mydk-product-container-auth');
    
    // 1. Fire the view_item_list event on load
    listContainers.forEach(function(container) {
      const listId = container.getAttribute('data-list-id') || "all";
      const listName = container.getAttribute('data-list-name') || "All";
      const productCards = container.querySelectorAll('.gtm-product-card');
      const listItems = [];
      
      productCards.forEach(function(card, index) {
        listItems.push({
          item_id: card.getAttribute('data-id'),
          item_name: card.getAttribute('data-name'),
          index: index + 1,
          item_brand: card.getAttribute('data-brand'),
          item_category: card.getAttribute('data-category'),
          item_variant: card.getAttribute('data-variant'),
          price: parseFloat(card.getAttribute('data-price')),
          quantity: 1
        });
      });

      if (listItems.length > 0 && typeof window.GTMHelper !== 'undefined') {
        window.GTMHelper.pushEvent("view_item_list", {
          ecommerce: {
            item_list_id: listId,
            item_list_name: listName,
            items: listItems
          }
        });
      }
    });
  });

  // 2. Event Delegation for select_item (Fixes Swiper Clones)
  document.addEventListener('click', function(e) {
    const card = e.target.closest('.gtm-product-card');
    
    if (card) {
      const container = card.closest('.mydk-product-container-auth');
      const listId = container ? (container.getAttribute('data-list-id') || "all") : "all";
      const listName = container ? (container.getAttribute('data-list-name') || "All") : "All";
      
      // Calculate index based on its position in the container
      let cardIndex = 1;
      if (container) {
        const allCards = Array.from(container.querySelectorAll('.gtm-product-card'));
        const foundIndex = allCards.indexOf(card);
        if (foundIndex > -1) cardIndex = foundIndex + 1;
      }

      if (typeof window.GTMHelper !== 'undefined') {
        window.GTMHelper.pushEvent("select_item", {
          ecommerce: {
            item_list_id: listId,
            item_list_name: listName,
            items: [{
              item_id: card.getAttribute('data-id'),
              item_name: card.getAttribute('data-name'),
              item_brand: card.getAttribute('data-brand'),
              item_category: card.getAttribute('data-category'),
              item_variant: card.getAttribute('data-variant'),
              price: parseFloat(card.getAttribute('data-price')),
              index: cardIndex,
              quantity: 1
            }]
          }
        });
      }
    }
  }, true);


  // --- GLOBAL UI CLICK LISTENER (DELEGATION) ---
  document.addEventListener('click', function(e) {
    
    // RULE 1: Check for explicit data attributes (Logo, Nav, etc.)
    const trackableElement = e.target.closest('[data-gtm-event]');
    
    if (trackableElement) {
      const eventName = trackableElement.getAttribute('data-gtm-event');
      const specificData = {};
      const ctaText = trackableElement.getAttribute('data-gtm-cta');
      const headingTitle = trackableElement.getAttribute('data-gtm-heading');
      
      if (ctaText) specificData.cta_text = ctaText;
      if (headingTitle) specificData.heading_title = headingTitle;
      
      if (typeof window.GTMHelper !== 'undefined') {
        window.GTMHelper.pushEvent(eventName, specificData);
      }
      return; // Stop here so we don't fire twice
    }

    const clickedLink = e.target.closest('a');
    
    if (clickedLink && clickedLink.href && clickedLink.href.includes('portal.myduke.com.au/signup')) {
      if (typeof window.GTMHelper !== 'undefined') {
        
        // 1. Stop the browser from instantly changing pages
        e.preventDefault(); 
        
        // 2. Fire the event
        window.GTMHelper.pushEvent("sign_up_initiate");
        
        // 3. Wait 600 milliseconds for GTM to finish, then redirect manually
        setTimeout(function() {
          if (clickedLink.target === '_blank') {
            window.open(clickedLink.href, '_blank'); // Respect "open in new tab" settings
          } else {
            window.location.href = clickedLink.href; // Standard redirect
          }
        }, 600);
        
      }
    }
    
  }, true);

  // --- LOGIN SUCCESS TRACKER (CROSS-DOMAIN SAFE) ---
  document.addEventListener('DOMContentLoaded', function() {
    let attempts = 0;
    
    let verifyLoginState = setInterval(function() {
      attempts++;
      
      // Wait for the getUserId function to be ready
      if ((typeof getUserId === 'function' && typeof getUserId() !== 'undefined') || attempts > 10) {
        clearInterval(verifyLoginState);

        const currentUserId = typeof getUserId === 'function' ? getUserId() : "";
        const previousAuthState = localStorage.getItem('gtm_auth_state');

        if (currentUserId !== "") {
          // The user is currently logged in
          if (previousAuthState !== 'logged_in') {
            // They were NOT logged in previously. They just returned from the portal!
            if (typeof window.GTMHelper !== 'undefined') {
              window.GTMHelper.pushEvent("login_success");
            }
            // Update local storage so it doesn't fire again on their next click
            localStorage.setItem('gtm_auth_state', 'logged_in');
          }
        } else {
          // The user is currently logged out. Update state so we know for next time.
          localStorage.setItem('gtm_auth_state', 'logged_out');
        }
      }
    }, 500);
  });

</script>