<script>
  window.dataLayer = window.dataLayer || [];
  window.GTMHelper = window.GTMHelper || {};

  // --- BUILD BASE DATA ---
  window.GTMHelper.getBaseData = function() {
    let pageType = "{{ template.name | default: 'other' }}";
    if (pageType === "index") pageType = "home";
    
    // Safely call your existing custom function
    let userId = (typeof getUserId === 'function' && getUserId() !== 'undefined') ? getUserId() : "";
    let userType = userId ? "existing" : "new";

    // Helper to safely call your existing cookie function, with a fallback
    let getUTM = function(param) {
      if (typeof readgafCookie === 'function') {
        let val = readgafCookie(param);
        return val ? val : "NA";
      }
      return "NA";
    };

    return {
      'user_type': userType,
      'userID': userId,
      'page_type': pageType,
      'utm_source': getUTM('utm_source'),
      'utm_medium': getUTM('utm_medium'),
      'utm_campaign': getUTM('utm_campaign'),
      'utm_version': getUTM('utm_version'),
      'utm_content': getUTM('utm_content')
    };
  };

  // --- MAIN ASYNC PUSH FUNCTION ---
  window.GTMHelper.pushEvent = function(eventName, specificEventData = {}) {
    let attempts = 0;
    
    // Set up the polling interval exactly like your previous site
    let waitForUser = setInterval(function() {
      attempts++;
      
      // If the function is ready and returns a value, OR we hit a timeout to prevent infinite loops
      if ((typeof getUserId === 'function' && typeof getUserId() !== 'undefined') || attempts > 10) {
        clearInterval(waitForUser);
        
        const baseData = window.GTMHelper.getBaseData();
        
        // Clear previous ecommerce object to prevent data leakage
        if (specificEventData.ecommerce) {
           window.dataLayer.push({ ecommerce: null });
        }

        // Merge the event name, base data, and specific event data
        const payload = Object.assign({ event: eventName }, baseData, specificEventData);
        
        window.dataLayer.push(payload);
        console.log(`GTM Event Pushed: ${eventName}`, payload);
      }
    }, 500);
  };


  // --- GLOBAL LIST & SELECT ITEM TRACKER ---
  document.addEventListener('DOMContentLoaded', function() {
    const listContainers = document.querySelectorAll('.mydk-product-container-auth');
    
    listContainers.forEach(function(container) {
      
      // Dynamically grab the List ID and Name, defaulting to "all"
      const listId = container.getAttribute('data-list-id') || "all";
      const listName = container.getAttribute('data-list-name') || "All";

      const productCards = container.querySelectorAll('.gtm-product-card');
      const listItems = [];
      
      productCards.forEach(function(card, index) {
        listItems.push({
          item_id: card.getAttribute('data-id'),
          item_name: card.getAttribute('data-name'),
          index: index + 1,
          item_brand: card.getAttribute('data-brand'),
          item_category: card.getAttribute('data-category'),
          item_variant: card.getAttribute('data-variant'),
          price: parseFloat(card.getAttribute('data-price')),
          quantity: 1
        });
        
        card.addEventListener('click', function() {
          if (typeof window.GTMHelper !== 'undefined') {
            window.GTMHelper.pushEvent("select_item", {
              ecommerce: {
                item_list_id: listId,
                item_list_name: listName,
                items: [{
                  item_id: card.getAttribute('data-id'),
                  item_name: card.getAttribute('data-name'),
                  item_brand: card.getAttribute('data-brand'),
                  item_category: card.getAttribute('data-category'),
                  item_variant: card.getAttribute('data-variant'),
                  price: parseFloat(card.getAttribute('data-price')),
                  index: index + 1,
                  quantity: 1
                }]
              }
            });
          }
        });
      });

      if (listItems.length > 0 && typeof window.GTMHelper !== 'undefined') {
        window.GTMHelper.pushEvent("view_item_list", {
          ecommerce: {
            item_list_id: listId,
            item_list_name: listName,
            items: listItems
          }
        });
      }
    });
  });
</script>