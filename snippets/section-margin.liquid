#shopify-section-{{ section.id }} {
{% if section.settings.margin_top == 'no-indent' or section.settings.margin_top == blank %}
  padding-top: 0;
{% elsif section.settings.margin_top == 'xl' %}
  padding-top: 8rem;
{% elsif section.settings.margin_top == 'l' %}
  padding-top: 6rem;
{% elsif section.settings.margin_top == 'm' %}
  padding-top: 3.6rem;
{% elsif section.settings.margin_top == 's' %}
  padding-top: 2.4rem;
{% else %}
  padding-top: 1.6rem;
{% endif %}

{% if section.settings.margin_bottom == 'no-indent' or section.settings.margin_bottom == blank %}
  padding-bottom: 0;
{% elsif section.settings.margin_bottom == 'xl' %}
  padding-bottom: 8rem;
{% elsif section.settings.margin_bottom == 'l' %}
  padding-bottom: 6rem;
{% elsif section.settings.margin_bottom == 'm' %}
  padding-bottom: 3.6rem;
{% elsif section.settings.margin_bottom == 's' %}
  padding-bottom: 2.4rem;
{% else %}
  padding-bottom: 1.6rem;
{% endif %}
}

@media screen and (min-width: 750px) { #shopify-section-{{ section.id }} {
{% if section.settings.margin_top == 'no-indent' %}
  padding-top: 0;
{% elsif section.settings.margin_top == 'xl' %}
  padding-top: 12rem;
{% elsif section.settings.margin_top == 'l' %}
  padding-top: 8rem;
{% elsif section.settings.margin_top == 'm' %}
  padding-top: 5rem;
{% elsif section.settings.margin_top == 's' %}
  padding-top: 3.2rem;
{% else %}
  padding-top: 2.4rem;
{% endif %}

{% if section.settings.margin_bottom == 'no-indent' %}
  padding-bottom: 0;
{% elsif section.settings.margin_bottom == 'xl' %}
  padding-bottom: 12rem;
{% elsif section.settings.margin_bottom == 'l' %}
  padding-bottom: 8rem;
{% elsif section.settings.margin_bottom == 'm' %}
  padding-bottom: 5rem;
{% elsif section.settings.margin_bottom == 's' %}
  padding-bottom: 3.2rem;
{% else %}
  padding-bottom: 2.4rem;
{% endif %}
} }

@media screen and (min-width: 1440px) { #shopify-section-{{ section.id }} {
{% if section.settings.margin_top == 'no-indent' %}
  padding-top: 0;
{% elsif section.settings.margin_top == 'xl' %}
  padding-top: 15rem;
{% elsif section.settings.margin_top == 'l' %}
  padding-top: 12rem;
{% elsif section.settings.margin_top == 'm' %}
  padding-top: 8rem;
{% elsif section.settings.margin_top == 's' %}
  padding-top: 4.8rem;
{% else %}
  padding-top: 3.2rem;
{% endif %}

{% if section.settings.margin_bottom == 'no-indent' %}
  padding-bottom: 0;
{% elsif section.settings.margin_bottom == 'xl' %}
  padding-bottom: 15rem;
{% elsif section.settings.margin_bottom == 'l' %}
  padding-bottom: 12rem;
{% elsif section.settings.margin_bottom == 'm' %}
  padding-bottom: 8rem;
{% elsif section.settings.margin_bottom == 's' %}
  padding-bottom: 4.8rem;
{% else %}
  padding-bottom: 3.2rem;
{% endif %}

} }
